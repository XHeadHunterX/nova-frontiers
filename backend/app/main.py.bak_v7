        );

        CREATE TABLE IF NOT EXISTS planet_control_events (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          planet_id INTEGER NOT NULL REFERENCES planets(id) ON DELETE CASCADE,
          player_id INTEGER REFERENCES players(id) ON DELETE SET NULL,
          action_key TEXT NOT NULL,
          action_name TEXT NOT NULL,
          influence_delta INTEGER NOT NULL DEFAULT 0,
          security_delta INTEGER NOT NULL DEFAULT 0,
          stability_delta INTEGER NOT NULL DEFAULT 0,
          pirate_delta INTEGER NOT NULL DEFAULT 0,
          market_delta INTEGER NOT NULL DEFAULT 0,
          conflict_delta INTEGER NOT NULL DEFAULT 0,
          message TEXT NOT NULL,
          created_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS combat_battles (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          player_id INTEGER NOT NULL REFERENCES players(id) ON DELETE CASCADE,
          target_ref TEXT NOT NULL,
          target_type TEXT NOT NULL,
          target_name TEXT NOT NULL,
          planet_id INTEGER NOT NULL REFERENCES planets(id) ON DELETE CASCADE,
          legal_state TEXT NOT NULL DEFAULT 'legal',
          status TEXT NOT NULL DEFAULT 'complete',
          outcome TEXT NOT NULL DEFAULT 'pending',
          winner TEXT,
          rounds INTEGER NOT NULL DEFAULT 0,
          log_json TEXT NOT NULL DEFAULT '[]',
          rewards_json TEXT NOT NULL DEFAULT '{}',
          penalties_json TEXT NOT NULL DEFAULT '{}',
          summary TEXT NOT NULL DEFAULT '',
          started_at TEXT NOT NULL,
          completed_at TEXT
        );

        CREATE TABLE IF NOT EXISTS combat_cooldowns (
          player_id INTEGER PRIMARY KEY REFERENCES players(id) ON DELETE CASCADE,
          pvp_until TEXT,
          combat_until TEXT,
          updated_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS salvage_sites (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          planet_id INTEGER NOT NULL REFERENCES planets(id) ON DELETE CASCADE,
          battle_id INTEGER REFERENCES combat_battles(id) ON DELETE SET NULL,
          source_type TEXT NOT NULL DEFAULT 'combat',
          source_name TEXT NOT NULL,
          ship_name TEXT NOT NULL,
          ship_role TEXT NOT NULL DEFAULT 'ship',
          ship_tier INTEGER NOT NULL DEFAULT 1,
          difficulty INTEGER NOT NULL DEFAULT 1,
          energy_cost INTEGER NOT NULL DEFAULT 10,
          salvage_value INTEGER NOT NULL DEFAULT 0,
          qty_remaining INTEGER NOT NULL DEFAULT 1,
          materials_json TEXT NOT NULL DEFAULT '{}',
          created_at TEXT NOT NULL,
          expires_at TEXT
        );
        """
    )
    ensure_schema_evolution(conn)
    conn.commit()
    seed(conn)
    ensure_ship_size_content(conn)
    ensure_galaxy_faction_content(conn)
    normalize_inventory_metadata(conn)
    ensure_balance_content(conn)
    ensure_crafting_content(conn)
    ensure_refinery_content(conn)
    ensure_player_market_content(conn)
    ensure_planet_control_content(conn)
    ensure_persistent_npc_content(conn)
    ensure_pirate_station_content(conn)
    ensure_profile_content(conn)
    ensure_progression_content(conn)
    ensure_ship_parts(conn)
    ensure_radar_content(conn)
    apply_runtime_game_settings(conn)
    conn.commit()
    conn.close()




def clamp_int(value: int, low: int = 1, high: int = 100) -> int:
    return max(low, min(high, int(value)))


def planet_npc_profile_from_seed(p: tuple) -> tuple[int, int, int, int, int, int, int, int]:
    # p = (galaxy_id, code, name, type, x, y, security, market, customs, pirates, defense, medical)
    typ = str(p[3]).lower()
    security = int(p[6]); market = int(p[7]); customs = int(p[8]); pirates = int(p[9]); defense = int(p[10]); medical = int(p[11])
    base_pop = {
        "core": 8_500_000,
        "trade": 3_800_000,
        "jump": 1_600_000,
        "shadow": 920_000,
        "dark": 780_000,
        "freeport": 1_150_000,
        "industrial": 2_400_000,
        "shipyard": 1_250_000,
        "mining": 640_000,
        "research": 1_100_000,
        "ancient": 260_000,
    }
    population = 750_000
    for key, val in base_pop.items():
        if key in typ:
            population = val
            break
    density = clamp_int((population // 120_000) + market // 3 + security // 8, 20, 95)
    activity = clamp_int(market * 0.62 + (100 - pirates) * 0.12 + population / 180_000, 20, 95)
    friendly = clamp_int((security + medical + market) / 3 - pirates * 0.18, 8, 92)
    hostile = clamp_int(pirates * 0.72 + (100 - security) * 0.25, 5, 95)
    lawful = clamp_int((security + customs + defense) / 3, 8, 95)
    economy_bias = clamp_int(market * 0.75 + population / 200_000, 20, 96)
    criminal_bias = clamp_int(pirates * 0.8 + (100 - customs) * 0.25, 8, 94)
    return int(population), int(density), int(activity), int(friendly), int(hostile), int(lawful), int(economy_bias), int(criminal_bias)


