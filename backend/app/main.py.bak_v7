_GAME_CONFIG_DEFAULTS: Dict[str, Any] = {}


def game_config_targets() -> Dict[str, Dict[str, Any]]:
    return {
        "CLIENT_RUNTIME_BALANCE": CLIENT_RUNTIME_BALANCE,
        "NPC_OBJECTIVE_BALANCE": NPC_OBJECTIVE_BALANCE,
        "NPC_LIFE_BALANCE": NPC_LIFE_BALANCE,
        "RADAR_BALANCE": RADAR_BALANCE,
        "OPEN_WORLD_BALANCE": OPEN_WORLD_BALANCE,
        "SIMULATION_BALANCE": SIMULATION_BALANCE,
        "NPC_MARKET_BALANCE": NPC_MARKET_BALANCE,
        "TRAVEL_BALANCE": TRAVEL_BALANCE,
        "SHIP_SIZE_BALANCE": SHIP_SIZE_BALANCE,
        "CARGO_HANDLING_BALANCE": CARGO_HANDLING_BALANCE,
        "MARKET_LAW_BALANCE": MARKET_LAW_BALANCE,
        "COMBAT_BALANCE": COMBAT_BALANCE,
        "PIRATE_STATION_BALANCE": PIRATE_STATION_BALANCE,
        "FACTION_WAR_BALANCE": FACTION_WAR_BALANCE,
        "PVE_BALANCE": PVE_BALANCE,
        "CRAFTING_BALANCE": CRAFTING_BALANCE,
        "RANKED_CRAFTING_BALANCE": RANKED_CRAFTING_BALANCE,
        "RECIPE_DROP_BALANCE": RECIPE_DROP_BALANCE,
        "PLAYER_MARKET_BALANCE": PLAYER_MARKET_BALANCE,
        "PLANET_CONTROL_BALANCE": PLANET_CONTROL_BALANCE,
        "PLANETARY_DEFENSE_BALANCE": PLANETARY_DEFENSE_BALANCE,
        "INVENTORY_BALANCE": INVENTORY_BALANCE,
        "TIER_BALANCE": TIER_BALANCE,
        "SKILL_XP_BALANCE": SKILL_XP_BALANCE,
