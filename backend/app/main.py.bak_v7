def job_rank_from_metrics(job_code: str, xp: int, metrics: Dict[str, int]) -> int:
    profile = JOB_PROFILE.get(job_code, {})
    primary = profile.get("primary", "runs")
    value = profile.get("value", "value")
    rank = 1
    for req in JOB_RANK_THRESHOLDS:
        if xp >= req["xp"] and metrics.get(primary, 0) >= req["primary"] and metrics.get(value, 0) >= req["value"]:
            rank = req["rank"]
    return rank


def job_next_requirement(job_code: str, xp: int, metrics: Dict[str, int]) -> Dict[str, Any]:
    profile = JOB_PROFILE.get(job_code, {})
    primary = profile.get("primary", "runs")
    value = profile.get("value", "value")
    current = job_rank_from_metrics(job_code, xp, metrics)
    next_req = next((r for r in JOB_RANK_THRESHOLDS if r["rank"] == min(10, current + 1)), JOB_RANK_THRESHOLDS[-1])
    return {
        "current_rank": current,
        "next_rank": min(10, current + 1),
        "xp_needed": max(0, next_req["xp"] - xp),
        "primary_metric": primary,
        "primary_needed": max(0, next_req["primary"] - metrics.get(primary, 0)),
        "value_metric": value,
        "value_needed": max(0, next_req["value"] - metrics.get(value, 0)),
    }


def migrate() -> None:
    conn = connect()
    c = conn.cursor()
    c.executescript(
        """
        CREATE TABLE IF NOT EXISTS users (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          username TEXT NOT NULL UNIQUE,
          password_hash TEXT NOT NULL,
          role TEXT NOT NULL DEFAULT 'player',
          god_mode INTEGER NOT NULL DEFAULT 0,
          created_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS sessions (
          token TEXT PRIMARY KEY,
          user_id INTEGER NOT NULL REFERENCES users(id) ON DELETE CASCADE,
          created_at TEXT NOT NULL,
          expires_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS galaxies (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          code TEXT NOT NULL UNIQUE,
          name TEXT NOT NULL,
          sector TEXT NOT NULL,
          color TEXT NOT NULL,
          description TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS planets (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          galaxy_id INTEGER NOT NULL REFERENCES galaxies(id),
          code TEXT NOT NULL UNIQUE,
          name TEXT NOT NULL,
          type TEXT NOT NULL,
          x REAL NOT NULL,
          y REAL NOT NULL,
          security_level INTEGER NOT NULL,
          market_activity INTEGER NOT NULL,
          customs_rating INTEGER NOT NULL,
          pirate_activity INTEGER NOT NULL,
          defense_strength INTEGER NOT NULL,
          medical_quality INTEGER NOT NULL,
          stability_level INTEGER NOT NULL DEFAULT 60,
          population INTEGER NOT NULL DEFAULT 250000,
          npc_density INTEGER NOT NULL DEFAULT 50,
          npc_activity INTEGER NOT NULL DEFAULT 50,
          friendliness INTEGER NOT NULL DEFAULT 50,
          hostility INTEGER NOT NULL DEFAULT 50,
          lawfulness INTEGER NOT NULL DEFAULT 50,
          npc_economy_bias INTEGER NOT NULL DEFAULT 50,
          npc_criminal_bias INTEGER NOT NULL DEFAULT 50,
          controller_type TEXT NOT NULL DEFAULT 'npc',
          controller_id INTEGER,
          attack_cooldown_until TEXT,
          tax_rate REAL NOT NULL DEFAULT 0.03
        );

        CREATE TABLE IF NOT EXISTS guilds (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          name TEXT NOT NULL UNIQUE,
          tag TEXT NOT NULL,
          respect INTEGER NOT NULL DEFAULT 0,
          treasury INTEGER NOT NULL DEFAULT 0,
          created_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS guild_members (
          guild_id INTEGER NOT NULL REFERENCES guilds(id) ON DELETE CASCADE,
          player_id INTEGER NOT NULL,
          rank TEXT NOT NULL DEFAULT 'Member',
          contribution INTEGER NOT NULL DEFAULT 0,
          PRIMARY KEY (guild_id, player_id)
        );

        CREATE TABLE IF NOT EXISTS guild_skills (
          guild_id INTEGER NOT NULL REFERENCES guilds(id) ON DELETE CASCADE,
          skill_key TEXT NOT NULL,
          level INTEGER NOT NULL DEFAULT 0,
          PRIMARY KEY (guild_id, skill_key)
        );

        CREATE TABLE IF NOT EXISTS players (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          user_id INTEGER NOT NULL UNIQUE REFERENCES users(id) ON DELETE CASCADE,
          callsign TEXT NOT NULL,
          level INTEGER NOT NULL DEFAULT 1,
          xp INTEGER NOT NULL DEFAULT 0,
          skill_points INTEGER NOT NULL DEFAULT 0,
          credits INTEGER NOT NULL DEFAULT 2500,
          fuel INTEGER NOT NULL DEFAULT 100,
          max_fuel INTEGER NOT NULL DEFAULT 100,
          cargo INTEGER NOT NULL DEFAULT 0,
          max_cargo INTEGER NOT NULL DEFAULT 50,
          scrap INTEGER NOT NULL DEFAULT 0,
          loyalty INTEGER NOT NULL DEFAULT 0,
          health INTEGER NOT NULL DEFAULT 100,
          max_health INTEGER NOT NULL DEFAULT 100,
          reputation INTEGER NOT NULL DEFAULT 0,
          faction_standing INTEGER NOT NULL DEFAULT 0,
          security_status TEXT NOT NULL DEFAULT 'Clean',
          location_planet_id INTEGER NOT NULL REFERENCES planets(id),
          active_ship_id INTEGER,
          guild_id INTEGER REFERENCES guilds(id),
          hospital_until TEXT,
          travel_until TEXT,
          travel_destination_id INTEGER,
          heat INTEGER NOT NULL DEFAULT 0,
          heat_updated_at TEXT,
          jailed_until TEXT,
          jail_reason TEXT,
          jail_severity TEXT,
          jail_location TEXT,
          illegal_action_cooldown_until TEXT,
          breakout_cooldown_until TEXT,
          breakout_failures INTEGER NOT NULL DEFAULT 0,
          created_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS user_profiles (
          user_id INTEGER PRIMARY KEY REFERENCES users(id) ON DELETE CASCADE,
          display_name TEXT NOT NULL,
          avatar_id TEXT NOT NULL DEFAULT 'default',
          bio TEXT NOT NULL DEFAULT '',
          updated_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS chat_messages (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          user_id INTEGER REFERENCES users(id) ON DELETE SET NULL,
          player_id INTEGER REFERENCES players(id) ON DELETE SET NULL,
