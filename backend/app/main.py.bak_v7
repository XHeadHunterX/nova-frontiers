def merge_qty(base: Dict[str, int], code: str, qty: int) -> None:
    qty = int(qty or 0)
    if qty > 0:
        base[code] = int(base.get(code, 0)) + qty


def salvage_materials_required_to_build_ship(target: Dict[str, Any], enemy: Dict[str, Any]) -> Dict[str, int]:
    tier = max(1, int(enemy.get("tier") or target.get("tier") or 1))
    role = str(target.get("role") or enemy.get("role") or target.get("career") or "").lower()
    name = str(enemy.get("name") or target.get("shipName") or target.get("ship_class") or "").lower()
    rating = max(100, int(enemy.get("combatRating") or target.get("power") or 100))
    hull = max(1000, int(enemy.get("hull") or rating * 18))
    shield = max(200, int(enemy.get("shield") or rating * 7))
    heavy = any(x in name for x in ["carrier", "frigate", "siege", "capital", "dread", "gunship", "battleship"])
    industrial = any(x in role for x in ["miner", "salvage", "hauler", "cargo", "trader", "industrial"])

    mats = {
        "titanium_ingot": max(6, int(hull / 3600) + tier * 5),
        "ferrite_bars": max(5, int(hull / 4300) + tier * 4),
        "refined_alloy": max(3, int((hull + shield) / 9000) + tier * (3 if heavy else 2)),
        "circuit_bundle": max(2, int(shield / 4200) + tier),
        "helium3_cells": max(1, tier + (2 if "explor" in role or "scout" in role else 0)),
    }
    if heavy or role in {"combat", "pirate", "mercenary", "bounty", "security", "patrol", "outlaw", "raider", "siege", "fleet"}:
        merge_qty(mats, "iridium_filament", max(1, tier))
        merge_qty(mats, "weapon_parts", max(1, tier * 2))
    if industrial:
        merge_qty(mats, "alloy_fragments", max(2, tier * 2))
        merge_qty(mats, "refined_alloy", max(1, tier))
    if "explor" in role or "scout" in role or "smuggl" in role:
        merge_qty(mats, "quantum_glass", max(1, tier // 2 + 1))
        merge_qty(mats, "sensor_shards", max(1, tier))
    if tier >= 5:
        merge_qty(mats, "void_crystal_lattice", max(1, tier - 4))
    return mats


def salvage_recovered_ship_build_materials(target: Dict[str, Any], enemy: Dict[str, Any]) -> Dict[str, int]:
    pct = float(COMBAT_BALANCE.get("ship_material_recovery_pct", 0.10))
    required = salvage_materials_required_to_build_ship(target, enemy)
    recovered: Dict[str, int] = {}
    for code, qty in required.items():
        merge_qty(recovered, code, max(1, int(math.ceil(int(qty) * pct))))
    return recovered


def commodity_profile_by_code(conn: sqlite3.Connection, code: str) -> Optional[Dict[str, Any]]:
    c = row(conn, "SELECT * FROM commodities WHERE code=?", (code,))
    if not c:
        return None
    return {"name": c.get("name"), "item_type": c.get("category") or "goods", "category": "illicit_goods" if int(c.get("legal") or 1) == 0 else "goods", "base_value": int(c.get("base_price") or 1), "mass": float(c.get("mass") or 1), "legal": int(c.get("legal") or 1), "rarity": "uncommon" if int(c.get("base_price") or 0) > 600 else "common", "description": c.get("description") or "Recovered cargo"}


def player_cargo_drop_materials(conn: sqlite3.Connection, player_id: int, rng: random.Random) -> Dict[str, int]:
    drop_pct = rng.uniform(float(COMBAT_BALANCE.get("cargo_drop_min_pct", 0.05)), float(COMBAT_BALANCE.get("cargo_drop_max_pct", 0.50)))
    mats: Dict[str, int] = {}
    for ch in rows(conn, "SELECT ch.qty, c.code FROM cargo_hold ch JOIN commodities c ON c.id=ch.commodity_id WHERE ch.player_id=? AND ch.qty>0", (player_id,)):
        qty = max(0, int(math.floor(int(ch.get("qty") or 0) * drop_pct)))
        if qty > 0:
            merge_qty(mats, str(ch.get("code")), qty)
    for inv in rows(conn, """
        SELECT item_code, qty
        FROM inventory
        WHERE player_id=? AND qty>0 AND cargo_exempt=0
          AND category IN ('goods','illicit_goods','raw_materials','crafting_materials','refined_materials','salvage','consumables')
        LIMIT 80
    """, (player_id,)):
        qty = max(0, int(math.floor(int(inv.get("qty") or 0) * drop_pct)))
        if qty > 0:
            merge_qty(mats, str(inv.get("item_code")), qty)
    return mats


def npc_cargo_drop_materials(target: Dict[str, Any], enemy: Dict[str, Any], rng: random.Random) -> Dict[str, int]:
    role = str(target.get("role") or enemy.get("role") or target.get("career") or "").lower()
    tier = max(1, int(enemy.get("tier") or target.get("level") or 1))
    level = max(1, int(target.get("level") or tier))
    base_units = int(COMBAT_BALANCE.get("npc_cargo_drop_base_units", 8) + tier * COMBAT_BALANCE.get("npc_cargo_drop_units_per_tier", 4) + level * COMBAT_BALANCE.get("npc_cargo_drop_units_per_level", 0.35))
    drop_pct = rng.uniform(float(COMBAT_BALANCE.get("cargo_drop_min_pct", 0.05)), float(COMBAT_BALANCE.get("cargo_drop_max_pct", 0.50)))
    qty = max(1, int(base_units * drop_pct))
    pools = {
        "trader": ["nutrient_paste", "electronics", "microchips", "luxury_goods"],
        "hauler": ["nutrient_paste", "electronics", "polymer", "reactor"],
        "cargo": ["nutrient_paste", "electronics", "polymer", "reactor"],
        "miner": ["titanium", "nickel_iron", "helium_3", "iridium"],
        "salvager": ["scrap", "alloy_fragments", "circuit", "weapon_parts"],
        "explorer": ["quantum_silicate", "quantum_glass", "sensor_shards", "ancient_relic"],
        "smuggler": ["combat_stims", "volatile_reagents", "luxury_goods", "black_boxes"],
        "pirate": ["combat_stims", "weapon_parts", "electronics", "luxury_goods"],
        "mercenary": ["weapon_parts", "trauma_gel", "electronics", "circuit_bundle"],
        "security": ["weapon_parts", "trauma_gel", "circuit_bundle", "electronics"],
    }
    pool = ["electronics", "polymer", "scrap", "alloy_fragments"]
    for key, values in pools.items():
        if key in role:
            pool = values
            break
    mats: Dict[str, int] = {}
    splits = rng.randint(1, min(3, len(pool)))
    chosen = rng.sample(pool, splits)
    for i, code in enumerate(chosen):
        share = max(1, qty // splits + (1 if i < qty % splits else 0))
        merge_qty(mats, code, share)
    return mats


def salvage_cargo_drop_materials(conn: sqlite3.Connection, target: Dict[str, Any], enemy: Dict[str, Any], rng: random.Random) -> Dict[str, int]:
    if target.get("kind") == "player" and target.get("rawId"):
        return player_cargo_drop_materials(conn, int(target.get("rawId")), rng)
    return npc_cargo_drop_materials(target, enemy, rng)


def salvage_materials_for_ship(conn: sqlite3.Connection, target: Dict[str, Any], enemy: Dict[str, Any]) -> Dict[str, Any]:
    tier = max(1, int(enemy.get("tier") or 1))
    difficulty = combat_target_difficulty(target, enemy)
    role = str(target.get("role") or enemy.get("role") or "ship").lower()
    rng = random.Random(f"salvage-drop:{target.get('id') or target.get('rawId') or target.get('name')}:{enemy.get('name')}:{int(time.time()//30)}")
    base_scrap = max(40, int((enemy.get("combatRating") or 100) * 0.06 + tier * 55 + difficulty * 35))
    mats: Dict[str, int] = {"scrap": base_scrap, "circuit": max(1, tier + difficulty // 2)}
    if role in {"combat", "pirate", "mercenary", "bounty", "security", "patrol", "outlaw", "raider"}:
        merge_qty(mats, "weapon_parts", max(1, tier))
    if role in {"miner", "salvager", "industrial", "hauler", "trader", "cargo"}:
        merge_qty(mats, "alloy_fragments", max(1, tier + 1))
    if role in {"smuggler", "scout", "explorer", "exploration"}:
        merge_qty(mats, "sensor_shards", max(1, tier))

    for code, qty in salvage_recovered_ship_build_materials(target, enemy).items():
        merge_qty(mats, code, qty)
    for code, qty in salvage_cargo_drop_materials(conn, target, enemy, rng).items():
        merge_qty(mats, code, qty)
    return mats


def create_salvage_site(conn: sqlite3.Connection, planet_id: int, battle_id: Optional[int], target: Dict[str, Any], enemy: Dict[str, Any], source_type: str = "combat") -> Dict[str, Any]:
    materials = salvage_materials_for_ship(conn, target, enemy)
    tier = max(1, int(enemy.get("tier") or 1))
    difficulty = combat_target_difficulty(target, enemy)
    energy_cost = int(COMBAT_BALANCE["salvage_energy_base"] + tier * COMBAT_BALANCE["salvage_energy_per_tier"] + difficulty * COMBAT_BALANCE["salvage_energy_per_difficulty"])
    value = int(sum(int(v) for v in materials.values()) * (18 + tier * 9))
    expires = utcnow() + timedelta(hours=COMBAT_BALANCE["salvage_site_expire_hours"])
    conn.execute(
        """
        INSERT INTO salvage_sites (planet_id,battle_id,source_type,source_name,ship_name,ship_role,ship_tier,difficulty,energy_cost,salvage_value,qty_remaining,materials_json,created_at,expires_at,x_pct,y_pct)
        VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        """,
        (planet_id, battle_id, source_type, target.get("name") or "Unknown Combatant", enemy.get("name") or target.get("shipName") or "Wrecked Ship", str(target.get("role") or enemy.get("role") or "ship"), tier, difficulty, energy_cost, value, 1, encode_json(materials), iso(), iso(expires), target.get("x_pct"), target.get("y_pct")),
    )
    sid = scalar(conn, "SELECT last_insert_rowid()")
    conn.execute("DELETE FROM salvage_sites WHERE planet_id=? AND id NOT IN (SELECT id FROM salvage_sites WHERE planet_id=? AND qty_remaining>0 ORDER BY id DESC LIMIT ?)", (planet_id, planet_id, COMBAT_BALANCE["max_salvage_sites_per_planet"]))
    return {"id": sid, "materials": materials, "energyCost": energy_cost, "value": value}


def build_salvage_sites(conn: sqlite3.Connection, planet_id: int) -> List[Dict[str, Any]]:
    conn.execute("UPDATE salvage_sites SET qty_remaining=0 WHERE expires_at IS NOT NULL AND expires_at<=?", (iso(),))
    sites = rows(conn, "SELECT * FROM salvage_sites WHERE planet_id=? AND qty_remaining>0 ORDER BY id DESC LIMIT 20", (planet_id,))
    for site in sites:
        site["materials"] = decode_json(site.get("materials_json"), {}) or {}
        site["image_url"] = ship_visual_payload(site.get("ship_name") or "Wreck", site.get("ship_role") or "salvage")
        site["tier_display"] = get_tier_display_data(clamp_tier(site.get("ship_tier", 1)), 7)
        site["label"] = f"T{site.get('ship_tier')} {site.get('ship_name')} wreck"
    return sites


def salvage_drop_item_profile(conn: sqlite3.Connection, code: str, tier: int = 1) -> Dict[str, Any]:
    code = str(code or "").strip()
    c = commodity_profile_by_code(conn, code)
    if c:
        return {**c, "source_kind": "cargo"}
    if code in SALVAGE_DROP_ITEM_PROFILES:
        return {**SALVAGE_DROP_ITEM_PROFILES[code], "source_kind": "material"}
    # Existing inventory definitions are valid if this code came from a destroyed player's cargo.
    inv = row(conn, "SELECT name,item_type,category,legal,base_value,mass,rarity,description FROM inventory WHERE item_code=? ORDER BY id DESC LIMIT 1", (code,))
    if inv:
        return {**dict(inv), "source_kind": "cargo"}
    return {
        "name": label_for_api(code),
        "item_type": "salvage",
        "category": "salvage",
        "legal": 1,
        "base_value": max(40, int(tier) * 110),
        "mass": 0.35,
        "rarity": "rare" if int(tier) >= 4 else "uncommon" if int(tier) >= 2 else "common",
        "description": "Recovered from destroyed ship wreckage.",
        "source_kind": "material",
    }


def simulate_npc_vs_npc_salvage(conn: sqlite3.Connection, force: bool = False) -> None:
    tick = row(conn, "SELECT value FROM app_state WHERE key='npc_combat_salvage_tick'") if row(conn, "SELECT name FROM sqlite_master WHERE type='table' AND name='app_state'") else None
    last = parse_dt(tick.get("value")) if tick else None
    now = utcnow()
    if not force and last and (now - last).total_seconds() < COMBAT_BALANCE["npc_vs_npc_salvage_minutes"] * 60:
        return
    conn.execute("CREATE TABLE IF NOT EXISTS app_state (key TEXT PRIMARY KEY, value TEXT NOT NULL)")
    conn.execute("INSERT INTO app_state (key,value) VALUES ('npc_combat_salvage_tick',?) ON CONFLICT(key) DO UPDATE SET value=excluded.value", (iso(now),))
    rng = random.Random(f"npc-vs-npc:{int(now.timestamp()//(COMBAT_BALANCE['npc_vs_npc_salvage_minutes']*60))}")
    if not force and rng.random() > COMBAT_BALANCE["npc_vs_npc_salvage_chance"]:
        return
    planets = rows(conn, "SELECT * FROM planets ORDER BY RANDOM() LIMIT 5")
    for planet in planets:
        npcs = rows(conn, "SELECT * FROM npc_agents WHERE planet_id=? ORDER BY aggression DESC, power DESC LIMIT 8", (planet["id"],))
        if len(npcs) < 2:
            continue
        a, b = rng.sample(npcs, 2)
        hostile_pressure = int(planet.get("hostility") or 0) + int(planet.get("pirate_activity") or 0) + int(planet.get("conflict_level") or 0)
        if not force and rng.random() > min(0.72, 0.12 + hostile_pressure / 260.0):
            continue
        loser = a if int(a.get("power") or 0) < int(b.get("power") or 0) else b
        enemy = npc_combat_ship_profile(loser)
        target = {"name": loser.get("name"), "role": loser.get("role") or loser.get("career_code"), "level": loser.get("level"), "power": loser.get("power"), "shipName": loser.get("ship_class")}
        site = create_salvage_site(conn, planet["id"], None, target, enemy, source_type="npc_vs_npc")
        conn.execute("INSERT INTO npc_action_log (planet_id,action_type,actor_name,message,impact_json,created_at) VALUES (?,?,?,?,?,?)", (planet["id"], "npc_battle_salvage", "Local combatants", f"NPC skirmish left a {enemy['name']} wreck near {planet['name']}.", encode_json({"salvageSiteId": site["id"], "tier": enemy.get("tier")}), iso()))
        break

def nearby_combat_targets(conn: sqlite3.Connection, player: Dict[str, Any]) -> List[Dict[str, Any]]:
    targets: List[Dict[str, Any]] = []; player_power = get_ship_power(conn, player.get("active_ship_id") or 0)
    for n in rows(conn, "SELECT * FROM npc_agents WHERE planet_id=? ORDER BY aggression DESC, level DESC LIMIT 42", (player["location_planet_id"],)):
        if combat_actor_is_immune(conn, f"npc:{n['id']}"):
            continue
        profile = npc_combat_ship_profile(n)
        base = {"id": f"npc:{n['id']}", "rawId": n["id"], "kind":"npc", "targetType":"npc", "name": n.get("name"), "role": n.get("role") or n.get("career_code"), "career": n.get("career_code"), "level": n.get("level"), "power": n.get("power"), "disposition": n.get("disposition"), "shipName": n.get("ship_class"), "ship": profile, "image_url": profile["image_url"]}
        legal = combat_target_legality(conn, player, base)
        danger = "Extreme" if int(n.get("power") or 0) > player_power * 1.6 else "High" if int(n.get("power") or 0) > player_power else "Manageable"
        reward_profile = combat_reward_profile(base, profile, legal)
        base.update({"legal": legal, "danger": danger, "attackable": True, "rewardEstimate": reward_profile["credits"], "energyCost": reward_profile["energyCost"], "rewardProfile": reward_profile})
        targets.append(base)
    for other in rows(conn, """SELECT p.*, u.username, up.display_name FROM players p JOIN users u ON u.id=p.user_id LEFT JOIN user_profiles up ON up.user_id=u.id WHERE p.location_planet_id=? AND p.id<>? LIMIT 20""", (player["location_planet_id"], player["id"])):
        if combat_actor_is_immune(conn, f"player:{other['id']}"):
            continue
        ship = row(conn, "SELECT s.*, t.name as template_name, t.class_name, t.role, t.slots_json, t.ship_tier FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=?", (other.get("active_ship_id"),)) if other.get("active_ship_id") else None
        prof = combat_ship_profile(conn, ship, "Player Ship"); name = other.get("display_name") or other.get("callsign") or other.get("username")
        targets.append({"id": f"player:{other['id']}", "rawId": other["id"], "kind":"player", "targetType":"player", "name": name, "role":"player", "level": other.get("level"), "power": prof["combatRating"], "disposition":"player", "shipName": prof["name"], "ship": prof, "image_url": prof["image_url"], "legal": combat_target_legality(conn, player, {"kind":"player"}, mode="duel"), "danger":"Player", "attackable": True, "rewardEstimate": 0})
    return targets

def get_combat_target(conn: sqlite3.Connection, player: Dict[str, Any], target_ref: str) -> Dict[str, Any]:
    if not target_ref or ":" not in target_ref: raise HTTPException(400, "Invalid combat target")
    kind, raw = target_ref.split(":", 1)
    if combat_actor_is_immune(conn, target_ref):
        raise HTTPException(409, "That ship has post-battle immunity for a few seconds.")
    if kind == "traveler":
        m = re.match(r"(\d+)-(\d+)-(\d+)-([a-zA-Z_]+)-(\d+)", raw)
        if m:
            npc_id = int(m.group(1))
        else:
            simple = re.match(r"(\d+)(?::[a-zA-Z_]+)?$", raw)
            if not simple:
                raise HTTPException(400, "Invalid traveler target")
            npc_id = int(simple.group(1))
        if combat_actor_is_immune(conn, f"npc:{npc_id}"):
            raise HTTPException(409, "That ship has post-battle immunity for a few seconds.")
        n = row(conn, "SELECT * FROM npc_agents WHERE id=?", (npc_id,))
        if not n:
            raise HTTPException(404, "Traveler is gone")
        prof = npc_combat_ship_profile(n)
        return {"id": target_ref, "rawId": n["id"], "kind":"npc", "targetType":"traveler", "inTransit": True, "name": n.get("name") or "NPC Traveler", "role": n.get("role") or n.get("career_code"), "career": n.get("career_code"), "level": n.get("level"), "power": n.get("power"), "disposition": n.get("disposition"), "shipName": n.get("ship_class"), "ship": prof, "image_url": prof["image_url"]}
    if kind == "npc":
        if combat_actor_is_immune(conn, f"npc:{int(raw)}"):
            raise HTTPException(409, "That ship has post-battle immunity for a few seconds.")
        n = row(conn, "SELECT * FROM npc_agents WHERE id=?", (int(raw),))
        if not n or int(n.get("planet_id") or 0) != int(player["location_planet_id"]): raise HTTPException(400, "Target is no longer at your current location")
        prof = npc_combat_ship_profile(n)
        return {"id": target_ref, "rawId": n["id"], "kind":"npc", "targetType":"npc", "name": n.get("name"), "role": n.get("role") or n.get("career_code"), "career": n.get("career_code"), "level": n.get("level"), "power": n.get("power"), "disposition": n.get("disposition"), "shipName": n.get("ship_class"), "ship": prof, "image_url": prof["image_url"]}
    if kind == "player":
        if combat_actor_is_immune(conn, f"player:{int(raw)}"):
            raise HTTPException(409, "That ship has post-battle immunity for a few seconds.")
        other = row(conn, "SELECT p.*, u.username, up.display_name FROM players p JOIN users u ON u.id=p.user_id LEFT JOIN user_profiles up ON up.user_id=u.id WHERE p.id=?", (int(raw),))
        if not other or int(other.get("location_planet_id") or 0) != int(player["location_planet_id"]): raise HTTPException(400, "Player target is not at your current location")
        ship = row(conn, "SELECT s.*, t.name as template_name, t.class_name, t.role, t.slots_json, t.ship_tier FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=?", (other.get("active_ship_id"),)) if other.get("active_ship_id") else None
        prof = combat_ship_profile(conn, ship, "Player Ship")
        return {"id": target_ref, "rawId": other["id"], "kind":"player", "targetType":"player", "name": other.get("display_name") or other.get("callsign") or other.get("username"), "role":"player", "level": other.get("level"), "power": prof["combatRating"], "disposition":"player", "ship": prof, "image_url": prof["image_url"]}
    raise HTTPException(400, "Unknown combat target type")

def combat_preview(conn: sqlite3.Connection, player: Dict[str, Any], target_ref: str, mode: str = "attack") -> Dict[str, Any]:
    block = combat_now_block_reason(conn, player); target = get_combat_target(conn, player, target_ref)
    active_ship = row(conn, "SELECT s.*, t.name as template_name, t.class_name, t.role, t.slots_json, t.ship_tier FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=?", (player.get("active_ship_id"),)) if player.get("active_ship_id") else None
    your = combat_ship_profile(conn, active_ship, "Your Ship"); enemy = target["ship"]; legal = combat_target_legality(conn, player, target, mode)
    skills = player_skill_totals(conn, player["id"]); combat_skill = int(skills.get("combat", 0)); bounty_skill = int(skills.get("bounty_hunting", 0))
    ratio = your["combatRating"] / max(1, enemy["combatRating"])
    win_est = max(12, min(88, int(50 + (ratio - 1) * 24 + combat_skill * 0.18 + bounty_skill * 0.08)))
    reward_profile = combat_reward_profile(target, enemy, legal)
    defense_preview = planetary_defense_preview(conn, player, legal)
    mods = [f"Combat skill {combat_skill}", f"Ship combat {your['combatRating']}", f"Enemy combat {enemy['combatRating']}", f"Enemy tier T{reward_profile['tier']}", f"Difficulty {reward_profile['difficulty']}", legal["label"]]
    if legal.get("criminal"):
        mods.append(f"Planetary defense response {defense_preview.get('chance')}%")
    return {"blockedReason": block, "target": target, "yourShip": your, "enemyShip": enemy, "legal": legal, "planetaryDefense": defense_preview, "estimatedWinChance": win_est, "estimatedReward": reward_profile["credits"], "estimatedXp": reward_profile["xp"], "energyCost": reward_profile["energyCost"], "rewardProfile": reward_profile, "possibleLoot":["combat_salvage", "weapon_parts", "combat_data", "area_wreck_salvage"], "modifiers":mods, "warning": None if not legal.get("criminal") else "This is unlawful combat. Planetary defense, heat, jail, and faction penalties can apply."}

def apply_damage_to_track(state: Dict[str, Any], raw_damage: int, pierce: float = 0.0) -> Dict[str, Any]:
    damage = max(0, int(raw_damage)); shield_hit = min(state["shield"], int(damage * (1 - pierce))); state["shield"] -= shield_hit
    remain = damage - shield_hit; mitigated = max(1, int(remain * (100 / (100 + max(0, state.get("armor", 0)))))) if remain > 0 else 0
    hull_hit = min(state["hull"], mitigated); state["hull"] -= hull_hit
    return {"shield": shield_hit, "hull": hull_hit, "raw": damage}

def choose_combat_action(actor: Dict[str, Any], round_no: int, defensive: bool = False) -> Dict[str, Any]:
    if defensive and round_no % 3 == 0: return {"name":"Brace Shields", "type":"defend", "damage":0, "accuracy":1, "energy":0}
    weapons = actor.get("weapons") or []
    return weapons[(round_no - 1) % len(weapons)] if weapons else {"name":"Basic Attack", "type":"projectile", "damage":50, "accuracy":0.55, "energy":5}


def planetary_defense_preview(conn: sqlite3.Connection, player: Dict[str, Any], legal: Dict[str, Any]) -> Dict[str, Any]:
    planet = row(conn, "SELECT * FROM planets WHERE id=?", (player.get("location_planet_id"),)) or {}
    if legal.get("spaceCombat"):
        return {"chance": 0, "label": "No planetary defense in open space", "security": int(planet.get("security_level") or 0)}
    if not legal.get("criminal"):
        return {"chance": 0, "label": "No planetary defense response expected", "security": int(planet.get("security_level") or 0)}
    security = int(planet.get("security_level") or 50)
    defense = int(planet.get("defense_strength") or 50)
    lawfulness = int(planet.get("lawfulness") or security)
    raw = 0.03 + security * PLANETARY_DEFENSE_BALANCE["security_mult"] + defense * PLANETARY_DEFENSE_BALANCE["defense_strength_mult"] + lawfulness * PLANETARY_DEFENSE_BALANCE["lawfulness_mult"]
    cap = PLANETARY_DEFENSE_BALANCE["high_security_join_chance"] if security >= 60 else 0.48 if security >= 35 else PLANETARY_DEFENSE_BALANCE["low_security_join_chance"] + 0.18
    chance = max(PLANETARY_DEFENSE_BALANCE["low_security_join_chance"], min(cap, raw))
    return {"chance": round(chance * 100, 1), "label": "Planetary defense may intervene", "security": security, "defense": defense, "lawfulness": lawfulness}


def maybe_apply_planetary_defense(conn: sqlite3.Connection, player: Dict[str, Any], legal: Dict[str, Any], enemy: Dict[str, Any], log: List[Dict[str, Any]], rng: random.Random) -> Dict[str, Any]:
    preview = planetary_defense_preview(conn, player, legal)
    chance = float(preview.get("chance") or 0) / 100.0
    if not legal.get("criminal") or chance <= 0 or rng.random() > chance:
        return {"joined": False, **preview}
    planet = row(conn, "SELECT * FROM planets WHERE id=?", (player.get("location_planet_id"),)) or {}
    security = int(planet.get("security_level") or 50)
    defense = int(planet.get("defense_strength") or 50)
    boost = 1.0 + min(0.65, (security + defense) * PLANETARY_DEFENSE_BALANCE["enemy_power_mult"] / 100.0)
    enemy["hull"] = int(enemy.get("hull", 100) * (1.0 + min(0.35, security / 260.0)))
    enemy["shield"] = int(enemy.get("shield", 0) * (1.0 + min(0.55, defense / 180.0)) + defense * 18)
    enemy["combatRating"] = int(enemy.get("combatRating", 100) * boost)
    enemy.setdefault("weapons", []).append({"name":"Planetary Defense Laser", "type":"laser", "damage": max(80, int(defense * 5.5)), "accuracy": min(0.86, 0.54 + security / 260.0), "energy": 0})
    log.append({"round":0,"actor":"defense","action":"Planetary Defense Intercept","weaponType":"defense","hit":True,"shieldDamage":0,"hullDamage":0,"playerHull":0,"enemyHull":enemy["hull"],"playerShield":0,"enemyShield":enemy["shield"],"text":f"Planetary defense joins the fight against unlawful aggression. Security {security}, defense {defense}."})
    increase_player_heat(conn, player["id"], PLANETARY_DEFENSE_BALANCE["heat_on_intervention"], "planetary defense response")
    return {"joined": True, **preview, "boost": round(boost, 2)}

def simulate_combat_battle(conn: sqlite3.Connection, player: Dict[str, Any], target_ref: str, mode: str = "attack", god: bool = False) -> Dict[str, Any]:
    preview = combat_preview(conn, player, target_ref, mode)
    if preview.get("blockedReason") and not god: raise HTTPException(409, preview["blockedReason"])
    target = preview["target"]; legal = preview["legal"]; your = dict(preview["yourShip"]); enemy = dict(preview["enemyShip"])
    energy_cost = int(preview.get("energyCost") or combat_energy_cost(target, enemy))
    spend(conn, player["id"], energy=energy_cost, god=god)
    skills = player_skill_totals(conn, player["id"]); combat_bonus = min(0.22, int(skills.get("combat", 0)) * 0.0035 + int(skills.get("piloting", 0)) * 0.0018)
    rng = random.Random(f"{player['id']}:{target_ref}:{int(time.time()//3)}"); log: List[Dict[str, Any]] = []
    defense_result = maybe_apply_planetary_defense(conn, player, legal, enemy, log, rng)
    y_state = {"hull": your["hull"], "shield": your["shield"], "armor": your["armor"], "energy": your["energy"]}
    e_state = {"hull": enemy["hull"], "shield": enemy["shield"], "armor": enemy["armor"], "energy": enemy["energy"]}
    for round_no in range(1, COMBAT_BALANCE["max_rounds"] + 1):
        if y_state["hull"] <= 0 or e_state["hull"] <= 0: break
        for side in ["player", "enemy"]:
            attacker = your if side == "player" else enemy; defender = e_state if side == "player" else y_state
            astate = y_state if side == "player" else e_state; defensive = side == "enemy" and str(target.get("role") or "").lower() in {"trader", "miner", "medic"}
            action = choose_combat_action(attacker, round_no, defensive)
            if action["type"] == "defend":
                astate["shield"] = min(attacker["shield"], astate["shield"] + int(attacker["shield"] * 0.08 + 35))
                log.append({"round":round_no,"actor":side,"action":"Brace Shields","weaponType":"defend","hit":True,"shieldDamage":0,"hullDamage":0,"playerHull":y_state["hull"],"enemyHull":e_state["hull"],"playerShield":y_state["shield"],"enemyShield":e_state["shield"],"text":f"{attacker['name']} braces and regenerates shields."}); continue
            acc = float(action.get("accuracy") or attacker.get("accuracy") or 0.55) + (combat_bonus if side == "player" else 0) - (enemy.get("evasion", 0) if side == "player" else your.get("evasion", 0)); acc = max(0.12, min(0.92, acc))
            hit = (god and side == "player") or rng.random() <= acc
            if hit:
                crit = rng.random() <= (0.06 + (combat_bonus if side == "player" else 0)); base = int(action.get("damage") or 50)
                career_bonus = 1.08 if side == "player" and legal["state"] == "legal" and active_career_code(conn, player["id"]) in {"bounty_hunter", "security_pilot", "mercenary"} else 1.0
                dealt = apply_damage_to_track(defender, int(base * (1.45 if crit else 1.0) * career_bonus), pierce=0.12 if action.get("type") == "missile" else 0.0)
                text = f"{attacker['name']} fires {action.get('name')} and hits for {dealt['shield']} shield / {dealt['hull']} hull damage."
                log.append({"round":round_no,"actor":side,"action":action.get("name"),"weaponType":action.get("type"),"hit":True,"critical":crit,"shieldDamage":dealt["shield"],"hullDamage":dealt["hull"],"playerHull":y_state["hull"],"enemyHull":e_state["hull"],"playerShield":y_state["shield"],"enemyShield":e_state["shield"],"text":("CRITICAL: " if crit else "") + text})
            else:
                log.append({"round":round_no,"actor":side,"action":action.get("name"),"weaponType":action.get("type"),"hit":False,"shieldDamage":0,"hullDamage":0,"playerHull":y_state["hull"],"enemyHull":e_state["hull"],"playerShield":y_state["shield"],"enemyShield":e_state["shield"],"text":f"{attacker['name']} fires {action.get('name')} but misses."})
            if y_state["hull"] <= 0 or e_state["hull"] <= 0: break
    player_won = e_state["hull"] <= 0 or (y_state["hull"] > 0 and e_state["hull"] < y_state["hull"] and len(log) >= COMBAT_BALANCE["max_rounds"] * 2)
    outcome = "victory" if player_won else "defeat"; rewards: Dict[str, Any] = {"credits": 0, "xp": 0, "items": []}; penalties: Dict[str, Any] = {"shipDamage": max(0, your["hull"] - y_state["hull"]), "heat": 0, "jailed": False, "planetaryDefense": defense_result}
    if player_won:
        reward_profile = preview.get("rewardProfile") or combat_reward_profile(target, enemy, legal)
        credits = int(reward_profile["credits"]); xp = int(reward_profile["xp"])
        conn.execute("UPDATE players SET credits=credits+? WHERE id=?", (credits, player["id"])); add_xp(conn, player["id"], xp)
        rewards.update({"credits": credits, "xp": xp, "energySpent": energy_cost, "rewardProfile": reward_profile, "progression": grant_action_progression(conn, player["id"], "combat", 1.0 + (target.get("level") or 1) / 30, True)})
        if target.get("inTransit"):
            site_preview = create_salvage_site(conn, player["location_planet_id"], None, target, enemy, source_type="open_space_intercept_pending")
            rewards["salvageSite"] = {"id": site_preview["id"], "energyCost": site_preview["energyCost"], "value": site_preview["value"], "materials": site_preview["materials"]}
        else:
            rewards["salvageSite"] = None
            rewards["salvageNote"] = "Planetary forces auto-salvaged this local wreck. Intercepts and open-space battles leave salvage icons on the map."
        if rng.random() < float(reward_profile.get("lootChance") or COMBAT_BALANCE["salvage_drop_chance"]):
            qty = max(1, int((target.get("level") or 1) / 5) + int(enemy.get("tier") or 1)); add_inventory_item(conn, player["id"], "combat_salvage", "Combat Salvage", "salvage", qty, 1, 420, 0.5, "Recovered loose material after battle", "combat", category="salvage", rarity="uncommon", respect_cargo=True, god=god); rewards["items"].append({"code":"combat_salvage", "name":"Combat Salvage", "qty":qty})
        recipe_drops = roll_normal_combat_recipe_drops(conn, player["id"], target, rng)
        if recipe_drops:
            rewards["recipes"] = recipe_drops
        if legal["state"] == "legal": conn.execute("UPDATE planets SET security_level=max(1,min(100,security_level+1)), pirate_activity=max(1,min(100,pirate_activity-1)) WHERE id=?", (player["location_planet_id"],))
    else:
        if y_state["hull"] <= 0:
            player_ship_target = {
                "id": f"player:{player['id']}:destroyed",
                "rawId": player["id"],
                "kind": "player",
                "name": player.get("callsign") or "Destroyed Player Ship",
                "role": "player",
                "level": player.get("level"),
                "shipName": your.get("name") or "Player Ship",
            }
            player_wreck = create_salvage_site(conn, player["location_planet_id"], None, player_ship_target, your, source_type="player_destroyed")
            penalties["playerSalvageSite"] = player_wreck
        damage_or_destroy_ship(conn, player["id"], max(80, int((your["hull"] - y_state["hull"]) * 0.35)), "combat defeat", god, hospital_minutes=0); grant_action_progression(conn, player["id"], "combat", 0.45, False)
    if legal.get("criminal"):
        heat = increase_player_heat(conn, player["id"], int(legal.get("heatGain") or 0), "unlawful combat"); penalties["heat"] = heat
        if (not player_won and rng.random() < float(legal.get("jailRisk") or 0)) and not god:
            sev = "high" if legal["state"] == "criminal" else "medium"; lo, hi = COMBAT_BALANCE["illegal_attack_jail_minutes"][legal["state"]]; jail_player(conn, player["id"], sev, rng.randint(lo, hi), "unlawful combat apprehension"); penalties["jailed"] = True
    rounds = max([x.get("round", 0) for x in log] or [0]); summary = f"{outcome.title()} against {target.get('name')}. {len(log)} actions over {rounds} rounds."
    conn.execute("""INSERT INTO combat_battles (player_id,target_ref,target_type,target_name,planet_id,legal_state,status,outcome,winner,rounds,log_json,rewards_json,penalties_json,summary,started_at,completed_at) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""", (player["id"], target_ref, target.get("kind") or target.get("targetType"), target.get("name"), player["location_planet_id"], legal["state"], "complete", outcome, "player" if player_won else "enemy", rounds, encode_json(log), encode_json(rewards), encode_json(penalties), summary, iso(), iso()))
    battle_id = scalar(conn, "SELECT last_insert_rowid()")
    if player_won and rewards.get("salvageSite"):
        if rewards.get("salvageSite"):
            conn.execute("UPDATE salvage_sites SET battle_id=?, source_type='open_space_intercept' WHERE id=?", (battle_id, rewards["salvageSite"]["id"]))
    set_combat_actor_immunity(conn, f"player:{player['id']}")
    set_combat_actor_immunity(conn, target_ref)
    if target.get("kind") == "npc" and target.get("rawId"):
        set_combat_actor_immunity(conn, f"npc:{target['rawId']}")
    if target.get("kind") == "player" and target.get("rawId"):
        set_combat_actor_immunity(conn, f"player:{target['rawId']}")
    if target.get("kind") == "player" or legal.get("criminal"):
        cd_until = utcnow() + timedelta(seconds=COMBAT_BALANCE["pvp_cooldown_seconds"] if target.get("kind") == "player" else 180)
        conn.execute("INSERT INTO combat_cooldowns (player_id,combat_until,updated_at) VALUES (?,?,?) ON CONFLICT(player_id) DO UPDATE SET combat_until=excluded.combat_until, updated_at=excluded.updated_at", (player["id"], iso(cd_until), iso()))
    else:
        immune_until = utcnow() + timedelta(seconds=int(COMBAT_BALANCE.get("post_battle_immunity_seconds", 5)))
        conn.execute("INSERT INTO combat_cooldowns (player_id,combat_until,updated_at) VALUES (?,?,?) ON CONFLICT(player_id) DO UPDATE SET combat_until=excluded.combat_until, updated_at=excluded.updated_at", (player["id"], iso(immune_until), iso()))
    add_event(conn, player["id"], "combat", summary, {"battleId": battle_id, "outcome": outcome, "legalState": legal["state"]})
    return {"message": summary, "battleId": battle_id, "battle": {"id": battle_id, "status":"complete", "outcome":outcome, "winner":"player" if player_won else "enemy", "rounds":rounds, "log":log, "rewards":rewards, "penalties":penalties, "summary":summary, "yourShip": your, "enemyShip": enemy, "target": target, "legal": legal, "actionDelayMs": int(COMBAT_BALANCE.get("round_ms", 3000)), "postBattleImmunitySeconds": int(COMBAT_BALANCE.get("post_battle_immunity_seconds", 5)), "escapeChance": round(player_escape_chance(conn, player), 3), "balance": COMBAT_BALANCE}}

def build_combat_battle_payload(b: Optional[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
    if not b: return None
    return {**b, "log": decode_json(b.get("log_json"), []) or [], "rewards": decode_json(b.get("rewards_json"), {}) or {}, "penalties": decode_json(b.get("penalties_json"), {}) or {}}

def build_fight_state(conn: sqlite3.Connection, player: Dict[str, Any], user: Dict[str, Any]) -> Dict[str, Any]:
    block = combat_now_block_reason(conn, player); targets = nearby_combat_targets(conn, player)
    active_ship = row(conn, "SELECT s.*, t.name as template_name, t.class_name, t.role, t.slots_json, t.ship_tier FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=?", (player.get("active_ship_id"),)) if player.get("active_ship_id") else None
    latest = row(conn, "SELECT * FROM combat_battles WHERE player_id=? ORDER BY id DESC LIMIT 1", (player["id"],))
    recent = rows(conn, "SELECT id,target_ref,target_type,target_name,planet_id,legal_state,status,outcome,winner,rounds,rewards_json,penalties_json,summary,started_at,completed_at FROM combat_battles WHERE player_id=? ORDER BY id DESC LIMIT 12", (player["id"],))
    for r in recent:
        r["rewards"] = decode_json(r.pop("rewards_json", "{}"), {}) or {}; r["penalties"] = decode_json(r.pop("penalties_json", "{}"), {}) or {}
    planet = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],)) or {}
    return {"blockedReason": block, "cargoProtection": cargo_operation_status(conn, player["id"]), "locationRules": {"planetId": player["location_planet_id"], "security": planet.get("security_level"), "lawfulness": planet.get("lawfulness"), "summary": "Bounties, pirates, and hostile targets are legal. Civilian or unprovoked attacks can raise heat and cause jail."}, "activeShip": combat_ship_profile(conn, active_ship, "Your Ship"), "targets": targets, "latestBattle": build_combat_battle_payload(latest), "recentBattles": recent, "balance": COMBAT_BALANCE}

def npc_planet_summary(conn: sqlite3.Connection, planet_id: int) -> Dict[str, Any]:
    p = row(conn, "SELECT * FROM planets WHERE id=?", (planet_id,)) or {}
    total = scalar(conn, "SELECT COUNT(*) FROM npc_agents WHERE planet_id=?", (planet_id,)) if p else 0
    careers = rows(conn, "SELECT COALESCE(career_code, role) as career, COUNT(*) as count, ROUND(AVG(level),1) as avg_level, ROUND(AVG(power),1) as avg_power FROM npc_agents WHERE planet_id=? GROUP BY COALESCE(career_code, role) ORDER BY count DESC", (planet_id,))
    dispositions = rows(conn, "SELECT disposition, COUNT(*) as count FROM npc_agents WHERE planet_id=? GROUP BY disposition", (planet_id,))
    return {
        "population": p.get("population", 0),
        "simulated_npcs": total,
        "target_npcs": target_npc_count_for_planet(p) if p else 0,
        "density": p.get("npc_density", 0),
        "activity": p.get("npc_activity", 0),
        "friendliness": p.get("friendliness", 0),
        "hostility": p.get("hostility", 0),
        "lawfulness": p.get("lawfulness", 0),
        "economy_bias": p.get("npc_economy_bias", 0),
        "criminal_bias": p.get("npc_criminal_bias", 0),
        "careers": careers,
        "dispositions": dispositions,
    }

def build_state(conn, user, player):
    apply_runtime_game_settings(conn)
    resolve_completed_crafting_jobs(conn, player["id"], bool(user.get("god_mode")))
    resolve_completed_cargo_operations(conn, player["id"])
    resolve_player_legal_state(conn, player["id"])
    resolve_market_restock(conn, force=False)
    simulate_npc_market_arbitrage(conn, force=False)
    regenerate_energy(conn, player["id"])
    if user.get("god_mode"):
        conn.execute("UPDATE players SET energy=max(energy,999999999), max_energy=max(max_energy,999999999), energy_updated_at=? WHERE id=?", (iso(), player["id"]))
    player = get_player(conn, player["id"])
    ensure_galaxy_faction_content(conn)
    process_planet_faction_wars(conn, player)
    process_guild_planet_xp_bonus(conn)
    player = get_player(conn, player["id"])
    ensure_ship_parts(conn)
    ensure_radar_content(conn)
    planet = row(conn, "SELECT p.*, g.name as galaxy_name, g.code as galaxy_code FROM planets p JOIN galaxies g ON g.id=p.galaxy_id WHERE p.id=?", (player["location_planet_id"],))
    active_ship = row(conn, "SELECT s.*, t.name as template_name, t.class_name, t.role, t.slots_json, t.ship_tier, t.upkeep_cost, t.size_class as template_size_class, t.mass as template_mass FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=?", (player["active_ship_id"],))
    if active_ship:
        active_ship["speed_profile"] = ship_speed_profile(conn, active_ship)
    ship_modules = rows(conn, "SELECT sm.*, mt.name, mt.slot_type, mt.rarity, mt.stats_json, mt.tier as template_tier, mt.max_tier as template_max_tier, mt.price FROM ship_modules sm JOIN module_templates mt ON mt.id=sm.module_template_id WHERE sm.player_id=?", (player["id"],))
    cargo = rows(conn, "SELECT ch.*, c.code, c.name, c.legal, c.category, c.base_price, c.mass, c.tier, c.max_tier, c.tier_locked FROM cargo_hold ch JOIN commodities c ON c.id=ch.commodity_id WHERE ch.player_id=? AND ch.qty>0", (player["id"],))
    market = rows(conn, "SELECT mp.*, c.code, c.name, c.legal, c.category, c.base_price, c.mass, c.description, c.tier, c.max_tier, c.tier_locked FROM market_prices mp JOIN commodities c ON c.id=mp.commodity_id WHERE mp.planet_id=? ORDER BY c.legal DESC, c.category, c.name", (player["location_planet_id"],))
    for item in cargo:
        item["item_code"] = item.get("code")
        item["item_type"] = item.get("category")
        item["category"] = "illicit_goods" if not int(item.get("legal", 1)) else "goods"
        attach_tier_metadata(item)
        attach_item_visual(item)
    for item in market:
        item["item_code"] = item.get("code")
        item["item_type"] = item.get("category")
        item["visual_category"] = "illicit_goods" if not int(item.get("legal", 1)) else "goods"
        item["category_label"] = INVENTORY_CATEGORY_LABELS.get(item["visual_category"], label_for_api(item["visual_category"]))
        attach_tier_metadata(item)
        attach_item_visual(item, item_type_key="item_type", category_key="visual_category", legal_key="legal")
        enrich_market_item(conn, item, planet)
    cargo_usage = build_cargo_usage(conn, player["id"])
    inventory_summary = build_inventory_summary(conn, player["id"])
    guild = row(conn, "SELECT * FROM guilds WHERE id=?", (player["guild_id"],)) if player.get("guild_id") else None
    ship_power = get_ship_power(conn, player["active_ship_id"]) if player.get("active_ship_id") else 0
    inventory_rows = rows(conn, "SELECT * FROM inventory WHERE player_id=? ORDER BY category, item_type, name", (player["id"],))
    for item in inventory_rows:
        attach_tier_metadata(item)
        attach_item_visual(item)
    for mod in ship_modules:
        mod["item_type"] = "ship_module"
        mod["category"] = "ship_modules"
        mod["legal"] = 1
        mod["current_tier"] = clamp_tier(mod.get("current_tier", mod.get("template_tier", 1)))
        mod["max_tier"] = clamp_tier(mod.get("max_tier", mod.get("template_max_tier", 5)))
        mod["tier_source"] = mod.get("tier_source") or "purchased"
        mod["stats"] = apply_tier_to_item_stats(decode_json(mod.get("stats_json"), {}) or {}, mod["current_tier"])
        attach_tier_metadata(mod)
        attach_item_visual(mod)
    ship_templates = rows(conn, "SELECT * FROM ship_templates ORDER BY price")
    for st in ship_templates:
        st["current_tier"] = clamp_tier(st.get("ship_tier", 1))
        st["max_tier"] = max(st["current_tier"], st["current_tier"] + 2)
        st["tier_display"] = get_tier_display_data(st["current_tier"], st["max_tier"])
        st["image_url"] = ship_visual_payload(st.get("name") or st.get("code"), st.get("role") or st.get("class_name"))
    module_templates = rows(conn, "SELECT * FROM module_templates ORDER BY slot_type, price")
    for mt in module_templates:
        mt["item_type"] = "ship_module"
        mt["category"] = "ship_modules"
        mt["legal"] = 1
        mt["current_tier"] = clamp_tier(mt.get("tier", 1))
        mt["stats"] = apply_tier_to_item_stats(decode_json(mt.get("stats_json"), {}) or {}, mt["current_tier"])
        attach_tier_metadata(mt)
        attach_item_visual(mt)
    ships = rows(conn, "SELECT s.*, t.name as template_name, t.class_name, t.role, t.price, t.ship_tier, t.upkeep_cost FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.player_id=? ORDER BY s.starter DESC, t.price", (player["id"],))
    for sh in ships:
        sh["current_tier"] = clamp_tier(sh.get("current_tier", sh.get("ship_tier", 1)))
        sh["max_tier"] = clamp_tier(sh.get("max_tier", max(sh["current_tier"], sh["current_tier"] + 2)))
        sh["tier_display"] = get_tier_display_data(sh["current_tier"], sh["max_tier"])
        sh["image_url"] = ship_visual_payload(sh.get("name") or sh.get("template_name"), sh.get("role") or sh.get("class_name"))
    if active_ship:
        active_ship["current_tier"] = clamp_tier(active_ship.get("current_tier", active_ship.get("ship_tier", 1)))
        active_ship["max_tier"] = clamp_tier(active_ship.get("max_tier", max(active_ship["current_tier"], active_ship["current_tier"] + 2)))
        active_ship["tier_display"] = get_tier_display_data(active_ship["current_tier"], active_ship["max_tier"])
        active_ship["image_url"] = ship_visual_payload(active_ship.get("name") or active_ship.get("template_name"), active_ship.get("role") or active_ship.get("class_name"))
    operations = rows(conn, "SELECT po.*, p.name as planet_name, p.galaxy_id as galaxy_id FROM pve_operations po LEFT JOIN planets p ON p.id=po.planet_id ORDER BY difficulty, name")
    for op in operations:
        op_planet = row(conn, "SELECT * FROM planets WHERE id=?", (op["planet_id"],)) if op.get("planet_id") else planet
        op.update(pve_operation_runtime_stats(op, ship_power, bool(user["god_mode"]), conn, player["id"], op_planet or planet))
    active_career = active_job_runtime(conn, player["id"])
    travel_state = build_travel_state(conn, player)
    galaxy_map = build_galaxy_map(conn, player)
    system_map = build_system_map(conn, player)
    if planet:
        planet["image_url"] = planet_visual_payload(planet)
    ship_status = build_ship_status(conn, player, active_ship)
    all_planets = rows(conn, "SELECT p.*, g.name as galaxy_name, g.code as galaxy_code FROM planets p JOIN galaxies g ON g.id=p.galaxy_id ORDER BY g.id, p.name")
    for pl in all_planets:
        pl["image_url"] = planet_visual_payload(pl)
    activity_rows = rows(conn, "SELECT nal.*, p.name as planet_name, p.galaxy_id FROM npc_action_log nal LEFT JOIN planets p ON p.id=nal.planet_id ORDER BY nal.id DESC LIMIT 100")
    for ev in activity_rows:
        enrich_activity_event(ev)
    ensure_achievement_rows(conn, player["id"])
    profile = profile_payload(conn, user, player)
    achievements = build_achievements_state(conn, player["id"])
    chat_messages = build_chat_messages(conn, user["id"])
    active_pirate_station = pirate_station_payload(conn, player["id"])
    return {
        "user": {"id": user["id"], "username": user["username"], "role": user["role"], "god_mode": bool(user["god_mode"]), "dev_mode": DEV_MODE},
        "profile": profile,
        "achievements": achievements,
        "public_profiles": [public_profile_payload(conn, int(u["id"])) for u in rows(conn, "SELECT id FROM users ORDER BY id LIMIT 80")],
        "avatar_options": PROFILE_AVATAR_OPTIONS,
        "chat_messages": chat_messages,
        "active_pirate_station": active_pirate_station,
        "player": player,
        "player_faction": player_faction(conn, player),
        "factions": rows(conn, "SELECT * FROM factions ORDER BY id"),
        "next_level_xp": level_xp_required(player["level"]),
        "location": planet,
        "planet_control": build_planet_control_state(conn, player["id"], planet),
        "galaxies": rows(conn, "SELECT * FROM galaxies"),
        "planets": all_planets,
        "travel_state": travel_state,
        "map_operation": active_player_map_operation(conn, player["id"]),
        "tool_capabilities": player_tool_capabilities(conn, player),
        "cargo_operation": cargo_operation_status(conn, player["id"]),
        "galaxy_map": galaxy_map,
        "system_map": system_map,
        "ship_status": ship_status,
        "hangar": build_hangar_state(conn, player, user),
        "active_ship": active_ship,
        "ships": ships,
        "ship_templates": ship_templates,
        "modules": ship_modules,
        "ship_parts": rows(conn, "SELECT * FROM ship_parts WHERE ship_id=? ORDER BY id", (player["active_ship_id"],)) if player.get("active_ship_id") else [],
        "module_templates": module_templates,
        "cargo": cargo,
        "cargo_usage": cargo_usage,
        "inventory": inventory_rows,
        "inventory_summary": inventory_summary,
        "inventory_value": calculate_inventory_value(conn, player["id"]),
        "inventory_categories": INVENTORY_CATEGORY_LABELS,
        "inventory_rarity_order": INVENTORY_RARITY_ORDER,
        "tier_definitions": TIER_DEFINITIONS,
        "tier_balance": TIER_BALANCE,
        "heat_jail": jail_heat_status(conn, player["id"]),
        "fight": build_fight_state(conn, player, user),
        "combat_balance": COMBAT_BALANCE,
        "market_law_balance": MARKET_LAW_BALANCE,
        "market": market,
        "jobs": build_jobs_state(conn, player["id"]),
        "career_tasks": active_career_tasks(conn, player["id"]),
        "active_career": active_career,
        "recommended_actions": build_recommended_actions(conn, player["id"], ship_power, planet, bool(user["god_mode"])),
        "skill_totals": player_skill_totals(conn, player["id"]),
        "skills": build_skills_state(conn, player["id"]),
        "skills_catalog": PHASE16_SKILL_CATALOG,
        "progression_balance": SKILL_XP_BALANCE,
        "properties": rows(conn, "SELECT pp.*, pt.name, pt.type, pt.base_price, pt.storage, pt.income, pt.bonus_json, p.name as planet_name FROM player_properties pp JOIN property_templates pt ON pt.id=pp.property_template_id JOIN planets p ON p.id=pp.planet_id WHERE pp.player_id=?", (player["id"],)),
        "property_templates": rows(conn, "SELECT * FROM property_templates ORDER BY base_price"),
        "establishments": rows(conn, "SELECT pe.*, p.name as planet_name FROM planet_establishments pe JOIN planets p ON p.id=pe.planet_id WHERE pe.planet_id=? ORDER BY service_type", (player["location_planet_id"],)),
        "ship_power": ship_power,
        "operations": operations,
        "bounties": rows(conn, "SELECT b.*, p.name as planet_name FROM bounties b JOIN planets p ON p.id=b.planet_id WHERE b.status='open' ORDER BY threat"),
        "npc_agents": rows(conn, "SELECT * FROM npc_agents WHERE planet_id=? ORDER BY career_code, job_rank DESC, level DESC LIMIT 80", (player["location_planet_id"],)),
        "npc_summary": npc_planet_summary(conn, player["location_planet_id"]),
        "salvage_sites": build_salvage_sites(conn, player["location_planet_id"]),
        "npc_activity": activity_rows,
        "simulation": {"balance": SIMULATION_BALANCE, **(row(conn, "SELECT * FROM simulation_ticks WHERE id=1") or {})},
        "game_tuning": build_game_tuning_state(conn, user),
        "market_history": rows(conn, "SELECT mh.*, c.name as commodity_name, p.name as planet_name FROM market_history mh JOIN commodities c ON c.id=mh.commodity_id JOIN planets p ON p.id=mh.planet_id ORDER BY mh.id DESC LIMIT 50"),
        "market_transactions": rows(conn, "SELECT mt.*, p.name as planet_name, COALESCE(c.name, mt.item_name) as commodity_name FROM market_transactions mt LEFT JOIN commodities c ON c.id=mt.commodity_id LEFT JOIN planets p ON p.id=mt.planet_id WHERE mt.player_id=? OR mt.player_id IS NULL ORDER BY mt.id DESC LIMIT 60", (player["id"],)),
        "player_market": build_player_market_state(conn, player["id"]),
        "crafting_recipes": build_crafting_state(conn, player["id"], planet, bool(user["god_mode"])),
        "crafting_queue": crafting_queue_payload(conn, player["id"]),
        "crafting_history": rows(conn, "SELECT * FROM crafting_history WHERE player_id=? ORDER BY id DESC LIMIT 40", (player["id"],)),
        "crafting_balance": CRAFTING_BALANCE,
        "guild": guild,
        "guild_skills": rows(conn, "SELECT * FROM guild_skills WHERE guild_id=?", (player["guild_id"],)) if player.get("guild_id") else [],
        "guilds": rows(conn, "SELECT * FROM guilds ORDER BY respect DESC"),
        "wars": active_or_upcoming_planet_wars(conn),
        "planet_wars": active_or_upcoming_planet_wars(conn),
        "resolved_planet_wars": resolved_planet_faction_wars(conn),
        "galaxy_wars": active_or_upcoming_planet_wars(conn),
        "resolved_galaxy_wars": resolved_planet_faction_wars(conn),
        "events": rows(conn, "SELECT * FROM events WHERE player_id IS NULL OR player_id=? ORDER BY id DESC LIMIT 30", (player["id"],)),
        "money_sinks": rows(conn, "SELECT * FROM money_sinks WHERE player_id=? ORDER BY id DESC LIMIT 25", (player["id"],)),
        "server_time": iso(),
    }


@app.post("/api/action")
def action(req: ActionRequest, ctx: Tuple[Dict[str,Any], Dict[str,Any]] = Depends(current_context)) -> Dict[str, Any]:
    user, player = ctx
    conn = connect()
    try:
        conn.execute("BEGIN IMMEDIATE")
        player = resolve_completed_travel(conn, get_player(conn, player["id"]))
        player = resolve_intercept_if_close(conn, get_player(conn, player["id"]))
        resolve_completed_cargo_operations(conn, player["id"])
        advance_pirate_station_run(conn, player["id"])
        player = get_player(conn, player["id"])
        ensure_action_allowed(conn, user, player, req)
        result = handle_action(conn, user, player, req)
        conn.commit()
        fresh = get_player(conn, player["id"])
        fresh_user = row(conn, "SELECT * FROM users WHERE id=?", (user["id"],)) or user
        return {"ok": True, "result": result, "state": build_state(conn, fresh_user, fresh)}
    except HTTPException:
        conn.rollback()
        raise
    except Exception as ex:
        conn.rollback()
        raise HTTPException(500, str(ex))
    finally:
        conn.close()



def handle_action_forced_travel(conn, user, player, action_type: str, payload: Dict[str, Any], god: bool = False) -> Dict[str, Any]:
    # Used by the War page's Navigate button to start the next manual leg.
    # It still uses the normal travel action path: no teleporting.
    return handle_action(conn, user, player, ActionRequest(type=action_type, payload=payload, nonce=uuid.uuid4().hex))


def handle_action(conn, user, player, req: ActionRequest) -> Dict[str, Any]:
    t = {"activate_ship":"set_active_ship", "install_equipment":"equip_module", "remove_equipment":"unequip_module", "repair_ship":"repair_refuel", "refuel_ship":"repair_refuel", "recharge_ship":"repair_refuel"}.get(req.type, req.type)
    god = bool(user["god_mode"])
    pid = player["id"]
    payload = req.payload or {}
    apply_runtime_game_settings(conn)
    resolve_completed_crafting_jobs(conn, pid, bool(user.get("god_mode")))
    player = get_player(conn, pid)

    docked_only_actions = {
        "buy_commodity", "sell_commodity", "buy_ship", "buy_module", "buy_property",
        "create_player_listing", "buy_player_listing", "cancel_player_listing",
        "equip_module", "unequip_module", "set_active_ship", "repair_refuel",
        "upgrade_module", "upgrade_inventory_item", "equip_inventory_item",
        "salvage_inventory_item", "use_inventory_item", "pve_operation",
        "run_smuggling_route", "planet_control_action", "career_task",
        "accept_bounty", "start_combat", "preview_combat", "mine", "salvage",
        "collect_property_income", "upgrade_property", "insure_ship",
    }
    if t in docked_only_actions:
        t_until = parse_dt(player.get("travel_until"))
        if (t_until and t_until > utcnow()) or player_is_in_open_space(conn, pid):
            raise HTTPException(409, "You are in open space. Dock at a planet or station before using market, crafting, repairs, hangar, planet services, or local combat.")

    if t == "update_profile":
        current_username = user["username"]
        new_username = normalize_username(str(payload.get("username") or current_username))
        display_name = normalize_display_name(str(payload.get("displayName") or payload.get("display_name") or player.get("callsign") or current_username))
        avatar_id = clean_avatar_id(str(payload.get("avatarId") or payload.get("avatar_id") or DEFAULT_AVATAR_ID))
        selected_badge_code = str(payload.get("selectedBadgeCode") or payload.get("selected_badge_code") or "").strip()
        if selected_badge_code and not selected_badge_is_unlocked(conn, pid, selected_badge_code):
            raise HTTPException(400, "Selected achievement badge is not unlocked")
        bio = normalize_bio(str(payload.get("bio") or ""))
        if new_username != current_username:
            conflict = row(conn, "SELECT id FROM users WHERE username=? AND id<>?", (new_username, user["id"]))
            if conflict:
                raise HTTPException(409, "Username is already taken")
            conn.execute("UPDATE users SET username=? WHERE id=?", (new_username, user["id"]))
        ensure_user_profile(conn, user, player)
        conn.execute(
            "UPDATE user_profiles SET display_name=?, avatar_id=?, bio=?, selected_badge_code=?, updated_at=? WHERE user_id=?",
            (display_name, avatar_id, bio, selected_badge_code, iso(), user["id"]),
        )
        conn.execute("UPDATE players SET callsign=? WHERE id=?", (display_name, pid))
        add_event(conn, pid, "profile", "Profile updated.")
        grant_achievement_progress(conn, pid, "social", 1)
        return {"message":"Profile saved.", "username":new_username, "displayName":display_name, "avatarId":avatar_id, "selectedBadgeCode":selected_badge_code}

    if t == "set_achievement_badge":
        badge_code = str(payload.get("badgeCode") or payload.get("selectedBadgeCode") or "").strip()
        if badge_code and not selected_badge_is_unlocked(conn, pid, badge_code):
            raise HTTPException(400, "Achievement badge is not unlocked")
        ensure_user_profile(conn, user, player)
        conn.execute("UPDATE user_profiles SET selected_badge_code=?, updated_at=? WHERE user_id=?", (badge_code, iso(), user["id"]))
        add_event(conn, pid, "profile", f"Selected profile badge {badge_code or 'none'}.")
        return {"message":"Profile achievement badge updated.", "selectedBadgeCode":badge_code}

    if t == "view_public_profile":
        target_user_id = int(payload.get("userId") or payload.get("user_id") or 0)
        if not target_user_id:
            target_player_id = int(payload.get("playerId") or payload.get("player_id") or 0)
            target = row(conn, "SELECT user_id FROM players WHERE id=?", (target_player_id,))
            target_user_id = int(target.get("user_id") or 0) if target else 0
        public_profile = public_profile_payload(conn, target_user_id, pid)
        if not public_profile:
            raise HTTPException(404, "Profile not found")
        return {"message":"Profile loaded.", "publicProfile":public_profile}

    if t == "send_chat_message":
        ensure_user_profile(conn, user, player)
        text = " ".join(str(payload.get("message") or "").strip().split())
        if not text:
            raise HTTPException(400, "Chat message cannot be blank")
        if len(text) > PROFILE_LIMITS["chat_max"]:
            raise HTTPException(400, f"Chat message must be {PROFILE_LIMITS['chat_max']} characters or less")
        profile = row(conn, "SELECT * FROM user_profiles WHERE user_id=?", (user["id"],)) or {}
        sender = profile.get("display_name") or player.get("callsign") or user.get("username")
        avatar_id = clean_avatar_id(profile.get("avatar_id"))
        conn.execute(
            "INSERT INTO chat_messages (user_id,player_id,sender_type,sender_name,avatar_id,message,created_at) VALUES (?,?,?,?,?,?,?)",
            (user["id"], pid, "player", sender, avatar_id, text, iso()),
        )
        conn.execute("DELETE FROM chat_messages WHERE id NOT IN (SELECT id FROM chat_messages ORDER BY id DESC LIMIT 160)")
        return {"message":"Chat message sent."}


    if t == "enter_pirate_station":
        station_id = int(payload.get("station_id") or payload.get("stationId") or 0)
        station = row(conn, "SELECT * FROM pirate_stations WHERE id=?", (station_id,))
        if not station:
            raise HTTPException(404, "Pirate station not found")
        require_player_action_range(conn, player, station, "system", "enter pirate station", god)
        return begin_pirate_station_run(conn, player, station_id)

    if t == "pirate_station_move":
        dx = float(payload.get("dx") or 0)
        dy = float(payload.get("dy") or 0)
        return move_pirate_station_player(conn, player, dx, dy)

    if t == "pirate_station_retreat":
        return retreat_pirate_station(conn, player, escaped=False)

    if t == "pirate_station_start_battle":
        enemy_id = int(payload.get("enemy_id") or payload.get("enemyId") or 0)
        return start_pirate_station_battle(conn, player, enemy_id)

    if t == "pirate_station_resolve_battle":
        return resolve_pirate_station_battle(conn, player, god)

    if t == "pirate_station_close_battle":
        return close_pirate_station_battle(conn, player)

    if t == "go_here":
        map_type = str(payload.get("map_type") or "system").lower()
        x_pct = max(1.0, min(99.0, float(payload.get("x_pct") or 50)))
        y_pct = max(1.0, min(99.0, float(payload.get("y_pct") or 50)))
        t_until = parse_dt(player.get("travel_until"))
        if t_until and t_until > utcnow():
            raise HTTPException(409, "Already traveling. Finish the current route before plotting a new waypoint.")
        current = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],))
        if not current:
            raise HTTPException(400, "Current location is unknown")
        active_map = build_galaxy_map(conn, player) if map_type == "galaxy" else build_system_map(conn, player)
        nodes = active_map.get("nodes", [])
        if not nodes:
            raise HTTPException(404, "No navigable map nodes are available")
        origin_key = active_map.get("current_galaxy_id") if map_type == "galaxy" else active_map.get("current_planet_id")
        travel_state = build_travel_state(conn, player)
        if travel_state.get("open_space") and (not travel_state.get("open_space_map_type") or travel_state.get("open_space_map_type") == map_type):
            origin_node = {"id": origin_key, "x_pct": float(travel_state.get("open_space_x_pct") or 50), "y_pct": float(travel_state.get("open_space_y_pct") or 50), "name": "Current open-space position"}
        else:
            origin_node = next((n for n in nodes if str(n.get("id")) == str(origin_key)), nodes[0])
        distance = ((float(origin_node.get("x_pct") or 50) - x_pct) ** 2 + (float(origin_node.get("y_pct") or 50) - y_pct) ** 2) ** 0.5
        ship = row(conn, "SELECT * FROM ships WHERE id=?", (player["active_ship_id"],)) if player.get("active_ship_id") else None
        seconds = map_route_seconds_for_distance(conn, ship or {}, distance, god)
        fuel_cost = 0 if god else max(1, int(distance / 14))
        spend(conn, pid, fuel=fuel_cost, god=god)
        now = utcnow()
        arrival = now + timedelta(seconds=seconds)
        clear_player_open_space(conn, pid)
        clear_player_intercept(conn, pid)
        clear_player_route(conn, pid)
        set_player_waypoint(conn, pid, {
            "map_type": map_type,
            "x_pct": x_pct,
            "y_pct": y_pct,
            "label": payload.get("label") or "Open-space waypoint",
            "origin_x_pct": float(origin_node.get("x_pct") or 50),
            "origin_y_pct": float(origin_node.get("y_pct") or 50),
            "started_at": iso(now),
            "arrival_at": iso(arrival),
        })
        conn.execute(
            """UPDATE players
               SET travel_until=?, travel_destination_id=?, travel_mode='waypoint',
                   travel_started_at=?, travel_origin_planet_id=?, travel_origin_galaxy_id=?, travel_destination_galaxy_id=?
               WHERE id=?""",
            (iso(arrival), current["id"], iso(now), current["id"], current["galaxy_id"], current["galaxy_id"], pid),
        )
        add_event(conn, pid, "travel", f"Open-space waypoint plotted to {x_pct:.1f} / {y_pct:.1f}. ETA {seconds} seconds.", {"map_type": map_type, "x_pct": x_pct, "y_pct": y_pct})
        return {"message": f"Open-space waypoint plotted to {x_pct:.1f} / {y_pct:.1f}.", "seconds": seconds, "fuel_cost": fuel_cost, "x_pct": x_pct, "y_pct": y_pct}

    if t == "cancel_travel":
        travel_state = build_travel_state(conn, player)
        if not travel_state.get("active"):
            return {"message": "No active travel route to cancel."}
        map_type = str(travel_state.get("map_type") or ("galaxy" if travel_state.get("mode") in {"galaxy", "galaxy_route"} else "system")).lower()
        point = current_player_map_position(conn, player, map_type)
        clear_player_waypoint(conn, pid)
        clear_player_intercept(conn, pid)
        clear_player_route(conn, pid)
        set_player_open_space(conn, pid, {
            "active": True,
            "map_type": map_type,
            "x_pct": float(point.get("x_pct") or 50),
            "y_pct": float(point.get("y_pct") or 50),
            "anchor_planet_id": player.get("location_planet_id"),
            "anchor_galaxy_id": player.get("travel_origin_galaxy_id"),
            "arrived_at": iso(),
            "label": "Cancelled route position",
        })
        conn.execute(
            """UPDATE players
               SET travel_until=NULL, travel_destination_id=NULL, travel_mode=NULL,
                   travel_started_at=NULL, travel_origin_planet_id=NULL, travel_origin_galaxy_id=NULL, travel_destination_galaxy_id=NULL
               WHERE id=?""",
            (pid,),
        )
        add_event(conn, pid, "travel", f"Travel cancelled at {point.get('x_pct'):.1f} / {point.get('y_pct'):.1f}.", {"map_type": map_type, "x_pct": point.get("x_pct"), "y_pct": point.get("y_pct")})
        return {"message": "Travel cancelled. Ship is holding in open space.", "open_space": True, "x_pct": point.get("x_pct"), "y_pct": point.get("y_pct"), "map_type": map_type}

    if t == "scan_area":
        map_type = str(payload.get("map_type") or "system").lower()
        spend(conn, pid, energy=OPEN_WORLD_BALANCE["scan_area_energy"], god=god)
        scan_quality = clamp_int(45 + int(player_skill_totals(conn, pid).get("scanning", 0) or 0) * 2 + random.randint(-8, 18), 5, 99)
        add_event(conn, pid, "exploration", f"Area scan complete. Signal quality {scan_quality}%.", {"map_type": map_type, "scan_quality": scan_quality})
        grant_action_progression(conn, pid, "exploration", max(1.0, scan_quality / 30), True)
        return {"message": f"Area scan complete. Signal quality {scan_quality}%. Check ore and ancient-site contacts on the map.", "scan_quality": scan_quality}

    if t == "scan_exploration_site":
        site_id = str(payload.get("site_id") or payload.get("siteId") or "")
        obj = row(conn, "SELECT * FROM map_objects WHERE object_key=? AND kind='exploration' AND state NOT IN ('deleted','expired','depleted') AND qty_remaining>0", (site_id,))
        if not obj:
            raise HTTPException(404, "Exploration signal is gone or already investigated")
        caps = player_tool_capabilities(conn, player)
        if not caps.get("can_scan") and not god:
            raise HTTPException(400, "Requires an equipped scanner/probe/relic module")
        site = map_object_to_payload(obj, player)
        require_player_action_range(conn, player, site, str(site.get("map_type") or "system"), "scan exploration site", god)
        energy = int(site.get("scanEnergy") or OPEN_WORLD_BALANCE["scan_site_energy"])
        spend(conn, pid, energy=energy, god=god)
        meta = decode_json(obj.get("metadata_json"), {}) or {}
        meta["signalState"] = "resolved"
        meta["signalQuality"] = min(100, int(meta.get("signalQuality") or 50) + 8)
        meta["name"] = meta.get("realName") or obj.get("name")
        conn.execute("UPDATE map_objects SET name=?, metadata_json=?, state='available', updated_at=? WHERE id=?", (meta.get("realName") or obj.get("name"), encode_json(meta), iso(), obj["id"]))
        map_op = start_player_map_operation(conn, player, site_id, "scanning", 8, f"Scanned {meta.get('realName') or site.get('name')}.", {"signalQuality": meta["signalQuality"]})
        grant_action_progression(conn, pid, "exploration", max(1.0, int(site.get("signalQuality") or 50) / 25), True)
        add_event(conn, pid, "exploration", f"Scanned {meta.get('realName') or site.get('name')}: {site.get('rewardHint')} potential, {site.get('riskBand')} risk.")
        return {"message": f"Scan complete: {meta.get('realName') or site.get('name')} shows {site.get('rewardHint')} potential, {site.get('riskBand')} risk, quality {meta['signalQuality']}%.", "mapOperation": map_op}

    if t == "investigate_exploration_site":
        site_id = str(payload.get("site_id") or payload.get("siteId") or "")
        obj = row(conn, "SELECT * FROM map_objects WHERE object_key=? AND kind='exploration' AND state NOT IN ('deleted','expired','depleted') AND qty_remaining>0", (site_id,))
        if not obj:
            raise HTTPException(404, "Exploration site is gone or already investigated")
        caps = player_tool_capabilities(conn, player)
        if not caps.get("can_investigate") and not god:
            raise HTTPException(400, "Requires an equipped scanner/probe/relic module")
        site = map_object_to_payload(obj, player)
        require_player_action_range(conn, player, site, str(site.get("map_type") or "system"), "investigate exploration site", god)
        energy = int(site.get("investigateEnergy") or OPEN_WORLD_BALANCE["investigate_site_energy"])
        spend(conn, pid, energy=energy, god=god)
        skills = player_skill_totals(conn, pid)
        scan_skill = int(skills.get("scanning", 0) or 0)
        exploration_skill = int(skills.get("exploration", 0) or 0)
        quality = int(site.get("signalQuality") or 50)
        tier = int(site.get("rewardTier") or site.get("tier") or 1)
        risk = int(site.get("riskLevel") or 40)
        roll = random.randint(1, 100) + scan_skill + exploration_skill + quality // 8 - risk // 10
        if roll < 35:
            payout = random.randint(0, 450 * tier)
            outcome = "low-yield"
        elif roll < 75:
            payout = random.randint(1200 * tier, 4500 * tier)
            outcome = "useful"
        else:
            payout = random.randint(6000 * tier, 18000 * tier)
            outcome = "jackpot"
        if not god:
            conn.execute("UPDATE players SET credits=credits+? WHERE id=?", (payout, pid))
        conn.execute("UPDATE map_objects SET qty_remaining=0, state='depleted', locked_by_player_id=NULL, operation_type='', operation_until=NULL, updated_at=? WHERE id=?", (iso(), obj["id"]))
        map_op = start_player_map_operation(conn, player, site_id, "investigation", 14 + tier * 3, f"Investigated {site.get('realName') or site.get('name')} — {outcome}.", {"outcome": outcome, "payout": payout})
        grant_action_progression(conn, pid, "exploration", max(2.0, tier * 2.2), True)
        add_event(conn, pid, "exploration", f"Investigation {outcome}: {site.get('realName') or site.get('name')} yielded {payout:,} credits.", {"site_id": site_id, "outcome": outcome, "payout": payout})
        return {"message": f"Investigation {outcome}: recovered {payout:,} credits. Factors: signal quality {quality}%, exploration {exploration_skill}, scanning {scan_skill}, risk {risk}%.", "mapOperation": map_op}

    if t == "resolve_intercept_now":
        player_now = get_player(conn, pid)
        if player_now.get("travel_mode") != "intercept":
            return {"message": "No active intercept course."}
        dest = row(conn, "SELECT * FROM planets WHERE id=?", (player_now.get("travel_destination_id"),))
        origin = row(conn, "SELECT * FROM planets WHERE id=?", (player_now.get("travel_origin_planet_id") or player_now.get("location_planet_id"),))
        if not dest:
            raise HTTPException(404, "Intercept destination is no longer available")
        resolve_completed_intercept(conn, player_now, dest, origin)
        return {"message": "Intercept range reached. Combat resolved."}

    if t == "intercept_traveler":
        target_ref = normalize_traveler_target_ref(str(payload.get("target_ref") or payload.get("traveler_id") or payload.get("id") or ""))
        current = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],))
        if not current:
            raise HTTPException(400, "Current location is unknown")
        t_until = parse_dt(player.get("travel_until"))
        if t_until and t_until > utcnow():
            raise HTTPException(409, "Already traveling. Finish the current route before plotting an intercept.")

        system_map = build_system_map(conn, player)
        galaxy_map = build_galaxy_map(conn, player)
        traffic = list(system_map.get("traffic", [])) + list(galaxy_map.get("traffic", []))
        target = next((x for x in traffic if x.get("combatTargetRef") == target_ref or x.get("id") == target_ref), None)
        if not target:
            _ = get_combat_target(conn, player, target_ref)
            target = {"name": target_ref, "x_pct": 50, "y_pct": 50, "to": current["id"], "id": target_ref + ":system"}
        map_type = "galaxy" if str(target.get("id") or target_ref).endswith(":galaxy") else "system"
        if map_type == "system":
            dest_planet_id = int(target.get("to") or current["id"])
        else:
            dest_galaxy_id = int(target.get("to") or current.get("galaxy_id") or 0)
            pick = row(conn, "SELECT * FROM planets WHERE galaxy_id=? ORDER BY security_level DESC, id LIMIT 1", (dest_galaxy_id,))
            dest_planet_id = int((pick or current)["id"])
        dest = row(conn, "SELECT * FROM planets WHERE id=?", (dest_planet_id,))
        if not dest:
            raise HTTPException(404, "Intercept destination drifted out of range")

        spend(conn, pid, fuel=OPEN_WORLD_BALANCE["min_intercept_fuel"], energy=OPEN_WORLD_BALANCE["intercept_energy"], god=god)
        now = utcnow()
        open_space = get_player_open_space(conn, pid)
        if open_space.get("active") and (not open_space.get("map_type") or str(open_space.get("map_type")) == map_type):
            origin_x = float(open_space.get("x_pct") or 50)
            origin_y = float(open_space.get("y_pct") or 50)
        else:
            origin_node = player_map_center(conn, player, map_type, (system_map if map_type == "system" else galaxy_map).get("nodes", []))
            origin_x = float(origin_node.get("x_pct") or 50)
            origin_y = float(origin_node.get("y_pct") or 50)
        target_x = float(target.get("x_pct") or 50)
        target_y = float(target.get("y_pct") or 50)
        dx = target_x - origin_x
        dy = target_y - origin_y
        intercept_distance = (dx * dx + dy * dy) ** 0.5
        intercept_ship = row(conn, "SELECT * FROM ships WHERE id=?", (player.get("active_ship_id"),)) if player.get("active_ship_id") else {}
        seconds = map_route_seconds_for_distance(conn, intercept_ship or {}, intercept_distance, god)
        arrival = now + timedelta(seconds=seconds)
        set_player_intercept(conn, pid, {
            "target_ref": target_ref,
            "target_name": target.get("name") or target_ref,
            "target_role": target.get("role"),
            "map_type": map_type,
            "origin_x_pct": origin_x,
            "origin_y_pct": origin_y,
            "x_pct": target_x,
            "y_pct": target_y,
            "started_at": iso(now),
            "arrival_at": iso(arrival),
        })
        conn.execute(
            """UPDATE players
               SET travel_until=?, travel_destination_id=?, travel_mode='intercept',
                   travel_started_at=?, travel_origin_planet_id=?, travel_origin_galaxy_id=?, travel_destination_galaxy_id=?
               WHERE id=?""",
            (iso(arrival), dest_planet_id, iso(now), current["id"], current["galaxy_id"], dest.get("galaxy_id"), pid),
        )
        add_event(conn, pid, "combat", f"Intercept course plotted against {target.get('name') or target_ref}. Weapons will engage automatically at close range.", {"target_ref": target_ref, "etaSeconds": seconds, "map_type": map_type})
        return {"message": f"Intercept course plotted against {target.get('name') or target_ref}. Auto-attack will trigger at close range in about {seconds} seconds.", "target_ref": target_ref, "etaSeconds": seconds, "mode": "intercept"}

    if t == "mine_ore_site":
        site_id = str(payload.get("site_id") or payload.get("siteId") or "")
        obj = row(conn, "SELECT * FROM map_objects WHERE object_key=? AND kind='ore' AND state NOT IN ('deleted','expired','depleted') AND qty_remaining>0", (site_id,))
        if not obj:
            raise HTTPException(404, "Ore field is gone or depleted")
        caps = player_tool_capabilities(conn, player)
        if not caps.get("can_mine") and not god:
            raise HTTPException(400, "Requires an equipped mining laser/drill")
        site = map_object_to_payload(obj, player)
        require_player_action_range(conn, player, site, str(site.get("map_type") or "system"), "mine ore site", god)
        energy = int(site.get("energyCost") or OPEN_WORLD_BALANCE["ore_mine_min_energy"])
        qty = max(1, min(int(site.get("qtyRemaining") or site.get("qty") or 1), max(1, int(site.get("tier") or 1) * 4 + 6)))
        code = str(obj.get("code") or site.get("oreCode") or "ore")
        spend(conn, pid, energy=energy, fuel=max(1, int(site.get("tier") or 1)), god=god)
        seconds = max(8, min(90, int(16 + int(site.get("tier") or 1) * 7)))
        map_op = start_player_map_operation(conn, player, site_id, "mining", seconds, f"Mining {site.get('name')} — extracting {qty} units.", {"qty": qty, "ore_code": code})
        conn.execute("UPDATE map_objects SET state='being_mined', locked_by_player_id=?, operation_type='mining', operation_until=?, updated_at=? WHERE id=?", (pid, map_op["ends_at"], iso(), obj["id"]))
        op = begin_cargo_operation(conn, pid, player["location_planet_id"], "mine_ore_site", code, site.get("name") or label_for_api(code), qty, float(site.get("massEach") or 1) * qty, 0, 0, 0, 1, {"ore_code": code, "ore_name": site.get("name"), "tier": int(site.get("tier") or 1), "unit_value": int(site.get("unitValue") or 60), "mass_each": float(site.get("massEach") or 1), "map_object_key": site_id, "location_name": "open space"}, god)
        remaining = max(0, int(obj.get("qty_remaining") or 0) - qty)
        conn.execute("UPDATE map_objects SET qty_remaining=?, state=?, locked_by_player_id=NULL, operation_type='', operation_until=NULL, updated_at=? WHERE id=?", (remaining, "depleted" if remaining <= 0 else "available", iso(), obj["id"]))
        op["mapOperation"] = map_op
        op["message"] = f"Mining started: {site.get('name')} ({qty} units). Watch the active operation indicator. " + op.get("message", "")
        return op

    if t == "attempt_combat_escape":
        chance = player_escape_chance(conn, player)
        roll = random.random()
        escaped = roll <= chance
        if escaped:
            set_combat_actor_immunity(conn, f"player:{pid}")
        add_event(conn, pid, "combat", f"Escape attempt {'succeeded' if escaped else 'failed'} at {round(chance*100)}% odds.", {"escaped": escaped, "chance": chance, "roll": roll, "battleId": payload.get("battle_id")})
        return {"message": "Escape succeeded." if escaped else "Escape failed.", "escaped": escaped, "chance": round(chance, 3), "roll": round(roll, 3), "immunitySeconds": int(COMBAT_BALANCE.get("post_battle_immunity_seconds", 5)) if escaped else 0}

    if t == "start_combat":
        target_ref = str(payload.get("target_ref") or payload.get("targetId") or "")
        mode = str(payload.get("mode") or "attack")
        result = simulate_combat_battle(conn, player, target_ref, mode, god)
        return result

    if t == "preview_combat":
        target_ref = str(payload.get("target_ref") or payload.get("targetId") or "")
        mode = str(payload.get("mode") or "attack")
        preview = combat_preview(conn, player, target_ref, mode)
        return {"message":"Combat preview ready.", "preview": preview}


    if t == "admin_save_game_config":
        if not user["god_mode"] or not DEV_MODE:
            raise HTTPException(403, "Game tuning is dev/admin only")
        key = str(payload.get("key") or "").strip()
        value = payload.get("value")
        if not isinstance(value, dict):
            raise HTTPException(400, "Config value must be a JSON object")
        save_game_config_override(conn, key, value, user.get("username") or str(user.get("id")))
        if key in {"RANKED_CRAFTING_BALANCE", "RECIPE_DROP_BALANCE"}:
            ensure_crafting_content(conn)
        add_event(conn, pid, "admin", f"Updated game tuning group {key}.", {"key": key})
        return {"message": f"Saved {key}."}

    if t == "admin_reset_game_config":
        if not user["god_mode"] or not DEV_MODE:
            raise HTTPException(403, "Game tuning is dev/admin only")
        key = str(payload.get("key") or "").strip()
        reset_game_config_override(conn, key)
        if key in {"RANKED_CRAFTING_BALANCE", "RECIPE_DROP_BALANCE"}:
            ensure_crafting_content(conn)
        add_event(conn, pid, "admin", f"Reset game tuning group {key}.", {"key": key})
        return {"message": f"Reset {key} to defaults."}

    if t == "admin_reset_all_game_configs":
        if not user["god_mode"] or not DEV_MODE:
            raise HTTPException(403, "Game tuning is dev/admin only")
        reset_all_game_config_overrides(conn)
        ensure_crafting_content(conn)
        add_event(conn, pid, "admin", "Reset all game tuning overrides.")
        return {"message": "Reset all game tuning overrides."}

    if t == "admin_godmode":
        if not user["god_mode"] or not DEV_MODE:
            raise HTTPException(403, "God mode endpoint is dev/admin only")
        ship = row(conn, "SELECT * FROM ships WHERE id=?", (player["active_ship_id"],))
        conn.execute("UPDATE players SET level=99,xp=0,skill_points=99999,credits=999999999,fuel=999999,max_fuel=999999,energy=999999,max_energy=999999,max_cargo=999999,scrap=999999,loyalty=999999,health=max_health,hospital_until=NULL,travel_until=NULL,travel_destination_id=NULL,cargo_operation_until=NULL,cargo_operation_started_at=NULL,cargo_operation_type=NULL,cargo_operation_summary=NULL,heat=0,heat_updated_at=NULL,jailed_until=NULL,jail_reason=NULL,jail_severity=NULL,jail_location=NULL,illegal_action_cooldown_until=NULL,breakout_cooldown_until=NULL,breakout_failures=0 WHERE id=?", (pid,))
        conn.execute("UPDATE pending_cargo_operations SET status='cancelled', completed_at=? WHERE player_id=? AND status='active'", (iso(), pid))
        if ship:
            conn.execute("UPDATE ships SET destroyed=0,hull=max_hull,shield=max_shield,insured=1,insurance_tier='premium' WHERE player_id=?", (pid,))
            ensure_ship_parts(conn)
            conn.execute("UPDATE ship_parts SET hp=max_hp WHERE ship_id IN (SELECT id FROM ships WHERE player_id=?)", (pid,))
            conn.execute("UPDATE ship_modules SET durability=100 WHERE player_id=?", (pid,))
        add_event(conn, pid, "admin", "God mode refreshed: unlimited resources and cleared penalties. Travel still uses ship speed.")
        return {"message":"God mode refreshed."}

    if t == "complete_travel":
        dest = player.get("travel_destination_id")
        if dest:
            conn.execute("UPDATE players SET travel_until=?, travel_started_at=? WHERE id=?", (iso(utcnow() - timedelta(seconds=2)), iso(utcnow() - timedelta(seconds=4)), pid))
            resolve_completed_travel(conn, get_player(conn, pid))
        return {"message":"Travel completed."}

    if t == "galaxy_travel":
        galaxy_id = int(payload.get("galaxy_id"))
        target_galaxy = row(conn, "SELECT * FROM galaxies WHERE id=?", (galaxy_id,))
        if not target_galaxy:
            raise HTTPException(404, "Galaxy not found")
        current = row(conn, "SELECT p.*, g.id as galaxy_id, g.name as galaxy_name FROM planets p JOIN galaxies g ON g.id=p.galaxy_id WHERE p.id=?", (player["location_planet_id"],))
        if current and int(current.get("galaxy_id") or 0) == galaxy_id:
            raise HTTPException(400, "Already in this galaxy")
        ship = row(conn, "SELECT * FROM ships WHERE id=?", (player["active_ship_id"],))
        if not ship or ship["destroyed"]:
            raise HTTPException(400, "No usable active ship")

        path = galaxy_path(conn, int(current["galaxy_id"]), galaxy_id)
        if not path or len(path) < 2:
            raise HTTPException(404, "No connected gate route exists to that galaxy")
        segments = route_segments_for_galaxy_path(conn, path)
        if not segments:
            raise HTTPException(404, "No usable gate segments exist for that route")

        local_gate = galaxy_gate_planet(conn, int(current["galaxy_id"]))
        if not god:
            if player_is_in_open_space(conn, pid):
                raise HTTPException(409, "Dock at the local Jump Gate before starting a galaxy jump.")
            if local_gate and int(current["id"]) != int(local_gate["id"]):
                raise HTTPException(400, f"Galaxy jumps require docking at the local Jump Gate first. Travel to {local_gate['name']} on the System Map.")

        total_distance = sum(float(s.get("distance") or 0) for s in segments)
        route_danger = int(sum(planet_control_effects(row(conn, "SELECT * FROM planets WHERE id=?", (int(s["to_planet_id"]),)) or {}).get("travel_danger", 20) for s in segments) / max(1, len(segments)))
        efficiency = travel_efficiency_bonus(conn, ship["id"])
        effective_speed = effective_ship_map_speed(conn, ship)
        total_minutes = sum(max(TRAVEL_BALANCE["minimum_galaxy_minutes"], int((float(s["distance"]) * TRAVEL_BALANCE["galaxy_distance_minutes"] / max(effective_speed, 0.1)) * (1.0 + route_danger * TRAVEL_BALANCE["danger_time_pressure"]) * (1.0 - efficiency))) for s in segments)
        fuel_cost = 0 if god else max(3, int((total_distance * TRAVEL_BALANCE["galaxy_fuel_mult"] / max(effective_speed, 0.1)) * (1.0 + route_danger * TRAVEL_BALANCE["danger_fuel_pressure"]) * (1.0 - efficiency)))
        spend(conn, pid, fuel=fuel_cost, god=god)
        start_galaxy_route_segment(conn, player, segments, 0, ship, False)
        route_name_parts = []
        for gid in path:
            g_row = row(conn, "SELECT name FROM galaxies WHERE id=?", (gid,))
            route_name_parts.append(str(g_row.get("name") if g_row else gid))
        route_names = " -> ".join(route_name_parts)
        grant_action_progression(conn, pid, "travel", max(1.0, total_minutes / 8), True)
        add_event(conn, pid, "travel", f"Multi-galaxy course plotted to {target_galaxy['name']} through {len(segments)} gate segments.", {"path": path, "segments": segments, "fuel_cost": fuel_cost})
        return {"message": f"Course plotted to {target_galaxy['name']}: {route_names}.", "minutes": total_minutes, "fuel_cost": fuel_cost, "route_danger": route_danger, "segments": segments, "path": path}

    if t == "travel":
        dest = int(payload.get("planet_id"))
        target = row(conn, "SELECT * FROM planets WHERE id=?", (dest,))
        if not target: raise HTTPException(404, "Planet not found")
        ship = row(conn, "SELECT * FROM ships WHERE id=?", (player["active_ship_id"],))
        if not ship or ship["destroyed"]: raise HTTPException(400, "No usable active ship")
        current = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],))
        if int(target.get("galaxy_id") or 0) != int(current.get("galaxy_id") or 0):
            raise HTTPException(400, "Use the Galaxies map for galaxy-to-galaxy travel")
        dock_requested = bool(payload.get("dock") or payload.get("dock_on_arrival") or payload.get("dockOnArrival"))
        open_space_before_travel = get_player_open_space(conn, pid)
        in_open_space_before_travel = bool(open_space_before_travel.get("active"))
        if int(target["id"]) == int(current["id"]):
            if in_open_space_before_travel:
                target_point = {**target, **system_planet_map_point(conn, int(target["id"]))}
                range_status = action_range_status(conn, player, target_point, "system")
                if not god and not range_status.get("inRange"):
                    return start_docking_approach(conn, player, target_point, god)
                clear_player_open_space(conn, pid); clear_player_waypoint(conn, pid); clear_player_intercept(conn, pid); clear_player_route(conn, pid)
                add_event(conn, pid, "travel", f"Docked at {target['name']}. Ship left open space and is no longer visible as a map object.")
                return {"message": f"Docked at {target['name']}.", "docked": True}
            raise HTTPException(400, "Already docked at this location")
        dist = local_distance(current, target)
        route_danger = int((planet_control_effects(current).get("travel_danger", 20) + planet_control_effects(target).get("travel_danger", 20)) / 2)
        efficiency = travel_efficiency_bonus(conn, ship["id"])
        effective_speed = effective_ship_map_speed(conn, ship)
        fuel_cost = 0 if god else max(1, int((dist * TRAVEL_BALANCE["local_fuel_mult"] / max(effective_speed, 0.1)) * (1.0 + route_danger * TRAVEL_BALANCE["danger_fuel_pressure"]) * (1.0 - efficiency)))
        origin_point_for_speed = current_player_map_position(conn, player, "system")
        target_point_for_speed = system_planet_map_point(conn, int(target["id"]))
        map_distance = pct_distance(origin_point_for_speed, target_point_for_speed)
        seconds = map_route_seconds_for_distance(conn, ship, map_distance, god)
        minutes = max(1, int(math.ceil(seconds / 60)))
        spend(conn, pid, fuel=fuel_cost, god=god)
        route_meta = {}
        active_map = build_system_map(conn, player)
        target_node = next((n for n in active_map.get("nodes", []) if str(n.get("id")) == str(dest)), None)
        if in_open_space_before_travel or dock_requested:
            route_meta = {
                "map_type": "system",
                "origin_x_pct": float(origin_point_for_speed.get("x_pct") or 50),
                "origin_y_pct": float(origin_point_for_speed.get("y_pct") or 50),
                "destination_x_pct": float((target_node or target_point_for_speed).get("x_pct") or 50),
                "destination_y_pct": float((target_node or target_point_for_speed).get("y_pct") or 50),
                "label": f"Docking approach to {target['name']}" if dock_requested else f"Local travel to {target['name']}",
                "route_target_type": "dock" if dock_requested else "local",
                "route_target_id": int(target["id"]),
            }
        clear_player_open_space(conn, pid); clear_player_waypoint(conn, pid); clear_player_intercept(conn, pid); clear_player_route(conn, pid)
        now = utcnow(); arrival = now + timedelta(seconds=seconds)
        if route_meta:
            route_meta.update({"started_at": iso(now), "arrival_at": iso(arrival)})
            set_player_route(conn, pid, route_meta)
        travel_mode = 'dock' if dock_requested else 'local'
        conn.execute("""UPDATE players SET travel_until=?, travel_destination_id=?, travel_mode=?, travel_started_at=?, travel_origin_planet_id=?, travel_origin_galaxy_id=?, travel_destination_galaxy_id=? WHERE id=?""", (iso(arrival),dest,travel_mode,iso(now),current["id"],current["galaxy_id"],current["galaxy_id"],pid))
        grant_action_progression(conn, pid, "travel", max(1.0, seconds / 60 / 6), True)
        verb = "Docking approach" if dock_requested else "Local travel"
        add_event(conn, pid, "travel", f"{verb} started to {target['name']}. ETA {seconds} seconds. Route danger {route_danger}%.")
        return {"message":f"{verb} started to {target['name']}. Route danger {route_danger}%.", "seconds":seconds, "minutes":minutes, "fuel_cost":fuel_cost, "route_danger":route_danger, "dockOnArrival": dock_requested}

    if t == "planet_control_action":
        return run_planet_control_action(conn, player, str(payload.get("action_key") or ""), god)

    if t == "attempt_bribe":
        status = resolve_player_legal_state(conn, pid)
        if not status.get("jailed"):
            return {"message": "You are not jailed."}
        player_now = get_player(conn, pid)
        planet = row(conn, "SELECT * FROM planets WHERE id=?", (player_now["location_planet_id"],)) or {}
        bribe = bribe_preview(conn, player_now, planet, int(status.get("jailRemainingSeconds") or 0))
        if not bribe.get("available"):
            raise HTTPException(400, bribe.get("reason") or "Bribe is unavailable")
        cost = int(bribe.get("cost") or 0)
        spend(conn, pid, credits=cost, god=god)
        if not god:
            log_money_sink(conn, pid, "jail_bribe", cost, "Paid detention bribe to leave custody early")
        increase_player_heat(conn, pid, 4, "jail bribe")
        cd = utcnow() + timedelta(seconds=MARKET_LAW_BALANCE["post_release_illegal_cooldown_seconds"])
        conn.execute("""
            UPDATE players
            SET jailed_until=NULL, jail_reason=NULL, jail_severity=NULL, jail_location=NULL,
                illegal_action_cooldown_until=?, breakout_failures=0
            WHERE id=?
        """, (iso(cd), pid))
        add_event(conn, pid, "jail", f"Paid a {cost:,} credit bribe and left custody. Illegal market cooldown remains active.")
        return {"message": f"Bribe paid: {cost:,} credits. You are out, but illegal activity is on cooldown.", "cost": cost}

    if t == "attempt_breakout":
        status = resolve_player_legal_state(conn, pid)
        if not status.get("jailed"):
            return {"message": "You are not jailed."}
        player_now = get_player(conn, pid)
        planet = row(conn, "SELECT * FROM planets WHERE id=?", (player_now["location_planet_id"],)) or {}
        preview = breakout_preview(conn, player_now, planet)
        if not preview.get("available"):
            raise HTTPException(409, preview.get("reason") or "Breakout is on cooldown")
        chance = min(MARKET_LAW_BALANCE["breakout_max_chance"], max(MARKET_LAW_BALANCE["breakout_min_chance"], float(preview.get("chance") or 0) / 100.0))
        rng = random.Random(f"breakout:{pid}:{int(time.time() // 30)}:{player_now.get('breakout_failures') or 0}")
        success = god or rng.random() < chance
        cooldown_until = utcnow() + timedelta(seconds=MARKET_LAW_BALANCE["breakout_cooldown_seconds"])
        if success:
            increase_player_heat(conn, pid, 12, "successful breakout")
            illegal_cd = utcnow() + timedelta(seconds=max(MARKET_LAW_BALANCE["post_release_illegal_cooldown_seconds"], MARKET_LAW_BALANCE["breakout_cooldown_seconds"] * 2))
            conn.execute("""
                UPDATE players
                SET jailed_until=NULL, jail_reason=NULL, jail_severity=NULL, jail_location=NULL,
                    breakout_cooldown_until=?, illegal_action_cooldown_until=?, breakout_failures=0
                WHERE id=?
            """, (iso(cooldown_until), iso(illegal_cd), pid))
            grant_action_progression(conn, pid, "breakout", 1.25, True)
            add_event(conn, pid, "jail", f"Breakout succeeded at {round(chance*100,1)}%. Heat increased and illegal actions are cooling down.")
            return {"message": f"Breakout succeeded ({round(chance*100,1)}%). You are free, but heat increased.", "success": True, "chance": round(chance*100,1)}
        extra = random.randint(MARKET_LAW_BALANCE["breakout_fail_extra_min_minutes"], MARKET_LAW_BALANCE["breakout_fail_extra_max_minutes"])
        jail_until = parse_dt(player_now.get("jailed_until")) or utcnow()
        new_until = max(jail_until, utcnow()) + timedelta(minutes=extra)
        increase_player_heat(conn, pid, 10, "failed breakout")
        conn.execute("""
            UPDATE players
            SET jailed_until=?, breakout_cooldown_until=?, breakout_failures=breakout_failures+1
            WHERE id=?
        """, (iso(new_until), iso(cooldown_until), pid))
        grant_action_progression(conn, pid, "breakout", 0.65, False)
        add_event(conn, pid, "jail", f"Breakout failed. Sentence extended by {extra} minutes and breakout cooldown applied.")
        return {"message": f"Breakout failed ({round(chance*100,1)}%). Sentence extended by {extra} minutes.", "success": False, "chance": round(chance*100,1), "extra_minutes": extra}

    if t == "buy_commodity":
        commodity_id = int(payload["commodity_id"]); qty = max(1, int(payload.get("qty",1)))
        mp = row(conn, "SELECT mp.*, c.code, c.name, c.legal, c.category, c.base_price, c.mass, c.tier, c.description FROM market_prices mp JOIN commodities c ON c.id=mp.commodity_id WHERE mp.planet_id=? AND mp.commodity_id=?", (player["location_planet_id"], commodity_id))
        if not mp: raise HTTPException(404,"Commodity not for sale")
        if int(mp.get("supply") or 0) <= 0:
            raise HTTPException(400, "Out of stock")
        qty = min(qty, int(mp["supply"]))
        illicit = resolve_illicit_trade_or_raise(conn, pid, mp, qty, "illicit buy", god)
        if illicit.get("caught"):
            grant_action_progression(conn, pid, "illicit_trade", max(0.5, qty / 6), False)
            log_market_transaction(conn, pid, player["location_planet_id"], commodity_id, mp.get("code") or str(commodity_id), mp["name"], "illicit_buy_caught", qty, mp["buy_price"], 0, 0, 0, 0)
            add_event(conn, pid, "jail", f"Caught attempting to buy {qty}x {mp['name']}. Jailed for {illicit.get('jailMinutes')} minutes.")
            return {"message": f"Customs caught the illicit purchase. Jailed for {illicit.get('jailMinutes')} minutes.", "caught": True, "risk": illicit.get("risk")}
        cost = int(mp["buy_price"]) * qty
        station_fee = 0 if god else int(cost * (ECONOMY_CONFIG["legal_trade_station_fee"] if int(mp["legal"]) else ECONOMY_CONFIG["illegal_laundering_fee"]))
        mass = int(math.ceil(float(mp["mass"]) * qty))
        spend(conn, pid, credits=cost + station_fee, cargo_space=mass, god=god)
        if station_fee and not god:
            log_money_sink(conn, pid, "market_station_fee", station_fee, "Station brokerage, customs paperwork, cargo handling, and anti-inflation sink")
        demand_gain = max(1, qty // MARKET_LAW_BALANCE["buy_demand_gain_divisor"])
        mutate_market(conn, player["location_planet_id"], commodity_id, -int(qty * ECONOMY_CONFIG["player_market_force"]), demand_gain, "player_buy_illicit_pending" if not int(mp["legal"]) else "player_buy_pending")
        grant_action_progression(conn, pid, "legal_trade" if int(mp["legal"]) else "illicit_trade", max(1.0, qty / 4), True)
        risk_msg = f" Heat {illicit.get('heat')}%." if not illicit.get("legal") else ""
        op = begin_cargo_operation(conn, pid, player["location_planet_id"], "buy_commodity", mp.get("code") or str(commodity_id), mp["name"], qty, mass, cost, station_fee, cost + station_fee, int(mp["legal"]), {"commodity_id": commodity_id, "code": mp.get("code"), "unit_price": int(mp["buy_price"]), "tier": int(mp.get("tier") or 1)}, god)
        return {**op, "risk": illicit.get("risk"), "cost": cost, "fee": station_fee, "message": op["message"] + risk_msg}

    if t == "sell_commodity":
        commodity_id = int(payload["commodity_id"]); qty = max(1, int(payload.get("qty",1)))
        holding = row(conn, "SELECT ch.*, c.code, c.name, c.category, c.base_price, c.mass, c.legal, c.tier FROM cargo_hold ch JOIN commodities c ON c.id=ch.commodity_id WHERE ch.player_id=? AND ch.commodity_id=?", (pid, commodity_id))
        if not holding or int(holding["qty"] or 0) < qty: raise HTTPException(400,"Not enough cargo")
        mp = row(conn, "SELECT * FROM market_prices WHERE planet_id=? AND commodity_id=?", (player["location_planet_id"], commodity_id))
        if not mp: raise HTTPException(404, "Local market does not buy this commodity")
        illicit = resolve_illicit_trade_or_raise(conn, pid, holding, qty, "illicit sell", god)
        if illicit.get("caught"):
            seized = max(1, min(qty, qty // 2 or 1))
            mass_loss = int(math.ceil(float(holding.get("mass") or 1) * seized))
            conn.execute("UPDATE cargo_hold SET qty=max(0,qty-?) WHERE id=?", (seized, holding["id"]))
            conn.execute("UPDATE players SET cargo=max(0,cargo-?) WHERE id=?", (mass_loss, pid))
            grant_action_progression(conn, pid, "illicit_trade", max(0.5, qty / 6), False)
            log_market_transaction(conn, pid, player["location_planet_id"], commodity_id, holding.get("code") or str(commodity_id), holding["name"], "illicit_sell_caught", seized, int(mp["sell_price"]), 0, 0, 0, 0)
            add_event(conn, pid, "jail", f"Caught selling {holding['name']}. Seized {seized}x and jailed for {illicit.get('jailMinutes')} minutes.")
            return {"message": f"Customs caught the illicit sale. Seized {seized}x and jailed for {illicit.get('jailMinutes')} minutes.", "caught": True, "seized": seized, "risk": illicit.get("risk")}
        effective_sell_price = int(mp["sell_price"])
        if int(holding["legal"]):
            effective_sell_price = min(effective_sell_price, max(1, int(int(holding["avg_cost"] or mp["sell_price"]) * 0.98)))
        gross_revenue = effective_sell_price * qty
        sale_fee = 0 if god else int(gross_revenue * (ECONOMY_CONFIG["legal_trade_station_fee"] if int(holding["legal"]) else ECONOMY_CONFIG["illegal_laundering_fee"]))
        revenue = max(0, gross_revenue - sale_fee)
        mass = int(math.ceil(float(holding["mass"]) * qty))
        conn.execute("UPDATE cargo_hold SET qty=qty-? WHERE id=?", (qty, holding["id"]))
        conn.execute("UPDATE players SET cargo=max(0,cargo-?) WHERE id=?", (mass,pid))
        if sale_fee and not god:
            log_money_sink(conn, pid, "market_sale_fee", sale_fee, "Brokerage, laundering, docking, exchange spread, and tariff sink")
        demand_relief = max(1, qty // MARKET_LAW_BALANCE["sell_demand_relief_divisor"])
        mutate_market(conn, player["location_planet_id"], commodity_id, int(qty * ECONOMY_CONFIG["player_market_force"]), -demand_relief, "player_sell_illicit_pending" if not int(holding["legal"]) else "player_sell_pending")
        profit = max(0, (effective_sell_price - int(holding["avg_cost"] or 0)) * qty)
        active = row(conn,"SELECT * FROM player_jobs WHERE player_id=? AND active=1", (pid,))
        if active and active["job_code"] == "trader" and int(holding["legal"]):
            increment_job_metrics(conn, pid, "trader", {"trades": 1, "trade_profit": profit})
        if active and active["job_code"] == "smuggler" and not int(holding["legal"]):
            increment_job_metrics(conn, pid, "smuggler", {"smuggles": 1, "contraband_profit": revenue})
        grant_action_progression(conn, pid, "legal_trade" if int(holding["legal"]) else "illicit_trade", max(1.0, qty / 4), True)
        op = begin_cargo_operation(conn, pid, player["location_planet_id"], "sell_commodity", holding.get("code") or str(commodity_id), holding["name"], qty, mass, gross_revenue, sale_fee, revenue, int(holding["legal"]), {"commodity_id": commodity_id, "code": holding.get("code"), "unit_price": effective_sell_price, "tier": int(holding.get("tier") or 1)}, god)
        return {**op, "revenue": revenue, "gross": gross_revenue, "fee": sale_fee, "profit": profit, "risk": illicit.get("risk")}

    if t in {"sell_inventory_item", "sell_inventory"}:
        item_code = str(payload.get("item_code") or "")
        qty = max(1, int(payload.get("qty", 1)))
        inv = row(conn, "SELECT * FROM inventory WHERE player_id=? AND item_code=?", (pid, item_code))
        if not inv or int(inv["qty"] or 0) - int(inv.get("reserved_qty") or 0) < qty:
            raise HTTPException(400, "Not enough available inventory")
        commodity = row(conn, "SELECT * FROM commodities WHERE code=?", (item_code,))
        mp = row(conn, "SELECT * FROM market_prices WHERE planet_id=? AND commodity_id=?", (player["location_planet_id"], commodity["id"])) if commodity else None
        legal = int(inv.get("legal", 1))
        illicit = resolve_illicit_trade_or_raise(conn, pid, {**dict(inv), **({"category": commodity.get("category"), "base_price": commodity.get("base_price"), "tier": commodity.get("tier")} if commodity else {})}, qty, "illicit inventory sell", god)
        if illicit.get("caught"):
            seized = max(1, min(qty, qty // 2 or 1))
            remove_inventory_item(conn, pid, item_code, seized)
            grant_action_progression(conn, pid, "illicit_trade", max(0.5, qty / 6), False)
            log_market_transaction(conn, pid, player["location_planet_id"], commodity["id"] if commodity else None, item_code, inv["name"], "illicit_inventory_caught", seized, 0, 0, 0, 0, 0)
            add_event(conn, pid, "jail", f"Caught selling illegal inventory: {inv['name']}. Seized {seized}x and jailed for {illicit.get('jailMinutes')} minutes.")
            return {"message": f"Customs caught the illicit inventory sale. Seized {seized}x and jailed for {illicit.get('jailMinutes')} minutes.", "caught": True, "seized": seized, "risk": illicit.get("risk")}
        if mp:
            unit_price = int(mp["sell_price"])
        else:
            tier_value = int(attach_tier_metadata(dict(inv)).get("tier_value") or inv.get("base_value") or 0)
            base_mult = ECONOMY_BALANCE["raw_ore_sell_mult"] if str(inv.get("item_type") or "").lower() == "ore" or str(inv.get("category") or "").lower() == "raw_materials" else ECONOMY_BALANCE["non_market_item_sell_mult"]
            unit_price = max(1, int(tier_value * base_mult))
        gross_revenue = unit_price * qty
        sale_fee = 0 if god else int(gross_revenue * (ECONOMY_BALANCE["legal_sell_fee"] if legal else ECONOMY_BALANCE["illegal_sell_fee"]))
        revenue = max(0, gross_revenue - sale_fee)
        remove_inventory_item(conn, pid, item_code, qty)
        if sale_fee and not god:
            log_money_sink(conn, pid, "inventory_sale_fee", sale_fee, "Brokerage, liquidation, laundering, and tariff sink")
        if commodity and mp:
            demand_relief = max(1, qty // MARKET_LAW_BALANCE["sell_demand_relief_divisor"])
            mutate_market(conn, player["location_planet_id"], commodity["id"], int(qty * ECONOMY_CONFIG["player_market_force"]), -demand_relief, "player_inventory_sell_illicit_pending" if not legal else "player_inventory_sell_pending")
        grant_action_progression(conn, pid, "legal_trade" if legal else "illicit_trade", max(1.0, qty / 4), True)
        mass = int(math.ceil(float(inv.get("mass") or 0) * qty))
        op = begin_cargo_operation(conn, pid, player["location_planet_id"], "sell_inventory_item", item_code, inv["name"], qty, mass, gross_revenue, sale_fee, revenue, legal, {"commodity_id": commodity["id"] if commodity else None, "code": item_code, "unit_price": unit_price, "tier": int(inv.get("current_tier") or inv.get("base_tier") or 1)}, god)
        return {**op, "revenue":revenue, "gross":gross_revenue, "fee":sale_fee, "risk": illicit.get("risk")}

    if t == "inspect_inventory_item":
        item_code = str(payload.get("item_code") or "")
        source = str(payload.get("source") or "inventory")
        item = None
        if source == "cargo_hold" and payload.get("commodity_id"):
            cargo_row = row(conn, """
                SELECT ch.id, c.code as item_code, c.name, c.category as item_type,
                       CASE WHEN c.legal=0 THEN 'illicit_goods' ELSE 'goods' END as category,
                       c.category as subcategory, ch.qty, 0 as reserved_qty, 9999 as stack_size,
                       c.legal, c.base_price as base_value, c.mass, 0 as cargo_exempt, 0 as usable,
                       1 as sellable, 0 as craftable_material, 0 as equippable, '' as image_id,
                       c.description, 'cargo_hold' as source, ch.avg_cost, c.id as commodity_id, '' as acquired_at
                FROM cargo_hold ch JOIN commodities c ON c.id=ch.commodity_id
                WHERE ch.player_id=? AND ch.commodity_id=?
            """, (pid, int(payload.get("commodity_id"))))
            item = cargo_row
        else:
            item = row(conn, "SELECT * FROM inventory WHERE player_id=? AND item_code=?", (pid, item_code))
        if not item:
            raise HTTPException(404, "Inventory item not found")
        return {"message": f"Inspected {item.get('name') or item_code}.", "item": enrich_inventory_entry(conn, pid, item)}

    if t == "use_inventory_item":
        item_code = str(payload.get("item_code") or "")
        qty = max(1, int(payload.get("qty", 1)))
        check = validate_inventory_action(conn, pid, item_code, qty, "use")
        if not check["ok"]:
            raise HTTPException(400, "; ".join(check["reasons"]))
        inv = check["item"]
        item_type = str(inv.get("item_type") or "").lower()
        category = str(inv.get("category") or "").lower()
        msg = f"Used {qty}x {inv['name']}."
        if item_type in {"fuel", "energy_cell", "reactor", "power_cell"} or category == "fuel_supplies":
            gain = INVENTORY_BALANCE["consumable_fuel_pct"] * qty
            conn.execute("UPDATE players SET fuel=min(max_fuel,fuel+?) WHERE id=?", (gain, pid))
            msg = f"Consumed {qty}x {inv['name']} and restored {gain} fuel."
        elif item_type in {"repair", "medkit"} or "repair" in item_type:
            ship = row(conn, "SELECT * FROM ships WHERE id=? AND player_id=?", (player.get("active_ship_id"), pid)) if player.get("active_ship_id") else None
            if ship:
                repair = max(10, int((ship.get("max_hull") or 100) * INVENTORY_BALANCE["consumable_heal_pct"] / 100) * qty)
                conn.execute("UPDATE ships SET hull=min(max_hull,hull+?) WHERE id=?", (repair, ship["id"]))
                msg = f"Used {qty}x {inv['name']} and repaired {repair} hull."
            else:
                heal = INVENTORY_BALANCE["consumable_heal_pct"] * qty
                conn.execute("UPDATE players SET health=min(max_health,health+?) WHERE id=?", (heal, pid))
                msg = f"Used {qty}x {inv['name']} and recovered {heal} health."
        elif category == "consumables" or item_type in {"consumable", "medical"}:
            heal = INVENTORY_BALANCE["consumable_heal_pct"] * qty
            energy = INVENTORY_BALANCE["consumable_energy_pct"] * qty
            conn.execute("UPDATE players SET health=min(max_health,health+?), energy=min(max_energy,energy+?) WHERE id=?", (heal, energy, pid))
            msg = f"Used {qty}x {inv['name']} and recovered {heal} health / {energy} energy."
        else:
            raise HTTPException(400, "Item has no usable effect yet")
        remove_inventory_item(conn, pid, item_code, qty)
        add_event(conn, pid, "inventory", msg)
        return {"message": msg}

    if t == "equip_inventory_item":
        item_code = str(payload.get("item_code") or "")
        check = validate_inventory_action(conn, pid, item_code, 1, "equip")
        if not check["ok"]:
            raise HTTPException(400, "; ".join(check["reasons"]))
        inv = check["item"]
        template = row(conn, "SELECT * FROM module_templates WHERE code=?", (item_code,))
        if not template:
            raise HTTPException(400, "This item is marked equippable but has no ship module template yet")
        ship_id = int(payload.get("ship_id") or player.get("active_ship_id") or 0)
        ship = row(conn,"SELECT s.*, t.slots_json FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=? AND s.player_id=?", (ship_id,pid))
        if not ship:
            raise HTTPException(404, "Active ship not found")
        mod_runtime = dict(template)
        hydrate_module_for_loadout(mod_runtime)
        slot_id = payload.get("slot_id") or payload.get("slotId")
        target = next((x for x in build_ship_slots(conn, ship) if x.get("slotId") == slot_id), None) if slot_id else find_first_compatible_slot(conn, ship, mod_runtime)
        if not target:
            raise HTTPException(400, "No open compatible slot")
        reason = equipment_blocked_reason_for_slot(conn, ship, target, mod_runtime)
        if reason and not god:
            raise HTTPException(400, reason)
        remove_inventory_item(conn, pid, item_code, 1)
        conn.execute("INSERT INTO ship_modules (player_id,ship_id,module_template_id,slot_type,equipped,durability,equipped_slot_id,current_tier,max_tier,tier_source) VALUES (?,?,?,?,1,100,?,?,?,?)", (pid, ship_id, template["id"], canonical_slot_type(template["slot_type"]), target["slotId"], clamp_tier(template.get("tier",1)), clamp_tier(template.get("max_tier",5)), "inventory_equip"))
        return {"message": f"Equipped {inv['name']} in {target['slotLabel']} on {ship['name']}."}


    if t == "create_player_listing":
        listing = listing_payload_from_inventory(conn, pid, payload)
        qty = int(listing["qty"])
        unit_price = max(1, int(payload.get("unit_price") or listing["base_value"] or 1))
        if unit_price > max_listing_unit_price(int(listing.get("base_value") or 1)) and not god:
            raise HTTPException(400, f"Unit price too high. Max allowed is {max_listing_unit_price(int(listing.get('base_value') or 1)):,}.")
        gross = qty * unit_price
        listing_fee = 0 if god else player_market_listing_fee(qty, unit_price)
        spend(conn, pid, credits=listing_fee, god=god)
        if listing_fee and not god:
            log_money_sink(conn, pid, "player_market_listing_fee", listing_fee, "Player-market listing escrow and exchange fee")
        remove_listing_source_item(conn, pid, listing)
        now = iso()
        conn.execute(
            """
            INSERT INTO player_market_listings
              (seller_player_id,seller_name,planet_id,origin,source_ref,item_code,item_name,item_type,category,qty,remaining_qty,unit_price,legal,base_value,mass,description,rarity,status,created_at,expires_at,tier,max_tier,tier_source)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
            """,
            (
                pid, player["callsign"], player["location_planet_id"], listing["origin"], listing["source_ref"], listing["item_code"], listing["item_name"],
                listing["item_type"], listing["category"], qty, qty, unit_price, int(listing["legal"]), int(listing["base_value"]), float(listing["mass"]),
                listing["description"], listing["rarity"], "active", now, iso(utcnow()+timedelta(days=7)), clamp_tier(listing.get("tier", 1)), clamp_tier(listing.get("max_tier", 3)), listing.get("tier_source") or "listed"
            ),
        )
        log_market_transaction(conn, pid, player["location_planet_id"], None, listing["item_code"], listing["item_name"], "player_market_list", qty, unit_price, gross, listing_fee, -listing_fee, int(listing["legal"]), "player_market")
        add_event(conn, pid, "player_market", f"Listed {qty}x {listing['item_name']} for {unit_price:,} credits each. Fee {listing_fee:,}.")
        return {"message": f"Listed {qty}x {listing['item_name']} on the player market.", "listing_fee": listing_fee}

    if t == "cancel_player_listing":
        listing_id = int(payload.get("listing_id") or 0)
        listing = row(conn, "SELECT * FROM player_market_listings WHERE id=?", (listing_id,))
        if not listing or listing["status"] != "active":
            raise HTTPException(404, "Active listing not found")
        if listing.get("seller_player_id") != pid and not god:
            raise HTTPException(403, "You can only cancel your own listings")
        qty = int(listing.get("remaining_qty") or 0)
        if qty > 0 and listing.get("seller_player_id"):
            add_listing_item_to_player(conn, int(listing["seller_player_id"]), listing, qty, "player_market_cancel")
        conn.execute("UPDATE player_market_listings SET status='cancelled', remaining_qty=0, closed_at=? WHERE id=?", (iso(), listing_id))
        log_market_transaction(conn, pid, player["location_planet_id"], None, listing["item_code"], listing["item_name"], "player_market_cancel", qty, listing["unit_price"], qty * int(listing["unit_price"]), 0, 0, int(listing["legal"]), "player_market")
        add_event(conn, pid, "player_market", f"Cancelled listing for {qty}x {listing['item_name']}.")
        return {"message": f"Cancelled listing for {listing['item_name']}."}

    if t == "buy_player_listing":
        listing_id = int(payload.get("listing_id") or 0)
        requested_qty = max(1, int(payload.get("qty", 1)))
        listing = row(conn, "SELECT * FROM player_market_listings WHERE id=?", (listing_id,))
        if not listing or listing["status"] != "active" or int(listing.get("remaining_qty") or 0) <= 0:
            raise HTTPException(404, "Active listing not found")
        if listing.get("seller_player_id") == pid and not god:
            raise HTTPException(400, "You cannot buy your own listing")
        qty = min(requested_qty, int(listing["remaining_qty"]))
        mass = int(math.ceil(float(listing.get("mass") or 1) * qty))
        usage = build_cargo_usage(conn, pid)
        if mass > int(usage.get("free") or 0) and not god:
            raise HTTPException(400, "Not enough cargo capacity")
        gross = qty * int(listing["unit_price"])
        sale_fee = player_market_sale_fee(gross)
        spend(conn, pid, credits=gross, god=god)
        add_listing_item_to_player(conn, pid, listing, qty, "player_market_buy")
        seller_id = listing.get("seller_player_id")
        if seller_id:
            net = max(0, gross - sale_fee)
            conn.execute("UPDATE players SET credits=credits+? WHERE id=?", (net, int(seller_id)))
            if sale_fee:
                log_money_sink(conn, int(seller_id), "player_market_sale_fee", sale_fee, "Player-market exchange commission and anti-inflation sink")
        remaining = int(listing["remaining_qty"]) - qty
        status = "sold" if remaining <= 0 else "active"
        conn.execute("UPDATE player_market_listings SET remaining_qty=?, status=?, closed_at=CASE WHEN ?='sold' THEN ? ELSE closed_at END WHERE id=?", (remaining, status, status, iso(), listing_id))
        log_market_transaction(conn, pid, player["location_planet_id"], None, listing["item_code"], listing["item_name"], "player_market_buy", qty, int(listing["unit_price"]), gross, 0, gross, int(listing["legal"]), "player_market")
        if seller_id:
            log_market_transaction(conn, int(seller_id), listing.get("planet_id") or player["location_planet_id"], None, listing["item_code"], listing["item_name"], "player_market_sale", qty, int(listing["unit_price"]), gross, sale_fee, gross - sale_fee, int(listing["legal"]), "player_market")
        add_event(conn, pid, "player_market", f"Bought {qty}x {listing['item_name']} from {listing['seller_name']} for {gross:,} credits.")
        return {"message": f"Bought {qty}x {listing['item_name']} from player market.", "gross": gross, "qty": qty}

    if t == "run_smuggling_route":
        illegal = row(conn, "SELECT c.*, mp.buy_price, mp.sell_price FROM commodities c JOIN market_prices mp ON mp.commodity_id=c.id WHERE c.legal=0 AND mp.planet_id=? ORDER BY (mp.sell_price-mp.buy_price) DESC LIMIT 1", (player["location_planet_id"],))
        if not illegal: raise HTTPException(400,"No contraband route here")
        qty = int(payload.get("qty", 5))
        cost = illegal["buy_price"] * qty
        spend(conn, pid, credits=cost, cargo_space=qty, energy=14, fuel=3, god=god)
        customs = resolve_npc_roll(conn,"customs",player["location_planet_id"],"standard")
        smuggle = get_ship_power(conn, player["active_ship_id"])//200 + random.randint(10,100) + (500 if god else 0)
        if customs > smuggle:
            fine = cost * 2
            if not god:
                conn.execute("UPDATE players SET credits=max(0,credits-?), reputation=reputation-25, security_status='Wanted' WHERE id=?", (fine,pid))
            consequence = apply_operation_consequence(conn, pid, 4, "fail" if smuggle > customs * 0.55 else "critical_fail", "customs pursuit", god)
            add_event(conn, pid, "smuggling", "NPC customs caught your smuggling run.")
            return {"message":f"Smuggling failed. NPC customs caught you. {consequence}", "fine":fine}
        profit = int(cost * random.uniform(1.35, 2.5))
        conn.execute("UPDATE players SET credits=credits+?, reputation=reputation-5, loyalty=loyalty+? WHERE id=?", (profit, 5, pid))
        active = row(conn,"SELECT * FROM player_jobs WHERE player_id=? AND active=1", (pid,))
        if active and active["job_code"] == "smuggler":
            increment_job_metrics(conn, pid, "smuggler", {"smuggles": 1, "contraband_profit": profit})
        add_xp(conn, pid, 850)
        add_event(conn, pid, "smuggling", f"Smuggling success: {illegal['name']} moved for {profit:,} credits.")
        return {"message":"Smuggling success against NPC customs.", "profit":profit}

    if t == "pve_operation":
        op = row(conn, "SELECT * FROM pve_operations WHERE code=?", (payload.get("code"),))
        if not op: raise HTTPException(404,"Operation not found")
        ship_power = get_ship_power(conn, player["active_ship_id"])
        op_planet = row(conn, "SELECT * FROM planets WHERE id=?", (op["planet_id"],)) if op.get("planet_id") else row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],))
        runtime = pve_operation_runtime_stats(op, ship_power, god, conn, pid, op_planet)
        progression_key = pve_progression_key(op.get("op_type"))
        energy_cost = runtime["energy_cost"]
        fuel_cost = runtime["fuel_cost"]
        reward_min = runtime["preview_reward_min"]
        reward_max = runtime["preview_reward_max"]
        success_odds = runtime["success_odds"]
        spend(conn, pid, fuel=fuel_cost, energy=energy_cost, god=god)
        outcome = resolve_pve_outcome(success_odds, god)
        if outcome == "critical_success":
            reward = int(random.randint(reward_min, reward_max) * 1.35)
            scrap = int(op["difficulty"] * random.randint(25, 90 if runtime["operation_tier"] == "basic" else 180))
            conn.execute("UPDATE players SET credits=credits+?, scrap=scrap+?, loyalty=loyalty+? WHERE id=?", (reward,scrap,op["skill_reward"]+2,pid))
            add_xp(conn, pid, runtime["xp_critical"])
            world_note = apply_pve_world_rewards(conn, pid, player["location_planet_id"], op, outcome, runtime)
            grant_action_progression(conn, pid, progression_key, max(1.0, int(op.get("difficulty") or 1) * 1.8), True)
            add_event(conn, pid, "pve", f"Critical success on {op['name']} for {reward:,} credits. {world_note}")
            return {"message":f"Critical success: {op['name']} {world_note}", "reward":reward, "scrap":scrap, "outcome":outcome, "success_odds":round(success_odds,2), "energy_cost":energy_cost, "world_note":world_note}
        if outcome == "success":
            reward = random.randint(reward_min, reward_max)
            scrap = op["difficulty"] * random.randint(10, 45 if runtime["operation_tier"] == "basic" else 120)
            conn.execute("UPDATE players SET credits=credits+?, scrap=scrap+?, loyalty=loyalty+? WHERE id=?", (reward,scrap,op["skill_reward"],pid))
            add_xp(conn, pid, runtime["xp_reward"])
            world_note = apply_pve_world_rewards(conn, pid, player["location_planet_id"], op, outcome, runtime)
            grant_action_progression(conn, pid, progression_key, max(1.0, int(op.get("difficulty") or 1) * 1.2), True)
            add_event(conn, pid, "pve", f"Completed {op['name']} for {reward:,} credits. {world_note}")
            return {"message":f"Completed {op['name']} {world_note}", "reward":reward, "scrap":scrap, "outcome":outcome, "success_odds":round(success_odds,2), "energy_cost":energy_cost, "world_note":world_note}
        if outcome == "partial":
            reward = int(random.randint(reward_min, reward_max) * 0.38)
            scrap = op["difficulty"] * random.randint(5, 18 if runtime["operation_tier"] == "basic" else 45)
            consequence = apply_operation_consequence(conn, pid, op["difficulty"], outcome, op["name"], god)
            conn.execute("UPDATE players SET credits=credits+?, scrap=scrap+? WHERE id=?", (reward,scrap,pid))
            add_xp(conn, pid, runtime["xp_partial"])
            world_note = apply_pve_world_rewards(conn, pid, player["location_planet_id"], op, outcome, runtime)
            grant_action_progression(conn, pid, progression_key, max(0.5, int(op.get("difficulty") or 1) * 0.55), False)
            add_event(conn, pid, "pve", f"Partial completion: {op['name']}. {consequence} {world_note}")
            return {"message":f"Partial completion: {op['name']}. {consequence} {world_note}", "reward":reward, "scrap":scrap, "outcome":outcome, "success_odds":round(success_odds,2), "energy_cost":energy_cost, "world_note":world_note}
        consequence = apply_operation_consequence(conn, pid, op["difficulty"], outcome, op["name"], god)
        grant_action_progression(conn, pid, progression_key, max(0.35, int(op.get("difficulty") or 1) * 0.35), False)
        add_event(conn, pid, "pve", f"{outcome.replace('_',' ').title()} on {op['name']}. {consequence}")
        return {"message":f"{outcome.replace('_',' ').title()}. {consequence}", "outcome":outcome, "success_odds":round(success_odds,2), "energy_cost":energy_cost}

    if t == "accept_bounty":
        bounty = row(conn, "SELECT * FROM bounties WHERE id=? AND status='open'", (int(payload["bounty_id"]),))
        if not bounty: raise HTTPException(404,"Bounty not found")
        difficulty = max(1, bounty["threat"] // 12)
        spend(conn, pid, fuel=max(1,difficulty), energy=max(8,difficulty*4), god=god)
        ship_power = get_ship_power(conn, player["active_ship_id"])
        bounty_planet = row(conn, "SELECT * FROM planets WHERE id=?", (bounty["planet_id"],))
        mock_op = {"op_type":"bounty", "difficulty": difficulty, "solo":1, "group_recommended":0, "reward_min":bounty["reward"], "reward_max":bounty["reward"], "skill_reward":2}
        odds = operation_context(conn, pid, mock_op, ship_power, bounty_planet, god)["success_odds"]
        outcome = resolve_pve_outcome(odds, god)
        if outcome in ("critical_success", "success"):
            multiplier = 1.25 if outcome == "critical_success" else 1.0
            payout = int(bounty["reward"] * multiplier)
            conn.execute("UPDATE bounties SET status='claimed' WHERE id=?", (bounty["id"],))
            conn.execute("UPDATE players SET credits=credits+?, reputation=reputation+?, loyalty=loyalty+10 WHERE id=?", (payout, bounty["threat"], pid))
            add_xp(conn, pid, bounty["threat"]*140)
            active = row(conn,"SELECT * FROM player_jobs WHERE player_id=? AND active=1", (pid,))
            if active and active["job_code"] == "bounty_hunter":
                increment_job_metrics(conn, pid, "bounty_hunter", {"bounties": 1, "bounty_value": payout})
            grant_action_progression(conn, pid, "bounty", max(1.0, difficulty * 1.4), True)
            add_event(conn, pid, "bounty", f"Captured NPC bounty {bounty['name']}.")
            return {"message":f"Bounty captured: {bounty['name']}", "reward":payout, "outcome":outcome}
        consequence = apply_operation_consequence(conn, pid, difficulty, outcome, "bounty fight", god)
        grant_action_progression(conn, pid, "bounty", max(0.35, difficulty * 0.45), False)
        if outcome == "partial":
            partial = int(bounty["reward"] * 0.20)
            conn.execute("UPDATE players SET credits=credits+?, reputation=reputation+? WHERE id=?", (partial, max(1,bounty["threat"]//5), pid))
            return {"message":f"Bounty escaped, but you recovered intel worth {partial:,}. {consequence}", "reward":partial, "outcome":outcome}
        return {"message":f"Bounty escaped. {consequence}", "outcome":outcome}

    if t == "mine":
        spend(conn,pid,fuel=5,energy=10,god=god)
        difficulty = random.choice([2,2,3,4])
        planet_now = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],))
        odds = operation_context(conn, pid, {"op_type":"mining", "difficulty":difficulty, "solo":1, "group_recommended":0}, get_ship_power(conn, player["active_ship_id"]), planet_now, god)["success_odds"]
        outcome = resolve_pve_outcome(odds, god)
        if outcome in ("critical_success", "success", "partial"):
            mult = {"critical_success":1.8,"success":1.0,"partial":0.45}[outcome]
            qty = int((80 + random.randint(20,180) + (1000 if god else 0)) * mult)
            conn.execute("INSERT INTO inventory (player_id,item_code,name,item_type,qty,legal,base_value,mass) VALUES (?,?,?,?,?,?,?,?) ON CONFLICT(player_id,item_code) DO UPDATE SET qty=qty+excluded.qty", (pid,"titanium","Titanium Ore","material",qty,1,40,1))
            conn.execute("UPDATE players SET scrap=scrap+? WHERE id=?", (qty//4,pid))
            add_xp(conn,pid,int(350*mult))
            active = row(conn,"SELECT * FROM player_jobs WHERE player_id=? AND active=1", (pid,))
            if active and active["job_code"] == "miner":
                increment_job_metrics(conn,pid,"miner",{"mining_runs":1,"ore_value":qty*40})
            grant_action_progression(conn, pid, "mining", max(0.6, difficulty * mult), outcome != "partial")
            msg = f"{outcome.replace('_',' ').title()}: mined {qty} Titanium Ore from NPC asteroid fields."
            if outcome == "partial":
                msg += " " + apply_operation_consequence(conn,pid,difficulty,outcome,"mining mishap",god)
            return {"message":msg,"outcome":outcome}
        consequence = apply_operation_consequence(conn,pid,difficulty,outcome,"mining accident",god)
        grant_action_progression(conn, pid, "mining", max(0.35, difficulty * 0.35), False)
        return {"message":f"Mining failed. {consequence}","outcome":outcome}

    if t == "salvage_site":
        site_id = int(payload.get("site_id") or payload.get("salvageSiteId") or 0)
        caps = player_tool_capabilities(conn, player)
        if not caps.get("can_salvage") and not god:
            raise HTTPException(400, "Requires an equipped salvage module")
        site = row(conn, "SELECT * FROM salvage_sites WHERE id=? AND planet_id=? AND qty_remaining>0", (site_id, player["location_planet_id"]))
        if not site:
            raise HTTPException(404, "Salvage site not found at your current location")
        salvage_target = {
            "x_pct": float(site.get("x_pct") if site.get("x_pct") is not None else system_planet_map_point(conn, player["location_planet_id"]).get("x_pct")),
            "y_pct": float(site.get("y_pct") if site.get("y_pct") is not None else system_planet_map_point(conn, player["location_planet_id"]).get("y_pct")),
        }
        require_player_action_range(conn, player, salvage_target, "system", "salvage wreck", god)
        if parse_dt(site.get("expires_at")) and parse_dt(site.get("expires_at")) <= utcnow():
            conn.execute("UPDATE salvage_sites SET qty_remaining=0 WHERE id=?", (site_id,))
            raise HTTPException(400, "That wreck has already been stripped or drifted away")
        energy_cost = int(site.get("energy_cost") or 10)
        spend(conn, pid, energy=energy_cost, fuel=max(1, int(site.get("difficulty") or 1)), god=god)
        map_op = start_player_map_operation(conn, player, f"salvage:{site_id}", "salvage", max(10, int(site.get("difficulty") or 1) * 8), f"Salvaging {site.get('ship_name') or 'wreck'} debris.", {"salvage_site_id": site_id})
        mats = decode_json(site.get("materials_json"), {}) or {}
        skill_bonus = min(1.45, 1.0 + int(player_skill_totals(conn, pid).get("salvaging", 0)) * 0.006)
        awarded = []
        scrap_gain = 0
        for code, qty_raw in mats.items():
            qty = max(1, int(int(qty_raw) * skill_bonus))
            if code == "scrap":
                scrap_gain += qty
                conn.execute("UPDATE players SET scrap=scrap+? WHERE id=?", (qty, pid))
            else:
                tier = int(site.get("ship_tier") or 1)
                profile = salvage_drop_item_profile(conn, code, tier)
                nice = profile.get("name") or label_for_api(code)
                add_inventory_item(
                    conn,
                    pid,
                    code,
                    nice,
                    profile.get("item_type") or "salvage",
                    qty,
                    int(profile.get("legal", 1) or 1),
                    int(profile.get("base_value") or max(40, tier * 110)),
                    float(profile.get("mass") or 0.35),
                    profile.get("description") or f"Recovered from {site.get('ship_name')} wreck",
                    "salvage_site_cargo" if profile.get("source_kind") == "cargo" else "salvage_site_materials",
                    category=profile.get("category") or "salvage",
                    rarity=profile.get("rarity") or ("uncommon" if tier < 4 else "rare"),
                    tier=tier,
                    respect_cargo=True,
                    god=god,
                )
                awarded.append({"code": code, "name": nice, "qty": qty, "kind": profile.get("source_kind")})
        conn.execute("UPDATE salvage_sites SET qty_remaining=max(0,qty_remaining-1) WHERE id=?", (site_id,))
        grant_action_progression(conn, pid, "salvage", max(1.0, int(site.get("difficulty") or 1) * 0.8), True)
        add_xp(conn, pid, max(60, int(site.get("salvage_value") or 0) // 12))
        active = row(conn,"SELECT * FROM player_jobs WHERE player_id=? AND active=1", (pid,))
        if active and active["job_code"] == "salvager":
            increment_job_metrics(conn,pid,"salvager",{"salvage_runs":1,"salvage_value":int(site.get("salvage_value") or 0)})
        add_event(conn, pid, "salvage", f"Stripped wreckage from {site.get('ship_name')} for salvage materials.")
        return {"message":f"Salvaged {site.get('ship_name')} wreck.", "scrap":scrap_gain, "items":awarded, "energyCost":energy_cost}

    if t == "salvage":
        spend(conn,pid,fuel=4,energy=10,god=god)
        difficulty = random.choice([2,3,3,4])
        planet_now = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],))
        odds = operation_context(conn, pid, {"op_type":"salvage", "difficulty":difficulty, "solo":1, "group_recommended":0}, get_ship_power(conn, player["active_ship_id"]), planet_now, god)["success_odds"]
        outcome = resolve_pve_outcome(odds, god)
        if outcome in ("critical_success", "success", "partial"):
            mult = {"critical_success":1.7,"success":1.0,"partial":0.4}[outcome]
            scrap = int((200 + random.randint(50,250) + (2000 if god else 0)) * mult)
            circuits = max(1,int(random.randint(5,30) * mult))
            conn.execute("UPDATE players SET scrap=scrap+? WHERE id=?", (scrap,pid))
            conn.execute("INSERT INTO inventory (player_id,item_code,name,item_type,qty,legal,base_value,mass) VALUES (?,?,?,?,?,?,?,?) ON CONFLICT(player_id,item_code) DO UPDATE SET qty=qty+excluded.qty", (pid,"circuit","Circuit Wafers","component",circuits,1,120,0.2))
            add_xp(conn,pid,int(300*mult))
            active = row(conn,"SELECT * FROM player_jobs WHERE player_id=? AND active=1", (pid,))
            if active and active["job_code"] == "salvager":
                increment_job_metrics(conn,pid,"salvager",{"salvage_runs":1,"salvage_value":scrap+circuits*120})
            grant_action_progression(conn, pid, "salvage", max(0.6, difficulty * mult), outcome != "partial")
            msg = f"{outcome.replace('_',' ').title()}: salvaged {scrap} scrap and {circuits} circuit wafers."
            if outcome == "partial":
                msg += " " + apply_operation_consequence(conn,pid,difficulty,outcome,"salvage ambush",god)
            return {"message":msg,"outcome":outcome}
        consequence = apply_operation_consequence(conn,pid,difficulty,outcome,"salvage accident",god)
        grant_action_progression(conn, pid, "salvage", max(0.35, difficulty * 0.35), False)
        return {"message":f"Salvage failed. {consequence}","outcome":outcome}


    if t == "upgrade_inventory_item":
        item_code = str(payload.get("item_code") or "")
        inv = row(conn, "SELECT * FROM inventory WHERE player_id=? AND item_code=?", (pid, item_code))
        if not inv:
            raise HTTPException(404, "Inventory item not found")
        if int(inv.get("reserved_qty") or 0) > 0:
            raise HTTPException(400, "Reserved/listed items cannot be upgraded")
        preview = tier_upgrade_preview(conn, pid, inv)
        if not preview.get("can_upgrade") and not god:
            raise HTTPException(400, preview.get("reason") or "Cannot upgrade item")
        cost = int(preview.get("credits") or 0)
        spend(conn, pid, credits=cost, god=god)
        if not god:
            for m in preview.get("materials") or []:
                remove_crafting_material(conn, pid, m["item_code"], int(m["required"]))
            log_money_sink(conn, pid, "tier_upgrade", cost, f"Tier upgrade for {inv['name']}")
        odds = float(preview.get("success_odds") or 0.75)
        if god or random.random() <= odds:
            conn.execute("UPDATE inventory SET current_tier=min(max_tier,current_tier+1), tier_source='upgraded', base_value=CAST(base_value * 1.08 AS INTEGER) WHERE player_id=? AND item_code=?", (pid, item_code))
            updated = row(conn, "SELECT * FROM inventory WHERE player_id=? AND item_code=?", (pid, item_code)) or inv
            add_event(conn, pid, "upgrade", f"Upgraded {inv['name']} to T{int(updated.get('current_tier') or 1)}.", {"item_code": item_code, "tier": int(updated.get("current_tier") or 1)})
            return {"message": f"Upgraded {inv['name']} to Tier {int(updated.get('current_tier') or 1)}", "outcome": "success", "tier": int(updated.get("current_tier") or 1)}
        add_event(conn, pid, "upgrade", f"Upgrade failed for {inv['name']}. Materials consumed; item unchanged.", {"item_code": item_code, "tier": int(inv.get("current_tier") or 1)})
        return {"message": f"Upgrade failed for {inv['name']}. Materials consumed; item unchanged.", "outcome": "failure"}

    if t == "salvage_inventory_item":
        item_code = str(payload.get("item_code") or "")
        qty = max(1, int(payload.get("qty") or 1))
        inv = row(conn, "SELECT * FROM inventory WHERE player_id=? AND item_code=?", (pid, item_code))
        if not inv:
            raise HTTPException(404, "Inventory item not found")
        if int(inv.get("reserved_qty") or 0) > 0:
            raise HTTPException(400, "Reserved/listed items cannot be salvaged")
        if inv.get("category") in {"quest_items", "goods", "illicit_goods"}:
            raise HTTPException(400, "This item category is not salvageable")
        qty = min(qty, int(inv.get("qty") or 0))
        preview = calculate_tier_salvage_output(attach_tier_metadata(dict(inv)))
        remove_inventory_item(conn, pid, item_code, qty)
        scrap = int(preview.get("scrap") or 1) * qty
        conn.execute("UPDATE players SET scrap=scrap+? WHERE id=?", (scrap, pid))
        for m in preview.get("materials") or []:
            add_inventory_item(conn, pid, m["item_code"], m["name"], "salvage", int(m["qty"]) * qty, 1, 120 + 160 * int(m.get("tier") or 0), 0.6, "Recovered upgrade material from salvage.", "salvage", "salvage", "uncommon", tier=int(m.get("tier") or 0), max_tier=max(2, int(m.get("tier") or 0)+2), tier_source="salvaged", respect_cargo=True, god=god)
        add_event(conn, pid, "salvage", f"Salvaged {qty}x {inv['name']} into {scrap} scrap and upgrade materials.", {"item_code": item_code, "scrap": scrap})
        return {"message": f"Salvaged {qty}x {inv['name']} into {scrap} scrap.", "outcome": "salvaged", "scrap": scrap, "materials": preview.get("materials")}

    if t == "upgrade_module":
        module_id = int(payload.get("module_id") or 0)
        mod = row(conn, "SELECT sm.*, mt.name, mt.price, mt.rarity, mt.slot_type FROM ship_modules sm JOIN module_templates mt ON mt.id=sm.module_template_id WHERE sm.id=? AND sm.player_id=?", (module_id, pid))
        if not mod:
            raise HTTPException(404, "Module not found")
        if int(mod.get("equipped") or 0):
            raise HTTPException(400, "Unequip module before upgrading it")
        fake = {"item_code": str(module_id), "name": mod["name"], "category":"ship_modules", "base_value": int(mod.get("price") or 0), "rarity": mod.get("rarity") or "rare", "current_tier": int(mod.get("current_tier") or 1), "max_tier": int(mod.get("max_tier") or 5), "tier_locked": 0}
        preview = tier_upgrade_preview(conn, pid, fake)
        if not preview.get("can_upgrade") and not god:
            raise HTTPException(400, preview.get("reason") or "Cannot upgrade module")
        spend(conn, pid, credits=int(preview.get("credits") or 0), god=god)
        if not god:
            for m in preview.get("materials") or []:
                remove_crafting_material(conn, pid, m["item_code"], int(m["required"]))
        if god or random.random() <= float(preview.get("success_odds") or 0.75):
            conn.execute("UPDATE ship_modules SET current_tier=min(max_tier,current_tier+1), tier_source='upgraded' WHERE id=?", (module_id,))
            upgraded = row(conn, "SELECT current_tier FROM ship_modules WHERE id=?", (module_id,))
            add_event(conn, pid, "upgrade", f"Upgraded module {mod['name']} to T{int(upgraded.get('current_tier') or 1)}.")
            return {"message": f"Upgraded module {mod['name']} to Tier {int(upgraded.get('current_tier') or 1)}", "outcome": "success"}
        return {"message": f"Upgrade failed for module {mod['name']}. Materials consumed; module unchanged.", "outcome": "failure"}

    if t in {"craft", "craft_recipe"}:
        code = str(payload.get("recipe") or payload.get("recipe_code") or "")
        recipe_raw = row(conn, "SELECT * FROM crafting_recipes WHERE code=?", (code,))
        if not recipe_raw:
            raise HTTPException(404, "Recipe not found")
        recipe = recipe_from_row(recipe_raw)
        ensure_starter_recipe_licenses(conn, pid)
        enrich_recipe_timing(recipe)
        planet = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],))
        report = recipe_requirement_report(conn, pid, recipe, planet, god)
        if not report["can_craft"]:
            raise HTTPException(400, "; ".join(report["blockers"]) or "Cannot craft recipe")

        active_jobs = active_crafting_jobs(conn, pid)
        if len(active_jobs) >= int(CRAFTING_BALANCE.get("max_active_jobs", 6)) and not god:
            raise HTTPException(400, f"Crafting queue full: {len(active_jobs)} active / {CRAFTING_BALANCE.get('max_active_jobs', 6)} max")
        if active_jobs and not CRAFTING_BALANCE.get("allow_parallel_jobs", True) and not god:
            raise HTTPException(400, "A crafting job is already active")

        effective_credits = int(report["effective_credits"])
        energy_cost = int(recipe.get("energy") or 0)
        if not god:
            consume_recipe_license(conn, pid, recipe)
        spend(conn, pid, credits=effective_credits, energy=energy_cost, god=god)
        if effective_credits and not god:
            log_money_sink(conn, pid, "crafting_fee", effective_credits, f"Crafting cost for {recipe['name']}; materials are a controlled economy sink")
        consume_recipe_inputs(conn, pid, recipe)

        odds = float(report["success_odds"])
        duration = 0 if (god and CRAFTING_BALANCE.get("god_instant_crafting")) else int(recipe.get("craft_seconds") or crafting_duration_seconds(recipe))
        if duration <= 0:
            # Admin-tuned instant mode still uses the same completion path.
            now = utcnow()
            completes = now
        else:
            now = utcnow()
            completes = now + timedelta(seconds=duration)

        output_preview = recipe_output_preview(conn, recipe.get("output") or {})
        conn.execute(
            """
            INSERT INTO crafting_queue
              (player_id,recipe_code,recipe_name,status,recipe_snapshot_json,output_preview_json,success_odds,credits_spent,energy_spent,xp_reward,started_at,completes_at,message)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?)
            """,
            (
                pid,
                recipe["code"],
                recipe["name"],
                "active",
                encode_json(recipe),
                encode_json(output_preview),
                odds,
                effective_credits,
                energy_cost,
                int(recipe.get("xp_reward") or 0),
                iso(now),
                iso(completes),
                f"Crafting started: {recipe['name']} ({craft_duration_label(duration)}).",
            ),
        )
        job_id = conn.execute("SELECT last_insert_rowid()").fetchone()[0]
        add_event(conn, pid, "crafting", f"Crafting started: {recipe['name']}. Completes in {craft_duration_label(duration)}.", {"recipe": recipe["code"], "job_id": job_id, "duration_seconds": duration})
        if duration <= 0:
            job = row(conn, "SELECT * FROM crafting_queue WHERE id=?", (job_id,))
            result = finalize_crafting_job(conn, job, god)
            return result
        return {
            "message": f"Crafting started: {recipe['name']}. Completes in {craft_duration_label(duration)}.",
            "job_id": job_id,
            "recipe": recipe["code"],
            "craft_seconds": duration,
            "craft_time_label": craft_duration_label(duration),
            "success_odds": round(odds, 2),
            "credits_spent": effective_credits,
            "energy_spent": energy_cost,
        }

    if t == "claim_crafting":
        completed = resolve_completed_crafting_jobs(conn, pid, god)
        return {"message": f"Resolved {len(completed)} completed crafting job(s).", "completed": completed}

    if t == "cancel_crafting":
        job_id = int(payload.get("job_id") or 0)
        job = row(conn, "SELECT * FROM crafting_queue WHERE id=? AND player_id=? AND status='active'", (job_id, pid))
        if not job:
            raise HTTPException(404, "Active crafting job not found")
        started = parse_dt(job.get("started_at")) or utcnow()
        elapsed = max(0, int((utcnow() - started).total_seconds()))
        total = max(1, int(((parse_dt(job.get("completes_at")) or utcnow()) - started).total_seconds()))
        refund_rate = 0.35 if elapsed < total * 0.25 else 0.10
        credit_refund = int(int(job.get("credits_spent") or 0) * refund_rate)
        energy_refund = int(int(job.get("energy_spent") or 0) * refund_rate)
        if credit_refund or energy_refund:
            conn.execute("UPDATE players SET credits=credits+?, energy=min(max_energy,energy+?) WHERE id=?", (credit_refund, energy_refund, pid))
        conn.execute("UPDATE crafting_queue SET status='cancelled', completed_at=?, message=? WHERE id=?", (iso(), f"Cancelled. Refunded {credit_refund} credits and {energy_refund} energy.", job_id))
        add_event(conn, pid, "crafting", f"Cancelled crafting job {job.get('recipe_name')}.", {"job_id": job_id, "credit_refund": credit_refund, "energy_refund": energy_refund})
        return {"message": f"Cancelled {job.get('recipe_name')}. Refunded {credit_refund} credits and {energy_refund} energy."}

    if t == "buy_ship":
        template = row(conn,"SELECT * FROM ship_templates WHERE code=?", (payload.get("code"),))
        if not template: raise HTTPException(404,"Ship not found")
        existing = row(conn, "SELECT s.id FROM ships s WHERE s.player_id=? AND s.template_id=?", (pid, template["id"]))
        if existing and not god:
            raise HTTPException(400, "You already own this ship class")
        spend(conn,pid,credits=template["price"],god=god)
        conn.execute("""INSERT INTO ships (player_id,template_id,name,hull,max_hull,shield,max_shield,armor,cargo_capacity,fuel_capacity,drive_speed,size_class,mass,insured,insurance_tier,destroyed,starter)
                      VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""", (pid,template["id"],template["name"],template["hull"],template["hull"],template["shield"],template["shield"],template["armor"],template["cargo_capacity"],template["fuel_capacity"],template["drive_speed"],template.get("size_class","M"),template.get("mass",340),0,"none",0,template["starter"]))
        new_ship_id = conn.execute("SELECT last_insert_rowid()").fetchone()[0]
        conn.execute("UPDATE ships SET current_tier=?, max_tier=?, tier_source='purchased' WHERE id=?", (clamp_tier(template.get("ship_tier", 1)), max(clamp_tier(template.get("ship_tier", 1)), clamp_tier(template.get("ship_tier", 1))+2), new_ship_id))
        create_ship_parts(conn, new_ship_id)
        add_event(conn, pid, "hangar", f"Purchased ship: {template['name']}.")
        return {"message":f"Purchased ship: {template['name']}"}

    if t == "set_active_ship":
        ship = row(conn,"SELECT s.*, t.slots_json, t.ship_tier, t.role, t.class_name FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=? AND s.player_id=?", (int(payload["ship_id"]),pid))
        if not ship: raise HTTPException(404,"Ship not found")
        if ship["destroyed"]: raise HTTPException(400,"Ship destroyed. Use starter ship or insurance claim.")
        derived = ship_derived_stats(conn, ship)
        cargo_cap = int(derived.get("cargo_capacity") or ship.get("cargo_capacity") or 0)
        fuel_cap = int(derived.get("fuel_capacity") or ship.get("fuel_capacity") or 0)
        usage = build_cargo_usage(conn, pid)
        if int(usage.get("total") or 0) > cargo_cap and not god:
            raise HTTPException(400, f"Cargo exceeds this ship capacity. Free {int(usage.get('total') or 0) - cargo_cap:,} cargo first.")
        conn.execute("UPDATE players SET active_ship_id=?, max_cargo=?, max_fuel=? WHERE id=?", (ship["id"],cargo_cap,fuel_cap,pid))
        add_event(conn, pid, "hangar", f"Active ship set to {ship['name']}.")
        return {"message":f"Active ship set to {ship['name']}"}

    if t == "launch_starter_ship":
        ship = row(conn,"SELECT * FROM ships WHERE player_id=? AND starter=1", (pid,))
        conn.execute("UPDATE ships SET destroyed=0,hull=max_hull,shield=max_shield WHERE id=?", (ship["id"],))
        conn.execute("UPDATE players SET active_ship_id=?, max_cargo=?, max_fuel=? WHERE id=?", (ship["id"],ship["cargo_capacity"],ship["fuel_capacity"],pid))
        return {"message":"Starter ship launched. It is permanent and always available."}

    if t == "insure_ship":
        ship = row(conn,"SELECT * FROM ships WHERE id=? AND player_id=?", (int(payload["ship_id"]),pid))
        if not ship: raise HTTPException(404,"Ship not found")
        tier = payload.get("tier","standard")
        rate = {"basic":0.03,"standard":0.06,"premium":0.10}.get(tier,0.06)
        cost = int(ship["max_hull"] * 18 * rate)
        spend(conn,pid,credits=cost,god=god)
        if not god: log_money_sink(conn, pid, "ship_insurance", cost, f"Insurance premium: {tier}")
        conn.execute("UPDATE ships SET insured=1, insurance_tier=? WHERE id=?", (tier,ship["id"]))
        return {"message":f"Ship insured: {tier}. Cost {cost:,}."}

    if t == "repair_refuel":
        ship = row(conn,"SELECT * FROM ships WHERE id=?", (player["active_ship_id"],))
        if not ship:
            raise HTTPException(400, "No active ship to service")
        ensure_ship_parts(conn)
        part_missing = sum(r["max_hp"] - r["hp"] for r in rows(conn, "SELECT * FROM ship_parts WHERE ship_id=?", (ship["id"],)))
        module_missing = sum(100 - r["durability"] for r in rows(conn, "SELECT * FROM ship_modules WHERE ship_id=?", (ship["id"],)))
        fuel_missing = max(0, player["max_fuel"] - player["fuel"])
        cost = max(0, (ship["max_hull"]-ship["hull"])*2 + (ship["max_shield"]-ship["shield"]) + part_missing*4 + module_missing*75 + fuel_missing*10)
        spend(conn,pid,credits=cost,god=god)
        if not god: log_money_sink(conn, pid, "ship_repair_refuel", cost, "Ship hull, shields, part HP, modules, and fuel restored")
        conn.execute("UPDATE ships SET hull=max_hull, shield=max_shield WHERE id=?", (ship["id"],))
        conn.execute("UPDATE ship_parts SET hp=max_hp WHERE ship_id=?", (ship["id"],))
        conn.execute("UPDATE ship_modules SET durability=100 WHERE ship_id=?", (ship["id"],))
        conn.execute("UPDATE players SET fuel=max_fuel WHERE id=?", (pid,))
        active = row(conn,"SELECT * FROM player_jobs WHERE player_id=? AND active=1", (pid,))
        if active and active["job_code"] == "engineer":
            increment_job_metrics(conn,pid,"engineer",{"repairs":1,"repair_value":cost})
        return {"message":f"Ship fully repaired, modules restored, parts rebuilt, and fuel topped off. Cost {cost:,}."}

    if t == "buy_module":
        mt = row(conn,"SELECT * FROM module_templates WHERE code=?", (payload.get("code"),))
        if not mt: raise HTTPException(404,"Module not found")
        usage = build_cargo_usage(conn, pid)
        if int(usage.get("free") or 0) < 3 and not god:
            raise HTTPException(400, "Not enough cargo capacity to store another module")
        spend(conn,pid,credits=mt["price"],god=god)
        conn.execute("INSERT INTO ship_modules (player_id,ship_id,module_template_id,slot_type,equipped,durability,current_tier,max_tier,tier_source) VALUES (?,?,?,?,?,?,?,?,?)", (pid,None,mt["id"],mt["slot_type"],0,100,clamp_tier(mt.get("tier",1)),clamp_tier(mt.get("max_tier",5)),"purchased"))
        add_event(conn, pid, "hangar", f"Purchased module: {mt['name']}.")
        return {"message":f"Purchased module: {mt['name']}"}

    if t == "unequip_module":
        mid = int(payload.get("module_id") or payload.get("equipment_id") or payload.get("id"))
        sm = row(conn,"SELECT sm.*, mt.name FROM ship_modules sm JOIN module_templates mt ON mt.id=sm.module_template_id WHERE sm.id=? AND sm.player_id=? AND sm.equipped=1", (mid,pid))
        if not sm: raise HTTPException(404,"Equipped module not found")
        usage = build_cargo_usage(conn, pid)
        if int(usage.get("free") or 0) < 3 and not god:
            raise HTTPException(400, "Not enough cargo capacity to store unequipped module")
        old_ship_id = sm.get("ship_id")
        conn.execute("UPDATE ship_modules SET ship_id=NULL, equipped=0, equipped_slot_id=NULL WHERE id=?", (mid,))
        if int(player.get("active_ship_id") or 0) == int(old_ship_id or 0):
            ship = row(conn,"SELECT s.*, t.slots_json, t.ship_tier, t.role, t.class_name FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=? AND s.player_id=?", (old_ship_id,pid))
            if ship:
                derived = ship_derived_stats(conn, ship)
                conn.execute("UPDATE players SET max_cargo=?, max_fuel=? WHERE id=?", (int(derived.get("cargo_capacity") or ship["cargo_capacity"]), int(derived.get("fuel_capacity") or ship["fuel_capacity"]), pid))
        add_event(conn, pid, "hangar", f"Removed module: {sm['name']}.")
        return {"message":"Module unequipped to storage."}

    if t == "equip_module":
        mid = int(payload.get("module_id") or payload.get("equipment_id") or payload.get("id"))
        sm = row(conn,"SELECT sm.*, mt.code, mt.name, mt.slot_type, mt.rarity, mt.price, mt.stats_json, mt.tier as template_tier, mt.max_tier as template_max_tier, mt.min_ship_tier, mt.power_usage FROM ship_modules sm JOIN module_templates mt ON mt.id=sm.module_template_id WHERE sm.id=? AND sm.player_id=?", (mid,pid))
        if not sm: raise HTTPException(404,"Module not found")
        ship_id = int(payload.get("ship_id") or player["active_ship_id"])
        ship = row(conn,"SELECT s.*, t.slots_json, t.ship_tier, t.role, t.class_name FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=? AND s.player_id=?", (ship_id,pid))
        if not ship: raise HTTPException(404,"Ship not found")
        if int(sm.get("equipped") or 0) == 1 and int(sm.get("ship_id") or 0) == ship_id:
            return {"message":"Module already equipped on this ship."}
        if int(sm.get("equipped") or 0) == 1 and not god:
            raise HTTPException(400, "Module is already equipped on another ship. Unequip it first.")
        hydrate_module_for_loadout(sm)
        slot_id = payload.get("slot_id") or payload.get("slotId")
        target = next((x for x in build_ship_slots(conn, ship) if x.get("slotId") == slot_id), None) if slot_id else find_first_compatible_slot(conn, ship, sm)
        reasons = module_blocked_reasons(conn, pid, ship, sm, god, target.get("slotId") if target else slot_id)
        reasons = [r for r in reasons if r != "Already equipped"]
        if not target and not reasons:
            reasons = ["No open compatible slot"]
        if reasons and not god:
            raise HTTPException(400, "; ".join(reasons))
        if not target:
            target = {"slotId": slot_id or "utility_1", "slotLabel": slot_id or "Utility"}
        conn.execute("UPDATE ship_modules SET ship_id=?, equipped=1, equipped_slot_id=?, slot_type=? WHERE id=?", (ship_id, target["slotId"], canonical_slot_type(sm.get("slot_type")), mid))
        if int(player.get("active_ship_id") or 0) == ship_id:
            derived = ship_derived_stats(conn, ship)
            conn.execute("UPDATE players SET max_cargo=?, max_fuel=? WHERE id=?", (int(derived.get("cargo_capacity") or ship["cargo_capacity"]), int(derived.get("fuel_capacity") or ship["fuel_capacity"]), pid))
        grant_action_progression(conn, pid, "repair", 0.35, True)
        add_event(conn, pid, "hangar", f"Installed module: {sm['name']} in {target.get('slotLabel') or target.get('slotId')}.")
        return {"message":f"Module equipped: {sm['name']} in {target.get('slotLabel') or target.get('slotId')}"}

    if t == "switch_job":
        code = payload.get("job_code")
        job = row(conn,"SELECT * FROM jobs WHERE code=?", (code,))
        if not job: raise HTTPException(404,"Job not found")
        # Phase 16: careers are selectable specializations. Switching active career does not wipe old career XP/rank.
        conn.execute("UPDATE player_jobs SET active=0 WHERE player_id=?", (pid,))
        conn.execute(
            "INSERT INTO player_jobs (player_id,job_code,xp,rank,active,last_active_at,career_changed_at) VALUES (?,?,?,?,1,?,?) "
            "ON CONFLICT(player_id,job_code) DO UPDATE SET active=1, last_active_at=excluded.last_active_at, career_changed_at=excluded.career_changed_at",
            (pid, code, 0, 1, iso(), iso()),
        )
        return {"message":f"Active career set to {job['name']}. Previous career progress was preserved."}

    if t == "career_task":
        active = row(conn,"SELECT pj.*, j.name FROM player_jobs pj JOIN jobs j ON j.code=pj.job_code WHERE pj.player_id=? AND pj.active=1", (pid,))
        if not active: raise HTTPException(400,"No active career")
        profile = JOB_PROFILE.get(active["job_code"], {})
        task_key = payload.get("task_key")
        tasks = profile.get("tasks", [])
        task = next((x for x in tasks if x["key"] == task_key), tasks[0] if tasks else None)
        if not task: raise HTTPException(400,"No career tasks configured")
        metrics_now = get_job_metrics(conn,pid,active["job_code"])
        rank = job_rank_from_metrics(active["job_code"], active["xp"], metrics_now)
        active_runtime = dict(active)
        active_runtime["computed_rank"] = rank
        active_runtime["metrics"] = metrics_now
        task_runtime = career_task_runtime_stats(conn, pid, active_runtime, task, row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],)), get_ship_power(conn, player["active_ship_id"]), god)
        energy_cost = int(task_runtime["energy_cost"])
        fuel_cost = int(task_runtime.get("fuel_cost") or 0)
        spend(conn, pid, energy=energy_cost, fuel=fuel_cost, god=god)
        base_reward = random.randint(task_runtime["preview_reward_min"], max(task_runtime["preview_reward_min"], task_runtime["preview_reward_max"]))
        reward = base_reward + (50000 if god else 0)
        xp = int(task_runtime["xp_reward"])
        # Career jobs have possible NPC/PVE consequences too, but milder than combat contracts.
        odds = task_runtime["success_odds"]
        outcome = resolve_pve_outcome(odds, god)
        consequence = ""
        if outcome == "critical_success":
            reward = int(reward * 1.45); xp = int(xp * 1.35)
        elif outcome == "partial":
            reward = int(reward * 0.45); xp = int(xp * 0.55)
        elif outcome in ("fail", "critical_fail"):
            reward = 0; xp = int(xp * 0.20)
            consequence = apply_operation_consequence(conn, pid, 2 if outcome == "fail" else 4, outcome, f"career task: {task['name']}", god)
        else:
            consequence = ""
        conn.execute("UPDATE players SET credits=credits+? WHERE id=?", (reward,pid))
        conn.execute("UPDATE player_jobs SET xp=xp+? WHERE player_id=? AND job_code=?", (xp,pid,active["job_code"]))
        metric_changes = {}
        for key, val in task.get("metrics", {}).items():
            metric_changes[key] = reward if val == "profit" else int(val)
        increment_job_metrics(conn, pid, active["job_code"], metric_changes)
        new = row(conn,"SELECT * FROM player_jobs WHERE player_id=? AND job_code=?", (pid,active["job_code"]))
        metrics = get_job_metrics(conn, pid, active["job_code"])
        new_rank = job_rank_from_metrics(active["job_code"], new["xp"], metrics)
        conn.execute("UPDATE player_jobs SET rank=? WHERE player_id=? AND job_code=?", (new_rank,pid,active["job_code"]))
        add_xp(conn,pid,xp)
        career_action_map = {
            "miner": "mining", "salvager": "salvage", "engineer": "crafting", "shipwright": "crafting",
            "trader": "legal_trade", "dockmaster": "legal_trade", "quartermaster": "hauling",
            "bounty_hunter": "bounty", "security_pilot": "security", "marshal": "security", "mercenary": "combat",
            "explorer": "exploration", "smuggler": "illicit_trade", "medic": "repair", "diplomat": "legal_trade",
        }
        grant_action_progression(conn, pid, career_action_map.get(active["job_code"], "combat"), max(1.0, xp / 800), outcome in ("critical_success", "success", "partial"))
        # Career work gives small tangible outputs so jobs feed inventory/economy before full crafting.
        career_note = ""
        if outcome in ("critical_success", "success", "partial"):
            job_code = active["job_code"]
            note_qty = max(1, int((1 if outcome == "partial" else 2) + rank / 2))
            if job_code == "miner":
                add_inventory_item(conn, pid, "titanium", "Titanium Ore", "ore", note_qty * 12, 1, 40, 1, "Career mining output", "career_job", "raw_materials", respect_cargo=True, god=god)
                career_note = f" Added {note_qty*12} Titanium Ore."
            elif job_code == "salvager":
                add_inventory_item(conn, pid, "circuit", "Circuit Wafers", "component", note_qty * 3, 1, 120, 0.2, "Career salvage output", "career_job", "crafting_materials", respect_cargo=True, god=god)
                career_note = f" Added {note_qty*3} Circuit Wafers."
            elif job_code == "engineer":
                add_inventory_item(conn, pid, "polymer", "Industrial Polymer", "material", note_qty * 5, 1, 85, 0.3, "Engineering job leftovers", "career_job", "crafting_materials", respect_cargo=True, god=god)
                career_note = f" Added {note_qty*5} Polymer."
            elif job_code == "medic":
                add_inventory_item(conn, pid, "bio_gel", "Bio Gel", "medical", note_qty, 1, 650, 0.4, "Medical contract surplus", "career_job", "crafting_materials", respect_cargo=True, god=god)
                career_note = f" Added {note_qty} Bio Gel."
            elif job_code in {"security_pilot", "bounty_hunter", "marshal", "mercenary"}:
                conn.execute("UPDATE planets SET security_level=max(1,min(100,security_level+1)), pirate_activity=max(1,min(100,pirate_activity-1)) WHERE id=?", (player["location_planet_id"],))
                career_note = " Local security improved."
            elif job_code in {"trader", "quartermaster", "dockmaster"}:
                commodity = choose_market_commodity(conn, legal=True, categories=["food", "industrial", "energy", "electronics"])
                if commodity:
                    mutate_market(conn, player["location_planet_id"], commodity["id"], 2, -1, "player_career_trade")
                    career_note = " Local supply movement improved."
        msg = f"{outcome.replace('_',' ').title()}: {task['name']} for {active['name']}. Earned {reward:,} credits, {xp:,} career XP."
        if consequence:
            msg += " " + consequence
        if career_note:
            msg += career_note
        if new_rank > rank:
            msg += f" Promotion achieved: Rank {new_rank}."
        add_event(conn, pid, "career", msg)
        return {"message":msg, "outcome":outcome, "career_rank":new_rank, "energy_cost":energy_cost}

    if t == "unlock_skill":
        key = payload.get("skill_key")
        if key in PHASE16_SKILL_CATALOG:
            raise HTTPException(400, "Core skills level by doing their related actions, not by spending points.")
        node = row(conn,"SELECT * FROM skill_nodes WHERE key=?", (key,))
        if not node: raise HTTPException(404,"Skill not found")
        cur = row(conn,"SELECT * FROM player_skills WHERE player_id=? AND skill_key=?", (pid,key))
        lvl = cur["level"] if cur else 0
        if lvl >= node["max_level"]: raise HTTPException(400,"Skill maxed")
        reqs = decode_json(node["req_json"], {})
        prev_key = reqs.get("prev")
        if prev_key and not god:
            prev = row(conn, "SELECT * FROM player_skills WHERE player_id=? AND skill_key=?", (pid, prev_key))
            if not prev or int(prev.get("level") or 0) <= 0:
                raise HTTPException(400, "Previous skill node required")
        cost = node["cost_base"] * (lvl+1)
        if player["skill_points"] < cost and not god: raise HTTPException(400,"Not enough skill points")
        if not god: conn.execute("UPDATE players SET skill_points=skill_points-? WHERE id=?", (cost,pid))
        conn.execute("INSERT INTO player_skills (player_id,skill_key,level) VALUES (?,?,1) ON CONFLICT(player_id,skill_key) DO UPDATE SET level=level+1", (pid,key))
        return {"message":f"Unlocked {node['name']} level {lvl+1}."}

    if t == "buy_property":
        pt = row(conn,"SELECT * FROM property_templates WHERE code=?", (payload.get("code"),))
        if not pt: raise HTTPException(404,"Property not found")
        spend(conn,pid,credits=pt["base_price"],god=god)
        if not god: log_money_sink(conn, pid, "property_purchase", int(pt["base_price"]), "Long-term property investment sink")
        conn.execute("INSERT INTO player_properties (player_id,planet_id,property_template_id,level,last_collected_at) VALUES (?,?,?,?,?)", (pid,player["location_planet_id"],pt["id"],1,iso()))
        return {"message":f"Purchased property: {pt['name']}"}

    if t == "collect_property_income":
        props = rows(conn,"SELECT pp.*, pt.income FROM player_properties pp JOIN property_templates pt ON pt.id=pp.property_template_id WHERE pp.player_id=?", (pid,))
        total = 0
        for prop in props:
            last = parse_dt(prop["last_collected_at"]) or utcnow()
            hours = min(72, max(0, int((utcnow()-last).total_seconds()//3600)))
            total += prop["income"] * prop["level"] * hours
            conn.execute("UPDATE player_properties SET last_collected_at=? WHERE id=?", (iso(), prop["id"]))
        conn.execute("UPDATE players SET credits=credits+? WHERE id=?", (total,pid))
        return {"message":f"Collected {total:,} credits from properties."}

    if t == "upgrade_property":
        pp = row(conn,"SELECT * FROM player_properties WHERE id=? AND player_id=?", (int(payload["property_id"]),pid))
        if not pp: raise HTTPException(404,"Property not found")
        cost = pp["level"] * 50000
        spend(conn,pid,credits=cost,god=god)
        if not god: log_money_sink(conn, pid, "property_upgrade", cost, "Property upgrade and maintenance sink")
        conn.execute("UPDATE player_properties SET level=level+1 WHERE id=?", (pp["id"],))
        return {"message":"Property upgraded."}

    if t == "create_guild":
        name = payload.get("name","New Guild")[:40]
        cost = 250000
        spend(conn,pid,credits=cost,god=god)
        tag = ''.join([x[0] for x in name.split()])[:5].upper() or "GUILD"
        conn.execute("INSERT INTO guilds (name,tag,respect,treasury,created_at) VALUES (?,?,?,?,?)", (name,tag,0,0,iso()))
        gid = scalar(conn,"SELECT id FROM guilds WHERE name=?", (name,))
        conn.execute("INSERT INTO guild_members (guild_id,player_id,rank,contribution) VALUES (?,?,?,?)", (gid,pid,"Founder",0))
        conn.execute("UPDATE players SET guild_id=? WHERE id=?", (gid,pid))
        return {"message":f"Guild created: {name}"}

    if t == "donate_guild":
        if not player["guild_id"]: raise HTTPException(400,"No guild")
        amount = int(payload.get("credits",1000))
        spend(conn,pid,credits=amount,god=god)
        conn.execute("UPDATE guilds SET treasury=treasury+?, respect=respect+? WHERE id=?", (amount, amount//1000, player["guild_id"]))
        conn.execute("UPDATE guild_members SET contribution=contribution+? WHERE guild_id=? AND player_id=?", (amount//1000,player["guild_id"],pid))
        return {"message":f"Donated {amount:,} credits to guild."}

    if t == "guild_skill":
        if not player["guild_id"]: raise HTTPException(400,"No guild")
        key = payload.get("skill_key","fleet_logistics")
        guild = row(conn,"SELECT * FROM guilds WHERE id=?", (player["guild_id"],))
        lvlrow = row(conn,"SELECT * FROM guild_skills WHERE guild_id=? AND skill_key=?", (guild["id"],key))
        lvl = lvlrow["level"] if lvlrow else 0
        cost = (lvl+1)*2500
        if guild["respect"] < cost and not god: raise HTTPException(400,"Not enough guild respect")
        if not god: conn.execute("UPDATE guilds SET respect=respect-? WHERE id=?", (cost,guild["id"]))
        conn.execute("INSERT INTO guild_skills (guild_id,skill_key,level) VALUES (?,?,1) ON CONFLICT(guild_id,skill_key) DO UPDATE SET level=level+1", (guild["id"],key))
        return {"message":f"Guild skill upgraded: {key}"}

    if t in {"declare_planet_war", "declare_galaxy_war"}:
        faction = player_faction(conn, player)
        if not faction:
            raise HTTPException(400, "No faction assigned")
        if not player.get("guild_id"):
            raise HTTPException(400, "No guild")
        planet_id = int(payload.get("planet_id") or payload.get("galaxy_id") or 0)
        planet = row(conn, "SELECT * FROM planets WHERE id=?", (planet_id,))
        if not planet:
            raise HTTPException(404, "Planet not found")
        guild = row(conn, "SELECT * FROM guilds WHERE id=?", (player["guild_id"],))
        if not guild:
            raise HTTPException(400, "Guild not found")
        ok, reason = faction_can_declare_on_planet(conn, faction["id"], guild["id"], planet)
        if not ok and not god:
            raise HTTPException(400, reason)
        cost = guild_planet_war_declare_cost(conn, guild["id"], planet)
        if int(guild.get("treasury") or 0) < cost and not god:
            raise HTTPException(400, f"Guild treasury cannot afford planet war declaration cost: {cost:,} credits.")
        if not god:
            conn.execute("UPDATE guilds SET treasury=treasury-? WHERE id=?", (cost, guild["id"]))
        opens = utcnow() + timedelta(hours=float(FACTION_WAR_BALANCE.get("planet_war_declared_delay_hours", 48)))
        conn.execute(
            "INSERT INTO planet_faction_wars (planet_id,galaxy_id,declaring_guild_id,attacking_faction_id,defending_faction_id,status,declared_at,opens_at,declare_cost,message) VALUES (?,?,?,?,?,?,?,?,?,?)",
            (planet_id, planet["galaxy_id"], guild["id"], faction["id"], planet.get("faction_id"), "declared", iso(), iso(opens), cost, f"{guild['name']} declared a faction war on {planet['name']}. Capture ring opens in 2 days."),
        )
        add_event(conn, pid, "planet_war", f"{guild['name']} declared faction war on {planet['name']}. Capture ring opens in 2 days.", {"planetId": planet_id, "cost": cost})
        return {"message": f"Planet war declared on {planet['name']}. Capture ring opens in 2 days.", "cost": cost, "openPage": "Faction War"}

    if t in {"navigate_to_planet_war", "navigate_to_galaxy_war"}:
        war_id = int(payload.get("war_id") or 0)
        war = row(conn, "SELECT w.*, p.name as planet_name FROM planet_faction_wars w JOIN planets p ON p.id=w.planet_id WHERE w.id=?", (war_id,))
        if not war:
            raise HTTPException(404, "War not found")
        current = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],))
        if not current:
            raise HTTPException(400, "Current location not found")
        if int(current["galaxy_id"]) == int(war["galaxy_id"]):
            planet_node = build_system_map_shallow(conn, player)
            target_node = next((n for n in planet_node.get("nodes", []) if int(n["id"]) == int(war["planet_id"])), None)
            if target_node:
                return handle_action_forced_travel(conn, user, player, "go_here", {
                    "x_pct": float(target_node.get("x_pct") or 50),
                    "y_pct": float(target_node.get("y_pct") or 50),
                    "map_type": "system",
                    "label": f"{war['planet_name']} capture ring",
                }, god)
            return handle_action_forced_travel(conn, user, player, "travel", {"planet_id": war["planet_id"]}, god)
        if "gate" not in str(current.get("type") or "").lower():
            gate = galaxy_gate_planet(conn, int(current["galaxy_id"]))
            if not gate:
                raise HTTPException(400, "No gate in current galaxy")
            return handle_action_forced_travel(conn, user, player, "travel", {"planet_id": gate["id"]}, god)
        if not galaxy_is_adjacent(conn, int(current["galaxy_id"]), int(war["galaxy_id"])):
            raise HTTPException(400, "War planet is not in an adjacent galaxy from this gate. Use gate lanes manually until adjacent.")
        return handle_action_forced_travel(conn, user, player, "galaxy_travel", {"galaxy_id": war["galaxy_id"]}, god)

    if t == "join_faction":
        code = str(payload.get("faction_code") or "")
        faction = row(conn, "SELECT * FROM factions WHERE code=?", (code,))
        if not faction:
            raise HTTPException(404, "Faction not found")
        conn.execute("UPDATE players SET faction_id=? WHERE id=?", (faction["id"], pid))
        add_event(conn, pid, "faction", f"Joined {faction['name']}.")
        return {"message": f"Joined {faction['name']}."}

    if t in {"declare_war", "siege_planet", "launch_assault"}:
        if t == "declare_war":
            return handle_action_forced_travel(conn, user, player, "declare_planet_war", {"planet_id": int(payload.get("planet_id") or 0)}, god)
        raise HTTPException(400, "Old siege/assault wars were removed. Planet faction wars now resolve through the live capture ring.")

    if t == "hospital_expedite":
        minutes = int(payload.get("minutes",30))
        h_until = parse_dt(player.get("hospital_until"))
        if not h_until or h_until <= utcnow(): return {"message":"You are not hospitalized."}
        cost = minutes * 1500
        spend(conn,pid,credits=cost,god=god)
        if not god: log_money_sink(conn, pid, "hospital_surgery", cost, "Paid surgery acceleration; 10-minute minimum remains")
        min_until = utcnow() + timedelta(minutes=10)
        new_until = max(min_until, h_until - timedelta(minutes=minutes))
        conn.execute("UPDATE players SET hospital_until=? WHERE id=?", (iso(new_until),pid))
        return {"message":f"Surgery expedited by {minutes} minutes. Minimum hospital time remains 10 minutes."}

    if t == "spawn_npcs":
        if not user["god_mode"] or not DEV_MODE: raise HTTPException(403,"Admin only")
        # Adds fresh bounties and NPC agents at every planet for testing.
        planet_ids = [r["id"] for r in rows(conn,"SELECT id FROM planets")]
        for i in range(20):
            planet_id = random.choice(planet_ids)
            conn.execute("INSERT INTO bounties (name,target_type,planet_id,threat,reward,status) VALUES (?,?,?,?,?,?)", (f"NPC Raider {uuid.uuid4().hex[:5]}","npc",planet_id,random.randint(10,95),random.randint(25000,250000),"open"))
        simulated = simulate_npc_activity(conn, force=True)
        return {"message":f"Spawned NPC bounties and ran {simulated} simulated human-like NPC actions."}

    if t == "simulate_npc_tick":
        if not user["god_mode"] or not DEV_MODE: raise HTTPException(403,"Admin only")
        simulated = simulate_npc_activity(conn, force=True)
        return {"message":f"Simulated {simulated} NPC human-like market/combat/trade/customs actions."}

    raise HTTPException(400, f"Unknown action: {t}")
