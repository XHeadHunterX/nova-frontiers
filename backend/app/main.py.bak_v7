        ("guildhall","Guild Hall",18000000), ("defense","Planet Defense Grid",24000000)
    ]
    for pid in planet_ids:
        for typ, name, price in services:
            conn.execute("INSERT INTO planet_establishments (planet_id,name,service_type,price,level) VALUES (?,?,?,?,?)", (pid, name, typ, price, 1))

    ops = [
        ("bounty_hunt","Bounty Hunting","bounty",1,0,3,15,25000,150000,2,"Hunt wanted captains, fugitives, and pirates."),
        ("sector_patrol","Sector Patrol","patrol",1,0,2,20,15000,80000,2,"Secure local space and eliminate minor threats."),
        ("anomaly_scan","Anomaly Scan","exploration",1,0,2,15,10000,60000,2,"Scan unknown signals and unstable phenomena."),
        ("derelict_salvage","Derelict Salvage","salvage",1,0,3,25,20000,120000,2,"Recover cargo and parts from wrecked ships."),
        ("mining_expedition","Mining Expedition","mining",1,0,2,30,30000,200000,2,"Extract valuable ore from asteroid fields."),
        ("artifact_recovery","Artifact Recovery","exploration",1,0,4,35,45000,250000,3,"Recover unusual relics under unstable conditions."),
        ("cargo_haul","Cargo Hauling","trade",1,0,2,18,20000,100000,2,"Move legal goods through active trade lanes."),
        ("convoy_escort","Convoy Escort","escort",1,1,4,35,50000,300000,3,"Protect NPC trader ships from raiders."),
        ("rescue_signal","Rescue Signal","medical",1,0,3,20,25000,130000,2,"Respond to distress calls and recover survivors."),
        ("pirate_hideout","Pirate Hideout Assault","group",1,1,6,45,90000,450000,4,"Clear a fortified outlaw base."),
        ("dreadnought_boss","Dreadnought Boss","boss",1,1,8,60,150000,800000,5,"Fight a heavily armed pirate fleet boss."),
        ("alien_raid","Alien Nest Raid","boss",1,1,9,70,180000,900000,5,"Destroy alien growth fleets before they spread."),
        ("world_event","World Event","event",1,1,7,90,100000,700000,4,"Dynamic server-wide crisis with high rewards."),
        ("smuggler_interdict","Smuggler Interdiction","law",1,0,4,25,35000,180000,3,"Stop NPC smugglers and seize illegal cargo."),
        ("black_box","Black Box Recovery","salvage",1,0,3,18,30000,160000,2,"Recover lost flight data from combat zones."),
    ]
    for i, op in enumerate(ops):
        pid = planet_ids[i % len(planet_ids)]
        conn.execute("INSERT INTO pve_operations (code,name,op_type,solo,group_recommended,difficulty,duration_minutes,reward_min,reward_max,skill_reward,description,planet_id) VALUES (?,?,?,?,?,?,?,?,?,?,?,?)", (*op, pid))

    npc_roles = ["customs","patrol","trader","pirate","medic","dockmaster","market_maker","defender","bounty","miner","salvager"]
    for pid in planet_ids:
        p = row(conn, "SELECT * FROM planets WHERE id=?", (pid,))
        for role in npc_roles:
            base = {
                "customs": p["customs_rating"], "patrol": p["security_level"], "trader": p["market_activity"],
                "pirate": p["pirate_activity"], "medic": p["medical_quality"], "defender": p["defense_strength"],
            }.get(role, 55)
            conn.execute("INSERT INTO npc_agents (planet_id,role,name,power,disposition) VALUES (?,?,?,?,?)", (pid, role, f"NPC {role.title()} - {p['name']}", int(base*0.62), "neutral"))

    # Seed bounties.
    names = ["Draxil Vorn","Sister Nyxara","Kaal the Relentless","Zarek-9","The Sand Viper","Void Reaper X","RogueSpecter","EclipseGhost"]
    for i, name in enumerate(names):
        pid = planet_ids[i % len(planet_ids)]
        threat = 25 + i * 7
        conn.execute("INSERT INTO bounties (name,target_type,planet_id,threat,reward,status) VALUES (?,?,?,?,?,?)", (name,"npc",pid,threat,80000 + i*35000,"open"))

    # Users/players.
    conn.execute("INSERT INTO users (username,password_hash,role,god_mode,created_at) VALUES (?,?,?,?,?)", ("godmode", pw_hash("godmode123"), "admin", 1, now))
    conn.execute("INSERT INTO users (username,password_hash,role,god_mode,created_at) VALUES (?,?,?,?,?)", ("pilot", pw_hash("pilot123"), "player", 0, now))
    conn.execute("INSERT INTO guilds (name,tag,respect,treasury,created_at) VALUES (?,?,?,?,?)", ("Void Reapers", "VOID", 128750, 37842990, now))
    guild_id = scalar(conn, "SELECT id FROM guilds WHERE name='Void Reapers'")
    for username, callsign, god in [("godmode","STARLORD87",1), ("pilot","RookiePilot",0)]:
        uid = scalar(conn, "SELECT id FROM users WHERE username=?", (username,))
        loc = scalar(conn, "SELECT id FROM planets WHERE code='solaria'")
        if god:
            vals = (uid,callsign,47,850000,12845,94732419,1250,1500,0,1000,18640,12450,500,500,78000,12000,"Honored",loc,guild_id,now)
        else:
            vals = (uid,callsign,1,0,3,5000,160,220,0,40,100,0,100,100,0,0,"Clean",loc,None,now)
        conn.execute("""INSERT INTO players (user_id,callsign,level,xp,skill_points,credits,fuel,max_fuel,cargo,max_cargo,scrap,loyalty,health,max_health,reputation,faction_standing,security_status,location_planet_id,guild_id,created_at)
                      VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""", vals)
        pid = scalar(conn, "SELECT id FROM players WHERE user_id=?", (uid,))
        starter_template = row(conn, "SELECT * FROM ship_templates WHERE starter=1")
        conn.execute("""INSERT INTO ships (player_id,template_id,name,hull,max_hull,shield,max_shield,armor,cargo_capacity,fuel_capacity,drive_speed,size_class,mass,insured,insurance_tier,destroyed,starter)
                      VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""", (pid,starter_template["id"],starter_template["name"],starter_template["hull"],starter_template["hull"],starter_template["shield"],starter_template["shield"],starter_template["armor"],starter_template["cargo_capacity"],starter_template["fuel_capacity"],starter_template["drive_speed"],starter_template.get("size_class","S"),starter_template.get("mass",145),1,"starter",0,1))
        active_ship = scalar(conn, "SELECT id FROM ships WHERE player_id=? ORDER BY id LIMIT 1", (pid,))
        conn.execute("UPDATE players SET active_ship_id=?, max_cargo=?, max_fuel=? WHERE id=?", (active_ship, starter_template["cargo_capacity"], starter_template["fuel_capacity"], pid))
        if god:
            # Add premium ships and modules.
            for st in rows(conn, "SELECT * FROM ship_templates WHERE starter=0"):
                conn.execute("""INSERT INTO ships (player_id,template_id,name,hull,max_hull,shield,max_shield,armor,cargo_capacity,fuel_capacity,drive_speed,size_class,mass,insured,insurance_tier,destroyed,starter)
                              VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""", (pid, st["id"], st["name"], st["hull"], st["hull"], st["shield"], st["shield"], st["armor"], st["cargo_capacity"], st["fuel_capacity"], st["drive_speed"],st.get("size_class","M"),st.get("mass",340),1,"premium",0,0))
            eclipse_id = scalar(conn, "SELECT s.id FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.player_id=? AND t.code='eclipse_hunter'", (pid,))
            conn.execute("UPDATE players SET active_ship_id=?, max_cargo=1000, max_fuel=1500 WHERE id=?", (eclipse_id,pid))
            for mt in rows(conn, "SELECT * FROM module_templates"):
                conn.execute("INSERT INTO ship_modules (player_id,ship_id,module_template_id,slot_type,equipped,durability) VALUES (?,?,?,?,?,?)", (pid, eclipse_id, mt["id"], mt["slot_type"], 1 if mt["slot_type"] in ["weapon","defense","utility","core"] else 0, 100))
            for com in rows(conn, "SELECT * FROM commodities"):
                conn.execute("INSERT INTO cargo_hold (player_id,commodity_id,qty,avg_cost) VALUES (?,?,?,?)", (pid, com["id"], 20, com["base_price"]))
            items = [("titanium","Titanium Ore","material",50000,1,40,1),("iridium","Iridium","material",12000,1,200,1),("circuit","Circuit Wafers","component",8000,1,120,0.2),("polymer","Polymer","material",9000,1,60,1),("fuel_cell","Fuel Cells","consumable",2000,1,300,1),("ammo","Railgun Ammunition","ammo",5000,1,40,0.1),("chemicals","Industrial Chemicals","material",5000,1,260,1),("nutrient_paste","Nutrient Paste","food",4000,1,95,1),("hydro_spices","Hydroponic Spices","food",2000,1,310,0.4),("bio_gel","Bio-Gel","medical",2400,1,520,0.6),("volatile_reagents","Volatile Reagents","contraband",900,0,3900,0.5)]
            for code,name,typ,qty,legal,val,mass in items:
                conn.execute("INSERT INTO inventory (player_id,item_code,name,item_type,qty,legal,base_value,mass) VALUES (?,?,?,?,?,?,?,?)", (pid,code,name,typ,qty,legal,val,mass))
            conn.execute("INSERT INTO guild_members (guild_id,player_id,rank,contribution) VALUES (?,?,?,?)", (guild_id,pid,"Councillor",12430))
            for key in [r["key"] for r in rows(conn,"SELECT key FROM skill_nodes")]:
                conn.execute("INSERT INTO player_skills (player_id,skill_key,level) VALUES (?,?,?)", (pid,key,3))
            for job in rows(conn,"SELECT code FROM jobs"):
                active = 1 if job["code"] == "trader" else 0
                conn.execute("INSERT INTO player_jobs (player_id,job_code,xp,rank,active) VALUES (?,?,?,?,?)", (pid, job["code"], 25000, 6 if active else 3, active))
            for pt in rows(conn,"SELECT * FROM property_templates LIMIT 5"):
                conn.execute("INSERT INTO player_properties (player_id,planet_id,property_template_id,level,last_collected_at) VALUES (?,?,?,?,?)", (pid, loc, pt["id"], 3, now))
        else:
            for key in ["piloting_1","trading_1","combat_1"]:
                conn.execute("INSERT INTO player_skills (player_id,skill_key,level) VALUES (?,?,?)", (pid,key,1))
            conn.execute("INSERT INTO player_jobs (player_id,job_code,xp,rank,active) VALUES (?,?,?,?,?)", (pid, "trader", 0, 1, 1))
    conn.commit()




def normalize_username(value: str) -> str:
    username = (value or "").strip().lower()
    safe = "".join(ch for ch in username if ch.isalnum() or ch in {"_", "-"})
    if len(safe) < PROFILE_LIMITS["username_min"] or len(safe) > PROFILE_LIMITS["username_max"]:
        raise HTTPException(400, f"Username must be {PROFILE_LIMITS['username_min']}-{PROFILE_LIMITS['username_max']} characters and use letters, numbers, underscore, or dash")
    return safe


def normalize_display_name(value: str) -> str:
    display = " ".join((value or "").strip().split())
    if len(display) < PROFILE_LIMITS["display_min"] or len(display) > PROFILE_LIMITS["display_max"]:
        raise HTTPException(400, f"Display name must be {PROFILE_LIMITS['display_min']}-{PROFILE_LIMITS['display_max']} characters")
    return display


def normalize_bio(value: str) -> str:
    bio = (value or "").strip()
    return bio[:PROFILE_LIMITS["bio_max"]]


def clean_avatar_id(value: Optional[str]) -> str:
    avatar_id = (value or DEFAULT_AVATAR_ID).strip()
    return avatar_id if avatar_id in PROFILE_AVATAR_BY_ID else DEFAULT_AVATAR_ID


def avatar_payload(avatar_id: Optional[str]) -> Dict[str, str]:
    return PROFILE_AVATAR_BY_ID.get(clean_avatar_id(avatar_id), PROFILE_AVATAR_BY_ID[DEFAULT_AVATAR_ID])


def achievement_tier_for_progress(progress: int) -> int:
    progress = int(progress or 0)
    tier = 0
    for i, target in enumerate(ACHIEVEMENT_TIER_THRESHOLDS, start=1):
        if progress >= int(target):
            tier = i
    return tier


def ensure_achievement_rows(conn: sqlite3.Connection, player_id: int) -> None:
    now = iso()
    for loop_key in ACHIEVEMENT_LOOPS.keys():
        conn.execute(
            "INSERT OR IGNORE INTO player_achievement_progress (player_id,loop_key,progress,tier_unlocked,updated_at) VALUES (?,?,?,?,?)",
            (player_id, loop_key, 0, 0, now),
        )


def grant_achievement_progress(conn: sqlite3.Connection, player_id: int, loop_key: str, amount: float = 1.0) -> Dict[str, Any]:
    if loop_key not in ACHIEVEMENT_LOOPS:
        return {}
    ensure_achievement_rows(conn, player_id)
    inc = max(1, int(round(float(amount or 1.0))))
    current = row(conn, "SELECT * FROM player_achievement_progress WHERE player_id=? AND loop_key=?", (player_id, loop_key)) or {"progress": 0, "tier_unlocked": 0}
    progress = int(current.get("progress") or 0) + inc
    tier = achievement_tier_for_progress(progress)
    old_tier = int(current.get("tier_unlocked") or 0)
    conn.execute(
        "UPDATE player_achievement_progress SET progress=?, tier_unlocked=?, updated_at=? WHERE player_id=? AND loop_key=?",
        (progress, tier, iso(), player_id, loop_key),
    )
    if tier > old_tier:
        meta = ACHIEVEMENT_LOOPS[loop_key]
        add_event(conn, player_id, "achievement", f"Achievement unlocked: {meta['name']} Tier {tier}.", {"loop": loop_key, "tier": tier, "badge": achievement_badge_code(loop_key, tier)})
    return {"loop": loop_key, "progress": progress, "tier": tier, "tierUp": tier > old_tier}


def selected_badge_is_unlocked(conn: sqlite3.Connection, player_id: int, badge_code: str) -> bool:
    badge_code = str(badge_code or "").strip()
    m = re.match(r"^([a-z0-9_]+)_t([1-8])$", badge_code)
    if not m:
        return False
    loop_key, tier_s = m.group(1), m.group(2)
    row_data = row(conn, "SELECT tier_unlocked FROM player_achievement_progress WHERE player_id=? AND loop_key=?", (player_id, loop_key))
    return bool(row_data and int(row_data.get("tier_unlocked") or 0) >= int(tier_s))


def achievement_passive_buffs(conn: sqlite3.Connection, player_id: int) -> Dict[str, float]:
    buffs: Dict[str, float] = {}
    for r in rows(conn, "SELECT loop_key,tier_unlocked FROM player_achievement_progress WHERE player_id=?", (player_id,)):
        if int(r.get("tier_unlocked") or 0) >= 8:
            for k, v in (ACHIEVEMENT_LOOPS.get(r["loop_key"], {}).get("buff") or {}).items():
                buffs[k] = buffs.get(k, 0.0) + float(v or 0)
    return buffs


def build_achievements_state(conn: sqlite3.Connection, player_id: int) -> Dict[str, Any]:
    ensure_achievement_rows(conn, player_id)
    progress_rows = {r["loop_key"]: r for r in rows(conn, "SELECT * FROM player_achievement_progress WHERE player_id=?", (player_id,))}
    loops = []
    unlocked_badges = []
    for loop_key, meta in ACHIEVEMENT_LOOPS.items():
        r = progress_rows.get(loop_key) or {}
        progress = int(r.get("progress") or 0)
        tier = achievement_tier_for_progress(progress)
        next_target = ACHIEVEMENT_TIER_THRESHOLDS[tier] if tier < 8 else ACHIEVEMENT_TIER_THRESHOLDS[-1]
        badges = []
        for t in range(1, 9):
            unlocked = tier >= t
            badge = {"code": achievement_badge_code(loop_key, t), "url": achievement_badge_url(loop_key, t), "tier": t, "unlocked": unlocked}
            badges.append(badge)
            if unlocked:
                unlocked_badges.append({**badge, "loopKey": loop_key, "name": meta["name"], "theme": ACHIEVEMENT_BADGE_THEME.get(loop_key)})
        loops.append({
            "loopKey": loop_key,
            "name": meta["name"],
            "summary": meta["summary"],
            "progress": progress,
            "tierUnlocked": tier,
            "nextTarget": next_target,
            "currentTarget": ACHIEVEMENT_TIER_THRESHOLDS[tier-1] if tier > 0 else 0,
            "percentToNext": 100 if tier >= 8 else int((progress / max(1, next_target)) * 100),
            "badges": badges,
            "tier8PassiveBuff": meta.get("buff") or {},
            "badgeUrl": achievement_badge_url(loop_key, max(1, tier or 1)),
            "theme": ACHIEVEMENT_BADGE_THEME.get(loop_key),
        })
    return {"loops": loops, "unlockedBadges": unlocked_badges, "passiveBuffs": achievement_passive_buffs(conn, player_id)}


def build_player_profile_stats(conn: sqlite3.Connection, player: Dict[str, Any], public: bool = False) -> Dict[str, Any]:
    pid = int(player["id"])
    events = rows(conn, "SELECT category, COUNT(*) as count FROM events WHERE player_id=? GROUP BY category", (pid,))
    by_cat = {e["category"]: int(e["count"] or 0) for e in events}
    jobs = rows(conn, "SELECT job_code, rank, xp FROM player_jobs WHERE player_id=? ORDER BY rank DESC, xp DESC LIMIT 8", (pid,))
    skills = rows(conn, "SELECT skill_key, level, xp FROM player_skills WHERE player_id=? ORDER BY level DESC, xp DESC LIMIT 8", (pid,))
    planet_count = int(scalar(conn, "SELECT COUNT(*) FROM planets WHERE controller_type='guild' AND controller_id=?", (player.get("guild_id"),)) or 0) if player.get("guild_id") else 0
    public_stats = {
        "level": int(player.get("level") or 1),
        "xp": int(player.get("xp") or 0),
        "careerHighlights": jobs,
        "skillHighlights": skills,
        "eventCounts": by_cat,
        "planetsGuildControls": planet_count,
        "joinedAt": player.get("created_at") or None,
        "travelEvents": by_cat.get("travel", 0),
        "combatEvents": by_cat.get("combat", 0) + by_cat.get("bounty", 0),
        "craftingEvents": by_cat.get("crafting", 0),
        "miningEvents": by_cat.get("mining", 0),
        "salvageEvents": by_cat.get("salvage", 0),
        "explorationEvents": by_cat.get("exploration", 0),
    }
    if public:
        return public_stats
    public_stats.update({
        "credits": int(player.get("credits") or 0),
        "fuel": int(player.get("fuel") or 0),
        "energy": int(player.get("energy") or 0),
        "health": int(player.get("health") or 0),
        "shipPower": int(get_ship_power(conn, int(player.get("active_ship_id") or 0))) if player.get("active_ship_id") else 0,
        "cargo": int(player.get("cargo") or 0),
    })
    return public_stats


def public_profile_payload(conn: sqlite3.Connection, target_user_id: int, viewer_player_id: Optional[int] = None) -> Dict[str, Any]:
    target = row(conn, "SELECT u.*, p.id as player_id, p.callsign, p.level, p.xp, p.guild_id, p.location_planet_id, p.active_ship_id FROM users u JOIN players p ON p.user_id=u.id WHERE u.id=?", (target_user_id,))
    if not target:
        return {}
    player = row(conn, "SELECT * FROM players WHERE id=?", (target["player_id"],))
    profile = ensure_user_profile(conn, target, player)
    avatar = avatar_payload(profile.get("avatar_id"))
    selected_badge = profile.get("selected_badge_code") or ""
    ach = build_achievements_state(conn, int(player["id"]))
    top_achievements = sorted(ach["loops"], key=lambda x: (x["tierUnlocked"], x["progress"]), reverse=True)[:6]
    loc = row(conn, "SELECT p.name as location_name, g.name as galaxy_name FROM planets p JOIN galaxies g ON g.id=p.galaxy_id WHERE p.id=?", (player.get("location_planet_id"),))
    current_ship = row(conn, "SELECT s.name, t.name as template_name, t.class_name, t.role FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=?", (player.get("active_ship_id"),)) if player.get("active_ship_id") else None
    payload = {
        "userId": target_user_id,
        "playerId": player["id"],
        "username": target.get("username"),
        "displayName": profile.get("display_name") or player.get("callsign") or target.get("username"),
        "avatarId": clean_avatar_id(profile.get("avatar_id")),
        "avatarUrl": avatar["url"],
        "bio": profile.get("bio") or "",
        "selectedBadgeCode": selected_badge,
        "selectedBadgeUrl": selected_badge,
        "selectedBadge": next((b for b in ach["unlockedBadges"] if b["code"] == selected_badge), None),
        "homeGalaxy": loc.get("galaxy_name") if loc else None,
        "currentLocation": loc.get("location_name") if loc else None,
        "currentShip": current_ship,
        "stats": build_player_profile_stats(conn, player, public=True),
        "topAchievements": top_achievements,
        "passiveBuffsPublic": ach["passiveBuffs"],
    }
    if viewer_player_id:
        conn.execute("INSERT INTO player_profile_views (viewer_player_id,target_player_id,viewed_at) VALUES (?,?,?)", (viewer_player_id, player["id"], iso()))
    return payload


def ensure_user_profile(conn: sqlite3.Connection, user: Dict[str, Any], player: Dict[str, Any]) -> Dict[str, Any]:
    existing = row(conn, "SELECT * FROM user_profiles WHERE user_id=?", (user["id"],))
    if existing:
        avatar_id = clean_avatar_id(existing.get("avatar_id"))
        if avatar_id != existing.get("avatar_id"):
            conn.execute("UPDATE user_profiles SET avatar_id=?, updated_at=? WHERE user_id=?", (avatar_id, iso(), user["id"]))
            existing["avatar_id"] = avatar_id
        return existing
    raw_display = str(player.get("callsign") or user.get("username") or "Pilot")
    try:
        display = normalize_display_name(raw_display)
    except HTTPException:
        display = "Nova Pilot"
    seed_avatar = "male_01" if user.get("username") == "godmode" else "female_01" if user.get("username") == "pilot" else DEFAULT_AVATAR_ID
    conn.execute(
        "INSERT INTO user_profiles (user_id,display_name,avatar_id,bio,updated_at) VALUES (?,?,?,?,?)",
        (user["id"], display, clean_avatar_id(seed_avatar), "", iso()),
    )
    return row(conn, "SELECT * FROM user_profiles WHERE user_id=?", (user["id"],)) or {}


def profile_payload(conn: sqlite3.Connection, user: Dict[str, Any], player: Dict[str, Any]) -> Dict[str, Any]:
    profile = ensure_user_profile(conn, user, player)
    avatar = avatar_payload(profile.get("avatar_id"))
    current_job = row(conn, "SELECT j.name, j.code, pj.rank, pj.xp FROM player_jobs pj JOIN jobs j ON j.code=pj.job_code WHERE pj.player_id=? AND pj.active=1 LIMIT 1", (player["id"],))
    current_ship = row(conn, "SELECT s.name, t.name as template_name, t.class_name, t.role FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=?", (player.get("active_ship_id"),)) if player.get("active_ship_id") else None
    loc = row(conn, "SELECT p.name as location_name, g.name as galaxy_name FROM planets p JOIN galaxies g ON g.id=p.galaxy_id WHERE p.id=?", (player.get("location_planet_id"),))
    achievements = build_achievements_state(conn, int(player["id"]))
    selected_badge = profile.get("selected_badge_code") or ""
    return {
        "username": user.get("username"),
        "displayName": profile.get("display_name") or player.get("callsign") or user.get("username"),
        "avatarId": clean_avatar_id(profile.get("avatar_id")),
        "avatarUrl": avatar["url"],
        "avatarLabel": avatar["label"],
        "bio": profile.get("bio") or "",
        "selectedBadgeCode": selected_badge,
        "selectedBadgeUrl": selected_badge,
        "selectedBadge": next((b for b in achievements["unlockedBadges"] if b["code"] == selected_badge), None),
        "homeGalaxy": loc.get("galaxy_name") if loc else None,
        "currentLocation": loc.get("location_name") if loc else None,
        "currentJob": current_job,
        "currentShip": current_ship,
        "stats": build_player_profile_stats(conn, player, public=False),
        "achievements": achievements,
    }


def ensure_profile_content(conn: sqlite3.Connection) -> None:
    if not scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='user_profiles'"):
        return
    for u in rows(conn, "SELECT u.*, p.id as player_id, p.callsign FROM users u JOIN players p ON p.user_id=u.id"):
        player_stub = {"id": u["player_id"], "callsign": u.get("callsign") or u.get("username"), "active_ship_id": None, "location_planet_id": None}
        ensure_user_profile(conn, u, player_stub)
        ensure_achievement_rows(conn, int(u["player_id"]))
    if not scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='chat_messages'"):
        return
    if scalar(conn, "SELECT COUNT(*) FROM chat_messages") == 0:
        seeds = [
            ("system", "System Beacon", "default", "Sector relay online. Pilot identity, avatar sync, and local channel are active."),
            ("npc", "Station Control", "female_07", "Docking lanes are nominal. Keep your manifest current before trade runs."),
            ("npc", "Market Broker", "male_09", "Legal goods are moving clean. Illicit cargo is profitable, but security scans are tightening."),
            ("npc", "Security Net", "male_04", "Pirate chatter detected near low-stability routes. Escorts and patrols are paying better."),
        ]
        for idx, (kind, name, avatar_id, msg) in enumerate(seeds):
            conn.execute(
                "INSERT INTO chat_messages (user_id,player_id,sender_type,sender_name,avatar_id,message,created_at) VALUES (NULL,NULL,?,?,?,?,?)",
                (kind, name, clean_avatar_id(avatar_id), msg, iso(utcnow() - timedelta(minutes=(len(seeds)-idx)*6))),
            )



def skill_xp_required(level: int) -> int:
    level = max(1, int(level))
    return int(SKILL_XP_BALANCE["base_curve"] * (level ** SKILL_XP_BALANCE["curve_power"]))


def skill_level_from_xp(xp: int, max_level: int = None) -> int:
    xp = max(0, int(xp or 0))
    max_level = int(max_level or SKILL_XP_BALANCE["max_level"])
    level = 0
    while level < max_level and xp >= skill_xp_required(level + 1):
        level += 1
    return level


def skill_progress_payload(xp: int, max_level: int = None) -> Dict[str, Any]:
    max_level = int(max_level or SKILL_XP_BALANCE["max_level"])
    level = skill_level_from_xp(xp, max_level)
    if level >= max_level:
        return {"level": level, "xp": int(xp or 0), "next_xp": None, "xp_into_level": 0, "xp_needed": 0, "progress_pct": 100}
    prev_req = skill_xp_required(level)
    next_req = skill_xp_required(level + 1)
    into = max(0, int(xp or 0) - prev_req)
    need = max(1, next_req - prev_req)
    return {"level": level, "xp": int(xp or 0), "next_xp": next_req, "xp_into_level": into, "xp_needed": max(0, next_req - int(xp or 0)), "progress_pct": round(min(100, into / need * 100), 1)}


def ensure_progression_content(conn: sqlite3.Connection) -> None:
    if not scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='skill_nodes'"):
        return
    for key, d in PHASE16_SKILL_CATALOG.items():
        conn.execute(
            """
            INSERT INTO skill_nodes
              (key,tree,name,max_level,cost_base,req_json,buff_json,description,summary,category,icon,trained_by_json,affects_json,passive_bonuses_json,unlock_json,xp_curve_base)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
            ON CONFLICT(key) DO UPDATE SET
              tree=excluded.tree,
              name=excluded.name,
              max_level=max(skill_nodes.max_level, excluded.max_level),
              description=excluded.description,
              summary=excluded.summary,
              category=excluded.category,
              icon=excluded.icon,
              trained_by_json=excluded.trained_by_json,
              affects_json=excluded.affects_json,
              passive_bonuses_json=excluded.passive_bonuses_json,
              unlock_json=excluded.unlock_json,
              xp_curve_base=excluded.xp_curve_base
            """,
            (
                key, key, d["name"], SKILL_XP_BALANCE["max_level"], 0, "{}", encode_json({key: 1}),
                d["description"], d["summary"], d["category"], d["icon"],
                encode_json(d.get("trained_by", [])), encode_json(d.get("affects", [])), encode_json(d.get("bonuses", [])),
                encode_json(d.get("unlocks", [])), SKILL_XP_BALANCE["base_curve"],
            ),
        )
    if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='jobs'"):
        for code, d in PHASE16_CAREER_DETAILS.items():
            j = row(conn, "SELECT * FROM jobs WHERE code=?", (code,))
            if j:
                perks = list(dict.fromkeys((decode_json(j.get("perks_json"), []) or []) + d.get("bonuses", [])))
                req = decode_json(j.get("req_json"), {}) or {}
                req["preferred_skills"] = d.get("preferred_skills", [])
                req["preferred_ships"] = d.get("preferred_ships", [])
                conn.execute(
                    "UPDATE jobs SET req_json=?, perks_json=? WHERE code=?",
                    (encode_json(req), encode_json(perks), code),
                )
    # Convert legacy manual-only skill levels into starter XP once so old saves do not show impossible zero progress.
    for ps in rows(conn, "SELECT ps.*, sn.max_level FROM player_skills ps JOIN skill_nodes sn ON sn.key=ps.skill_key WHERE COALESCE(ps.xp,0)=0 AND COALESCE(ps.level,0)>0"):
        starter_xp = skill_xp_required(int(ps["level"]))
        conn.execute("UPDATE player_skills SET xp=?, updated_at=? WHERE player_id=? AND skill_key=?", (starter_xp, iso(), ps["player_id"], ps["skill_key"]))


def grant_skill_xp(conn: sqlite3.Connection, player_id: int, skill_key: str, amount: int) -> Dict[str, Any]:
    if skill_key not in PHASE16_SKILL_CATALOG:
        return {"skill": skill_key, "xp_added": 0, "level_before": 0, "level_after": 0}
    amount = max(0, int(amount or 0))
    if amount <= 0:
        return {"skill": skill_key, "xp_added": 0, "level_before": 0, "level_after": 0}
    node = row(conn, "SELECT * FROM skill_nodes WHERE key=?", (skill_key,))
    max_level = int((node or {}).get("max_level") or SKILL_XP_BALANCE["max_level"])
    existing = row(conn, "SELECT * FROM player_skills WHERE player_id=? AND skill_key=?", (player_id, skill_key))
    old_xp = int((existing or {}).get("xp") or 0)
    old_level = int((existing or {}).get("level") or skill_level_from_xp(old_xp, max_level))
    new_xp = old_xp + amount
    new_level = skill_level_from_xp(new_xp, max_level)
    conn.execute(
        """
        INSERT INTO player_skills (player_id,skill_key,level,xp,updated_at)
        VALUES (?,?,?,?,?)
        ON CONFLICT(player_id,skill_key) DO UPDATE SET
          xp=excluded.xp,
          level=excluded.level,
          updated_at=excluded.updated_at
        """,
        (player_id, skill_key, new_level, new_xp, iso()),
    )
    return {"skill": skill_key, "xp_added": amount, "level_before": old_level, "level_after": new_level}


def active_career_code(conn: sqlite3.Connection, player_id: int) -> Optional[str]:
    active = row(conn, "SELECT job_code FROM player_jobs WHERE player_id=? AND active=1", (player_id,))
    return active["job_code"] if active else None


def grant_career_xp_if_active(conn: sqlite3.Connection, player_id: int, action_key: str, multiplier: float = 1.0) -> Dict[str, Any]:
    active = active_career_code(conn, player_id)
    cfg = ACTION_PROGRESSION.get(action_key, {})
    if not active or active not in (cfg.get("careers") or {}):
        return {}
    xp = max(1, int((cfg["careers"][active]) * multiplier))
    conn.execute(
        "INSERT INTO player_jobs (player_id,job_code,xp,rank,active,last_active_at) VALUES (?,?,?,?,1,?) "
        "ON CONFLICT(player_id,job_code) DO UPDATE SET xp=player_jobs.xp+excluded.xp, last_active_at=excluded.last_active_at",
        (player_id, active, xp, 1, iso()),
    )
    metrics = get_job_metrics(conn, player_id, active)
    row_now = row(conn, "SELECT * FROM player_jobs WHERE player_id=? AND job_code=?", (player_id, active))
    rank = job_rank_from_metrics(active, int((row_now or {}).get("xp") or 0), metrics)
    conn.execute("UPDATE player_jobs SET rank=? WHERE player_id=? AND job_code=?", (rank, player_id, active))
    return {"career": active, "xp_added": xp, "rank": rank}


def grant_action_progression(conn: sqlite3.Connection, player_id: int, action_key: str, multiplier: float = 1.0, success: bool = True) -> Dict[str, Any]:
    cfg = ACTION_PROGRESSION.get(action_key)
    if not cfg:
        return {}
    mult = max(0.05, float(multiplier or 1.0))
    if not success:
        mult *= 0.35
    skill_results = []
    for skill_key, xp in (cfg.get("skills") or {}).items():
        skill_results.append(grant_skill_xp(conn, player_id, skill_key, int(xp * mult)))
    career_result = grant_career_xp_if_active(conn, player_id, action_key, mult if success else mult * 0.75)
    achievement_result = {}
    loop_key = ACHIEVEMENT_ACTION_MAP.get(action_key)
    if loop_key:
        achievement_result = grant_achievement_progress(conn, player_id, loop_key, max(1, mult if success else mult * 0.35))
    return {"action": action_key, "skills": skill_results, "career": career_result, "achievement": achievement_result}


def skill_effects_for_display(skill_key: str, level: int) -> List[str]:
    level = max(0, int(level or 0))
    if skill_key == "smuggling":
        return [f"-{min(30, level * 0.45):.1f}% caught chance pressure", f"-{min(25, level * 0.35):.1f}% heat gain", f"+{min(18, level * 0.30):.1f}% illicit profit pressure"]
    if skill_key == "jailbreaking":
        return [f"+{min(70, level * 0.70):.1f}% breakout scaling before security/heat penalties", "Breakout final chance hard-capped at 80%", f"-{min(30, level * 0.25):.1f}% breakout cooldown pressure"]
    if skill_key == "trading":
        return [f"+{min(14, level * 0.18):.1f}% legal trade edge cap pressure", "No legal risk added", "Improves market readouts"]
    if skill_key == "crafting":
        return [f"+{min(24, level * 0.22):.1f}% crafting success pressure", "Less material waste on failures", "Supports higher-tier recipe unlocks"]
    if skill_key == "engineering":
        return [f"+{min(28, level * 0.24):.1f}% upgrade/install pressure", f"-{min(22, level * 0.20):.1f}% repair cost pressure", "Improves module work"]
    if skill_key == "piloting":
        return [f"-{min(22, level * 0.18):.1f}% travel fuel pressure", "Slight route evasion bonus", "Improves hauling/exploration routes"]
    return [f"Level {level} passive scaling is active", "Related actions grant this skill XP", "Career bonuses can stack with this skill inside caps"]


def build_skills_state(conn: sqlite3.Connection, player_id: int) -> List[Dict[str, Any]]:
    out: List[Dict[str, Any]] = []
    for key, d in PHASE16_SKILL_CATALOG.items():
        node = row(conn, "SELECT * FROM skill_nodes WHERE key=?", (key,)) or {}
        ps = row(conn, "SELECT * FROM player_skills WHERE player_id=? AND skill_key=?", (player_id, key)) or {}
        progress = skill_progress_payload(int(ps.get("xp") or 0), int(node.get("max_level") or SKILL_XP_BALANCE["max_level"]))
        out.append({
            "key": key,
            "tree": key,
            "name": d["name"],
            "icon": d.get("icon"),
            "category": d.get("category"),
            "summary": d.get("summary"),
            "description": d.get("description"),
            "trained_by": d.get("trained_by", []),
            "affects": d.get("affects", []),
            "passive_bonuses": d.get("bonuses", []),
            "current_effects": skill_effects_for_display(key, progress["level"]),
            "level": progress["level"],
            "xp": progress["xp"],
            "next_xp": progress["next_xp"],
            "xp_needed": progress["xp_needed"],
            "progress_pct": progress["progress_pct"],
            "max_level": int(node.get("max_level") or SKILL_XP_BALANCE["max_level"]),
        })
    return out


def career_rank_label(job_code: str, rank: int) -> str:
    base = {
        1:"Rookie", 2:"Licensed Operator", 3:"Specialist", 4:"Veteran", 5:"Elite",
        6:"Master", 7:"Sector Renowned", 8:"Guild Authority", 9:"Legendary", 10:"Mythic"
    }
    special = {
        "miner": {1:"Prospector", 5:"Deep-Core Veteran", 10:"Master Extractor"},
        "trader": {1:"Broker", 5:"Market Baron", 10:"Merchant Prince"},
        "smuggler": {1:"Runner", 5:"Ghost Lane Veteran", 10:"Black-Lane Legend"},
        "bounty_hunter": {1:"Tracker", 5:"Warrant Specialist", 10:"Sector Reaper"},
        "engineer": {1:"Mechanic", 5:"Systems Architect", 10:"Master Engineer"},
    }
    return (special.get(job_code, {}).get(int(rank)) or base.get(int(rank), f"Rank {rank}"))


def career_bonus_display(job_code: str, rank: int) -> List[str]:
    rank = max(1, int(rank or 1))
    details = PHASE16_CAREER_DETAILS.get(job_code, {})
    out = []
    for b in details.get("bonuses", [])[:5]:
        out.append(f"{b} • Rank {rank} scaling")
    if job_code == "smuggler":
        out.append("Illicit risk reduction stacks with Smuggling skill, but risk never reaches zero.")
    if job_code == "engineer":
        out.append("Craft/upgrade bonuses stack with Engineering and Crafting skills inside success caps.")
    if job_code == "trader":
        out.append("Legal market bonuses are capped to prevent infinite buy/sell loops.")
    return out or ["Matching career actions gain stronger rewards and career XP."]


def career_action_keys(job_code: str) -> List[str]:
    return [k for k, v in ACTION_PROGRESSION.items() if job_code in (v.get("careers") or {})]


def build_chat_messages(conn: sqlite3.Connection, current_user_id: int) -> List[Dict[str, Any]]:
    raw = rows(conn, "SELECT * FROM chat_messages ORDER BY id DESC LIMIT 80")
    raw.reverse()
    messages: List[Dict[str, Any]] = []
    user_cache: Dict[int, Dict[str, Any]] = {}
    for msg in raw:
        sender_name = msg.get("sender_name") or "Unknown"
        avatar_id = clean_avatar_id(msg.get("avatar_id"))
        if msg.get("user_id"):
            uid = int(msg["user_id"])
            if uid not in user_cache:
                u = row(conn, "SELECT u.id,u.username,p.id as player_id,p.callsign,up.display_name,up.avatar_id,up.selected_badge_code FROM users u LEFT JOIN players p ON p.user_id=u.id LEFT JOIN user_profiles up ON up.user_id=u.id WHERE u.id=?", (uid,)) or {}
                user_cache[uid] = u
            u = user_cache[uid]
            sender_name = u.get("display_name") or u.get("callsign") or u.get("username") or sender_name
            avatar_id = clean_avatar_id(u.get("avatar_id") or avatar_id)
        avatar = avatar_payload(avatar_id)
        selected_badge_code = ""
        player_id = msg.get("player_id")
        if msg.get("user_id"):
            selected_badge_code = (user_cache.get(int(msg["user_id"])) or {}).get("selected_badge_code") or ""
        messages.append({
            "id": msg["id"],
            "userId": msg.get("user_id"),
            "playerId": player_id,
            "senderType": msg.get("sender_type") or "player",
            "senderName": sender_name,
            "avatarId": avatar_id,
            "avatarUrl": avatar["url"],
            "selectedBadgeCode": selected_badge_code,
            "selectedBadgeUrl": selected_badge_code,
            "message": msg.get("message") or "",
            "createdAt": msg.get("created_at"),
            "isCurrentUser": bool(msg.get("user_id") and int(msg["user_id"]) == int(current_user_id)),
        })
    return messages

def simulation_background_loop() -> None:
    # Dedicated server-side loop. The DB timestamp still controls the real tick interval, so duplicate calls stay harmless.
    time.sleep(5)
    while not SIMULATION_STOP_EVENT.is_set():
        conn = None
        try:
            conn = connect()
            conn.execute("BEGIN IMMEDIATE")
            simulate_npc_activity(conn, force=False)
            conn.commit()
        except Exception:
            if conn:
                conn.rollback()
        finally:
            if conn:
                conn.close()
        SIMULATION_STOP_EVENT.wait(SIMULATION_BALANCE["background_loop_seconds"])


def start_simulation_thread() -> None:
    global SIMULATION_THREAD_STARTED
    if SIMULATION_THREAD_STARTED:
        return
    SIMULATION_THREAD_STARTED = True
    threading.Thread(target=simulation_background_loop, name="nova-world-simulation", daemon=True).start()


@app.on_event("startup")
def on_startup() -> None:
    migrate()
    start_simulation_thread()


@app.on_event("shutdown")
def on_shutdown() -> None:
    SIMULATION_STOP_EVENT.set()


def current_context(authorization: Optional[str] = Header(default=None)) -> Tuple[Dict[str,Any], Dict[str,Any]]:
    if not authorization or not authorization.lower().startswith("bearer "):
        raise HTTPException(401, "Missing bearer token")
    token = authorization.split(" ", 1)[1].strip()
    conn = connect()
    sess = row(conn, "SELECT * FROM sessions WHERE token=?", (token,))
    if not sess or parse_dt(sess["expires_at"]) < utcnow():
        conn.close()
        raise HTTPException(401, "Invalid or expired session")
    user = row(conn, "SELECT * FROM users WHERE id=?", (sess["user_id"],))
    player = row(conn, "SELECT * FROM players WHERE user_id=?", (user["id"],))
    conn.close()
    if not user or not player:
        raise HTTPException(401, "Missing player")
    return user, player


def ensure_action_allowed(conn: sqlite3.Connection, user: Dict[str,Any], player: Dict[str,Any], action: ActionRequest) -> None:
    nonce = action.nonce or str(uuid.uuid4())
    try:
        conn.execute("INSERT INTO action_nonces (player_id, nonce, created_at) VALUES (?,?,?)", (player["id"], nonce, iso()))
    except sqlite3.IntegrityError:
        raise HTTPException(409, "Duplicate action nonce rejected")
    legal_status = resolve_player_legal_state(conn, player["id"])
    jail_allowed = {"attempt_bribe", "attempt_breakout", "admin_godmode", "update_profile", "send_chat_message"}
    if legal_status.get("jailed") and action.type not in jail_allowed and not user["god_mode"]:
        raise HTTPException(409, f"You are jailed until {legal_status.get('jailedUntil')}: {legal_status.get('jailReason') or 'detained'}")
    h_until = parse_dt(player.get("hospital_until"))
    if h_until and h_until > utcnow() and action.type not in {"hospital_expedite","get_state","admin_godmode","launch_starter_ship","update_profile","send_chat_message"} and not user["god_mode"]:
        raise HTTPException(409, f"You are recovering until {h_until.isoformat()}")
    t_until = parse_dt(player.get("travel_until"))
    if t_until and t_until > utcnow() and action.type not in {"complete_travel","admin_godmode","update_profile","send_chat_message"} and not user["god_mode"]:
        raise HTTPException(409, f"You are in transit until {t_until.isoformat()}")
    cargo_status = cargo_operation_status(conn, player["id"])
    cargo_allowed = {"admin_godmode", "update_profile", "send_chat_message"}
    if cargo_status.get("active") and action.type not in cargo_allowed and not user["god_mode"]:
        raise HTTPException(409, f"Cargo {cargo_status.get('operationLabel','handling')} in progress until {cargo_status.get('completeAt')}. You cannot leave, change ships, fight, or start more cargo work.")
    station_run = active_pirate_station_run(conn, player["id"])
    station_allowed = {"admin_godmode", "update_profile", "send_chat_message", "pirate_station_move", "pirate_station_retreat", "pirate_station_start_battle", "pirate_station_resolve_battle", "pirate_station_close_battle"}
    if station_run and action.type not in station_allowed and not user["god_mode"]:
        raise HTTPException(409, "You are inside a pirate station assault. Finish, retreat, or close the battle screen before using normal planet/system actions.")


def add_event(conn: sqlite3.Connection, player_id: int, category: str, message: str, meta: Optional[dict] = None) -> None:
    conn.execute("INSERT INTO events (player_id,category,message,meta_json,created_at) VALUES (?,?,?,?,?)", (player_id, category, message, encode_json(meta or {}), iso()))


def ship_size_class(ship: Dict[str, Any]) -> str:
    code = str(ship.get("size_class") or "").upper()
    if code in {"S", "M", "L", "C"}:
        return code
    hull = int(ship.get("max_hull") or ship.get("hull") or 1000)
    if hull >= 80000:
        return "C"
    if hull >= 20000:
        return "L"
    if hull >= 6500:
        return "M"
    return "S"


def ship_mass_value(ship: Dict[str, Any]) -> float:
    mass = float(ship.get("mass") or 0)
    if mass > 0:
        return mass
    size = ship_size_class(ship)
    cfg = SHIP_SIZE_BALANCE.get(size, SHIP_SIZE_BALANCE["M"])
    return float(cfg.get("mass") or 340)


def ship_jump_drive_bonus(conn: sqlite3.Connection, ship_id: int) -> float:
    bonus = 0.0
    for m in rows(conn, "SELECT sm.durability, mt.stats_json, mt.slot_type, mt.code FROM ship_modules sm JOIN module_templates mt ON mt.id=sm.module_template_id WHERE sm.ship_id=? AND sm.equipped=1", (ship_id,)):
        stats = decode_json(m.get("stats_json"), {}) or {}
        if str(m.get("slot_type") or "").lower() in {"core", "engine"} or "drive" in str(m.get("code") or "").lower() or "jump" in stats:
            durability = max(0.15, float(m.get("durability") or 100) / 100.0)
            bonus += (float(stats.get("drive_speed") or 0) + float(stats.get("jump") or 0) / 100.0 + float(stats.get("fuel") or 0) / 600.0) * durability
    return max(0.0, bonus)


def effective_ship_map_speed(conn: sqlite3.Connection, ship: Dict[str, Any]) -> float:
    if not ship:
        return 1.0
    base = max(0.1, float(ship.get("drive_speed") or 1.0))
    size = ship_size_class(ship)
    cfg = SHIP_SIZE_BALANCE.get(size, SHIP_SIZE_BALANCE["M"])
    size_mult = float(cfg.get("speed_mult") or 1.0)
    mass = max(1.0, ship_mass_value(ship))
    baseline = float(cfg.get("mass") or mass or 340)
    mass_penalty = (baseline / mass) ** float(SHIP_SIZE_BALANCE.get("mass_speed_exponent", 0.18))
    jump_bonus = ship_jump_drive_bonus(conn, int(ship.get("id") or 0)) * float(SHIP_SIZE_BALANCE.get("jump_drive_speed_weight", 0.55))
    speed = (base + jump_bonus) * size_mult * mass_penalty
    return round(max(float(SHIP_SIZE_BALANCE.get("minimum_map_speed", 0.28)), min(float(SHIP_SIZE_BALANCE.get("maximum_map_speed", 4.25)), float(speed))), 4)


def ship_speed_profile(conn: sqlite3.Connection, ship: Dict[str, Any]) -> Dict[str, Any]:
    size = ship_size_class(ship or {})
    return {
        "size_class": size,
        "size_label": SHIP_SIZE_BALANCE.get(size, {}).get("label", size),
        "mass": round(ship_mass_value(ship or {}), 2),
        "base_drive_speed": float((ship or {}).get("drive_speed") or 0),
        "jump_drive_bonus": round(ship_jump_drive_bonus(conn, int((ship or {}).get("id") or 0)), 3),
        "effective_map_speed": effective_ship_map_speed(conn, ship or {}),
    }


def get_ship_power(conn: sqlite3.Connection, ship_id: int) -> int:
    ship = row(conn, "SELECT * FROM ships WHERE id=?", (ship_id,))
    if not ship or ship["destroyed"]:
        return 0
    ensure_ship_parts(conn)
    parts = rows(conn, "SELECT * FROM ship_parts WHERE ship_id=?", (ship_id,))
    part_ratio = sum((p["hp"] / max(1, p["max_hp"])) for p in parts) / max(1, len(parts))
    engine = next((p for p in parts if p["part_key"] == "engine"), None)
    weapons = next((p for p in parts if p["part_key"] == "weapons"), None)
    engine_ratio = (engine["hp"] / max(1, engine["max_hp"])) if engine else 1
    weapon_ratio = (weapons["hp"] / max(1, weapons["max_hp"])) if weapons else 1
    power = ship["hull"]//20 + ship["shield"]//12 + ship["armor"]*35 + int(ship["drive_speed"]*100*engine_ratio)
    for m in rows(conn, "SELECT sm.durability, mt.stats_json FROM ship_modules sm JOIN module_templates mt ON mt.id=sm.module_template_id WHERE sm.ship_id=? AND sm.equipped=1", (ship_id,)):
        stats = decode_json(m["stats_json"], {})
        durability_ratio = max(0.10, (m["durability"] or 100) / 100)
        power += int((stats.get("damage",0) * weapon_ratio + stats.get("shield",0)//2 + stats.get("armor",0)*40 + stats.get("drones",0)*100) * durability_ratio)
    return int(power * max(0.25, part_ratio))


def get_player(conn: sqlite3.Connection, player_id: int) -> Dict[str,Any]:
    p = row(conn, "SELECT * FROM players WHERE id=?", (player_id,))
    if not p:
        raise HTTPException(404, "Player not found")
    return p


def spend(conn, player_id: int, credits: int=0, fuel: int=0, scrap: int=0, cargo_space: int=0, energy: int=0, god: bool=False) -> None:
    p = get_player(conn, player_id)
    if god:
        return
    if p["credits"] < credits:
        raise HTTPException(400, "Not enough credits")
    if p["fuel"] < fuel:
        raise HTTPException(400, "Not enough fuel")
    if p["scrap"] < scrap:
        raise HTTPException(400, "Not enough scrap")
    if p.get("energy", 0) < energy:
        raise HTTPException(400, "Not enough energy")
    if cargo_space:
        usage = build_cargo_usage(conn, player_id)
        if usage["total"] + cargo_space > usage["max"]:
            raise HTTPException(400, "Not enough cargo capacity")
    conn.execute("UPDATE players SET credits=credits-?, fuel=fuel-?, scrap=scrap-?, energy=energy-?, energy_updated_at=COALESCE(energy_updated_at, ?) WHERE id=?", (credits,fuel,scrap,energy,iso(),player_id))


def add_xp(conn, player_id: int, amount: int) -> None:
    p = get_player(conn, player_id)
    new_xp = p["xp"] + amount
    level = p["level"]
    skill_points = p["skill_points"]
    # Level starts fast, moves to medium MMO grind, then becomes Korean-MMO slow late game.
    while new_xp >= level_xp_required(level):
        new_xp -= level_xp_required(level)
        level += 1
        skill_points += 3 + level//5
    conn.execute("UPDATE players SET xp=?, level=?, skill_points=? WHERE id=?", (new_xp, level, skill_points, player_id))


def damage_ship_parts(conn: sqlite3.Connection, ship_id: int, damage: int, focus: Optional[str] = None) -> int:
    ensure_ship_parts(conn)
    parts = rows(conn, "SELECT * FROM ship_parts WHERE ship_id=?", (ship_id,))
    if not parts or damage <= 0:
        return 0
    remaining = int(damage)
    if focus:
        ordered = sorted(parts, key=lambda p: 0 if p["part_key"] == focus else random.random())
    else:
        ordered = sorted(parts, key=lambda p: random.random())
    applied = 0
    for part in ordered:
        if remaining <= 0:
            break
        chunk = min(part["hp"], max(1, int(remaining * random.uniform(0.25, 0.55))))
        conn.execute("UPDATE ship_parts SET hp=max(0,hp-?) WHERE id=?", (chunk, part["id"]))
        applied += chunk
        remaining -= chunk
    return applied


def degrade_modules(conn: sqlite3.Connection, ship_id: int, amount: int) -> None:
    for mod in rows(conn, "SELECT * FROM ship_modules WHERE ship_id=? AND equipped=1", (ship_id,)):
        loss = random.randint(max(1, amount//3), max(2, amount))
        conn.execute("UPDATE ship_modules SET durability=max(0,durability-?) WHERE id=?", (loss, mod["id"]))


def damage_or_destroy_ship(conn, player_id: int, damage: int, reason: str, god: bool=False, hospital_minutes: int=0) -> str:
    if god:
        return "God mode avoided all damage."
    p = get_player(conn, player_id)
    ship = row(conn, "SELECT * FROM ships WHERE id=?", (p["active_ship_id"],))
    if not ship:
        return "No active ship."
    part_damage = damage_ship_parts(conn, ship["id"], max(1, damage//2))
    degrade_modules(conn, ship["id"], max(1, damage//550))
    shield_absorb = min(ship["shield"], max(0, damage//3))
    hull_damage = max(0, damage - shield_absorb)
    new_shield = max(0, ship["shield"] - shield_absorb)
    new_hull = max(0, ship["hull"] - hull_damage)
    if new_hull > 0:
        conn.execute("UPDATE ships SET hull=?, shield=? WHERE id=?", (new_hull, new_shield, ship["id"]))
        if hospital_minutes:
            conn.execute("UPDATE players SET hospital_until=? WHERE id=?", (iso(utcnow()+timedelta(minutes=max(10,hospital_minutes))), player_id))
        return f"Ship took {hull_damage:,} hull damage, {shield_absorb:,} shield damage, and {part_damage:,} part damage."
    conn.execute("UPDATE ships SET hull=0, shield=0, destroyed=1 WHERE id=?", (ship["id"],))
    lost_hold = int(scalar(conn, "SELECT COALESCE(SUM(qty),0) FROM cargo_hold WHERE player_id=?", (player_id,)) or 0)
    conn.execute("DELETE FROM cargo_hold WHERE player_id=?", (player_id,))
    conn.execute("UPDATE inventory SET qty=max(0, CAST(qty * 0.75 AS INTEGER)) WHERE player_id=? AND COALESCE(cargo_exempt,0)=0 AND category NOT IN ('quest_items')", (player_id,))
    conn.execute("UPDATE pending_cargo_operations SET status='lost', completed_at=? WHERE player_id=? AND status='active'", (iso(), player_id))
    starter = row(conn, "SELECT * FROM ships WHERE player_id=? AND starter=1 ORDER BY id LIMIT 1", (player_id,))
    recovery_minutes = max(30, hospital_minutes)
    if starter:
        conn.execute("UPDATE ships SET destroyed=0, hull=max_hull, shield=max_shield WHERE id=?", (starter["id"],))
        conn.execute("UPDATE players SET active_ship_id=?, cargo=0, hospital_until=? WHERE id=?", (starter["id"], iso(utcnow()+timedelta(minutes=recovery_minutes)), player_id))
    if ship["insured"]:
        payout = 0
        if ship["insurance_tier"] == "basic": payout = int(ship["max_hull"] * 12)
        elif ship["insurance_tier"] == "standard": payout = int(ship["max_hull"] * 18)
        elif ship["insurance_tier"] == "premium": payout = int(ship["max_hull"] * 25)
        elif ship["insurance_tier"] == "starter": payout = 0
        conn.execute("UPDATE players SET credits=credits+? WHERE id=?", (payout, player_id))
        return f"Ship destroyed by {reason}. Cargo hold was lost ({lost_hold} market units plus some inventory cargo). Insurance paid {payout:,} credits. Starter ship deployed. Recovery time: {recovery_minutes} minutes."
    return f"Ship destroyed by {reason}. Cargo hold was lost ({lost_hold} market units plus some inventory cargo). No insurance payout. Starter ship deployed. Recovery time: {recovery_minutes} minutes."

def resolve_npc_roll(conn: sqlite3.Connection, role: str, planet_id: int, tier: str="standard") -> int:
    p = row(conn, "SELECT * FROM planets WHERE id=?", (planet_id,))
    if not p:
        return 35
    role_aliases = {
        "customs": ["customs", "marshal", "dockmaster"],
        "patrol": ["patrol", "security", "bounty"],
        "trader": ["trader", "market_maker", "hauler"],
        "pirate": ["pirate", "mercenary", "smuggler"],
        "defender": ["defender", "patrol", "security", "mercenary"],
        "medic": ["medic"],
    }.get(role, [role])
    placeholders = ",".join("?" for _ in role_aliases)
    agents = rows(conn, f"SELECT * FROM npc_agents WHERE planet_id=? AND role IN ({placeholders}) ORDER BY power DESC LIMIT 8", tuple([planet_id] + role_aliases))
    if agents:
        avg = sum(int(a.get("power") or 30) + int(a.get("job_rank") or 1) * 3 + int(a.get("level") or 1) for a in agents) / len(agents)
    else:
        avg = {
            "customs": p["customs_rating"], "patrol": p["security_level"], "trader": p["market_activity"],
            "pirate": p["pirate_activity"], "defender": p["defense_strength"], "medic": p["medical_quality"],
        }.get(role, 55)
    # NPC rolls are explicitly weaker than comparable invested player rolls.
    mult = {"weak":0.42,"standard":0.58,"elite":0.72,"boss":1.05,"fleet":1.25}.get(tier,0.58)
    planet_mod = 1.0
    if role in {"pirate"}:
        planet_mod += (int(p.get("hostility") or 50) - 50) / 180.0
    if role in {"customs", "patrol", "defender"}:
        planet_mod += (int(p.get("lawfulness") or 50) - 50) / 220.0
    if role in {"trader"}:
        planet_mod += (int(p.get("npc_economy_bias") or 50) - 50) / 220.0
    return int(avg * mult * planet_mod * random.uniform(0.85, 1.15))


def get_job_metrics(conn: sqlite3.Connection, player_id: int, job_code: str) -> Dict[str, int]:
    return {r["metric_key"]: int(r["metric_value"]) for r in rows(conn, "SELECT metric_key, metric_value FROM player_job_metrics WHERE player_id=? AND job_code=?", (player_id, job_code))}


def increment_job_metrics(conn: sqlite3.Connection, player_id: int, job_code: str, changes: Dict[str, int]) -> None:
    for key, value in changes.items():
        conn.execute(
            "INSERT INTO player_job_metrics (player_id,job_code,metric_key,metric_value) VALUES (?,?,?,?) "
            "ON CONFLICT(player_id,job_code,metric_key) DO UPDATE SET metric_value=metric_value+excluded.metric_value",
            (player_id, job_code, key, int(value)),
        )


def build_jobs_state(conn: sqlite3.Connection, player_id: int) -> List[Dict[str, Any]]:
    out = []
    base_jobs = rows(conn, "SELECT j.*, COALESCE(pj.xp,0) xp, COALESCE(pj.rank,1) rank, COALESCE(pj.active,0) active FROM jobs j LEFT JOIN player_jobs pj ON pj.job_code=j.code AND pj.player_id=? ORDER BY j.name", (player_id,))
    skill_lookup = {s["key"]: s for s in build_skills_state(conn, player_id)}
    for j in base_jobs:
        profile = JOB_PROFILE.get(j["code"], {})
        details = PHASE16_CAREER_DETAILS.get(j["code"], {})
        metrics = get_job_metrics(conn, player_id, j["code"])
        rank = job_rank_from_metrics(j["code"], int(j["xp"]), metrics)
        if rank != int(j.get("rank") or 1):
            conn.execute("UPDATE player_jobs SET rank=? WHERE player_id=? AND job_code=?", (rank, player_id, j["code"]))
            j["rank"] = rank
        next_req = job_next_requirement(j["code"], int(j["xp"]), metrics)
        preferred_skills = details.get("preferred_skills", [])
        related_skills = [skill_lookup[k] for k in preferred_skills if k in skill_lookup]
        j["icon"] = details.get("icon", "briefcase")
        j["style"] = details.get("style", j.get("side", "neutral"))
        j["risk_profile"] = details.get("risk", "Standard")
        j["recommended_loop"] = details.get("loop", "Run matching career jobs for stronger rewards and rank progress.")
        j["preferred_skills"] = preferred_skills
        j["preferred_ships"] = details.get("preferred_ships", [])
        j["related_skills"] = related_skills
        j["career_actions"] = career_action_keys(j["code"])
        j["rank_title"] = career_rank_label(j["code"], rank)
        j["current_bonuses"] = career_bonus_display(j["code"], rank)
        j["next_rank_bonuses"] = career_bonus_display(j["code"], min(10, rank + 1))
        j["metrics_json"] = encode_json(metrics)
        j["next_req_json"] = encode_json(next_req)
        j["rank_buffs_json"] = encode_json(profile.get("buffs", []))
        j["tasks_json"] = encode_json(profile.get("tasks", []))
        j["next_requirement"] = next_req
        j["progress_pct"] = round(100 * (1 - min(1, next_req.get("xp_needed", 0) / max(1, int(j.get("xp") or 0) + next_req.get("xp_needed", 0)))) if rank < 10 else 100, 1)
        out.append(j)
    return out


BASIC_PVE_TYPES = {"patrol", "exploration", "salvage", "mining", "trade", "medical", "bounty"}


def is_basic_pve_operation(op: Dict[str, Any]) -> bool:
    return (
        int(op.get("solo") or 0) == 1
        and int(op.get("group_recommended") or 0) == 0
        and int(op.get("difficulty") or 1) <= 3
        and str(op.get("op_type") or "") in BASIC_PVE_TYPES
    )


def player_skill_totals(conn: sqlite3.Connection, player_id: int) -> Dict[str, int]:
    return {
        r["tree"]: int(r["total_level"] or 0)
        for r in rows(
            conn,
            """
            SELECT sn.tree, COALESCE(SUM(ps.level),0) as total_level
            FROM skill_nodes sn
            LEFT JOIN player_skills ps ON ps.skill_key=sn.key AND ps.player_id=?
            GROUP BY sn.tree
            """,
            (player_id,),
        )
    }


def active_job_runtime(conn: sqlite3.Connection, player_id: int) -> Optional[Dict[str, Any]]:
    active = row(conn, "SELECT pj.*, j.name, j.description FROM player_jobs pj JOIN jobs j ON j.code=pj.job_code WHERE pj.player_id=? AND pj.active=1", (player_id,))
    if not active:
        return None
    metrics = get_job_metrics(conn, player_id, active["job_code"])
    rank = job_rank_from_metrics(active["job_code"], int(active.get("xp") or 0), metrics)
    active["computed_rank"] = rank
    active["metrics"] = metrics
    active["next_requirement"] = job_next_requirement(active["job_code"], int(active.get("xp") or 0), metrics)
    active["next_unlock"] = CAREER_UNLOCK_LABELS.get(min(10, rank + 1), "max rank")
    return active


def pve_affinity(op_type: str) -> Dict[str, Any]:
    return OPERATION_AFFINITY.get(str(op_type or "").lower(), {"jobs": [], "skills": [], "risk": "general"})


def pve_progression_key(op_type: str) -> str:
    op_type = str(op_type or "").lower()
    if op_type == "mining":
        return "mining"
    if op_type == "salvage":
        return "salvage"
    if op_type in {"trade", "cargo", "escort"}:
        return "hauling" if op_type in {"cargo", "escort"} else "legal_trade"
    if op_type in {"bounty", "patrol", "law", "group", "boss"}:
        return "bounty" if op_type == "bounty" else "combat"
    if op_type in {"exploration"}:
        return "exploration"
    if op_type == "medical":
        return "repair"
    return "combat"


def planet_operation_modifier(planet: Optional[Dict[str, Any]], op_type: str) -> Tuple[float, List[str]]:
    if not planet:
        return 0.0, []
    security = int(planet.get("security_level") or 50)
    stability = int(planet.get("stability_level") or 60)
    pirates = int(planet.get("pirate_activity") or 50)
    market = int(planet.get("market_activity") or 50)
    medical = int(planet.get("medical_quality") or 50)
    law = int(planet.get("lawfulness") or 50)
    conflict = int(planet.get("conflict_level") or 20)
    market_modifier = int(planet.get("market_modifier") or 0)
    op_type = str(op_type or "").lower()
    raw = 0.0
    notes: List[str] = []
    if op_type in {"bounty", "patrol", "law", "escort", "group", "boss"}:
        raw += (security - 50) * 0.0012
        raw += (stability - 50) * 0.0008
        raw -= max(0, pirates - 50) * 0.0018
        raw -= max(0, conflict - 45) * 0.0012
        notes.append("security/stability vs pirate and conflict pressure")
    elif op_type in {"trade"}:
        raw += (market - 50) * 0.0014
        raw += (stability - 50) * 0.0012
        raw += (law - 50) * 0.0005
        raw += market_modifier * 0.0010
        raw -= max(0, conflict - 55) * 0.0010
        notes.append("market activity, control modifiers, and stability")
    elif op_type in {"mining", "salvage", "exploration"}:
        raw += (stability - 50) * 0.0010
        raw -= max(0, pirates - 55) * 0.0012
        raw -= max(0, conflict - 60) * 0.0008
        raw += (market - 50) * 0.0004
        notes.append("frontier stability, conflict, and local pirate risk")
    elif op_type == "medical":
        raw += (medical - 50) * 0.0016
        raw += (stability - 50) * 0.0008
        notes.append("medical infrastructure and stability")
    return max(-PVE_BALANCE["planet_condition_cap"], min(PVE_BALANCE["planet_condition_cap"], raw)), notes


def operation_context(
    conn: Optional[sqlite3.Connection],
    player_id: Optional[int],
    op: Dict[str, Any],
    ship_power: int,
    planet: Optional[Dict[str, Any]],
    god: bool = False,
) -> Dict[str, Any]:
    difficulty = max(1, int(op.get("difficulty") or 1))
    op_type = str(op.get("op_type") or "").lower()
    affinity = pve_affinity(op_type)
    basic = is_basic_pve_operation(op)
    active = active_job_runtime(conn, player_id) if conn and player_id else None
    skills = player_skill_totals(conn, player_id) if conn and player_id else {}

    base = (PVE_BALANCE["basic_base_success"] if basic else PVE_BALANCE["advanced_base_success"]) - (difficulty * (0.030 if basic else 0.045))
    ship_bonus = min(PVE_BALANCE["ship_bonus_cap"], max(0.0, ship_power / float(65000 + difficulty * 18000)))
    skill_levels = sum(skills.get(tree, 0) for tree in affinity.get("skills", []))
    skill_bonus = skill_levels * PVE_BALANCE["skill_bonus_per_level"]
    active_job_code = active["job_code"] if active else None
    job_match = bool(active_job_code and active_job_code in affinity.get("jobs", []))
    job_rank = int(active.get("computed_rank") or active.get("rank") or 1) if active else 0
    job_bonus = (job_rank * PVE_BALANCE["career_rank_bonus"]) if job_match else PVE_BALANCE["off_career_floor"]
    planet_bonus, planet_notes = planet_operation_modifier(planet, op_type)
    success_odds = max(0.18 if not basic else 0.66, min(0.96 if not basic else 0.97, base + ship_bonus + skill_bonus + job_bonus + planet_bonus))

    reward_mult = 1.0 + (0.025 * job_rank if job_match else 0.0) + min(0.18, skill_levels * 0.004)
    xp_mult = 1.0 + (0.020 * job_rank if job_match else 0.0) + min(0.15, skill_levels * 0.003)
    recommended = success_odds >= PVE_BALANCE["recommended_min_success"] or job_match
    reason = []
    if job_match:
        reason.append(f"matches active {active.get('name', 'career')}")
    if skill_levels:
        reason.append(f"{skill_levels} relevant skill levels")
    reason += planet_notes
    if basic:
        reason.append("starter-safe basic work")

    return {
        "affinity_jobs": affinity.get("jobs", []),
        "affinity_skills": affinity.get("skills", []),
        "risk_profile": affinity.get("risk", "general"),
        "skill_levels": skill_levels,
        "skill_bonus": round(skill_bonus, 3),
        "job_match": job_match,
        "job_bonus": round(job_bonus, 3),
        "planet_bonus": round(planet_bonus, 3),
        "ship_bonus": round(ship_bonus, 3),
        "reward_mult": round(reward_mult, 3),
        "xp_mult": round(xp_mult, 3),
        "success_odds": round(1.0 if god else success_odds, 2),
        "recommended": bool(god or recommended),
        "recommendation_reason": "; ".join(reason[:3]) or "neutral fit",
    }


def pve_operation_runtime_stats(
    op: Dict[str, Any],
    ship_power: int,
    god: bool=False,
    conn: Optional[sqlite3.Connection]=None,
    player_id: Optional[int]=None,
    planet: Optional[Dict[str, Any]]=None,
) -> Dict[str, Any]:
    difficulty = max(1, int(op.get("difficulty") or 1))
    ctx = operation_context(conn, player_id, op, ship_power, planet, god)

    if is_basic_pve_operation(op):
        reward_min = max(800, min(int(op.get("reward_min") or 0), difficulty * 2500))
        reward_max = max(reward_min + 800, min(int(op.get("reward_max") or reward_min), difficulty * 9000))
        xp_success = int(difficulty * 260 * ctx["xp_mult"])
        xp_partial = int(difficulty * 110 * ctx["xp_mult"])
        return {
            "operation_tier": "basic",
            "energy_cost": max(5, difficulty * 4),
            "fuel_cost": max(1, difficulty // 2),
            "preview_reward_min": int(reward_min * ctx["reward_mult"]),
            "preview_reward_max": int(reward_max * ctx["reward_mult"]),
            "xp_reward": xp_success,
            "xp_partial": xp_partial,
            "xp_critical": int(xp_success * 1.35),
            **ctx,
        }

    xp_success = int(difficulty * 600 * ctx["xp_mult"])
    return {
        "operation_tier": "advanced",
        "energy_cost": max(4, difficulty * 3),
        "fuel_cost": max(1, difficulty),
        "preview_reward_min": int((op.get("reward_min") or 0) * ctx["reward_mult"]),
        "preview_reward_max": int((op.get("reward_max") or 0) * ctx["reward_mult"]),
        "xp_reward": xp_success,
        "xp_partial": int(difficulty * 260 * ctx["xp_mult"]),
        "xp_critical": int(difficulty * 850 * ctx["xp_mult"]),
        **ctx,
    }


def career_task_runtime_stats(
    conn: sqlite3.Connection,
    player_id: int,
    active: Dict[str, Any],
    task: Dict[str, Any],
    planet: Optional[Dict[str, Any]],
    ship_power: int,
    god: bool=False,
) -> Dict[str, Any]:
    job_code = active["job_code"]
    rank = int(active.get("computed_rank") or active.get("rank") or 1)
    metrics = active.get("metrics") or get_job_metrics(conn, player_id, job_code)
    skill_totals = player_skill_totals(conn, player_id)
    job_req = decode_json(row(conn, "SELECT req_json FROM jobs WHERE code=?", (job_code,))["req_json"], {}) if row(conn, "SELECT req_json FROM jobs WHERE code=?", (job_code,)) else {}
    skill_keys = list((job_req.get("skills") or {}).keys())
    skill_levels = sum(skill_totals.get(k, 0) for k in skill_keys)
    task_index = max(0, next((idx for idx, x in enumerate(JOB_PROFILE.get(job_code, {}).get("tasks", [])) if x["key"] == task["key"]), 0))
    difficulty = 2 + task_index * 2
    planet_bonus, notes = planet_operation_modifier(planet, "trade" if job_code in {"trader", "quartermaster", "dockmaster"} else "bounty" if job_code in {"bounty_hunter", "security_pilot", "marshal", "mercenary"} else "salvage" if job_code in {"miner", "salvager", "engineer"} else "exploration")
    base = PVE_BALANCE["career_base_success"] - task_index * 0.055
    rank_bonus = rank * PVE_BALANCE["career_rank_bonus"]
    skill_bonus = skill_levels * PVE_BALANCE["skill_bonus_per_level"]
    ship_bonus = min(PVE_BALANCE["ship_bonus_cap"], max(0.0, ship_power / float(85000 + difficulty * 22000)))
    odds = max(0.38, min(0.96, base + rank_bonus + skill_bonus + ship_bonus + planet_bonus))
    reward_preview = int(task["base"] * (1 + (rank-1) * 0.18) * (1 + min(0.20, skill_levels * 0.004)))
    xp_preview = int(task["xp"] * (1 + (rank-1) * 0.08) * (1 + min(0.12, skill_levels * 0.003)))
    next_req = job_next_requirement(job_code, int(active.get("xp") or 0), metrics)
    return {
        "career_rank": rank,
        "success_odds": round(1.0 if god else odds, 2),
        "skill_levels": skill_levels,
        "ship_bonus": round(ship_bonus, 3),
        "skill_bonus": round(skill_bonus, 3),
        "job_bonus": round(rank_bonus, 3),
        "planet_bonus": round(planet_bonus, 3),
        "preview_reward_min": int(reward_preview * 0.85),
        "preview_reward_max": int(reward_preview * 1.30),
        "xp_reward": xp_preview,
        "energy_cost": int(task["energy"]),
        "fuel_cost": max(0, task_index),
        "operation_tier": "career",
        "risk_profile": "career-specialist",
        "recommended": odds >= 0.62,
        "recommendation_reason": f"rank {rank}; {skill_levels} matching skill levels" + (("; " + "; ".join(notes[:1])) if notes else ""),
        "next_requirement": next_req,
        "next_unlock": CAREER_UNLOCK_LABELS.get(min(10, rank + 1), "max rank"),
    }


def active_career_tasks(conn: sqlite3.Connection, player_id: int) -> List[Dict[str, Any]]:
    active = active_job_runtime(conn, player_id)
    if not active:
        return []
    profile = JOB_PROFILE.get(active["job_code"], {})
    p = get_player(conn, player_id)
    planet = row(conn, "SELECT * FROM planets WHERE id=?", (p["location_planet_id"],))
    ship_power = get_ship_power(conn, p["active_ship_id"]) if p.get("active_ship_id") else 0
    tasks = []
    for task in profile.get("tasks", []):
        enriched = dict(task)
        enriched["job_code"] = active["job_code"]
        enriched.update(career_task_runtime_stats(conn, player_id, active, task, planet, ship_power, False))
        tasks.append(enriched)
    return tasks


def build_recommended_actions(conn: sqlite3.Connection, player_id: int, ship_power: int, planet: Dict[str, Any], god: bool=False) -> List[Dict[str, Any]]:
    recs: List[Dict[str, Any]] = []
    ops = rows(conn, "SELECT po.*, p.name as planet_name, p.galaxy_id as galaxy_id FROM pve_operations po LEFT JOIN planets p ON p.id=po.planet_id WHERE p.galaxy_id=? ORDER BY difficulty, name", (planet["galaxy_id"],))
    for op in ops:
        runtime = pve_operation_runtime_stats(op, ship_power, god, conn, player_id, planet)
        score = runtime["success_odds"] + (0.08 if runtime.get("operation_tier") == "basic" else 0) + (0.10 if runtime.get("job_match") else 0)
        if runtime.get("recommended") or len(recs) < 4:
            recs.append({"kind":"pve", "code":op["code"], "name":op["name"], "description":op["description"], "score":round(score,3), **runtime})
    for task in active_career_tasks(conn, player_id):
        score = task["success_odds"] + 0.16
        recs.append({"kind":"career", "code":task["key"], "name":task["name"], "description":task.get("desc", ""), "score":round(score,3), **task})
    return sorted(recs, key=lambda x: (x.get("recommended", False), x.get("score", 0)), reverse=True)[:8]


def apply_pve_world_rewards(conn: sqlite3.Connection, player_id: int, planet_id: int, op: Dict[str, Any], outcome: str, runtime: Dict[str, Any]) -> str:
    if outcome not in {"critical_success", "success", "partial"}:
        return ""
    op_type = str(op.get("op_type") or "").lower()
    difficulty = max(1, int(op.get("difficulty") or 1))
    mult = {"critical_success": 1.55, "success": 1.0, "partial": 0.42}.get(outcome, 0.0)
    notes: List[str] = []
    def reward_item(code: str, name: str, typ: str, qty: int, legal: int, value: int, mass: float, desc: str, source: str, category: Optional[str] = None, rarity: Optional[str] = None) -> bool:
        if can_fit_cargo(conn, player_id, float(mass) * int(qty)):
            add_inventory_item(conn, player_id, code, name, typ, qty, legal, value, mass, desc, source, category, rarity)
            return True
        notes.append(f"Cargo full; could not load {qty}x {name}")
        return False
    if op_type == "mining":
        qty = max(1, int((18 + difficulty * 18) * mult))
        reward_item("titanium", "Titanium Ore", "ore", qty, 1, 40, 1, "Common shipbuilding ore", "pve_mining", "raw_materials")
        if outcome == "critical_success":
            rare = max(1, difficulty)
            reward_item("iridium", "Iridium Shards", "ore", rare, 1, 900, 0.4, "Rare conductive mining yield", "pve_mining", "raw_materials", "rare")
            notes.append(f"Recovered {rare} Iridium Shards")
        notes.append(f"Recovered {qty} Titanium Ore")
    elif op_type == "salvage":
        circuits = max(1, int((4 + difficulty * 4) * mult))
        polymer = max(1, int((8 + difficulty * 6) * mult))
        reward_item("circuit", "Circuit Wafers", "component", circuits, 1, 120, 0.2, "Recovered electronics component", "pve_salvage", "crafting_materials")
        reward_item("polymer", "Industrial Polymer", "material", polymer, 1, 85, 0.3, "Useful fabrication polymer", "pve_salvage", "crafting_materials")
        notes.append(f"Recovered {circuits} Circuit Wafers and {polymer} Polymer")
    elif op_type == "exploration":
        scans = max(1, int((1 + difficulty) * mult))
        reward_item("survey_data", "Survey Data", "job", scans, 1, 450, 0.1, "Exploration data packet sellable to brokers", "pve_exploration", "quest_items")
        notes.append(f"Logged {scans} Survey Data")
    elif op_type == "medical":
        gels = max(1, int((2 + difficulty) * mult))
        reward_item("bio_gel", "Bio Gel", "medical", gels, 1, 650, 0.4, "Medical crafting material", "pve_medical", "crafting_materials")
        notes.append(f"Recovered {gels} Bio Gel")
    elif op_type in {"bounty", "patrol", "law", "escort"}:
        conn.execute("UPDATE planets SET security_level=max(1,min(100,security_level+?)), stability_level=max(1,min(100,stability_level+?)), pirate_activity=max(1,min(100,pirate_activity-?)) WHERE id=?", (1 if outcome != "partial" else 0, 1 if outcome == "critical_success" else 0, 1 if outcome != "partial" else 0, planet_id))
        notes.append("Local security pressure improved")
    elif op_type == "trade":
        commodity = choose_market_commodity(conn, legal=True, categories=["food", "industrial", "energy", "electronics"])
        if commodity:
            mutate_market(conn, planet_id, commodity["id"], random.randint(1, 4), -random.randint(0, 2), "player_pve_trade")
            notes.append("Local legal supply lanes improved")
    return " ".join(notes)


def resolve_pve_outcome(success_odds: float, god: bool=False) -> str:
    if god:
        return "critical_success"
    roll = random.random()
    if roll <= max(0.02, success_odds * 0.08):
        return "critical_success"
    if roll <= success_odds:
        return "success"
    if roll <= min(0.96, success_odds + 0.24):
        return "partial"
    if roll >= 0.94 or success_odds < 0.28:
        return "critical_fail"
    return "fail"


def apply_operation_consequence(conn: sqlite3.Connection, player_id: int, difficulty: int, outcome: str, reason: str, god: bool=False) -> str:
    if god:
        return "No consequence in god mode."
    if outcome == "partial":
        damage = difficulty * random.randint(90, 240)
        return damage_or_destroy_ship(conn, player_id, damage, reason, False, hospital_minutes=random.choice([0,0,10]))
    if outcome == "fail":
        damage = difficulty * random.randint(260, 620)
        fuel_loss = difficulty * random.randint(1, 4)
        conn.execute("UPDATE players SET fuel=max(0,fuel-?) WHERE id=?", (fuel_loss, player_id))
        return damage_or_destroy_ship(conn, player_id, damage, reason, False, hospital_minutes=random.choice([0,10,20])) + f" Lost {fuel_loss} fuel."
    if outcome == "critical_fail":
        damage = difficulty * random.randint(700, 1500)
        p = get_player(conn, player_id)
        cargo_loss = min(p["cargo"], difficulty * random.randint(1, 4))
        fuel_loss = difficulty * random.randint(4, 10)
        conn.execute("UPDATE players SET cargo=max(0,cargo-?), fuel=max(0,fuel-?) WHERE id=?", (cargo_loss, fuel_loss, player_id))
        return damage_or_destroy_ship(conn, player_id, damage, reason, False, hospital_minutes=random.randint(20, 90)) + f" Critical failure: lost {cargo_loss} cargo mass and {fuel_loss} fuel."
    return "No consequence."


@app.post("/api/auth/login")
def login(req: LoginRequest) -> Dict[str, Any]:
    migrate()
    conn = connect()
    user = row(conn, "SELECT * FROM users WHERE username=?", (req.username.strip().lower(),))
    if not user or user["password_hash"] != pw_hash(req.password):
        conn.close()
        raise HTTPException(401, "Invalid login")
    token = str(uuid.uuid4())
    conn.execute("INSERT INTO sessions (token,user_id,created_at,expires_at) VALUES (?,?,?,?)", (token,user["id"],iso(),iso(utcnow()+timedelta(days=7))))
    conn.commit(); conn.close()
    return {"token": token, "user": {"username": user["username"], "role": user["role"], "god_mode": bool(user["god_mode"])}}


@app.get("/api/health")
def health() -> Dict[str, Any]:
    return {"ok": True, "db": str(DB_PATH), "time": iso()}


@app.get("/api/state")
def state(ctx: Tuple[Dict[str,Any], Dict[str,Any]] = Depends(current_context)) -> Dict[str, Any]:
    user, player = ctx
    conn = connect()
    # auto complete travel when arrival time has passed
    p = resolve_completed_travel(conn, get_player(conn, player["id"]))
    p = resolve_intercept_if_close(conn, get_player(conn, player["id"]))
    resolve_completed_cargo_operations(conn, player["id"])
    p = get_player(conn, player["id"])
    # NPCs and market restock are server-side, timestamp-backed world movement.
    simulate_npc_activity(conn, force=False)
    simulate_npc_vs_npc_salvage(conn, force=False)
    resolve_market_restock(conn, force=False)
    simulate_npc_market_arbitrage(conn, force=False)
    resolve_player_legal_state(conn, player["id"])
    advance_pirate_station_run(conn, player["id"])
    conn.commit()
    data = build_state(conn, user, p)
    conn.close()
    return data





COMBAT_LEGAL_ROLES = {"pirate", "mercenary", "bounty", "hunter", "hostile", "outlaw", "raider"}
COMBAT_SECURITY_ROLES = {"security", "patrol", "marshal", "customs"}


def combat_actor_immunity_key(actor_ref: str) -> str:
    return f"combat_immunity:{actor_ref}"


def set_combat_actor_immunity(conn: sqlite3.Connection, actor_ref: str, seconds: Optional[int] = None) -> None:
    seconds = int(seconds if seconds is not None else COMBAT_BALANCE.get("post_battle_immunity_seconds", 5))
    app_state_put_json(conn, combat_actor_immunity_key(str(actor_ref)), {"until": iso(utcnow() + timedelta(seconds=max(1, seconds)))})


def combat_actor_immunity_until(conn: sqlite3.Connection, actor_ref: str) -> Optional[datetime]:
    data = app_state_get_json(conn, combat_actor_immunity_key(str(actor_ref)))
    until = parse_dt(data.get("until")) if data else None
    if until and until > utcnow():
        return until
    if until:
        app_state_delete(conn, combat_actor_immunity_key(str(actor_ref)))
    return None


def combat_actor_is_immune(conn: sqlite3.Connection, actor_ref: str) -> bool:
    return combat_actor_immunity_until(conn, actor_ref) is not None


def player_escape_chance(conn: sqlite3.Connection, player: Dict[str, Any]) -> float:
    ship = row(conn, "SELECT s.*, t.drive_speed, t.mass, t.size_class, t.role FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=?", (player.get("active_ship_id"),)) if player.get("active_ship_id") else None
    skills = player_skill_totals(conn, player["id"])
    speed = float((ship or {}).get("drive_speed") or 1.0)
    mass = max(80.0, float((ship or {}).get("mass") or 340.0))
    speed_score = speed * 0.16 + min(0.22, 220.0 / mass * 0.10)
    skill_score = min(0.24, int(skills.get("piloting", 0)) * 0.006 + int(skills.get("stealth", 0)) * 0.004 + int(skills.get("exploration", 0)) * 0.002)
    role = str((ship or {}).get("role") or "").lower()
    role_bonus = 0.08 if role in {"exploration", "trade", "cargo", "starter"} else 0.03 if role in {"combat", "siege", "fleet"} else 0.05
    chance = 0.22 + speed_score + skill_score + role_bonus
    return max(float(COMBAT_BALANCE.get("escape_chance_min", 0.20)), min(float(COMBAT_BALANCE.get("escape_chance_max", 0.80)), chance))

def combat_now_block_reason(conn: sqlite3.Connection, player: Dict[str, Any]) -> Optional[str]:
    status = jail_heat_status(conn, player["id"])
    if status.get("jailed"):
        return f"Jailed: {status.get('jailReason') or 'detained'}"
    travel_until = parse_dt(player.get("travel_until"))
    if travel_until and travel_until > utcnow():
        return f"In transit until {player.get('travel_until')}"
    cargo_status = cargo_operation_status(conn, player["id"])
    if cargo_status.get("active"):
        return f"Cargo {cargo_status.get('operationLabel','handling')} in progress. You are protected but cannot fight until {cargo_status.get('completeAt')}."
    if not player.get("active_ship_id"):
        return "No active ship"
    ship = row(conn, "SELECT * FROM ships WHERE id=?", (player.get("active_ship_id"),))
    if not ship or int(ship.get("destroyed") or 0):
        return "Active ship is destroyed or unavailable"
    # Do not globally block the Fight page after an NPC battle. Specific PvP/unlawful cooldowns are enforced on those actions.
    return None

def combat_ship_profile(conn: sqlite3.Connection, ship: Optional[Dict[str, Any]], fallback_name: str = "Unknown Ship") -> Dict[str, Any]:
    if not ship:
        return {"name": fallback_name, "image_url": ship_visual_payload(fallback_name, "ship"), "hull": 600, "shield": 250, "armor": 12, "energy": 100, "combatRating": 100, "accuracy": 0.58, "evasion": 0.12, "weapons": [{"name":"Improvised Battery","type":"laser","damage":85,"accuracy":0.55,"energy":8}], "stats": {}}
    derived = ship_derived_stats(conn, ship)
    installed = ship_installed_modules(conn, int(ship["id"]))
    weapons = []
    for m in installed:
        compat = m.get("compatibleSlotTypes") or [m.get("slot_type") or "utility"]
        stats = m.get("stats") or decode_json(m.get("stats_json"), {}) or {}
        if any(x in {"weapon", "mining"} for x in compat) or stats.get("damage"):
            dmg = int(stats.get("damage") or stats.get("mining", 0) * 2.2 or 60)
            wtype = "missile" if "missile" in str(m.get("name", "")).lower() else "laser" if "laser" in str(m.get("name", "")).lower() else "projectile"
            weapons.append({"name": m.get("name") or "Weapon", "type": wtype, "damage": max(35, dmg), "accuracy": min(0.88, 0.55 + int(m.get("current_tier") or 1) * 0.035), "energy": int(m.get("power_usage") or stats.get("energy_use") or 8)})
    if not weapons:
        weapons = [{"name":"Light Defensive Battery", "type":"laser", "damage": max(45, int((derived.get("combat_rating") or 100) * 0.08)), "accuracy":0.56, "energy":8}]
    return {
        "id": ship.get("id"), "name": ship.get("name") or ship.get("template_name") or fallback_name,
        "class": ship.get("class_name") or ship.get("role") or "ship", "role": ship.get("role") or "general",
        "tier": int(ship.get("current_tier") or ship.get("ship_tier") or 1),
        "image_url": ship.get("image_url") or ship_visual_payload(ship.get("name") or ship.get("template_name") or fallback_name, ship.get("role") or ship.get("class_name")),
        "hull": max(100, int(derived.get("hull") or ship.get("hull") or ship.get("max_hull") or 600)),
        "shield": max(0, int(derived.get("shield") or ship.get("shield") or ship.get("max_shield") or 250)),
        "armor": max(0, int(derived.get("armor") or ship.get("armor") or 10)),
        "energy": max(60, int(derived.get("energy_capacity") or 100)),
        "combatRating": max(1, int(derived.get("combat_rating") or get_ship_power(conn, int(ship["id"])) or 100)),
        "accuracy": min(0.92, 0.52 + max(0, int(derived.get("scan_strength") or 0)) / 900.0),
        "evasion": min(0.55, max(0.05, int(derived.get("evasion") or 0) / 650.0)),
        "weapons": weapons, "stats": derived,
    }

def npc_combat_ship_profile(npc: Dict[str, Any]) -> Dict[str, Any]:
    level = max(1, int(npc.get("level") or 1)); power = max(80, int(npc.get("power") or level * 220))
    role = str(npc.get("role") or npc.get("career_code") or "npc").lower(); ship_class = npc.get("ship_class") or "NPC Ship"
    is_combat = role in COMBAT_LEGAL_ROLES or role in COMBAT_SECURITY_ROLES or int(npc.get("aggression") or 0) > 55
    return {"name": ship_class, "class": ship_class, "role": role, "tier": max(1, min(7, level // 9 + (1 if is_combat else 0))),
        "image_url": ship_visual_payload(ship_class, role), "hull": int(380 + power * (1.4 if is_combat else 0.95)),
        "shield": int(160 + power * (0.55 if is_combat else 0.32)), "armor": int(8 + level * (1.1 if is_combat else 0.55)),
        "energy": int(75 + level * 3), "combatRating": power, "accuracy": min(0.86, 0.48 + level * 0.009 + (0.06 if is_combat else 0)),
        "evasion": min(0.42, 0.06 + level * 0.004 + (0.06 if role in {"smuggler", "scout"} else 0)),
        "weapons": [{"name": "Pirate Cannon" if role in {"pirate", "mercenary"} else "Patrol Laser" if role in COMBAT_SECURITY_ROLES else "Defensive Laser", "type":"laser", "damage": int(55 + power * (0.18 if is_combat else 0.09)), "accuracy": min(0.84, 0.52 + level * 0.008), "energy": 8}], "stats": {}}

def combat_target_legality(conn: sqlite3.Connection, player: Dict[str, Any], target: Dict[str, Any], mode: str = "attack") -> Dict[str, Any]:
    planet = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],)) or {}
    security = int(planet.get("security_level") or 50); role = str(target.get("role") or target.get("career_code") or "").lower()
    if target.get("inTransit"):
        if role in COMBAT_LEGAL_ROLES or str(target.get("disposition") or "").lower() == "hostile":
            return {"state":"legal", "criminal": False, "spaceCombat": True, "label":"Open-space hostile intercept", "heatGain":0, "jailRisk":0}
        return {"state":"risky", "criminal": True, "spaceCombat": True, "label":"Open-space piracy intercept", "heatGain": COMBAT_BALANCE["illegal_attack_heat"].get("risky", 12), "jailRisk":0.04}
    disposition = str(target.get("disposition") or "neutral").lower(); kind = target.get("kind") or target.get("targetType")
    if mode == "duel": return {"state":"legal", "criminal": False, "label":"Consensual duel", "heatGain":0, "jailRisk":0}
    if kind == "player":
        state = "criminal" if security >= 45 else "risky"
        return {"state": state, "criminal": True, "label":"Unlawful PvP aggression" if state == "criminal" else "Low-security PvP aggression", "heatGain": COMBAT_BALANCE["illegal_attack_heat"][state], "jailRisk": 0.20 if state == "criminal" else 0.08}
    if role in COMBAT_LEGAL_ROLES or disposition == "hostile":
        return {"state":"legal", "criminal": False, "label":"Authorized hostile target", "heatGain":0, "jailRisk":0}
    if role in COMBAT_SECURITY_ROLES:
        return {"state":"criminal", "criminal": True, "label":"Attacking security forces", "heatGain":24, "jailRisk":0.30}
    state = "criminal" if security >= 50 else "risky"
    return {"state":state, "criminal": True, "label":"Unprovoked attack", "heatGain": COMBAT_BALANCE["illegal_attack_heat"].get(state, 12), "jailRisk": 0.24 if state == "criminal" else 0.10}


def combat_target_difficulty(target: Dict[str, Any], enemy: Dict[str, Any]) -> int:
    level = int(target.get("level") or 1)
    tier = int(enemy.get("tier") or 1)
    power = int(enemy.get("combatRating") or target.get("power") or 100)
    return max(1, min(10, int(round((level / 10.0) + tier + (power / 18000.0)))))


def combat_energy_cost(target: Dict[str, Any], enemy: Dict[str, Any]) -> int:
    difficulty = combat_target_difficulty(target, enemy)
    tier = int(enemy.get("tier") or 1)
    return max(6, int(COMBAT_BALANCE["energy_base_cost"] + tier * COMBAT_BALANCE["energy_per_tier"] + difficulty * COMBAT_BALANCE["energy_per_difficulty"]))


def combat_reward_profile(target: Dict[str, Any], enemy: Dict[str, Any], legal: Dict[str, Any]) -> Dict[str, Any]:
    role = str(target.get("role") or target.get("career") or enemy.get("role") or "ship").lower()
    tier = max(1, int(enemy.get("tier") or 1))
    level = max(1, int(target.get("level") or 1))
    power = max(100, int(enemy.get("combatRating") or target.get("power") or 100))
    difficulty = combat_target_difficulty(target, enemy)
    role_mult = float(COMBAT_BALANCE["reward_role_mult"].get(role, 1.0))
    legal_mult = 1.0 if legal.get("state") == "legal" else 1.18
    tier_mult = 1.0 + (tier - 1) * 0.24
    difficulty_mult = 1.0 + difficulty * 0.075
    credits = int(max(COMBAT_BALANCE["reward_credit_floor"], (level * 690 + power * 0.42) * role_mult * legal_mult * tier_mult * difficulty_mult))
    xp = int(max(80, 45 + level * 42 + tier * 70 + difficulty * 38))
    loot_chance = min(0.82, 0.18 + tier * 0.055 + difficulty * 0.025 + (0.08 if role in {"pirate", "mercenary", "bounty", "outlaw", "raider"} else 0))
    return {"credits": credits, "xp": xp, "tier": tier, "difficulty": difficulty, "roleMultiplier": round(role_mult, 2), "tierMultiplier": round(tier_mult, 2), "lootChance": round(loot_chance, 2), "energyCost": combat_energy_cost(target, enemy)}


