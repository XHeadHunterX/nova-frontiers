        {"code":"deepcore_19","name":"Deepcore-19","class_name":"Miner","role":"mining","price":350000,"hull":14500,"shield":4100,"armor":48,"cargo_capacity":700,"fuel_capacity":950,"drive_speed":0.95,"size_class":"L","mass":920,"slots_json":encode_json({"weapon":1,"defense":2,"utility":5,"core":3}),"starter":0},
        {"code":"reclaimer","name":"Reclaimer","class_name":"Salvager","role":"salvage","price":310000,"hull":12600,"shield":3900,"armor":40,"cargo_capacity":620,"fuel_capacity":880,"drive_speed":1.0,"size_class":"M","mass":520,"slots_json":encode_json({"weapon":1,"defense":2,"utility":5,"core":2}),"starter":0},
        {"code":"vanguard","name":"Vanguard","class_name":"Gunship","role":"combat","price":620000,"hull":22000,"shield":10000,"armor":64,"cargo_capacity":180,"fuel_capacity":900,"drive_speed":1.15,"size_class":"L","mass":760,"slots_json":encode_json({"weapon":6,"defense":4,"utility":2,"core":3}),"starter":0},
        {"code":"ironwall","name":"Ironwall Mk II","class_name":"Siege Frigate","role":"siege","price":1500000,"hull":46000,"shield":22000,"armor":86,"cargo_capacity":400,"fuel_capacity":1500,"drive_speed":0.72,"size_class":"L","mass":1250,"slots_json":encode_json({"weapon":6,"defense":6,"utility":3,"core":4}),"starter":0},
        {"code":"titans_bane","name":"Titan's Bane","class_name":"Carrier","role":"fleet","price":5000000,"hull":120000,"shield":54000,"armor":95,"cargo_capacity":1800,"fuel_capacity":3500,"drive_speed":0.45,"size_class":"C","mass":3200,"slots_json":encode_json({"weapon":6,"defense":8,"utility":6,"core":6}),"starter":0},
    ]
    insert_many(conn, "ship_templates", ship_templates)

    modules = [
        ("railgun_mk1","Railgun Mk I","weapon","common",18000,{"damage":180,"range":900}),
        ("plasma_accel","Plasma Accelerator","weapon","rare",85000,{"damage":520,"heat":18}),
