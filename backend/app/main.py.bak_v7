        ("quartermaster","Quartermaster","neutral","Move supplies and support guild logistics.",{"skills":{"trading":2,"command":1}},["guild supply","cargo bonus","war support"]),
        ("medic","Medic","lawful","Reduce hospital times and run recovery operations.",{"skills":{"survival":2}},["surgery discount","recovery speed","rescue missions"]),
        ("mercenary","Mercenary","outlaw","Sell firepower to the highest bidder.",{"skills":{"combat":3}},["combat contracts","war payout","boarding bonus"]),
        ("diplomat","Diplomat","neutral","Manipulate standings, treaties, and planetary influence.",{"skills":{"diplomacy":3}},["faction standing","war cost reduction","guild influence"]),
    ]
    for code,name,side,desc,req,perks in jobs:
        conn.execute("INSERT INTO jobs (code,name,side,description,req_json,perks_json) VALUES (?,?,?,?,?,?)", (code,name,side,desc,encode_json(req),encode_json(perks)))

    # Large player skill tree: 12 trees x 10 nodes = 120 nodes.
    trees = ["combat","piloting","trading","smuggling","engineering","industry","scanning","survival","diplomacy","command","crafting","warfare"]
    for tree in trees:
        for i in range(1, 11):
            key = f"{tree}_{i}"
            name = f"{tree.title()} Protocol {i}"
            req = {"prev": f"{tree}_{i-1}"} if i > 1 else {}
            buff = {tree: i * 2, "all_xp": 1 if i in (5,10) else 0}
            conn.execute("INSERT INTO skill_nodes (key,tree,name,max_level,cost_base,req_json,buff_json) VALUES (?,?,?,?,?,?,?)", (key,tree,name,5, i * 2, encode_json(req), encode_json(buff)))

    property_templates = [
        ("hab_pod","Helios Habitat Pod","residential",45000,10,120,{"rest_xp":1}),
        ("apartment","Solaria Prime Apartment","residential",180000,25,450,{"rest_xp":2,"standing":1}),
        ("lux_apt","Umbra Luxury Apartment","residential",950000,75,1600,{"rest_xp":4,"market":1}),
        ("warehouse","Avalon Warehouse Unit","storage",500000,450,950,{"cargo_storage":8}),
        ("trade_kiosk","Zephyr Trade Kiosk","store",750000,80,1900,{"trade_margin":1}),
        ("repair_stall","New Dawn Repair Stall","service",1100000,40,2600,{"repair_discount":2}),
        ("refinery","Frontier Refinery Stake","industrial",1750000,120,3900,{"refine_speed":2}),
