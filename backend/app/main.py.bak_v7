    for code,name,slot,rarity,price,stats in modules:
        conn.execute("INSERT INTO module_templates (code,name,slot_type,rarity,price,craftable,stats_json) VALUES (?,?,?,?,?,?,?)", (code,name,slot,rarity,price,1,encode_json(stats)))

    commodities = [
        ("food","Food Supplies",1,"civilian",75,1,"Basic colony food and ration packs."),
        ("meds","Medical Supplies",1,"medical",180,1,"Clinic stock, emergency kits, nanite gel."),
        ("ore","Refined Ore",1,"industrial",130,2,"Processed ore used by shipyards and foundries."),
        ("reactor","Reactor Cells",1,"energy",340,1,"Legal high-density reactor cells."),
        ("microchips","Microchips",1,"electronics",230,1,"Consumer and industrial microelectronics."),
        ("luxury","Luxury Goods",1,"luxury",820,1,"Status goods for rich orbital habitats."),
        ("alien_relics","Alien Relics",0,"contraband",6200,1,"Forbidden artifacts from dead systems."),
        ("ai_cores","Restricted AI Cores",0,"contraband",12800,1,"Illegal autonomous cores with blacklisted firmware."),
        ("forged_ids","Forged Transit IDs",0,"documents",1150,0.2,"Fake docking and customs identities."),
        ("restricted_weapons","Restricted Weapon Parts",0,"arms",8300,1,"Military components banned in core systems."),
        ("black_implants","Black Market Implants",0,"medical",4500,0.4,"Unregistered cybernetic augmentation kits."),
    ]
    for r in commodities:
        conn.execute("INSERT INTO commodities (code,name,legal,category,base_price,mass,description) VALUES (?,?,?,?,?,?,?)", r)
    rng = random.Random(42)
    planet_ids = [r["id"] for r in rows(conn, "SELECT id FROM planets")]
    commodity_rows = rows(conn, "SELECT id, base_price, legal FROM commodities")
    for pid in planet_ids:
        p = row(conn, "SELECT * FROM planets WHERE id=?", (pid,))
        for com in commodity_rows:
            supply = rng.randint(15, 95)
            demand = rng.randint(25, 98)
            risk = 1.0 + (p["pirate_activity"] / 400.0 if not com["legal"] else 0)
            buy = int(com["base_price"] * (1.25 - supply/180) * risk)
            sell = int(com["base_price"] * (0.75 + demand/160) * risk)
            conn.execute("INSERT INTO market_prices (planet_id, commodity_id, supply, demand, buy_price, sell_price, updated_at) VALUES (?,?,?,?,?,?,?)", (pid, com["id"], supply, demand, max(1,buy), max(1,sell), now))

    jobs = [
        ("trader","Trader","neutral","Move goods, build wealth, shape markets.",{"skills":{"trading":1}},["market margin","contract slots","lower tax"]),
        ("smuggler","Smuggler","outlaw","Run illegal cargo through patrols and customs.",{"skills":{"smuggling":2}},["customs evasion","hidden cargo","black market access"]),
