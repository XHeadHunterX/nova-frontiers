FIRST_NAMES = ["Asha","Ren","Darius","Lyra","Cass","Mira","Vex","Talen","Nyra","Juno","Orin","Sera","Kael","Voss","Ilya","Mako","Zed","Nova","Rook","Sable"]
LAST_NAMES = ["Vale","Kor","Santos","Nyx","Dray","Sol","Vega","Kade","Quinn","Rane","Vorn","Hale","Morrow","Sterling","Cross","Rhyse","Onyx","Graves","Rayne","Kestrel"]


def target_npc_count_for_planet(planet: Dict[str, Any]) -> int:
    # Represents active simulated NPC actors, not literal census. Population and density both matter.
    population = int(planet.get("population") or 250000)
    density = int(planet.get("npc_density") or 50)
    activity = int(planet.get("npc_activity") or 50)
    base = int((population ** 0.32) + density * 0.45 + activity * 0.25)
    return clamp_int(base, 18, 120)


def weighted_npc_career_choice(rng: random.Random, planet: Dict[str, Any]) -> str:
    lawful = int(planet.get("lawfulness") or planet.get("security_level") or 50)
    hostile = int(planet.get("hostility") or planet.get("pirate_activity") or 50)
    friendly = int(planet.get("friendliness") or 50)
    economy = int(planet.get("npc_economy_bias") or planet.get("market_activity") or 50)
    criminal = int(planet.get("npc_criminal_bias") or planet.get("pirate_activity") or 50)
    weights = {
        "trader": 8 + economy // 5,
        "smuggler": 4 + criminal // 4,
        "bounty_hunter": 5 + hostile // 8,
        "miner": 5 + (100 - economy) // 12,
        "salvager": 5 + hostile // 12,
        "explorer": 6,
        "engineer": 5 + economy // 12,
        "security_pilot": 4 + lawful // 7,
        "marshal": 3 + lawful // 8,
        "dockmaster": 3 + economy // 10,
        "shipwright": 3 + economy // 12,
        "quartermaster": 3 + lawful // 14,
        "medic": 3 + friendly // 8,
        "mercenary": 4 + hostile // 5,
        "diplomat": 2 + friendly // 12,
    }
    careers = list(weights.keys())
    return rng.choices(careers, weights=[weights[k] for k in careers], k=1)[0]


def ensure_persistent_npc_content(conn: sqlite3.Connection) -> None:
    if not scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='planets'"):
        return
    # Backfill planet profile values for older DBs.
    for p in rows(conn, "SELECT * FROM planets"):
        if not p.get("population") or int(p.get("population") or 0) <= 250000:
            seed_tuple = (p["galaxy_id"], p["code"], p["name"], p["type"], p["x"], p["y"], p["security_level"], p["market_activity"], p["customs_rating"], p["pirate_activity"], p["defense_strength"], p["medical_quality"])
            population, density, activity, friendly, hostile, lawful, economy_bias, criminal_bias = planet_npc_profile_from_seed(seed_tuple)
            conn.execute("""UPDATE planets SET population=?, npc_density=?, npc_activity=?, friendliness=?, hostility=?, lawfulness=?, npc_economy_bias=?, npc_criminal_bias=? WHERE id=?""", (population, density, activity, friendly, hostile, lawful, economy_bias, criminal_bias, p["id"]))
    planets = rows(conn, "SELECT * FROM planets")
    legacy_career_map = {
        "customs": "marshal", "patrol": "security_pilot", "trader": "trader", "pirate": "mercenary",
        "medic": "medic", "dockmaster": "dockmaster", "market_maker": "trader", "defender": "security_pilot",
        "bounty": "bounty_hunter", "miner": "miner", "salvager": "salvager",
        "black_market_runner": "smuggler", "hauler": "trader", "security": "security_pilot",
        "engineer": "engineer", "shipwright": "shipwright", "quartermaster": "quartermaster",
        "diplomat": "diplomat", "explorer": "explorer", "scout": "explorer", "marshal": "marshal",
        "mercenary": "mercenary", "smuggler": "smuggler", "hunter": "bounty_hunter",
    }
    for old in rows(conn, "SELECT * FROM npc_agents WHERE career_code IS NULL OR career_code='' LIMIT 10000"):
        career = legacy_career_map.get(old.get("role"), "trader")
        profile = NPC_CAREER_PROFILES.get(career, NPC_CAREER_PROFILES["trader"])
        conn.execute("UPDATE npc_agents SET career_code=?, level=COALESCE(NULLIF(level,0),1), xp=COALESCE(xp,0), credits=COALESCE(credits,0), ship_class=?, activity_rate=CASE WHEN activity_rate IS NULL OR activity_rate=0 THEN 50 ELSE activity_rate END, aggression=CASE WHEN aggression IS NULL OR aggression=0 THEN ? ELSE aggression END, friendliness=CASE WHEN friendliness IS NULL OR friendliness=0 THEN ? ELSE friendliness END, job_rank=CASE WHEN job_rank IS NULL OR job_rank=0 THEN 1 ELSE job_rank END, market_bias=? WHERE id=?", (career, profile["ship"], profile["aggression"], profile["friendly"], profile["market_bias"], old["id"]))
    for p in planets:
        existing = scalar(conn, "SELECT COUNT(*) FROM npc_agents WHERE planet_id=?", (p["id"],)) if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='npc_agents'") else 0
        target = target_npc_count_for_planet(p)
        rng = random.Random((p["id"] * 7919) + int(p.get("population") or 0))
        for _ in range(max(0, target - existing)):
            career = weighted_npc_career_choice(rng, p)
            profile = NPC_CAREER_PROFILES[career]
            role = rng.choice(profile["roles"])
            level = clamp_int(int(rng.triangular(1, 55, 8 + int(p.get("npc_activity") or 50) / 8)), 1, 80)
            rank = clamp_int(1 + level // 9, 1, 10)
            power_base = int((p.get("security_level", 50) + p.get("market_activity", 50) + p.get("defense_strength", 50)) / 3)
            # NPCs have similar opportunities, but worse rolls than equal player specialists.
            power = clamp_int(int((power_base + level * 1.7) * rng.uniform(0.48, 0.72)), 8, 92)
            aggression = clamp_int(profile["aggression"] + (int(p.get("hostility") or 50) - 50) * 0.45 + rng.randint(-8, 8), 1, 98)
            friendliness = clamp_int(profile["friendly"] + (int(p.get("friendliness") or 50) - 50) * 0.35 + rng.randint(-8, 8), 1, 98)
            disposition = "friendly" if friendliness - aggression > 22 else "hostile" if aggression - friendliness > 22 else "neutral"
            name = f"{rng.choice(FIRST_NAMES)} {rng.choice(LAST_NAMES)}"
            credits = int((level ** 2) * rng.randint(80, 260))
            xp = int(level_xp_required(level) * rng.uniform(0.15, 0.75)) if level > 1 else rng.randint(0, 600)
            conn.execute("""INSERT INTO npc_agents (planet_id,role,name,power,disposition,career_code,level,xp,credits,ship_class,activity_rate,aggression,friendliness,job_rank,market_bias,last_action_at,simulated) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,1)""", (p["id"], role, name, power, disposition, career, level, xp, credits, profile["ship"], clamp_int(int(p.get("npc_activity") or 50) + rng.randint(-15, 15), 5, 98), aggression, friendliness, rank, profile["market_bias"], iso(utcnow() - timedelta(minutes=rng.randint(10, 9000)))))


def ensure_schema_evolution(conn: sqlite3.Connection) -> None:
    conn.execute("""
        CREATE TABLE IF NOT EXISTS crafting_queue (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          player_id INTEGER NOT NULL REFERENCES players(id) ON DELETE CASCADE,
          recipe_code TEXT NOT NULL,
          recipe_name TEXT NOT NULL,
          status TEXT NOT NULL DEFAULT 'active',
          recipe_snapshot_json TEXT NOT NULL DEFAULT '{}',
          output_preview_json TEXT NOT NULL DEFAULT '{}',
          success_odds REAL NOT NULL DEFAULT 0.0,
          credits_spent INTEGER NOT NULL DEFAULT 0,
          energy_spent INTEGER NOT NULL DEFAULT 0,
          xp_reward INTEGER NOT NULL DEFAULT 0,
          started_at TEXT NOT NULL,
          completes_at TEXT NOT NULL,
          completed_at TEXT,
          outcome TEXT,
          output_json TEXT NOT NULL DEFAULT '{}',
          message TEXT NOT NULL DEFAULT ''
        )
    """)


    conn.executescript("""
        CREATE TABLE IF NOT EXISTS factions (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          code TEXT NOT NULL UNIQUE,
          name TEXT NOT NULL,
          color TEXT NOT NULL,
          description TEXT NOT NULL,
          home_galaxy_code TEXT NOT NULL DEFAULT ''
        );

        CREATE TABLE IF NOT EXISTS galaxy_gates (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          from_galaxy_id INTEGER NOT NULL REFERENCES galaxies(id) ON DELETE CASCADE,
          to_galaxy_id INTEGER NOT NULL REFERENCES galaxies(id) ON DELETE CASCADE,
          from_planet_id INTEGER REFERENCES planets(id) ON DELETE SET NULL,
          to_planet_id INTEGER REFERENCES planets(id) ON DELETE SET NULL,
          distance REAL NOT NULL DEFAULT 1,
          route_key TEXT NOT NULL UNIQUE
        );

        CREATE TABLE IF NOT EXISTS galaxy_wars (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          galaxy_id INTEGER NOT NULL REFERENCES galaxies(id) ON DELETE CASCADE,
          declaring_faction_id INTEGER NOT NULL REFERENCES factions(id),
          defending_faction_id INTEGER REFERENCES factions(id),
          status TEXT NOT NULL DEFAULT 'declared',
          declared_at TEXT NOT NULL,
          opens_at TEXT NOT NULL,
          capture_started_at TEXT,
          capture_owner_faction_id INTEGER REFERENCES factions(id),
          resolved_at TEXT,
          winner_faction_id INTEGER REFERENCES factions(id),
          cooldown_until TEXT,
          message TEXT NOT NULL DEFAULT ''
        );

        CREATE TABLE IF NOT EXISTS galaxy_war_presence (
          war_id INTEGER NOT NULL REFERENCES galaxy_wars(id) ON DELETE CASCADE,
          player_id INTEGER NOT NULL REFERENCES players(id) ON DELETE CASCADE,
          faction_id INTEGER NOT NULL REFERENCES factions(id),
          inside_ring INTEGER NOT NULL DEFAULT 0,
          x_pct REAL NOT NULL DEFAULT 50,
          y_pct REAL NOT NULL DEFAULT 50,
          last_seen TEXT NOT NULL,
          PRIMARY KEY (war_id, player_id)
        );

        CREATE TABLE IF NOT EXISTS planet_faction_wars (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          planet_id INTEGER NOT NULL REFERENCES planets(id) ON DELETE CASCADE,
          galaxy_id INTEGER NOT NULL REFERENCES galaxies(id) ON DELETE CASCADE,
          declaring_guild_id INTEGER NOT NULL REFERENCES guilds(id),
          attacking_faction_id INTEGER NOT NULL REFERENCES factions(id),
          defending_faction_id INTEGER REFERENCES factions(id),
          status TEXT NOT NULL DEFAULT 'declared',
          declared_at TEXT NOT NULL,
          opens_at TEXT NOT NULL,
          capture_started_at TEXT,
          capture_owner_faction_id INTEGER REFERENCES factions(id),
          resolved_at TEXT,
          winner_faction_id INTEGER REFERENCES factions(id),
          cooldown_until TEXT,
          declare_cost INTEGER NOT NULL DEFAULT 0,
          message TEXT NOT NULL DEFAULT ''
        );

        CREATE TABLE IF NOT EXISTS planet_war_presence (
          war_id INTEGER NOT NULL REFERENCES planet_faction_wars(id) ON DELETE CASCADE,
          player_id INTEGER NOT NULL REFERENCES players(id) ON DELETE CASCADE,
          faction_id INTEGER NOT NULL REFERENCES factions(id),
          side TEXT NOT NULL DEFAULT 'blocked',
          inside_ring INTEGER NOT NULL DEFAULT 0,
          x_pct REAL NOT NULL DEFAULT 50,
          y_pct REAL NOT NULL DEFAULT 50,
          last_seen TEXT NOT NULL,
          PRIMARY KEY (war_id, player_id)
        );

        CREATE TABLE IF NOT EXISTS map_objects (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          object_key TEXT NOT NULL UNIQUE,
          map_type TEXT NOT NULL DEFAULT 'system',
          galaxy_id INTEGER REFERENCES galaxies(id) ON DELETE CASCADE,
          planet_id INTEGER REFERENCES planets(id) ON DELETE SET NULL,
          kind TEXT NOT NULL,
          code TEXT NOT NULL DEFAULT '',
          name TEXT NOT NULL,
          x_pct REAL NOT NULL DEFAULT 50,
          y_pct REAL NOT NULL DEFAULT 50,
          tier INTEGER NOT NULL DEFAULT 1,
          qty_remaining INTEGER NOT NULL DEFAULT 1,
          state TEXT NOT NULL DEFAULT 'available',
          locked_by_player_id INTEGER REFERENCES players(id) ON DELETE SET NULL,
          operation_type TEXT NOT NULL DEFAULT '',
          operation_until TEXT,
          expires_at TEXT,
          metadata_json TEXT NOT NULL DEFAULT '{}',
          created_at TEXT NOT NULL,
          updated_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS player_map_operations (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          player_id INTEGER NOT NULL REFERENCES players(id) ON DELETE CASCADE,
          object_key TEXT NOT NULL,
          operation_type TEXT NOT NULL,
          status TEXT NOT NULL DEFAULT 'active',
          started_at TEXT NOT NULL,
          ends_at TEXT,
          message TEXT NOT NULL DEFAULT '',
          result_json TEXT NOT NULL DEFAULT '{}',
          created_at TEXT NOT NULL,
          updated_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS npc_map_state (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          npc_id INTEGER NOT NULL REFERENCES npc_agents(id) ON DELETE CASCADE,
          map_type TEXT NOT NULL DEFAULT 'system',
          galaxy_id INTEGER REFERENCES galaxies(id) ON DELETE CASCADE,
          planet_id INTEGER REFERENCES planets(id) ON DELETE SET NULL,
          role TEXT NOT NULL DEFAULT 'pilot',
          objective TEXT NOT NULL DEFAULT 'patrol',
          target_object_key TEXT NOT NULL DEFAULT '',
          x_pct REAL NOT NULL DEFAULT 50,
          y_pct REAL NOT NULL DEFAULT 50,
          origin_x_pct REAL NOT NULL DEFAULT 50,
          origin_y_pct REAL NOT NULL DEFAULT 50,
          destination_x_pct REAL NOT NULL DEFAULT 50,
          destination_y_pct REAL NOT NULL DEFAULT 50,
          started_at TEXT NOT NULL,
          arrival_at TEXT NOT NULL,
          action_until TEXT,
          action_state TEXT NOT NULL DEFAULT 'moving',
          cargo_json TEXT NOT NULL DEFAULT '{}',
          updated_at TEXT NOT NULL
        );
    """)

    conn.executescript("""
        CREATE TABLE IF NOT EXISTS pirate_stations (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          code TEXT NOT NULL UNIQUE,
          galaxy_id INTEGER NOT NULL REFERENCES galaxies(id) ON DELETE CASCADE,
          nearest_planet_id INTEGER REFERENCES planets(id) ON DELETE SET NULL,
          name TEXT NOT NULL,
          x_pct REAL NOT NULL,
          y_pct REAL NOT NULL,
          tier INTEGER NOT NULL DEFAULT 1,
          difficulty INTEGER NOT NULL DEFAULT 1,
          total_pirates INTEGER NOT NULL DEFAULT 8,
          remaining_pirates INTEGER NOT NULL DEFAULT 8,
          resource_pct INTEGER NOT NULL DEFAULT 100,
          status TEXT NOT NULL DEFAULT 'active',
          occupied_by_player_id INTEGER REFERENCES players(id) ON DELETE SET NULL,
          seed TEXT NOT NULL DEFAULT '',
          created_at TEXT NOT NULL,
          updated_at TEXT NOT NULL,
          respawn_at TEXT
        );

        CREATE TABLE IF NOT EXISTS pirate_station_runs (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          station_id INTEGER NOT NULL REFERENCES pirate_stations(id) ON DELETE CASCADE,
          player_id INTEGER NOT NULL REFERENCES players(id) ON DELETE CASCADE,
          status TEXT NOT NULL DEFAULT 'active',
          player_x_pct REAL NOT NULL DEFAULT 50,
          player_y_pct REAL NOT NULL DEFAULT 50,
          battle_open INTEGER NOT NULL DEFAULT 0,
          battle_target_enemy_id INTEGER REFERENCES pirate_station_enemies(id) ON DELETE SET NULL,
          battle_report_json TEXT NOT NULL DEFAULT '{}',
          started_at TEXT NOT NULL,
          updated_at TEXT NOT NULL,
          completed_at TEXT
        );

        CREATE TABLE IF NOT EXISTS pirate_station_enemies (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          run_id INTEGER NOT NULL REFERENCES pirate_station_runs(id) ON DELETE CASCADE,
          enemy_key TEXT NOT NULL,
          name TEXT NOT NULL,
          role TEXT NOT NULL DEFAULT 'pirate',
          x_pct REAL NOT NULL,
          y_pct REAL NOT NULL,
          hull INTEGER NOT NULL,
          max_hull INTEGER NOT NULL,
          shield INTEGER NOT NULL,
          max_shield INTEGER NOT NULL,
          power INTEGER NOT NULL,
          tier INTEGER NOT NULL DEFAULT 1,
          status TEXT NOT NULL DEFAULT 'active',
          spawned_at TEXT NOT NULL,
          updated_at TEXT NOT NULL
        );
    """)


    # SQLite-safe migration helpers for older generated zips/DBs.
    existing_player_cols = {r[1] for r in conn.execute("PRAGMA table_info(players)").fetchall()}
    player_cols = {
        "energy": "INTEGER NOT NULL DEFAULT 100",
        "max_energy": "INTEGER NOT NULL DEFAULT 100",
        "energy_updated_at": "TEXT",
        "travel_mode": "TEXT",
        "travel_started_at": "TEXT",
        "travel_origin_planet_id": "INTEGER",
        "travel_origin_galaxy_id": "INTEGER",
        "travel_destination_galaxy_id": "INTEGER",
        "visited_galaxies_json": "TEXT NOT NULL DEFAULT '[]'",
        "visited_planets_json": "TEXT NOT NULL DEFAULT '[]'",
        "visited_galaxy_routes_json": "TEXT NOT NULL DEFAULT '[]'",
        "visited_local_routes_json": "TEXT NOT NULL DEFAULT '[]'",
        "heat": "INTEGER NOT NULL DEFAULT 0",
        "heat_updated_at": "TEXT",
        "jailed_until": "TEXT",
        "jail_reason": "TEXT",
        "jail_severity": "TEXT",
        "jail_location": "TEXT",
        "illegal_action_cooldown_until": "TEXT",
        "breakout_cooldown_until": "TEXT",
        "breakout_failures": "INTEGER NOT NULL DEFAULT 0",
    }
    for col, ddl in player_cols.items():
        if col not in existing_player_cols:
            conn.execute(f"ALTER TABLE players ADD COLUMN {col} {ddl}")

    existing_planet_cols = {r[1] for r in conn.execute("PRAGMA table_info(planets)").fetchall()}
    planet_cols = {
        "stability_level": "INTEGER NOT NULL DEFAULT 60",
        "population": "INTEGER NOT NULL DEFAULT 250000",
        "npc_density": "INTEGER NOT NULL DEFAULT 50",
        "npc_activity": "INTEGER NOT NULL DEFAULT 50",
        "friendliness": "INTEGER NOT NULL DEFAULT 50",
        "hostility": "INTEGER NOT NULL DEFAULT 50",
        "lawfulness": "INTEGER NOT NULL DEFAULT 50",
        "npc_economy_bias": "INTEGER NOT NULL DEFAULT 50",
        "npc_criminal_bias": "INTEGER NOT NULL DEFAULT 50",
        "economy_type": "TEXT NOT NULL DEFAULT 'balanced'",
        "production_bonus": "INTEGER NOT NULL DEFAULT 0",
        "market_modifier": "INTEGER NOT NULL DEFAULT 0",
        "conflict_level": "INTEGER NOT NULL DEFAULT 20",
        "player_influence": "INTEGER NOT NULL DEFAULT 0",
        "faction_influence_json": "TEXT NOT NULL DEFAULT '{}'",
    }
    added_stability_level = False
    for col, ddl in planet_cols.items():
        if col not in existing_planet_cols:
            conn.execute(f"ALTER TABLE planets ADD COLUMN {col} {ddl}")
            if col == "stability_level":
                added_stability_level = True
    if added_stability_level:
        conn.execute("""
            UPDATE planets
            SET stability_level=max(15,min(95,CAST(((security_level + market_activity + defense_strength + medical_quality) / 4) - (pirate_activity / 8) AS INTEGER)))
        """)

    existing_salvage_cols = {r[1] for r in conn.execute("PRAGMA table_info(salvage_sites)").fetchall()} if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='salvage_sites'") else set()
    salvage_cols = {
        "x_pct": "REAL",
        "y_pct": "REAL",
    }
    for col, ddl in salvage_cols.items():
        if col not in existing_salvage_cols:
            conn.execute(f"ALTER TABLE salvage_sites ADD COLUMN {col} {ddl}")

    existing_npc_cols = {r[1] for r in conn.execute("PRAGMA table_info(npc_agents)").fetchall()} if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='npc_agents'") else set()
    npc_cols = {
        "career_code": "TEXT",
        "level": "INTEGER NOT NULL DEFAULT 1",
        "xp": "INTEGER NOT NULL DEFAULT 0",
        "credits": "INTEGER NOT NULL DEFAULT 0",
        "ship_class": "TEXT NOT NULL DEFAULT 'Civilian Shuttle'",
        "activity_rate": "INTEGER NOT NULL DEFAULT 50",
        "aggression": "INTEGER NOT NULL DEFAULT 50",
        "friendliness": "INTEGER NOT NULL DEFAULT 50",
        "job_rank": "INTEGER NOT NULL DEFAULT 1",
        "market_bias": "TEXT NOT NULL DEFAULT 'balanced'",
        "last_action_at": "TEXT",
        "simulated": "INTEGER NOT NULL DEFAULT 1",
        "skill_points": "INTEGER NOT NULL DEFAULT 0",
        "skills_json": "TEXT NOT NULL DEFAULT '{}'",
        "alive": "INTEGER NOT NULL DEFAULT 1",
        "generation": "INTEGER NOT NULL DEFAULT 1",
        "death_count": "INTEGER NOT NULL DEFAULT 0",
        "respawned_from_id": "INTEGER",
    }
    for col, ddl in npc_cols.items():
        if col not in existing_npc_cols:
            conn.execute(f"ALTER TABLE npc_agents ADD COLUMN {col} {ddl}")

    # Newer balance-pass tables for old local DBs.
    conn.executescript(
        """
        CREATE TABLE IF NOT EXISTS market_ticks (
          id INTEGER PRIMARY KEY CHECK (id = 1),
          last_tick_at TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS simulation_ticks (
          id INTEGER PRIMARY KEY CHECK (id = 1),
          last_tick_at TEXT NOT NULL,
          last_action_count INTEGER NOT NULL DEFAULT 0
        );
        CREATE TABLE IF NOT EXISTS npc_action_log (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          planet_id INTEGER REFERENCES planets(id),
          action_type TEXT NOT NULL,
          actor_name TEXT NOT NULL,
          message TEXT NOT NULL,
          impact_json TEXT NOT NULL DEFAULT '{}',
          created_at TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS market_history (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          planet_id INTEGER NOT NULL REFERENCES planets(id),
          commodity_id INTEGER NOT NULL REFERENCES commodities(id),
          source TEXT NOT NULL,
          supply_delta INTEGER NOT NULL,
          demand_delta INTEGER NOT NULL,
          buy_price INTEGER NOT NULL,
          sell_price INTEGER NOT NULL,
          created_at TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS market_transactions (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          player_id INTEGER REFERENCES players(id) ON DELETE SET NULL,
          planet_id INTEGER REFERENCES planets(id) ON DELETE SET NULL,
          commodity_id INTEGER REFERENCES commodities(id) ON DELETE SET NULL,
          item_code TEXT NOT NULL,
          item_name TEXT NOT NULL,
          action TEXT NOT NULL,
          qty INTEGER NOT NULL,
          unit_price INTEGER NOT NULL,
          gross INTEGER NOT NULL,
          fee INTEGER NOT NULL DEFAULT 0,
          net INTEGER NOT NULL,
          legal INTEGER NOT NULL DEFAULT 1,
          source TEXT NOT NULL DEFAULT 'player',
          created_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS pending_cargo_operations (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          player_id INTEGER NOT NULL REFERENCES players(id) ON DELETE CASCADE,
          planet_id INTEGER REFERENCES planets(id) ON DELETE SET NULL,
          operation_type TEXT NOT NULL,
          item_code TEXT NOT NULL,
          item_name TEXT NOT NULL,
          qty INTEGER NOT NULL,
          mass REAL NOT NULL DEFAULT 0,
          gross INTEGER NOT NULL DEFAULT 0,
          fee INTEGER NOT NULL DEFAULT 0,
          net INTEGER NOT NULL DEFAULT 0,
          legal INTEGER NOT NULL DEFAULT 1,
          payload_json TEXT NOT NULL DEFAULT '{}',
          status TEXT NOT NULL DEFAULT 'active',
          started_at TEXT NOT NULL,
          complete_at TEXT NOT NULL,
          completed_at TEXT
        );

        CREATE TABLE IF NOT EXISTS player_market_listings (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          seller_player_id INTEGER REFERENCES players(id) ON DELETE SET NULL,
          seller_name TEXT NOT NULL,
          planet_id INTEGER REFERENCES planets(id) ON DELETE SET NULL,
          origin TEXT NOT NULL DEFAULT 'inventory',
          source_ref TEXT NOT NULL DEFAULT '',
          item_code TEXT NOT NULL,
          item_name TEXT NOT NULL,
          item_type TEXT NOT NULL,
          category TEXT NOT NULL,
          qty INTEGER NOT NULL,
          remaining_qty INTEGER NOT NULL,
          unit_price INTEGER NOT NULL,
          legal INTEGER NOT NULL DEFAULT 1,
          base_value INTEGER NOT NULL DEFAULT 0,
          mass REAL NOT NULL DEFAULT 1,
          description TEXT NOT NULL DEFAULT '',
          rarity TEXT NOT NULL DEFAULT 'common',
          status TEXT NOT NULL DEFAULT 'active',
          created_at TEXT NOT NULL,
          expires_at TEXT NOT NULL,
          closed_at TEXT
        );

        CREATE TABLE IF NOT EXISTS crafting_recipes (
          code TEXT PRIMARY KEY,
          name TEXT NOT NULL,
          category TEXT NOT NULL,
          description TEXT NOT NULL,
          inputs_json TEXT NOT NULL,
          output_json TEXT NOT NULL,
          credits INTEGER NOT NULL DEFAULT 0,
          energy INTEGER NOT NULL DEFAULT 0,
          craft_minutes INTEGER NOT NULL DEFAULT 0,
          required_jobs_json TEXT NOT NULL DEFAULT '[]',
          required_job_rank INTEGER NOT NULL DEFAULT 1,
          required_skill_tree TEXT NOT NULL DEFAULT '',
          required_skill_total INTEGER NOT NULL DEFAULT 0,
          base_success REAL NOT NULL DEFAULT 0.85,
          xp_reward INTEGER NOT NULL DEFAULT 0,
          recipe_rank_key TEXT NOT NULL DEFAULT 'basic',
          recipe_rank_name TEXT NOT NULL DEFAULT 'Basic',
          base_recipe_code TEXT NOT NULL DEFAULT '',
          unlock_model TEXT NOT NULL DEFAULT 'unlimited',
          recipe_family TEXT NOT NULL DEFAULT '',
          set_code TEXT NOT NULL DEFAULT '',
          set_name TEXT NOT NULL DEFAULT '',
          updated_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS player_recipe_licenses (
          player_id INTEGER NOT NULL REFERENCES players(id) ON DELETE CASCADE,
          recipe_code TEXT NOT NULL REFERENCES crafting_recipes(code) ON DELETE CASCADE,
          charges_remaining INTEGER NOT NULL DEFAULT 1,
          acquired_at TEXT NOT NULL,
          updated_at TEXT NOT NULL,
          PRIMARY KEY (player_id, recipe_code)
        );

        CREATE TABLE IF NOT EXISTS crafting_history (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          player_id INTEGER NOT NULL REFERENCES players(id) ON DELETE CASCADE,
          recipe_code TEXT NOT NULL,
          recipe_name TEXT NOT NULL,
          outcome TEXT NOT NULL,
          output_json TEXT NOT NULL DEFAULT '{}',
          xp_reward INTEGER NOT NULL DEFAULT 0,
          credits_spent INTEGER NOT NULL DEFAULT 0,
          energy_spent INTEGER NOT NULL DEFAULT 0,
          created_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS player_recipe_licenses (
          player_id INTEGER NOT NULL REFERENCES players(id) ON DELETE CASCADE,
          recipe_code TEXT NOT NULL REFERENCES crafting_recipes(code) ON DELETE CASCADE,
          charges_remaining INTEGER NOT NULL DEFAULT 1,
          acquired_at TEXT NOT NULL,
          updated_at TEXT NOT NULL,
          PRIMARY KEY (player_id, recipe_code)
        );

        CREATE TABLE IF NOT EXISTS planet_control_events (
          id INTEGER PRIMARY KEY AUTOINCREMENT,
          planet_id INTEGER NOT NULL REFERENCES planets(id) ON DELETE CASCADE,
          player_id INTEGER REFERENCES players(id) ON DELETE SET NULL,
          action_key TEXT NOT NULL,
          action_name TEXT NOT NULL,
          influence_delta INTEGER NOT NULL DEFAULT 0,
          security_delta INTEGER NOT NULL DEFAULT 0,
          stability_delta INTEGER NOT NULL DEFAULT 0,
          pirate_delta INTEGER NOT NULL DEFAULT 0,
          market_delta INTEGER NOT NULL DEFAULT 0,
          conflict_delta INTEGER NOT NULL DEFAULT 0,
          message TEXT NOT NULL,
          created_at TEXT NOT NULL
        );
        """
    )

    existing_inventory_cols = {r[1] for r in conn.execute("PRAGMA table_info(inventory)").fetchall()} if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='inventory'") else set()
    inventory_cols = {
        "category": "TEXT NOT NULL DEFAULT 'goods'",
        "subcategory": "TEXT NOT NULL DEFAULT ''",
        "reserved_qty": "INTEGER NOT NULL DEFAULT 0",
        "stack_size": "INTEGER NOT NULL DEFAULT 9999",
        "rarity": "TEXT NOT NULL DEFAULT 'common'",
        "cargo_exempt": "INTEGER NOT NULL DEFAULT 0",
        "usable": "INTEGER NOT NULL DEFAULT 0",
        "sellable": "INTEGER NOT NULL DEFAULT 1",
        "craftable_material": "INTEGER NOT NULL DEFAULT 0",
        "equippable": "INTEGER NOT NULL DEFAULT 0",
        "image_id": "TEXT NOT NULL DEFAULT ''",
        "description": "TEXT NOT NULL DEFAULT ''",
        "source": "TEXT NOT NULL DEFAULT 'system'",
        "acquired_at": "TEXT NOT NULL DEFAULT ''",
    }
    for col, ddl in inventory_cols.items():
        if col not in existing_inventory_cols:
            conn.execute(f"ALTER TABLE inventory ADD COLUMN {col} {ddl}")

    def add_cols(table: str, col_defs: Dict[str, str]) -> None:
        if not scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name=?", (table,)):
            return
        existing = {r[1] for r in conn.execute(f"PRAGMA table_info({table})").fetchall()}
        for col, ddl in col_defs.items():
            if col not in existing:
                conn.execute(f"ALTER TABLE {table} ADD COLUMN {col} {ddl}")

    add_cols("players", {"cargo_operation_until":"TEXT", "cargo_operation_started_at":"TEXT", "cargo_operation_type":"TEXT", "cargo_operation_summary":"TEXT", "faction_id":"INTEGER"})
    add_cols("guilds", {"level":"INTEGER NOT NULL DEFAULT 1", "xp":"INTEGER NOT NULL DEFAULT 0", "skill_points":"INTEGER NOT NULL DEFAULT 0", "last_planet_xp_at":"TEXT"})
    add_cols("user_profiles", {"selected_badge_code":"TEXT NOT NULL DEFAULT ''"})
    conn.executescript("""
        CREATE INDEX IF NOT EXISTS idx_map_objects_scope ON map_objects(map_type, galaxy_id, planet_id, kind, state);
        CREATE INDEX IF NOT EXISTS idx_map_objects_key ON map_objects(object_key);
        CREATE INDEX IF NOT EXISTS idx_player_map_ops_active ON player_map_operations(player_id, status);
        CREATE INDEX IF NOT EXISTS idx_npc_map_state_scope ON npc_map_state(map_type, galaxy_id, planet_id, action_state);
    """)
    add_cols("galaxies", {"x_pct":"REAL NOT NULL DEFAULT 50", "y_pct":"REAL NOT NULL DEFAULT 50", "faction_id":"INTEGER", "home_depth":"INTEGER NOT NULL DEFAULT 99", "capturable":"INTEGER NOT NULL DEFAULT 1", "center_value":"INTEGER NOT NULL DEFAULT 1", "control_bonus_pct":"INTEGER NOT NULL DEFAULT 3", "war_cooldown_until":"TEXT"})
    add_cols("planets", {"faction_id":"INTEGER", "war_cooldown_until":"TEXT"})
    add_cols("market_prices", {"security_stock_bias":"INTEGER NOT NULL DEFAULT 0"})
    add_cols("commodities", {"tier":"INTEGER NOT NULL DEFAULT 1", "max_tier":"INTEGER NOT NULL DEFAULT 2", "tier_locked":"INTEGER NOT NULL DEFAULT 1"})
    add_cols("inventory", {"base_tier":"INTEGER NOT NULL DEFAULT 1", "current_tier":"INTEGER NOT NULL DEFAULT 1", "max_tier":"INTEGER NOT NULL DEFAULT 3", "tier_locked":"INTEGER NOT NULL DEFAULT 0", "tier_source":"TEXT NOT NULL DEFAULT 'system'", "item_stats_json":"TEXT NOT NULL DEFAULT '{}'"})
    add_cols("module_templates", {"tier":"INTEGER NOT NULL DEFAULT 1", "max_tier":"INTEGER NOT NULL DEFAULT 5", "min_ship_tier":"INTEGER NOT NULL DEFAULT 0", "power_usage":"INTEGER NOT NULL DEFAULT 0"})
    add_cols("ship_templates", {"ship_tier":"INTEGER NOT NULL DEFAULT 1", "upkeep_cost":"INTEGER NOT NULL DEFAULT 0", "size_class":"TEXT NOT NULL DEFAULT 'M'", "mass":"REAL NOT NULL DEFAULT 340"})
    add_cols("ships", {"current_tier":"INTEGER NOT NULL DEFAULT 1", "max_tier":"INTEGER NOT NULL DEFAULT 4", "tier_source":"TEXT NOT NULL DEFAULT 'purchased'", "size_class":"TEXT NOT NULL DEFAULT 'M'", "mass":"REAL NOT NULL DEFAULT 340"})
    add_cols("ship_modules", {"current_tier":"INTEGER NOT NULL DEFAULT 1", "max_tier":"INTEGER NOT NULL DEFAULT 5", "tier_source":"TEXT NOT NULL DEFAULT 'purchased'", "equipped_slot_id":"TEXT"})
    add_cols("ship_parts", {"tier":"INTEGER NOT NULL DEFAULT 1"})
    add_cols("crafting_recipes", {"recipe_tier":"INTEGER NOT NULL DEFAULT 1", "output_tier":"INTEGER NOT NULL DEFAULT 1", "required_material_tiers_json":"TEXT NOT NULL DEFAULT '{}'", "recipe_rank_key":"TEXT NOT NULL DEFAULT 'basic'", "recipe_rank_name":"TEXT NOT NULL DEFAULT 'Basic'", "base_recipe_code":"TEXT NOT NULL DEFAULT ''", "unlock_model":"TEXT NOT NULL DEFAULT 'unlimited'", "recipe_family":"TEXT NOT NULL DEFAULT ''", "set_code":"TEXT NOT NULL DEFAULT ''", "set_name":"TEXT NOT NULL DEFAULT ''"})
    add_cols("player_market_listings", {"tier":"INTEGER NOT NULL DEFAULT 1", "max_tier":"INTEGER NOT NULL DEFAULT 3", "tier_source":"TEXT NOT NULL DEFAULT 'listed'"})
    add_cols("skill_nodes", {
        "description": "TEXT NOT NULL DEFAULT ''",
        "summary": "TEXT NOT NULL DEFAULT ''",
        "category": "TEXT NOT NULL DEFAULT ''",
        "icon": "TEXT NOT NULL DEFAULT ''",
        "trained_by_json": "TEXT NOT NULL DEFAULT '[]'",
        "affects_json": "TEXT NOT NULL DEFAULT '[]'",
        "passive_bonuses_json": "TEXT NOT NULL DEFAULT '[]'",
        "unlock_json": "TEXT NOT NULL DEFAULT '[]'",
        "xp_curve_base": "INTEGER NOT NULL DEFAULT 220"
    })
    add_cols("player_skills", {"xp":"INTEGER NOT NULL DEFAULT 0", "updated_at":"TEXT NOT NULL DEFAULT ''"})
    add_cols("player_jobs", {"last_active_at":"TEXT", "career_changed_at":"TEXT"})
    conn.execute("""
        UPDATE inventory
        SET category=CASE
              WHEN item_type IN ('contraband','booster','documents','black_market') OR legal=0 THEN 'illicit_goods'
              WHEN item_type IN ('ore','gas','crystal','raw_material','raw') THEN 'raw_materials'
              WHEN item_type IN ('material','component','chemical','food','medical','electronics') THEN 'crafting_materials'
              WHEN item_type IN ('refined','alloy','wafer','refined_material') THEN 'refined_materials'
              WHEN item_type IN ('consumable','repair','medkit','ammo') THEN 'consumables'
              WHEN item_type IN ('fuel','energy_cell','reactor','power_cell') THEN 'fuel_supplies'
              WHEN item_type IN ('ship_part','engine_part','hull_part','reactor_part') THEN 'ship_parts'
              WHEN item_type IN ('ship_module','module','scanner','shield','engine','stealth','cargo_module') THEN 'ship_modules'
              WHEN item_type IN ('weapon','laser','railgun','missile') THEN 'weapons'
              WHEN item_type IN ('armor','plating','defense') THEN 'armor'
              WHEN item_type IN ('artifact','rare','relic','ancient') THEN 'rare_artifacts'
              WHEN item_type IN ('salvage','scrap','wreckage') THEN 'salvage'
              ELSE COALESCE(NULLIF(category,''),'goods')
            END,
            rarity=CASE
              WHEN legal=0 AND base_value >= 2500 THEN 'black_market'
              WHEN legal=0 THEN 'rare'
              WHEN base_value >= 50000 THEN 'legendary'
              WHEN base_value >= 18000 THEN 'epic'
              WHEN base_value >= 3500 THEN 'rare'
              WHEN base_value >= 650 THEN 'uncommon'
              ELSE COALESCE(NULLIF(rarity,''),'common')
            END,
            stack_size=CASE WHEN stack_size IS NULL OR stack_size <= 0 THEN 9999 ELSE stack_size END,
            reserved_qty=CASE WHEN reserved_qty IS NULL THEN 0 ELSE reserved_qty END,
            acquired_at=CASE WHEN acquired_at IS NULL OR acquired_at='' THEN datetime('now') ELSE acquired_at END,
            usable=CASE WHEN item_type IN ('consumable','repair','medkit','fuel','energy_cell') OR category IN ('consumables','fuel_supplies') THEN 1 ELSE COALESCE(usable,0) END,
            craftable_material=CASE WHEN category IN ('raw_materials','crafting_materials','refined_materials','salvage') OR item_type IN ('ore','gas','crystal','raw_material','material','component','chemical','refined','alloy','salvage','scrap') THEN 1 ELSE COALESCE(craftable_material,0) END,
            equippable=CASE WHEN category IN ('ship_modules','weapons','armor') OR item_type IN ('ship_module','module','weapon','armor') THEN 1 ELSE COALESCE(equippable,0) END,
            sellable=CASE WHEN sellable IS NULL THEN 1 ELSE sellable END,
            cargo_exempt=CASE WHEN category='quest_items' THEN 1 ELSE COALESCE(cargo_exempt,0) END,
            base_tier=CASE WHEN base_tier IS NULL THEN 1 ELSE base_tier END,
            current_tier=CASE WHEN current_tier IS NULL THEN base_tier ELSE current_tier END,
            max_tier=CASE WHEN max_tier IS NULL OR max_tier < current_tier THEN current_tier ELSE max_tier END,
            tier_source=COALESCE(NULLIF(tier_source,''), source, 'system'),
            item_stats_json=COALESCE(NULLIF(item_stats_json,''), '{}')
    """)
    normalize_tier_metadata(conn)
    ensure_ship_weapon_slot_content(conn)
    ensure_balance_content(conn)
    ensure_crafting_content(conn)
    ensure_refinery_content(conn)
    ensure_player_market_content(conn)
    ensure_planet_control_content(conn)
    ensure_persistent_npc_content(conn)
    ensure_pirate_station_content(conn)
    ensure_profile_content(conn)
    ensure_progression_content(conn)



def normalize_tier_metadata(conn: sqlite3.Connection) -> None:
    # Deterministic migration for older saves: assign sensible tiers without confusing rarity with tier.
    if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='commodities'"):
        for c in rows(conn, "SELECT id, base_price, category, legal FROM commodities"):
            tier = infer_tier_from_value(int(c.get("base_price") or 0), c.get("category") or "", "", int(c.get("legal", 1)))
            max_tier = max(tier, 3 if str(c.get("category") or "") in {"electronics", "medical", "contraband"} else 2)
            conn.execute("UPDATE commodities SET tier=?, max_tier=?, tier_locked=1 WHERE id=?", (tier, max_tier, c["id"]))
    if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='module_templates'"):
        for mt in rows(conn, "SELECT id, price, rarity, slot_type FROM module_templates"):
            tier = infer_tier_from_value(int(mt.get("price") or 0), "ship_modules", mt.get("rarity") or "", 1)
            min_ship_tier = max(0, tier - 2)
            power = max(1, int((tier + 1) * 3 + (int(mt.get("price") or 0) / 12000)))
            conn.execute("UPDATE module_templates SET tier=?, max_tier=max(max_tier,5), min_ship_tier=?, power_usage=? WHERE id=?", (tier, min_ship_tier, power, mt["id"]))
    if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='ship_templates'"):
        for st in rows(conn, "SELECT id, price, role, size_class, slots_json FROM ship_templates"):
            tier = infer_tier_from_value(int(st.get("price") or 0), "ships", "", 1)
            upkeep = max(50, int(int(st.get("price") or 0) * 0.006 * max(1, tier)))
            slots_json = encode_json(normalized_ship_weapon_slots(st.get("slots_json") or "{}", st.get("role") or "", st.get("size_class") or "M", tier))
            conn.execute("UPDATE ship_templates SET ship_tier=?, upkeep_cost=?, slots_json=? WHERE id=?", (tier, upkeep, slots_json, st["id"]))
    if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='ships'"):
        conn.execute("""
            UPDATE ships
            SET current_tier=COALESCE((SELECT ship_tier FROM ship_templates WHERE ship_templates.id=ships.template_id), current_tier, 1),
                max_tier=max(COALESCE(max_tier, 4), COALESCE((SELECT ship_tier FROM ship_templates WHERE ship_templates.id=ships.template_id), 1)+2),
                tier_source=COALESCE(NULLIF(tier_source,''), 'purchased')
        """)
    if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='ship_modules'"):
        conn.execute("""
            UPDATE ship_modules
            SET current_tier=COALESCE((SELECT tier FROM module_templates WHERE module_templates.id=ship_modules.module_template_id), current_tier, 1),
                max_tier=max(COALESCE(max_tier, 5), COALESCE((SELECT max_tier FROM module_templates WHERE module_templates.id=ship_modules.module_template_id), 5)),
                tier_source=COALESCE(NULLIF(tier_source,''), 'purchased')
        """)
    if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='inventory'"):
        for inv in rows(conn, "SELECT id, base_value, category, rarity, legal, current_tier, max_tier FROM inventory"):
            tier = infer_tier_from_value(int(inv.get("base_value") or 0), inv.get("category") or "", inv.get("rarity") or "", int(inv.get("legal", 1)))
            current = clamp_tier(inv.get("current_tier") if inv.get("current_tier") not in (None, "") else tier)
            if current == 1 and tier != 1:
                current = tier
            max_tier = max(current, clamp_tier(inv.get("max_tier") if inv.get("max_tier") not in (None, "") else get_max_tier_for_item({"category":inv.get("category"), "current_tier":current})))
            conn.execute("UPDATE inventory SET base_tier=?, current_tier=?, max_tier=?, tier_source=COALESCE(NULLIF(tier_source,''),'system') WHERE id=?", (tier, current, max_tier, inv["id"]))
    if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='crafting_recipes'"):
        for rec in rows(conn, "SELECT code, credits, category, output_json FROM crafting_recipes"):
            output = decode_json(rec.get("output_json"), {}) or {}
            out_base = int(output.get("base_value") or rec.get("credits") or 0)
            output_tier = clamp_tier(output.get("outputTier", output.get("tier", infer_tier_from_value(out_base, output.get("category") or rec.get("category") or "", output.get("rarity") or "", int(output.get("legal", 1))))))
            recipe_tier = max(output_tier, infer_tier_from_value(int(rec.get("credits") or 0), rec.get("category") or "", "", 1))
            conn.execute("UPDATE crafting_recipes SET recipe_tier=?, output_tier=?, required_material_tiers_json=COALESCE(NULLIF(required_material_tiers_json,''),'{}') WHERE code=?", (recipe_tier, output_tier, rec["code"]))
    if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='player_market_listings'"):
        for l in rows(conn, "SELECT id, base_value, category, rarity, legal FROM player_market_listings"):
            tier = infer_tier_from_value(int(l.get("base_value") or 0), l.get("category") or "", l.get("rarity") or "", int(l.get("legal", 1)))
            conn.execute("UPDATE player_market_listings SET tier=?, max_tier=max(COALESCE(max_tier, tier), ?), tier_source=COALESCE(NULLIF(tier_source,''),'listed') WHERE id=?", (tier, tier, l["id"]))


def ensure_balance_content(conn: sqlite3.Connection) -> None:
    # Idempotent content patch: adds chemical/cooking-style production inputs and economy stabilizers.
    extras = [
        ("chemicals","Industrial Chemicals",1,"chemical",260,1,"Reactive industrial chemicals used in med packs, fuel processing, and module coatings."),
        ("nutrient_paste","Nutrient Paste",1,"food",95,1,"Cheap station food stock and emergency ration base."),
        ("hydro_spices","Hydroponic Spices",1,"food",310,0.4,"High-margin culinary crops for morale meals and luxury contracts."),
        ("bio_gel","Bio-Gel",1,"medical",520,0.6,"Medical gel used by surgery bays and trauma kits."),
        ("volatile_reagents","Volatile Reagents",0,"contraband",3900,0.5,"Restricted chemical catalysts used in illegal boosters and stealth coatings."),
        ("combat_stims","Combat Stims",0,"contraband",5400,0.3,"Illegal pilot stimulants that improve short-term performance at legal risk."),
    ]
    existing = {r["code"] for r in rows(conn, "SELECT code FROM commodities")} if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='commodities'") else set()
    for r in extras:
        if r[0] not in existing:
            conn.execute("INSERT INTO commodities (code,name,legal,category,base_price,mass,description) VALUES (?,?,?,?,?,?,?)", r)
    # Ensure every planet has a market row for every commodity, including added balance-pass goods.
    planets = rows(conn, "SELECT * FROM planets") if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='planets'") else []
    commodities = rows(conn, "SELECT * FROM commodities") if scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='commodities'") else []
    rng = random.Random(2468)
    for p in planets:
        for c in commodities:
            exists = row(conn, "SELECT 1 FROM market_prices WHERE planet_id=? AND commodity_id=?", (p["id"], c["id"]))
            if not exists:
                supply = rng.randint(22, 72)
                demand = rng.randint(35, 88)
                buy, sell = price_from_supply_demand(c, p, supply, demand)
                conn.execute("INSERT INTO market_prices (planet_id, commodity_id, supply, demand, buy_price, sell_price, updated_at) VALUES (?,?,?,?,?,?,?)", (p["id"], c["id"], supply, demand, buy, sell, iso()))
    for p in planets:
        security = int(p.get("security_level") or 50)
        for c in commodities:
            valuable = int(c.get("base_price") or 0) >= NPC_MARKET_BALANCE["valuable_base_price"] or int(c.get("tier") or 1) >= NPC_MARKET_BALANCE["valuable_tier"] or not int(c.get("legal") or 1)
            if not valuable:
                continue
            mp = row(conn, "SELECT * FROM market_prices WHERE planet_id=? AND commodity_id=?", (p["id"], c["id"]))
            if not mp:
                continue
            if security < 45 and int(mp.get("supply") or 0) < NPC_MARKET_BALANCE["low_sec_stock_floor"]:
                conn.execute("UPDATE market_prices SET supply=?, demand=max(demand,65), security_stock_bias=1 WHERE planet_id=? AND commodity_id=?", (NPC_MARKET_BALANCE["low_sec_stock_floor"], p["id"], c["id"]))
                recalc_market_price(conn, p["id"], c["id"], "security_stock_bias", 0, 0)
            elif security > 70 and int(mp.get("supply") or 0) > NPC_MARKET_BALANCE["high_sec_stock_soft_cap"]:
                conn.execute("UPDATE market_prices SET supply=?, demand=max(demand,70), security_stock_bias=-1 WHERE planet_id=? AND commodity_id=?", (NPC_MARKET_BALANCE["high_sec_stock_soft_cap"], p["id"], c["id"]))
                recalc_market_price(conn, p["id"], c["id"], "security_stock_bias", 0, 0)
    conn.execute("INSERT OR IGNORE INTO market_ticks (id,last_tick_at) VALUES (1,?)", (iso(utcnow()-timedelta(minutes=999)),))
    conn.execute("INSERT OR IGNORE INTO simulation_ticks (id,last_tick_at,last_action_count) VALUES (1,?,0)", (iso(utcnow()-timedelta(minutes=999)),))




def planet_economy_type(planet: Dict[str, Any]) -> str:
    typ = str(planet.get("type") or "").lower()
    if "shipyard" in typ or "industrial" in typ:
        return "industrial"
    if "mining" in typ:
        return "extraction"
    if "trade" in typ or "freeport" in typ or "jump" in typ:
        return "trade"
    if "shadow" in typ or "dark" in typ:
        return "black_market"
    if "research" in typ or "ancient" in typ:
        return "research"
    if "core" in typ:
        return "core"
    return "balanced"


def ensure_planet_control_content(conn: sqlite3.Connection) -> None:
    if not scalar(conn, "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name='planets'"):
        return
    # Existing databases get deterministic planet-control values based on current planet personality.
    for p in rows(conn, "SELECT * FROM planets"):
        economy_type = p.get("economy_type") or planet_economy_type(p)
        production = int(p.get("production_bonus") or 0)
        market_mod = int(p.get("market_modifier") or 0)
        conflict = int(p.get("conflict_level") or 0)
        if production == 0:
            production = clamp_int(int((int(p.get("market_activity") or 50) + int(p.get("defense_strength") or 50)) / 8), 0, 30)
        if market_mod == 0:
            market_mod = clamp_int(int((int(p.get("market_activity") or 50) - 50) / 3), -15, 20)
        if conflict == 0 or conflict == 20:
            conflict = clamp_int(int(int(p.get("pirate_activity") or 50) * 0.55 + (100 - int(p.get("stability_level") or 60)) * 0.25), 5, 90)
        influence_json = p.get("faction_influence_json") or "{}"
        conn.execute(
            """
            UPDATE planets
            SET economy_type=?,
                production_bonus=max(0,min(50,?)),
                market_modifier=max(-30,min(40,?)),
                conflict_level=max(1,min(99,?)),
                faction_influence_json=COALESCE(NULLIF(faction_influence_json,''), ?)
            WHERE id=?
            """,
            (economy_type, production, market_mod, conflict, influence_json, p["id"]),
        )
    conn.execute("DELETE FROM planet_control_events WHERE id NOT IN (SELECT id FROM planet_control_events ORDER BY id DESC LIMIT ?)", (PLANET_CONTROL_BALANCE["event_log_limit"],))


def planet_control_effects(planet: Dict[str, Any]) -> Dict[str, Any]:
    security = int(planet.get("security_level") or 50)
    stability = int(planet.get("stability_level") or 60)
    pirates = int(planet.get("pirate_activity") or 50)
    conflict = int(planet.get("conflict_level") or 20)
    production = int(planet.get("production_bonus") or 0)
    market_mod = int(planet.get("market_modifier") or 0)
    tax = float(planet.get("tax_rate") or 0.03)
    illegal_risk = clamp_int(int(35 + (security * 0.35) + (pirates * 0.25) + (conflict * 0.20) - (stability * 0.18)), 5, 95)
    travel_danger = clamp_int(int(20 + pirates * 0.45 + conflict * 0.35 - security * 0.22 - stability * 0.12), 1, 95)
    crafting_bonus = clamp_int(int((stability - 50) / 4 + production / 5), -10, 15)
    legal_price_pressure = round((1 + tax * PLANET_CONTROL_BALANCE["tax_price_pressure"] + conflict * PLANET_CONTROL_BALANCE["conflict_price_pressure"] - stability * PLANET_CONTROL_BALANCE["stability_price_relief"] - security * PLANET_CONTROL_BALANCE["security_price_relief"] - market_mod / 700), 3)
    production_supply_bonus = round(production * PLANET_CONTROL_BALANCE["production_supply_bonus"], 3)
    return {
        "controller_label": PLANET_CONTROL_BALANCE["npc_controller_labels"].get(str(planet.get("controller_type") or "npc"), label_for_api(str(planet.get("controller_type") or "npc"))),
        "illegal_risk": illegal_risk,
        "travel_danger": travel_danger,
        "crafting_bonus": crafting_bonus,
        "legal_price_pressure": legal_price_pressure,
        "production_supply_bonus": production_supply_bonus,
        "tax_rate_pct": round(tax * 100, 1),
        "mission_effect": "Safer and more stable planets improve lawful PvE. Conflict and pirates increase danger but create combat/smuggling opportunities.",
    }


def json_list(value: Any) -> List[Any]:
    try:
        parsed = decode_json(value, [])
        return parsed if isinstance(parsed, list) else []
    except Exception:
        return []


def limited_json_list(values: List[Any], limit: int = 80) -> str:
    seen: List[Any] = []
    for value in values:
        if value not in seen:
            seen.append(value)
    return encode_json(seen[-limit:])


def route_key(a: Any, b: Any) -> str:
    aa, bb = str(a), str(b)
    return "::".join(sorted([aa, bb]))


def module_stat_total(conn: sqlite3.Connection, ship_id: Optional[int], key: str) -> float:
    if not ship_id:
        return 0.0
    total = 0.0
    for m in rows(conn, "SELECT sm.durability, sm.current_tier, mt.stats_json FROM ship_modules sm JOIN module_templates mt ON mt.id=sm.module_template_id WHERE sm.ship_id=? AND sm.equipped=1", (ship_id,)):
        stats = apply_tier_to_item_stats(decode_json(m.get("stats_json"), {}), int(m.get("current_tier") or 1))
        total += float(stats.get(key, 0) or 0) * max(0.10, float(m.get("durability") or 100) / 100.0)
    return total


def travel_efficiency_bonus(conn: sqlite3.Connection, ship_id: Optional[int]) -> float:
    return min(0.35, max(0.0, module_stat_total(conn, ship_id, "efficiency") / 180.0 + module_stat_total(conn, ship_id, "jump") / 240.0))


def first_planet_in_galaxy(conn: sqlite3.Connection, galaxy_id: int) -> Optional[Dict[str, Any]]:
    return row(conn, "SELECT * FROM planets WHERE galaxy_id=? ORDER BY security_level DESC, market_activity DESC, id LIMIT 1", (galaxy_id,))


def galaxy_centers(conn: sqlite3.Connection) -> Dict[int, Dict[str, float]]:
    centers: Dict[int, Dict[str, float]] = {}
    for g in rows(conn, "SELECT g.id, COALESCE(AVG(p.x),0) as x, COALESCE(AVG(p.y),0) as y FROM galaxies g LEFT JOIN planets p ON p.galaxy_id=g.id GROUP BY g.id"):
        centers[int(g["id"])] = {"x": float(g.get("x") or 0), "y": float(g.get("y") or 0)}
    return centers


def galaxy_distance(conn: sqlite3.Connection, a: int, b: int) -> float:
    centers = galaxy_centers(conn)
    ca, cb = centers.get(int(a), {"x": 0, "y": 0}), centers.get(int(b), {"x": 0, "y": 0})
    return math.sqrt((ca["x"] - cb["x"]) ** 2 + (ca["y"] - cb["y"]) ** 2)


def local_distance(a: Dict[str, Any], b: Dict[str, Any]) -> float:
    return math.sqrt((float(a.get("x") or 0) - float(b.get("x") or 0)) ** 2 + (float(a.get("y") or 0) - float(b.get("y") or 0)) ** 2)



INTERCEPT_CONTACT_RANGE_PCT = 2.05  # map percent; combat starts when ship circles visually touch, not at radar range.


ACTION_RANGE_SECONDS = 1.0
ACTION_RANGE_VISUAL_EPSILON_PCT = 1.35
ACTION_RANGE_MIN_PCT = 1.85
ACTION_RANGE_MAX_PCT = 3.25
MAP_TRAVEL_SECONDS_PER_PCT = 5.8
MAP_TRAVEL_MIN_SECONDS = 2


def map_route_seconds_for_distance(conn: sqlite3.Connection, ship: Dict[str, Any], distance_pct: float, god: bool = False) -> int:
    """Return travel duration from map distance using constant actor speed.

    The distance may change the ETA, but not the apparent ship speed. Effective
    speed is derived from ship mass/size and jump-drive/module bonuses only.
    No fixed route padding is applied because fixed overhead makes short routes
    crawl and long routes look faster.
    """
    # God mode removes resource costs, but it must not teleport or change map speed.
    speed = max(0.28, effective_ship_map_speed(conn, ship or {}))
    distance_pct = max(0.0, float(distance_pct or 0.0))
    return max(MAP_TRAVEL_MIN_SECONDS, int(math.ceil(distance_pct * MAP_TRAVEL_SECONDS_PER_PCT / speed)))


def system_planet_map_point(conn: sqlite3.Connection, planet_id: int) -> Dict[str, float]:
    p = row(conn, "SELECT * FROM planets WHERE id=?", (int(planet_id or 0),))
    if not p:
        return {"x_pct": 50.0, "y_pct": 50.0}
    x = round(max(7, min(93, 50 + float(p.get("x") or 0) / 2.3)), 2)
    y = round(max(8, min(92, 50 + float(p.get("y") or 0) / 2.3)), 2)
    return {
        "x_pct": clamp_pct((float(x) - 50) * 1.45 + 50, 2, 98),
        "y_pct": clamp_pct((float(y) - 50) * 1.45 + 50, 2, 98),
    }


def galaxy_map_point(conn: sqlite3.Connection, galaxy_id: int) -> Dict[str, float]:
    g = row(conn, "SELECT * FROM galaxies WHERE id=?", (int(galaxy_id or 0),))
    if not g:
        return {"x_pct": 50.0, "y_pct": 50.0}
    return {"x_pct": clamp_pct(float(g.get("x_pct") or 50), 2, 98), "y_pct": clamp_pct(float(g.get("y_pct") or 50), 2, 98)}


def map_point_for_player_anchor(conn: sqlite3.Connection, player: Dict[str, Any], map_type: str, planet_id: Optional[int] = None, galaxy_id: Optional[int] = None) -> Dict[str, float]:
    if map_type == "galaxy":
        gid = int(galaxy_id or player.get("travel_origin_galaxy_id") or 0)
        if not gid:
            cp = row(conn, "SELECT galaxy_id FROM planets WHERE id=?", (int(planet_id or player.get("location_planet_id") or 0),))
            gid = int((cp or {}).get("galaxy_id") or 0)
        return galaxy_map_point(conn, gid)
    return system_planet_map_point(conn, int(planet_id or player.get("location_planet_id") or 0))


def current_player_map_position(conn: sqlite3.Connection, player: Dict[str, Any], map_type: str = "system") -> Dict[str, float]:
    travel = build_travel_state(conn, player)
    map_type = "galaxy" if str(map_type).lower() == "galaxy" else "system"
    if travel.get("active"):
        travel_map_type = str(travel.get("map_type") or ("galaxy" if travel.get("mode") in {"galaxy", "galaxy_route"} else "system")).lower()
        if travel_map_type == map_type:
            if travel.get("destination_x_pct") is not None:
                origin = (
                    {"x_pct": float(travel.get("origin_x_pct") or 50), "y_pct": float(travel.get("origin_y_pct") or 50)}
                    if travel.get("origin_x_pct") is not None and travel.get("origin_y_pct") is not None
                    else map_point_for_player_anchor(conn, player, map_type, travel.get("origin_planet_id"), travel.get("origin_galaxy_id"))
                )
                dest = {"x_pct": float(travel.get("destination_x_pct") or 50), "y_pct": float(travel.get("destination_y_pct") or 50)}
                return deterministic_between(origin, dest, float(travel.get("progress") or 0))
            origin = map_point_for_player_anchor(conn, player, map_type, travel.get("origin_planet_id"), travel.get("origin_galaxy_id"))
            dest = map_point_for_player_anchor(conn, player, map_type, travel.get("destination_planet_id"), travel.get("destination_galaxy_id"))
            return deterministic_between(origin, dest, float(travel.get("progress") or 0))
    if travel.get("open_space") and (not travel.get("open_space_map_type") or str(travel.get("open_space_map_type")).lower() == map_type):
        return {"x_pct": float(travel.get("open_space_x_pct") or 50), "y_pct": float(travel.get("open_space_y_pct") or 50)}
    return map_point_for_player_anchor(conn, player, map_type)


def player_action_range_pct(conn: sqlite3.Connection, player: Dict[str, Any], seconds: float = ACTION_RANGE_SECONDS) -> float:
    ship = row(conn, "SELECT * FROM ships WHERE id=?", (player.get("active_ship_id"),)) if player.get("active_ship_id") else None
    speed = max(0.28, effective_ship_map_speed(conn, ship or {}))
    one_second_distance = speed / 5.8 * max(0.1, float(seconds or 1.0))
    return round(max(ACTION_RANGE_MIN_PCT, min(ACTION_RANGE_MAX_PCT, one_second_distance + ACTION_RANGE_VISUAL_EPSILON_PCT)), 3)


def action_range_status(conn: sqlite3.Connection, player: Dict[str, Any], target: Dict[str, Any], map_type: str = "system") -> Dict[str, Any]:
    actor = current_player_map_position(conn, player, map_type)
    target_point = {"x_pct": float(target.get("x_pct") or 50), "y_pct": float(target.get("y_pct") or 50)}
    distance = pct_distance(actor, target_point)
    allowed = player_action_range_pct(conn, player)
    return {
        "inRange": bool(distance <= allowed),
        "distancePct": round(distance, 3),
        "actionRangePct": allowed,
        "actorX": round(float(actor.get("x_pct") or 50), 3),
        "actorY": round(float(actor.get("y_pct") or 50), 3),
        "targetX": round(float(target_point.get("x_pct") or 50), 3),
        "targetY": round(float(target_point.get("y_pct") or 50), 3),
        "rangeLabel": "In Range" if distance <= allowed else "Out of Range",
    }


def require_player_action_range(conn: sqlite3.Connection, player: Dict[str, Any], target: Dict[str, Any], map_type: str = "system", action_name: str = "action", god: bool = False) -> Dict[str, Any]:
    status = action_range_status(conn, player, target, map_type)
    if not god and not status["inRange"]:
        raise HTTPException(
            409,
            f"{label_for_api(action_name)} requires close range. Distance {status['distancePct']}%, allowed {status['actionRangePct']}%. Plot an approach course first.",
        )
    return status


def start_docking_approach(conn: sqlite3.Connection, player: Dict[str, Any], target: Dict[str, Any], god: bool = False) -> Dict[str, Any]:
    pid = int(player["id"])
    current = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],))
    if not current:
        raise HTTPException(400, "Current location is unknown")
    ship = row(conn, "SELECT * FROM ships WHERE id=?", (player.get("active_ship_id"),)) if player.get("active_ship_id") else None
    if not ship or ship.get("destroyed"):
        raise HTTPException(400, "No usable active ship")
    origin = current_player_map_position(conn, player, "system")
    dest = {"x_pct": float(target.get("x_pct") or 50), "y_pct": float(target.get("y_pct") or 50)}
    distance = pct_distance(origin, dest)
    seconds = map_route_seconds_for_distance(conn, ship or {}, distance, god)
    fuel_cost = 0 if god else max(0, int(distance / 18))
    spend(conn, pid, fuel=fuel_cost, god=god)
    now = utcnow()
    arrival = now + timedelta(seconds=seconds)
    clear_player_open_space(conn, pid)
    clear_player_waypoint(conn, pid)
    clear_player_intercept(conn, pid)
    clear_player_route(conn, pid)
    set_player_route(conn, pid, {
        "map_type": "system",
        "origin_x_pct": float(origin.get("x_pct") or 50),
        "origin_y_pct": float(origin.get("y_pct") or 50),
        "destination_x_pct": float(dest.get("x_pct") or 50),
        "destination_y_pct": float(dest.get("y_pct") or 50),
        "label": f"Docking approach to {target.get('name') or 'target'}",
        "started_at": iso(now),
        "arrival_at": iso(arrival),
        "route_target_type": "dock",
        "route_target_id": int(target.get("id") or current["id"]),
    })
    conn.execute(
        """UPDATE players
           SET travel_until=?, travel_destination_id=?, travel_mode='dock',
               travel_started_at=?, travel_origin_planet_id=?, travel_origin_galaxy_id=?, travel_destination_galaxy_id=?
           WHERE id=?""",
        (iso(arrival), int(target.get("id") or current["id"]), iso(now), current["id"], current["galaxy_id"], current["galaxy_id"], pid),
    )
    add_event(conn, pid, "travel", f"Docking approach started to {target.get('name') or 'target'}. ETA {seconds} seconds.", {"etaSeconds": seconds, "target": target.get("id")})
    return {"message": f"Docking approach started to {target.get('name') or 'target'}.", "seconds": seconds, "fuel_cost": fuel_cost, "dockingApproach": True}


def galaxy_path(conn: sqlite3.Connection, from_gid: int, to_gid: int) -> List[int]:
    from_gid = int(from_gid or 0)
    to_gid = int(to_gid or 0)
    if not from_gid or not to_gid:
        return []
    if from_gid == to_gid:
        return [from_gid]
    graph: Dict[int, List[int]] = {}
    for r in rows(conn, "SELECT from_galaxy_id,to_galaxy_id FROM galaxy_gates"):
        graph.setdefault(int(r["from_galaxy_id"]), []).append(int(r["to_galaxy_id"]))
    queue: List[List[int]] = [[from_gid]]
    seen = {from_gid}
    while queue:
        path = queue.pop(0)
        for nxt in graph.get(path[-1], []):
            if nxt in seen:
                continue
            npath = path + [nxt]
            if nxt == to_gid:
                return npath
            seen.add(nxt)
            queue.append(npath)
    return []


def route_segments_for_galaxy_path(conn: sqlite3.Connection, path: List[int]) -> List[Dict[str, Any]]:
    segments: List[Dict[str, Any]] = []
    for idx in range(len(path) - 1):
        a = int(path[idx])
        b = int(path[idx + 1])
        gate = row(conn, "SELECT * FROM galaxy_gates WHERE from_galaxy_id=? AND to_galaxy_id=?", (a, b)) or {}
        to_planet = galaxy_gate_planet(conn, b) or first_planet_in_galaxy(conn, b)
        from_planet = galaxy_gate_planet(conn, a) or first_planet_in_galaxy(conn, a)
        if not to_planet or not from_planet:
            continue
        src_g = row(conn, "SELECT name FROM galaxies WHERE id=?", (a,)) or {}
        dst_g = row(conn, "SELECT name FROM galaxies WHERE id=?", (b,)) or {}
        segments.append({
            "index": idx,
            "from_galaxy_id": a,
            "to_galaxy_id": b,
            "from_galaxy_name": src_g.get("name") or f"Galaxy {a}",
            "to_galaxy_name": dst_g.get("name") or f"Galaxy {b}",
            "from_planet_id": int(from_planet["id"]),
            "to_planet_id": int(to_planet["id"]),
            "distance": float(gate.get("distance") or galaxy_distance(conn, a, b)),
            "from_x_pct": float(galaxy_map_point(conn, a).get("x_pct") or 50),
            "from_y_pct": float(galaxy_map_point(conn, a).get("y_pct") or 50),
            "to_x_pct": float(galaxy_map_point(conn, b).get("x_pct") or 50),
            "to_y_pct": float(galaxy_map_point(conn, b).get("y_pct") or 50),
        })
    return segments


def start_galaxy_route_segment(conn: sqlite3.Connection, player: Dict[str, Any], segments: List[Dict[str, Any]], index: int, ship: Dict[str, Any], god: bool = False, paid: bool = False) -> Dict[str, Any]:
    if index >= len(segments):
        clear_player_route(conn, player["id"])
        return get_player(conn, player["id"])
    seg = segments[index]
    current_planet = row(conn, "SELECT * FROM planets WHERE id=?", (player["location_planet_id"],)) or {}
    target_planet = row(conn, "SELECT * FROM planets WHERE id=?", (int(seg["to_planet_id"]),))
    if not target_planet:
        raise HTTPException(404, "Destination gate disappeared")
    route_danger = int((planet_control_effects(current_planet).get("travel_danger", 20) + planet_control_effects(target_planet).get("travel_danger", 20)) / 2)
    map_distance = pct_distance(
        {"x_pct": float(seg.get("from_x_pct") or 50), "y_pct": float(seg.get("from_y_pct") or 50)},
        {"x_pct": float(seg.get("to_x_pct") or 50), "y_pct": float(seg.get("to_y_pct") or 50)},
    )
    seconds = map_route_seconds_for_distance(conn, ship or {}, map_distance, god)
    now = utcnow()
    arrival = now + timedelta(seconds=seconds)
    route_meta = {
        "map_type": "galaxy",
        "origin_x_pct": float(seg.get("from_x_pct") or 50),
        "origin_y_pct": float(seg.get("from_y_pct") or 50),
        "destination_x_pct": float(seg.get("to_x_pct") or 50),
        "destination_y_pct": float(seg.get("to_y_pct") or 50),
        "route_segments": segments,
        "route_segments_json": encode_json(segments),
        "route_segment_index": index,
        "route_final_galaxy_id": int(segments[-1]["to_galaxy_id"]),
        "route_final_galaxy_name": segments[-1].get("to_galaxy_name"),
        "label": f"Gate route segment {index + 1}/{len(segments)}: {seg.get('from_galaxy_name')} -> {seg.get('to_galaxy_name')}",
        "started_at": iso(now),
        "arrival_at": iso(arrival),
    }
    clear_player_open_space(conn, player["id"])
    clear_player_waypoint(conn, player["id"])
    clear_player_intercept(conn, player["id"])
    set_player_route(conn, player["id"], route_meta)
    conn.execute(
        """UPDATE players
           SET travel_until=?, travel_destination_id=?, travel_mode='galaxy_route',
               travel_started_at=?, travel_origin_planet_id=?, travel_origin_galaxy_id=?, travel_destination_galaxy_id=?
           WHERE id=?""",
        (iso(arrival), int(seg["to_planet_id"]), iso(now), int(seg["from_planet_id"]), int(seg["from_galaxy_id"]), int(seg["to_galaxy_id"]), int(player["id"])),
    )
    return get_player(conn, player["id"])


def advance_player_galaxy_route(conn: sqlite3.Connection, player: Dict[str, Any], dest: Dict[str, Any], origin: Optional[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
    meta = get_player_route(conn, player["id"])
    segments = meta.get("route_segments") or decode_json(meta.get("route_segments_json"), []) or []
    idx = int(meta.get("route_segment_index") or 0)
    if not segments:
        return None
    seg = segments[idx]
    visited_galaxies = json_list(player.get("visited_galaxies_json"))
    visited_planets = json_list(player.get("visited_planets_json"))
    galaxy_routes = json_list(player.get("visited_galaxy_routes_json"))
    visited_galaxies.extend([int(seg.get("from_galaxy_id") or 0), int(seg.get("to_galaxy_id") or 0)])
    visited_planets.append(int(dest["id"]))
    galaxy_routes.append(route_key(seg.get("from_galaxy_id"), seg.get("to_galaxy_id")))
    conn.execute(
        """UPDATE players
           SET location_planet_id=?, visited_galaxies_json=?, visited_planets_json=?, visited_galaxy_routes_json=?
           WHERE id=?""",
        (
            int(dest["id"]),
            limited_json_list(visited_galaxies, TRAVEL_BALANCE["max_visited"]),
            limited_json_list(visited_planets, TRAVEL_BALANCE["max_visited"]),
            limited_json_list(galaxy_routes, TRAVEL_BALANCE["max_history_routes"]),
            int(player["id"]),
        ),
    )
    fresh = get_player(conn, player["id"])
    if idx + 1 < len(segments):
        ship = row(conn, "SELECT * FROM ships WHERE id=?", (fresh.get("active_ship_id"),)) or {}
        start_galaxy_route_segment(conn, fresh, segments, idx + 1, ship, False, paid=True)
        add_event(conn, player["id"], "travel", f"Auto-advanced gate route to {segments[idx + 1].get('to_galaxy_name')}.", {"segment": idx + 2, "segments": len(segments)})
        return get_player(conn, player["id"])
    clear_player_open_space(conn, player["id"])
    clear_player_waypoint(conn, player["id"])
    clear_player_intercept(conn, player["id"])
    clear_player_route(conn, player["id"])
    conn.execute("UPDATE players SET travel_until=NULL, travel_destination_id=NULL, travel_mode=NULL, travel_started_at=NULL, travel_origin_planet_id=NULL, travel_origin_galaxy_id=NULL, travel_destination_galaxy_id=NULL WHERE id=?", (player["id"],))
    add_event(conn, player["id"], "travel", f"Arrived in {seg.get('to_galaxy_name')} at {dest['name']}. Multi-galaxy route complete.", {"segments": len(segments)})
    return get_player(conn, player["id"])


def app_state_put_json(conn: sqlite3.Connection, key: str, value: Dict[str, Any]) -> None:
    conn.execute("CREATE TABLE IF NOT EXISTS app_state (key TEXT PRIMARY KEY, value TEXT NOT NULL)")
    conn.execute(
        "INSERT INTO app_state (key,value) VALUES (?,?) ON CONFLICT(key) DO UPDATE SET value=excluded.value",
        (key, encode_json(value)),
    )


def app_state_get_json(conn: sqlite3.Connection, key: str) -> Dict[str, Any]:
    conn.execute("CREATE TABLE IF NOT EXISTS app_state (key TEXT PRIMARY KEY, value TEXT NOT NULL)")
    found = row(conn, "SELECT value FROM app_state WHERE key=?", (key,))
    return decode_json(found.get("value"), {}) if found else {}


def app_state_delete(conn: sqlite3.Connection, key: str) -> None:
    conn.execute("CREATE TABLE IF NOT EXISTS app_state (key TEXT PRIMARY KEY, value TEXT NOT NULL)")
    conn.execute("DELETE FROM app_state WHERE key=?", (key,))


def intercept_state_key(player_id: int) -> str:
    return f"player:{int(player_id)}:active_intercept"


def normalize_traveler_target_ref(raw: str) -> str:
    target_ref = str(raw or "").strip()
    if not target_ref:
        raise HTTPException(400, "Invalid traveler target")
    if target_ref.startswith("traveler:"):
        return target_ref
    if target_ref.startswith("npc:") or target_ref.startswith("player:"):
        return target_ref
    if ":" not in target_ref:
        return "traveler:" + target_ref
    return target_ref


def clear_player_intercept(conn: sqlite3.Connection, player_id: int) -> None:
    app_state_delete(conn, intercept_state_key(player_id))


def set_player_intercept(conn: sqlite3.Connection, player_id: int, meta: Dict[str, Any]) -> None:
    app_state_put_json(conn, intercept_state_key(player_id), meta)


def get_player_intercept(conn: sqlite3.Connection, player_id: int) -> Dict[str, Any]:
    return app_state_get_json(conn, intercept_state_key(player_id))



def waypoint_state_key(player_id: int) -> str:
    return f"player:{int(player_id)}:active_waypoint"


def open_space_state_key(player_id: int) -> str:
    return f"player:{int(player_id)}:open_space"


def set_player_waypoint(conn: sqlite3.Connection, player_id: int, meta: Dict[str, Any]) -> None:
    app_state_put_json(conn, waypoint_state_key(player_id), meta)


def get_player_waypoint(conn: sqlite3.Connection, player_id: int) -> Dict[str, Any]:
    return app_state_get_json(conn, waypoint_state_key(player_id))


def clear_player_waypoint(conn: sqlite3.Connection, player_id: int) -> None:
    app_state_delete(conn, waypoint_state_key(player_id))


def set_player_open_space(conn: sqlite3.Connection, player_id: int, meta: Dict[str, Any]) -> None:
    app_state_put_json(conn, open_space_state_key(player_id), meta)


def get_player_open_space(conn: sqlite3.Connection, player_id: int) -> Dict[str, Any]:
    return app_state_get_json(conn, open_space_state_key(player_id))


def clear_player_open_space(conn: sqlite3.Connection, player_id: int) -> None:
    app_state_delete(conn, open_space_state_key(player_id))


def route_state_key(player_id: int) -> str:
    return f"player:{int(player_id)}:active_route"


def set_player_route(conn: sqlite3.Connection, player_id: int, meta: Dict[str, Any]) -> None:
    app_state_put_json(conn, route_state_key(player_id), meta)


def get_player_route(conn: sqlite3.Connection, player_id: int) -> Dict[str, Any]:
    return app_state_get_json(conn, route_state_key(player_id))


def clear_player_route(conn: sqlite3.Connection, player_id: int) -> None:
    app_state_delete(conn, route_state_key(player_id))


def player_is_in_open_space(conn: sqlite3.Connection, player_id: int) -> bool:
    meta = get_player_open_space(conn, player_id)
    return bool(meta.get("active"))


def resolve_completed_waypoint(conn: sqlite3.Connection, player: Dict[str, Any], dest: Dict[str, Any], origin: Optional[Dict[str, Any]]) -> Dict[str, Any]:
    meta = get_player_waypoint(conn, player["id"])
    clear_player_waypoint(conn, player["id"])
    clear_player_route(conn, player["id"])
    x_pct = float(meta.get("x_pct") if meta.get("x_pct") is not None else 50)
    y_pct = float(meta.get("y_pct") if meta.get("y_pct") is not None else 50)
    map_type = str(meta.get("map_type") or "system")
    set_player_open_space(conn, player["id"], {
        "active": True,
        "map_type": map_type,
        "x_pct": x_pct,
        "y_pct": y_pct,
        "anchor_planet_id": player.get("travel_origin_planet_id") or player.get("location_planet_id"),
        "anchor_galaxy_id": player.get("travel_origin_galaxy_id"),
        "arrived_at": iso(),
        "label": meta.get("label") or "Open-space waypoint",
    })
    conn.execute(
        """UPDATE players
           SET travel_until=NULL, travel_destination_id=NULL, travel_mode=NULL,
               travel_started_at=NULL, travel_origin_planet_id=NULL, travel_origin_galaxy_id=NULL, travel_destination_galaxy_id=NULL
           WHERE id=?""",
        (player["id"],),
    )
    add_event(conn, player["id"], "travel", f"Arrived at open-space waypoint ({x_pct:.1f}, {y_pct:.1f}).", {"map_type": map_type, "x_pct": x_pct, "y_pct": y_pct})
    return get_player(conn, player["id"])


def map_point_between(a: Dict[str, Any], b: Dict[str, Any], progress: float) -> Dict[str, float]:
    return {
        "x_pct": float(a.get("x_pct") or 50) + (float(b.get("x_pct") or 50) - float(a.get("x_pct") or 50)) * progress,
        "y_pct": float(a.get("y_pct") or 50) + (float(b.get("y_pct") or 50) - float(a.get("y_pct") or 50)) * progress,
    }


def resolve_intercept_if_close(conn: sqlite3.Connection, player: Dict[str, Any]) -> Dict[str, Any]:
    if player.get("travel_mode") != "intercept":
        return player
    travel = build_travel_state(conn, player)
    if not travel.get("active"):
        return player
    meta = get_player_intercept(conn, player["id"])
    target_ref = meta.get("target_ref")
    if not target_ref:
        return player
    map_type = str(meta.get("map_type") or travel.get("map_type") or "system")
    active_map = build_galaxy_map(conn, player) if map_type == "galaxy" else build_system_map(conn, player)
    nodes = {int(n["id"]): n for n in active_map.get("nodes", []) if str(n.get("id") or "").isdigit()}
    origin_key = int(travel.get("origin_galaxy_id") or 0) if map_type == "galaxy" else int(travel.get("origin_planet_id") or 0)
    origin_node = {"x_pct": float(meta.get("origin_x_pct")), "y_pct": float(meta.get("origin_y_pct"))} if meta.get("origin_x_pct") is not None else nodes.get(origin_key)
    destination = {"x_pct": float(meta.get("x_pct") or 50), "y_pct": float(meta.get("y_pct") or 50)}
    if not origin_node:
        return player
    own = map_point_between(origin_node, destination, float(travel.get("progress") or 0))
    target = next((x for x in active_map.get("traffic", []) if x.get("combatTargetRef") == target_ref or x.get("id") == target_ref), None)
    target_point = {"x_pct": float((target or meta).get("x_pct") or destination["x_pct"]), "y_pct": float((target or meta).get("y_pct") or destination["y_pct"])}
    dist_pct = ((own["x_pct"] - target_point["x_pct"]) ** 2 + (own["y_pct"] - target_point["y_pct"]) ** 2) ** 0.5
    if dist_pct <= INTERCEPT_CONTACT_RANGE_PCT:
        dest = row(conn, "SELECT * FROM planets WHERE id=?", (player.get("travel_destination_id"),))
        origin = row(conn, "SELECT * FROM planets WHERE id=?", (player.get("travel_origin_planet_id") or player.get("location_planet_id"),))
        if dest:
            meta["x_pct"] = target_point["x_pct"]
            meta["y_pct"] = target_point["y_pct"]
            set_player_intercept(conn, player["id"], meta)
            return resolve_completed_intercept(conn, player, dest, origin)
    return player


def resolve_completed_intercept(conn: sqlite3.Connection, player: Dict[str, Any], dest: Dict[str, Any], origin: Optional[Dict[str, Any]]) -> Dict[str, Any]:
    meta = get_player_intercept(conn, player["id"])
    raw_target_ref = str(meta.get("target_ref") or "")
    if not raw_target_ref:
        clear_player_intercept(conn, player["id"])
        conn.execute("UPDATE players SET travel_until=NULL, travel_destination_id=NULL, travel_mode=NULL, travel_started_at=NULL, travel_origin_planet_id=NULL, travel_origin_galaxy_id=NULL, travel_destination_galaxy_id=NULL WHERE id=?", (player["id"],))
        add_event(conn, player["id"], "combat", "Intercept course ended. Target data was lost before engagement.")
        return get_player(conn, player["id"])
    target_ref = normalize_traveler_target_ref(raw_target_ref)
    battle_message = "Intercept completed, but the target slipped away."
    battle_result: Dict[str, Any] = {}
    salvage_id = None
    try:
        # Intercept combat is allowed while travel_mode='intercept'. Clear the transient
        # travel fields before preview/combat so combat_now_block_reason does not reject it.
        conn.execute("UPDATE players SET travel_until=NULL, travel_destination_id=NULL, travel_mode=NULL, travel_started_at=NULL, travel_origin_planet_id=NULL, travel_origin_galaxy_id=NULL, travel_destination_galaxy_id=NULL WHERE id=?", (player["id"],))
        player_for_combat = get_player(conn, player["id"])
        battle_result = simulate_combat_battle(conn, player_for_combat, target_ref, "intercept", False)
        battle_message = battle_result.get("message") or battle_message
        salvage_site = ((battle_result.get("battle") or {}).get("rewards") or {}).get("salvageSite") or {}
        salvage_id = salvage_site.get("id")
        if salvage_id and (meta.get("x_pct") is not None or meta.get("y_pct") is not None):
            conn.execute(
                "UPDATE salvage_sites SET x_pct=COALESCE(?,x_pct), y_pct=COALESCE(?,y_pct), expires_at=? WHERE id=?",
                (
                    float(meta.get("x_pct")) if meta.get("x_pct") is not None else None,
                    float(meta.get("y_pct")) if meta.get("y_pct") is not None else None,
                    iso(utcnow() + timedelta(hours=24)),
                    salvage_id,
                ),
            )
    except HTTPException as ex:
        detail = getattr(ex, "detail", None) or "intercept failed"
        battle_message = f"Intercept failed: {detail}."
    finally:
        clear_player_intercept(conn, player["id"])

    visited_galaxies = json_list(player.get("visited_galaxies_json"))
    visited_planets = json_list(player.get("visited_planets_json"))
    galaxy_routes = json_list(player.get("visited_galaxy_routes_json"))
    local_routes = json_list(player.get("visited_local_routes_json"))
    if dest:
        visited_planets.append(int(dest["id"]))
        visited_galaxies.append(int(dest.get("galaxy_id") or 0))
    if origin and dest:
        local_routes.append(route_key(origin["id"], dest["id"]))

    conn.execute(
        """
        UPDATE players
        SET location_planet_id=?, travel_until=NULL, travel_destination_id=NULL, travel_mode=NULL,
            travel_started_at=NULL, travel_origin_planet_id=NULL, travel_origin_galaxy_id=NULL, travel_destination_galaxy_id=NULL,
            visited_galaxies_json=?, visited_planets_json=?, visited_galaxy_routes_json=?, visited_local_routes_json=?
        WHERE id=?
        """,
        (
            dest["id"],
            limited_json_list(visited_galaxies, TRAVEL_BALANCE["max_visited"]),
            limited_json_list(visited_planets, TRAVEL_BALANCE["max_visited"]),
            limited_json_list(galaxy_routes, TRAVEL_BALANCE["max_history_routes"]),
            limited_json_list(local_routes, TRAVEL_BALANCE["max_history_routes"]),
            player["id"],
        ),
    )
    add_event(
        conn,
        player["id"],
        "combat",
        battle_message,
        {"mode": "intercept", "target_ref": target_ref, "salvageSiteId": salvage_id, "battleId": ((battle_result.get("battle") or {}).get("id"))},
    )
    return get_player(conn, player["id"])


def resolve_completed_travel(conn: sqlite3.Connection, player: Dict[str, Any]) -> Dict[str, Any]:
    t_until = parse_dt(player.get("travel_until"))
    if not t_until or t_until > utcnow() or not player.get("travel_destination_id"):
        return player
    dest = row(conn, "SELECT p.*, g.id as dest_galaxy_id, g.name as dest_galaxy_name FROM planets p JOIN galaxies g ON g.id=p.galaxy_id WHERE p.id=?", (player["travel_destination_id"],))
    origin = row(conn, "SELECT p.*, g.id as origin_galaxy_id, g.name as origin_galaxy_name FROM planets p JOIN galaxies g ON g.id=p.galaxy_id WHERE p.id=?", (player.get("travel_origin_planet_id") or player["location_planet_id"],))
    if not dest:
        conn.execute("UPDATE players SET travel_until=NULL, travel_destination_id=NULL, travel_mode=NULL, travel_started_at=NULL, travel_origin_planet_id=NULL, travel_origin_galaxy_id=NULL, travel_destination_galaxy_id=NULL WHERE id=?", (player["id"],))
        return get_player(conn, player["id"])
    mode = player.get("travel_mode") or ("galaxy" if origin and int(origin.get("galaxy_id") or 0) != int(dest.get("galaxy_id") or 0) else "local")
    if mode == "intercept":
        return resolve_completed_intercept(conn, player, dest, origin)
    if mode == "waypoint":
        return resolve_completed_waypoint(conn, player, dest, origin)
    if mode == "galaxy_route":
        advanced = advance_player_galaxy_route(conn, player, dest, origin)
        if advanced:
            return advanced
        mode = "galaxy"
    clear_player_open_space(conn, player["id"])
    clear_player_waypoint(conn, player["id"])
    clear_player_intercept(conn, player["id"])
    clear_player_route(conn, player["id"])
    visited_galaxies = json_list(player.get("visited_galaxies_json"))
    visited_planets = json_list(player.get("visited_planets_json"))
    galaxy_routes = json_list(player.get("visited_galaxy_routes_json"))
    local_routes = json_list(player.get("visited_local_routes_json"))
    visited_planets.append(int(dest["id"]))
    if origin:
        visited_planets.append(int(origin["id"]))
    if mode == "galaxy":
        og = int(player.get("travel_origin_galaxy_id") or (origin.get("galaxy_id") if origin else dest.get("galaxy_id")) or dest.get("galaxy_id"))
        dg = int(dest.get("galaxy_id"))
        visited_galaxies.extend([og, dg])
        galaxy_routes.append(route_key(og, dg))
        msg = f"Arrived in {dest['dest_galaxy_name']} at {dest['name']}."
    else:
        if origin:
            local_routes.append(route_key(origin["id"], dest["id"]))
        visited_galaxies.append(int(dest.get("galaxy_id")))
        msg = f"Docked at {dest['name']}. Ship left the map and cannot be attacked while docked." if mode == "dock" else f"Arrived at {dest['name']}."
    conn.execute(
        """
        UPDATE players
        SET location_planet_id=?, travel_until=NULL, travel_destination_id=NULL, travel_mode=NULL,
            travel_started_at=NULL, travel_origin_planet_id=NULL, travel_origin_galaxy_id=NULL, travel_destination_galaxy_id=NULL,
            visited_galaxies_json=?, visited_planets_json=?, visited_galaxy_routes_json=?, visited_local_routes_json=?
        WHERE id=?
        """,
        (
            dest["id"], limited_json_list(visited_galaxies, TRAVEL_BALANCE["max_visited"]),
            limited_json_list(visited_planets, TRAVEL_BALANCE["max_visited"]),
            limited_json_list(galaxy_routes, TRAVEL_BALANCE["max_history_routes"]),
            limited_json_list(local_routes, TRAVEL_BALANCE["max_history_routes"]), player["id"],
        ),
    )
    add_event(conn, player["id"], "travel", msg, {"mode": mode, "destination_planet_id": dest["id"], "destination_galaxy_id": dest.get("galaxy_id")})
    conn.execute("INSERT INTO npc_action_log (planet_id,action_type,actor_name,message,impact_json,created_at) VALUES (?,?,?,?,?,?)", (dest["id"], "travel", "Traffic Control", msg, encode_json({"severity":"info","location_id":dest["id"]}), iso()))
    return get_player(conn, player["id"])


def build_travel_state(conn: sqlite3.Connection, player: Dict[str, Any]) -> Dict[str, Any]:
    origin = row(conn, "SELECT p.*, g.name as galaxy_name, g.id as galaxy_id FROM planets p JOIN galaxies g ON g.id=p.galaxy_id WHERE p.id=?", (player.get("travel_origin_planet_id") or player.get("location_planet_id"),))
    dest = row(conn, "SELECT p.*, g.name as galaxy_name, g.id as galaxy_id FROM planets p JOIN galaxies g ON g.id=p.galaxy_id WHERE p.id=?", (player.get("travel_destination_id"),)) if player.get("travel_destination_id") else None
    started = parse_dt(player.get("travel_started_at"))
    until = parse_dt(player.get("travel_until"))
    now = utcnow()
    active = bool(until and until > now and dest)
    total_seconds = max(1, int((until - started).total_seconds())) if active and started and until else 1
    elapsed = max(0, int((now - started).total_seconds())) if active and started else 0
    progress = max(0.0, min(1.0, elapsed / total_seconds)) if active else 1.0
    intercept_meta = get_player_intercept(conn, player["id"]) if (player.get("travel_mode") == "intercept") else {}
    waypoint_meta = get_player_waypoint(conn, player["id"]) if (player.get("travel_mode") == "waypoint") else {}
    route_meta = get_player_route(conn, player["id"]) if active and player.get("travel_mode") in {"local", "galaxy", "dock", "galaxy_route"} else {}
    open_space_meta = get_player_open_space(conn, player["id"]) if not active else {}
    travel_meta = intercept_meta or waypoint_meta or route_meta
    in_open_space = bool(open_space_meta.get("active")) and not active
    dest_x = travel_meta.get("destination_x_pct") if travel_meta.get("destination_x_pct") is not None else travel_meta.get("x_pct")
    dest_y = travel_meta.get("destination_y_pct") if travel_meta.get("destination_y_pct") is not None else travel_meta.get("y_pct")
    route_segments = decode_json(route_meta.get("route_segments_json"), []) if route_meta else []
    return {
        "active": active,
        "docked": (not active and not in_open_space),
        "open_space": in_open_space,
        "open_space_x_pct": open_space_meta.get("x_pct") if in_open_space else None,
        "open_space_y_pct": open_space_meta.get("y_pct") if in_open_space else None,
        "open_space_map_type": open_space_meta.get("map_type") if in_open_space else None,
        "dock_planet_id": player.get("location_planet_id") if (not active and not in_open_space) else None,
        "map_type": travel_meta.get("map_type") if travel_meta else (open_space_meta.get("map_type") if in_open_space else None),
        "mode": player.get("travel_mode") or None,
        "intercept_target_ref": intercept_meta.get("target_ref"),
        "intercept_target_name": intercept_meta.get("target_name"),
        "destination_x_pct": dest_x if travel_meta else None,
        "destination_y_pct": dest_y if travel_meta else None,
        "origin_x_pct": travel_meta.get("origin_x_pct") if travel_meta else None,
        "origin_y_pct": travel_meta.get("origin_y_pct") if travel_meta else None,
        "origin_planet_id": origin.get("id") if origin else None,
        "origin_planet_name": origin.get("name") if origin else None,
        "origin_galaxy_id": int(player.get("travel_origin_galaxy_id") or (origin.get("galaxy_id") if origin else 0) or 0),
        "origin_galaxy_name": origin.get("galaxy_name") if origin else None,
        "destination_planet_id": dest.get("id") if dest else None,
        "destination_planet_name": dest.get("name") if dest else None,
        "destination_galaxy_id": int(player.get("travel_destination_galaxy_id") or (dest.get("galaxy_id") if dest else 0) or 0),
        "destination_galaxy_name": dest.get("galaxy_name") if dest else None,
        "started_at": player.get("travel_started_at"),
        "arrival_at": player.get("travel_until"),
        "elapsed_seconds": elapsed if active else 0,
        "remaining_seconds": max(0, int((until - now).total_seconds())) if active and until else 0,
        "total_seconds": total_seconds if active else 0,
        "progress": round(progress, 4),
        "progress_pct": round(progress * 100, 1),
        "visited_galaxies": json_list(player.get("visited_galaxies_json")),
        "visited_planets": json_list(player.get("visited_planets_json")),
        "visited_galaxy_routes": json_list(player.get("visited_galaxy_routes_json")),
        "visited_local_routes": json_list(player.get("visited_local_routes_json")),
        "route_segments": route_segments,
        "route_segment_index": int(route_meta.get("route_segment_index") or 0) if route_meta else 0,
        "route_final_galaxy_id": route_meta.get("route_final_galaxy_id") if route_meta else None,
        "route_final_galaxy_name": route_meta.get("route_final_galaxy_name") if route_meta else None,
        "route_label": route_meta.get("label") if route_meta else None,
    }


def planet_visual_payload(planet: Dict[str, Any]) -> str:
    economy = str(planet.get("economy_type") or planet_economy_type(planet)).lower()
    color = {"industrial":"ffc247", "extraction":"4dff91", "trade":"35f2ff", "black_market":"ff4d9d", "research":"a65cff", "core":"8cffff", "balanced":"35f2ff"}.get(economy, "35f2ff")
    initials = "".join([x[:1] for x in str(planet.get("name") or "PL").split()[:2]]).upper() or "PL"
    svg = f"""<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 96 96'><defs><radialGradient id='p' cx='35%' cy='30%' r='70%'><stop offset='0%' stop-color='#{color}' stop-opacity='.85'/><stop offset='56%' stop-color='#102736'/><stop offset='100%' stop-color='#02060b'/></radialGradient></defs><rect width='96' height='96' rx='18' fill='#02060b'/><circle cx='48' cy='48' r='31' fill='url(#p)' stroke='#{color}' stroke-width='2'/><path d='M20 58 C35 50 58 74 78 42' stroke='#{color}' stroke-opacity='.45' stroke-width='4' fill='none'/><text x='48' y='55' text-anchor='middle' font-family='Segoe UI,Arial' font-size='20' font-weight='900' fill='#{color}'>{initials[:2]}</text></svg>"""
    return "data:image/svg+xml;utf8," + quote(svg)


def galaxy_visual_payload(galaxy: Dict[str, Any]) -> str:
    color = {"green":"4dff91","purple":"a65cff","orange":"ffae35","blue":"35f2ff"}.get(str(galaxy.get("color") or "blue"), "35f2ff")
    initials = "".join([x[:1] for x in str(galaxy.get("name") or "GX").split()[:2]]).upper() or "GX"
    svg = f"""<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 120'><defs><radialGradient id='g' cx='50%' cy='50%' r='55%'><stop offset='0%' stop-color='#{color}' stop-opacity='.95'/><stop offset='45%' stop-color='#{color}' stop-opacity='.35'/><stop offset='100%' stop-color='#02060b' stop-opacity='0'/></radialGradient></defs><rect width='120' height='120' fill='#02060b'/><circle cx='60' cy='60' r='47' fill='url(#g)'/><ellipse cx='60' cy='60' rx='53' ry='18' fill='none' stroke='#{color}' stroke-opacity='.55' stroke-width='3' transform='rotate(-22 60 60)'/><text x='60' y='68' text-anchor='middle' font-family='Segoe UI,Arial' font-size='24' font-weight='900' fill='#{color}'>{initials[:2]}</text></svg>"""
    return "data:image/svg+xml;utf8," + quote(svg)



def clamp_pct(v: float, low: float = 3.0, high: float = 97.0) -> float:
    return round(max(low, min(high, float(v))), 2)


def deterministic_between(a: Dict[str, Any], b: Dict[str, Any], progress: float) -> Dict[str, float]:
    return {"x_pct": clamp_pct(float(a.get("x_pct") or 50) + (float(b.get("x_pct") or 50) - float(a.get("x_pct") or 50)) * progress), "y_pct": clamp_pct(float(a.get("y_pct") or 50) + (float(b.get("y_pct") or 50) - float(a.get("y_pct") or 50)) * progress)}


def pct_distance(a: Dict[str, Any], b: Dict[str, Any]) -> float:
    return ((float(a.get("x_pct") or 50) - float(b.get("x_pct") or 50)) ** 2 + (float(a.get("y_pct") or 50) - float(b.get("y_pct") or 50)) ** 2) ** 0.5


def ship_radar_range_pct(conn: sqlite3.Connection, ship: Optional[Dict[str, Any]], map_type: str = "system") -> float:
    cfg = RADAR_BALANCE["galaxy" if map_type == "galaxy" else "system"]
    if not ship:
        return float(cfg["base_range_pct"])
    tier = clamp_tier(ship.get("current_tier", ship.get("ship_tier", 1)))
    radar_strength = 0.0
    scan_strength = 0.0
    try:
        for m in ship_installed_modules(conn, int(ship["id"])):
            stats = m.get("stats") or {}
            durability = max(0.1, float(m.get("durability") or 100) / 100.0)
            radar_strength += (float(stats.get("radar_strength") or 0) + float(stats.get("radar_range") or 0)) * durability
            scan_strength += float(stats.get("scanning") or 0) * durability
    except Exception:
        radar_strength = 0.0
        scan_strength = 0.0
    role = str(ship.get("role") or ship.get("class_name") or "").lower()
    role_bonus = 0.0
    for key, bonus in cfg.get("role_bonus", {}).items():
        if key in role:
            role_bonus = float(bonus)
            break
    range_pct = (
        float(cfg["base_range_pct"])
        + float(cfg["tier_bonus_pct"]) * max(0, tier - 1)
        + float(cfg["radar_stat_mult"]) * radar_strength
        + float(cfg["scanner_stat_mult"]) * scan_strength
        + role_bonus
    )
    return round(max(float(cfg["min_pct"]), min(float(cfg["max_pct"]), range_pct)), 2)


def active_ship_for_player(conn: sqlite3.Connection, player: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    if not player.get("active_ship_id"):
        return None
    ship = row(conn, "SELECT s.*, t.name as template_name, t.class_name, t.role, t.slots_json, t.ship_tier, t.size_class as template_size_class, t.mass as template_mass FROM ships s JOIN ship_templates t ON t.id=s.template_id WHERE s.id=?", (player.get("active_ship_id"),))
    if ship:
        ship["speed_profile"] = ship_speed_profile(conn, ship)
    return ship


def player_map_center(conn: sqlite3.Connection, player: Dict[str, Any], map_type: str, nodes: List[Dict[str, Any]]) -> Dict[str, Any]:
    travel = build_travel_state(conn, player)
    by_id = {int(n["id"]): n for n in nodes if str(n.get("id") or "").isdigit()}
    if travel.get("active"):
        origin_key = "origin_galaxy_id" if map_type == "galaxy" else "origin_planet_id"
        dest_key = "destination_galaxy_id" if map_type == "galaxy" else "destination_planet_id"
        if travel.get("mode") in {"waypoint", "intercept"} and travel.get("destination_x_pct") is not None:
            o = {"x_pct": travel.get("origin_x_pct"), "y_pct": travel.get("origin_y_pct")} if travel.get("origin_x_pct") is not None else by_id.get(int(travel.get(origin_key) or 0))
            if o:
                return deterministic_between(o, {"x_pct": travel.get("destination_x_pct"), "y_pct": travel.get("destination_y_pct")}, float(travel.get("progress") or 0))
        o = by_id.get(int(travel.get(origin_key) or 0))
        d = by_id.get(int(travel.get(dest_key) or 0))
        if o and d:
            return deterministic_between(o, d, float(travel.get("progress") or 0))
    if travel.get("open_space") and (not travel.get("open_space_map_type") or travel.get("open_space_map_type") == map_type):
        return {"x_pct": float(travel.get("open_space_x_pct") or 50), "y_pct": float(travel.get("open_space_y_pct") or 50)}
    current_key = None
    if map_type == "galaxy":
        current_planet = row(conn, "SELECT galaxy_id FROM planets WHERE id=?", (player.get("location_planet_id"),))
        current_key = int((current_planet or {}).get("galaxy_id") or 0)
    else:
        current_key = int(player.get("location_planet_id") or 0)
    return by_id.get(current_key) or (nodes[0] if nodes else {"x_pct": 50, "y_pct": 50})


def annotate_and_filter_by_player_radar(conn: sqlite3.Connection, player: Dict[str, Any], nodes: List[Dict[str, Any]], objects: List[Dict[str, Any]], map_type: str) -> List[Dict[str, Any]]:
    ship = active_ship_for_player(conn, player)
    radar_range = ship_radar_range_pct(conn, ship, map_type)
    center = player_map_center(conn, player, map_type, nodes)
    visible: List[Dict[str, Any]] = []
    for obj in objects:
        # The local player is rendered from travel_state only. Never re-emit player:self as traffic.
        if obj.get("id") == "player:self" or (obj.get("kind") == "self"):
            continue
        d = pct_distance(center, obj)
        if d <= radar_range:
            visible.append({**obj, "radarVisible": True, "radarDistancePct": round(d, 2), "radarRangePct": radar_range})
    return visible


def npc_radar_range_pct(npc: Dict[str, Any], map_type: str = "system") -> float:
    role = str(npc.get("role") or npc.get("career_code") or "pilot").lower()
    base = float(RADAR_BALANCE["npc_base_pct"].get(role, RADAR_BALANCE["npc_base_pct"].get("pilot", 12.0)))
    if map_type == "galaxy":
        base *= 0.68
    level_bonus = float(npc.get("level") or 1) * float(RADAR_BALANCE["npc_level_pct"])
    aggression_bonus = float(RADAR_BALANCE["npc_aggression_bonus_pct"]) if int(npc.get("aggression") or 0) >= 75 else 0.0
    return round(max(6.0, min(30.0 if map_type == "galaxy" else 44.0, base + level_bonus + aggression_bonus)), 2)


def npc_visible_objects(npc_point: Dict[str, Any], radar_range: float, objects: List[Dict[str, Any]], kind_filter: Optional[str] = None) -> List[Dict[str, Any]]:
    candidates = [o for o in objects if (not kind_filter or o.get("kind") == kind_filter)]
    return [o for o in candidates if pct_distance(npc_point, o) <= radar_range]


def weighted_choice_from_dict(rng: random.Random, weights: Dict[str, float]) -> str:
    cleaned = {k: max(0.0, float(v or 0)) for k, v in weights.items()}
    total = sum(cleaned.values())
    if total <= 0:
        return "search"
    roll = rng.uniform(0, total)
    upto = 0.0
    for key, weight in cleaned.items():
        upto += weight
        if roll <= upto:
            return key
    return next(reversed(cleaned.keys())) if cleaned else "search"


def npc_alignment_tags(npc: Dict[str, Any]) -> Dict[str, Any]:
    role = str(npc.get("role") or npc.get("career_code") or "pilot").lower()
    career = str(npc.get("career_code") or role or "pilot").lower()
    aggression = int(npc.get("aggression") or 0)
    friendliness = int(npc.get("friendliness") or 0)
    disposition = str(npc.get("disposition") or "").lower()
    bad = (
        role in COMBAT_LEGAL_ROLES
        or career in {"smuggler", "mercenary"}
        or "pirate" in role
        or "raider" in role
        or aggression >= int(NPC_OBJECTIVE_BALANCE["bad_guy_aggression_threshold"])
        or disposition == "hostile"
    )
    good = (
        career in {"security_pilot", "marshal", "medic", "diplomat", "dockmaster"}
        or role in COMBAT_SECURITY_ROLES
        or friendliness >= int(NPC_OBJECTIVE_BALANCE["good_guy_friendliness_threshold"])
        or disposition == "friendly"
    )
    return {
        "role": role,
        "career": career,
        "aggression": aggression,
        "friendliness": friendliness,
        "bad": bad,
        "good": good,
        "explorer": career == "explorer" or "explor" in role or "scout" in role,
        "miner": career == "miner" or "miner" in role,
        "salvager": career == "salvager" or "salvage" in role,
        "pirate": bad and not good,
        "security": career in {"security_pilot", "marshal"} or role in COMBAT_SECURITY_ROLES,
        "trader": career in {"trader", "quartermaster", "dockmaster"} or "trader" in role or "hauler" in role,
        "smuggler": career == "smuggler" or "smuggl" in role,
    }


def npc_objective_weights(npc: Dict[str, Any], visible_by_kind: Dict[str, List[Dict[str, Any]]], map_type: str) -> Dict[str, float]:
    tags = npc_alignment_tags(npc)
    weights = dict(NPC_OBJECTIVE_BALANCE["base_weights"])
    for key, value in NPC_OBJECTIVE_BALANCE["career_weights"].get(tags["career"], {}).items():
        weights[key] = weights.get(key, 0) + value

    if tags["bad"]:
        weights["pirate_intercept"] = weights.get("pirate_intercept", 0) + 18 + max(0, tags["aggression"] - 50) / 2
        weights["smuggle"] = weights.get("smuggle", 0) + 8
        weights["patrol_scan"] = max(1, weights.get("patrol_scan", 0) - 4)
        weights["escort"] = max(1, weights.get("escort", 0) - 2)

    if tags["good"]:
        weights["patrol_scan"] = weights.get("patrol_scan", 0) + 14
        weights["escort"] = weights.get("escort", 0) + 8
        weights["bounty_hunt"] = weights.get("bounty_hunt", 0) + 6
        weights["pirate_intercept"] = max(1, weights.get("pirate_intercept", 0) - 4)

    if tags["explorer"]:
        weights["explore"] = weights.get("explore", 0) + 18
        weights["search"] = weights.get("search", 0) + 6
    if tags["miner"]:
        weights["mine"] = weights.get("mine", 0) + 18
    if tags["salvager"]:
        weights["salvage"] = weights.get("salvage", 0) + 18
    if tags["trader"]:
        weights["trade_haul"] = weights.get("trade_haul", 0) + 16
    if tags["smuggler"]:
        weights["smuggle"] = weights.get("smuggle", 0) + 18

    contact_bonus = float(NPC_OBJECTIVE_BALANCE["visible_target_bonus"])
    no_target_bonus = float(NPC_OBJECTIVE_BALANCE["no_target_search_bonus"])
    if visible_by_kind.get("ore"):
        weights["mine"] = weights.get("mine", 0) + contact_bonus
    else:
        weights["mine"] = weights.get("mine", 0) * 0.45

    if visible_by_kind.get("salvage"):
        weights["salvage"] = weights.get("salvage", 0) + contact_bonus
    else:
        weights["salvage"] = weights.get("salvage", 0) * 0.45

    if visible_by_kind.get("exploration"):
        weights["explore"] = weights.get("explore", 0) + contact_bonus
    else:
        weights["explore"] = weights.get("explore", 0) * 0.55

    if visible_by_kind.get("ship"):
        weights["pirate_intercept"] = weights.get("pirate_intercept", 0) + (contact_bonus if tags["bad"] else contact_bonus * 0.25)
        weights["bounty_hunt"] = weights.get("bounty_hunt", 0) + (contact_bonus if tags["good"] or tags["security"] else contact_bonus * 0.35)
    else:
        weights["pirate_intercept"] = weights.get("pirate_intercept", 0) * 0.35
        weights["bounty_hunt"] = weights.get("bounty_hunt", 0) * 0.45

    if not any(visible_by_kind.values()):
        weights["search"] = weights.get("search", 0) + no_target_bonus
        weights["dock_refuel"] = weights.get("dock_refuel", 0) + 4

    if map_type == "galaxy":
        weights["trade_haul"] = weights.get("trade_haul", 0) + 4
        weights["smuggle"] = weights.get("smuggle", 0) + 3
        weights["mine"] = weights.get("mine", 0) * 0.85
        weights["salvage"] = weights.get("salvage", 0) * 0.85

    return weights


def nearest_node_to_object(nodes: List[Dict[str, Any]], obj: Dict[str, Any], exclude_id: Optional[int] = None) -> Optional[Dict[str, Any]]:
    candidates = [n for n in nodes if str(n.get("id") or "").isdigit() and (exclude_id is None or int(n.get("id") or 0) != int(exclude_id))]
    if not candidates:
        candidates = nodes
    return min(candidates, key=lambda n: pct_distance(n, obj)) if candidates else None


def npc_choose_objective_and_route(
    npc: Dict[str, Any],
    map_type: str,
    nodes: List[Dict[str, Any]],
    by_id: Dict[int, Dict[str, Any]],
    route_rng: random.Random,
    npc_point: Dict[str, Any],
    radar_range: float,
    radar_objects: List[Dict[str, Any]],
    traffic_so_far: List[Dict[str, Any]],
    default_origin_id: int,
    default_dest_id: int,
) -> Dict[str, Any]:
    visible_ore = npc_visible_objects(npc_point, radar_range, radar_objects, "ore")
    visible_salvage = npc_visible_objects(npc_point, radar_range, radar_objects, "salvage")
    visible_explore = npc_visible_objects(npc_point, radar_range, radar_objects, "exploration")
    visible_ships = [
        t for t in traffic_so_far
        if t.get("id") != "player:self" and pct_distance(npc_point, t) <= radar_range
    ]
    visible_by_kind = {
        "ore": visible_ore,
        "salvage": visible_salvage,
        "exploration": visible_explore,
        "ship": visible_ships,
    }
    weights = npc_objective_weights(npc, visible_by_kind, map_type)
    objective = weighted_choice_from_dict(route_rng, weights)

    target_obj: Optional[Dict[str, Any]] = None
    objective_label = "Search / sweep"
    action_state = "searching"
    target_kind = ""
    target_name = ""

    def pick_visible(items: List[Dict[str, Any]]) -> Optional[Dict[str, Any]]:
        if not items:
            return None
        # Prefer closer contacts, but still allow some RNG variance.
        ordered = sorted(items, key=lambda x: pct_distance(npc_point, x))[:4]
        return route_rng.choice(ordered)

    if objective == "mine":
        target_obj = pick_visible(visible_ore)
        objective_label = "Mine ore"
        action_state = "en route to mine visible ore" if target_obj else "searching for ore outside radar"
        target_kind = "ore"
    elif objective == "salvage":
        target_obj = pick_visible(visible_salvage)
        objective_label = "Salvage wreck"
        action_state = "en route to salvage visible wreckage" if target_obj else "searching for salvage outside radar"
        target_kind = "salvage"
    elif objective == "explore":
        target_obj = pick_visible(visible_explore)
        objective_label = "Scan ancient site"
        action_state = "en route to scan visible ancient signal" if target_obj else "surveying for unknown ancient signals"
        target_kind = "exploration"
    elif objective == "pirate_intercept":
        target_obj = pick_visible(visible_ships)
        objective_label = "Pirate intercept"
        action_state = "stalking radar-visible ship" if target_obj else "hunting blind beyond radar"
        target_kind = "ship"
    elif objective == "bounty_hunt":
        target_obj = pick_visible([s for s in visible_ships if s.get("hostile")])
        if not target_obj:
            target_obj = pick_visible(visible_ships)
        objective_label = "Bounty hunt"
        action_state = "tracking radar-visible hostile" if target_obj else "searching for hostile contacts"
        target_kind = "ship"
    elif objective == "patrol_scan":
        target_obj = pick_visible(visible_ships) or pick_visible(visible_explore) or pick_visible(visible_salvage)
        objective_label = "Patrol / scan"
        action_state = "investigating radar contact" if target_obj else "patrolling empty radar"
        target_kind = target_obj.get("kind", "") if target_obj else ""
    elif objective == "smuggle":
        objective_label = "Smuggle cargo"
        action_state = "running a low-profile route"
    elif objective == "trade_haul":
        objective_label = "Trade haul"
        action_state = "hauling cargo between markets"
    elif objective == "escort":
        target_obj = pick_visible(visible_ships)
        objective_label = "Escort"
        action_state = "shadowing radar-visible traffic" if target_obj else "moving to assigned escort lane"
        target_kind = "ship"
    elif objective == "dock_refuel":
        objective_label = "Dock / refuel"
        action_state = "returning to dock for refuel"

    target_x = None
    target_y = None
    if target_obj:
        target_name = target_obj.get("name") or target_obj.get("ship_name") or target_obj.get("label") or label_for_api(target_kind or "contact")
        target_x = float(target_obj.get("x_pct") or 50)
        target_y = float(target_obj.get("y_pct") or 50)
        target_node = nearest_node_to_object(nodes, target_obj, exclude_id=default_origin_id)
        d_id = int(target_node.get("id")) if target_node else default_dest_id
    else:
        # Objective search routes still have intent: go to a region likely to produce the desired contact.
        candidate_nodes = [n for n in nodes if str(n.get("id") or "").isdigit() and int(n.get("id") or 0) != int(default_origin_id)]
        if objective in {"trade_haul", "smuggle"}:
            candidate_nodes = sorted(candidate_nodes, key=lambda n: int(n.get("market_activity_avg") or n.get("market_activity") or n.get("legal_market_strength") or 50), reverse=True)
        elif objective in {"pirate_intercept", "bounty_hunt", "patrol_scan"}:
            candidate_nodes = sorted(candidate_nodes, key=lambda n: int(n.get("conflict_avg") or n.get("risk_level") or n.get("pirate_activity") or 30), reverse=True)
        elif objective in {"mine", "salvage", "explore"}:
            candidate_nodes = sorted(candidate_nodes, key=lambda n: int(n.get("risk_level") or n.get("conflict_avg") or n.get("ancient_site_count") or 25), reverse=True)
        if candidate_nodes:
            d_id = int(route_rng.choice(candidate_nodes[:min(4, len(candidate_nodes))]).get("id"))
        else:
            d_id = default_dest_id

    return {
        "objective": objective,
        "objectiveLabel": objective_label,
        "objectiveState": action_state,
        "objectiveTargetKind": target_kind,
        "objectiveTargetName": target_name,
        "objectiveHasTarget": bool(target_obj),
        "objectiveDestinationId": d_id,
        "objectiveTargetX": target_x,
        "objectiveTargetY": target_y,
        "objectiveTargetObjectKey": (target_obj or {}).get("objectKey") or (target_obj or {}).get("siteId") or (target_obj or {}).get("explorationSiteId") or (target_obj or {}).get("salvageSiteId") or (target_obj or {}).get("id") or "",
        "visibleCounts": {k: len(v) for k, v in visible_by_kind.items()},
        "objectiveWeights": {k: round(float(v), 1) for k, v in weights.items() if float(v) > 0},
    }


def build_open_world_traffic(conn: sqlite3.Connection, player: Dict[str, Any], map_type: str, nodes: List[Dict[str, Any]], radar_objects: Optional[List[Dict[str, Any]]] = None) -> List[Dict[str, Any]]:
    if len(nodes) < 2:
        return []
    radar_objects = radar_objects or []
    by_id = {int(n["id"]): n for n in nodes if str(n.get("id") or "").isdigit()}
    traffic: List[Dict[str, Any]] = []
    travel = build_travel_state(conn, player)

    # The local player is not part of traffic. The frontend renders one canonical self ship
    # from travel_state/open-space state. Emitting player:self here caused the orange follower marker.

    # Real other players in transit, if any exist in persistence.
    for other in rows(conn, """SELECT p.*, u.id as user_id, u.username, up.display_name, up.avatar_id, up.selected_badge_code FROM players p JOIN users u ON u.id=p.user_id LEFT JOIN user_profiles up ON up.user_id=u.id WHERE p.id<>? AND p.travel_until IS NOT NULL ORDER BY p.id LIMIT 12""", (player["id"],)):
        tv = build_travel_state(conn, other)
        if not tv.get("active"):
            continue
        origin_key = "origin_galaxy_id" if map_type == "galaxy" else "origin_planet_id"
        dest_key = "destination_galaxy_id" if map_type == "galaxy" else "destination_planet_id"
        o = by_id.get(int(tv.get(origin_key) or 0)); d = by_id.get(int(tv.get(dest_key) or 0))
        if not o or not d:
            continue
        pt = deterministic_between(o, d, float(tv.get("progress") or 0))
        traffic.append({"id":f"player:{other['id']}", "combatTargetRef":f"player:{other['id']}", "kind":"player", "userId":other.get("user_id"), "playerId":other.get("id"), "profileUserId":other.get("user_id"), "avatarId":other.get("avatar_id"), "selectedBadgeCode":other.get("selected_badge_code"), "name":other.get("display_name") or other.get("username") or "Player", "role":"player", "from":o["id"], "to":d["id"], "progress":round(float(tv.get("progress") or 0)*100,1), **pt, "attackable":True, "label":"Player in transit. Intercept happens in open space without planetary defense."})

    # Persistent NPC traffic is server-side and DB-backed. NPCs move to an objective,
    # perform a short action there, then pick a new objective from their current position.
    max_count = OPEN_WORLD_BALANCE["galaxy_npc_traffic"] if map_type == "galaxy" else OPEN_WORLD_BALANCE["system_npc_traffic"]
    traffic.extend(build_persistent_npc_traffic(conn, player, map_type, nodes, by_id, radar_objects, traffic, max_count))
    traffic = [t for t in traffic if t.get("id") != "player:self" and t.get("kind") != "self"]
    return traffic[:max_count]




def current_map_scope(conn: sqlite3.Connection, player: Dict[str, Any], map_type: str) -> Dict[str, Any]:
    current = row(conn, "SELECT p.*, g.id as galaxy_id FROM planets p JOIN galaxies g ON g.id=p.galaxy_id WHERE p.id=?", (player.get("location_planet_id"),))
    gid = int((current or {}).get("galaxy_id") or 0)
    pid = int((current or {}).get("id") or 0) if map_type == "system" else None
    return {"galaxy_id": gid, "planet_id": pid, "current": current}


def map_object_scope_key(map_type: str, galaxy_id: int, planet_id: Optional[int]) -> str:
    return f"{map_type}:g{int(galaxy_id or 0)}:p{int(planet_id or 0)}"


def find_nearest_node(nodes: List[Dict[str, Any]], x_pct: float, y_pct: float) -> Dict[str, Any]:
    if not nodes:
        return {"name": "open space", "x_pct": 50, "y_pct": 50}
    return min(nodes, key=lambda n: ((float(n.get("x_pct") or 50)-x_pct)**2 + (float(n.get("y_pct") or 50)-y_pct)**2))


def map_object_to_payload(obj: Dict[str, Any], player: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    meta = decode_json(obj.get("metadata_json"), {}) or {}
    kind = str(obj.get("kind") or meta.get("kind") or "object")
    base = {
        "dbId": obj.get("id"),
        "objectKey": obj.get("object_key"),
        "id": obj.get("object_key"),
        "siteId": obj.get("object_key"),
        "explorationSiteId": obj.get("object_key"),
        "salvageSiteId": obj.get("object_key"),
        "kind": kind,
        "code": obj.get("code"),
        "name": obj.get("name"),
        "x_pct": float(obj.get("x_pct") or 50),
        "y_pct": float(obj.get("y_pct") or 50),
        "tier": int(obj.get("tier") or 1),
        "qty": int(obj.get("qty_remaining") or 0),
        "qtyRemaining": int(obj.get("qty_remaining") or 0),
        "state": obj.get("state") or "available",
        "operationType": obj.get("operation_type") or "",
        "operationUntil": obj.get("operation_until"),
        "expiresAt": obj.get("expires_at"),
        "map_type": obj.get("map_type"),
        "mapType": obj.get("map_type"),
        "image_url": meta.get("image_url") or "/assets/fallbacks/material.svg",
        "selectedSummary": meta.get("selectedSummary") or "",
        "outcomeFactors": meta.get("outcomeFactors") or "",
        "label": meta.get("label") or obj.get("name"),
        **meta,
    }
    if kind == "ore":
        base.update({
            "oreCode": obj.get("code"),
            "energyCost": int(meta.get("energyCost") or meta.get("energy_cost") or 10),
            "massEach": float(meta.get("massEach") or 1.0),
            "unitValue": int(meta.get("unitValue") or 60),
            "siteId": obj.get("object_key"),
        })
    elif kind == "exploration":
        base.update({
            "siteCode": obj.get("code"),
            "explorationSiteId": obj.get("object_key"),
            "signalState": meta.get("signalState") or "unknown",
            "signalQuality": int(meta.get("signalQuality") or 50),
            "rewardTier": int(meta.get("rewardTier") or obj.get("tier") or 1),
            "rewardHint": meta.get("rewardHint") or "Unknown",
            "riskLevel": int(meta.get("riskLevel") or 40),
            "riskBand": meta.get("riskBand") or "Moderate",
            "scanEnergy": int(meta.get("scanEnergy") or OPEN_WORLD_BALANCE.get("scan_site_energy", 6)),
            "investigateEnergy": int(meta.get("investigateEnergy") or OPEN_WORLD_BALANCE.get("investigate_site_energy", 12)),
            "realName": meta.get("realName") or obj.get("name"),
        })
    elif kind == "salvage":
        base.update({"salvageSiteId": obj.get("object_key"), "energy_cost": int(meta.get("energy_cost") or 10)})
    return base


def ensure_db_map_objects(conn: sqlite3.Connection, player: Dict[str, Any], nodes: List[Dict[str, Any]], map_type: str) -> None:
    scope = current_map_scope(conn, player, map_type)
    gid = int(scope["galaxy_id"] or 0)
    pid = scope["planet_id"]
    if not gid or not nodes:
        return
    scope_key = map_object_scope_key(map_type, gid, pid)
    existing = int(scalar(conn, "SELECT COUNT(*) FROM map_objects WHERE map_type=? AND galaxy_id=? AND COALESCE(planet_id,0)=?", (map_type, gid, int(pid or 0))) or 0)
    now = iso()
    if existing:
        # Clear expired/depleted temporary rows but leave permanent resource fields.
        conn.execute("UPDATE map_objects SET state='depleted' WHERE qty_remaining<=0 AND map_type=? AND galaxy_id=? AND COALESCE(planet_id,0)=?", (map_type, gid, int(pid or 0)))
        return

    rng = random.Random(f"db-map-objects:{scope_key}")
    ores = [
        ("titanium", "Titanium Ore", 1, 1.0, 28),
        ("nickel_iron", "Nickel-Iron Rock", 1, 1.1, 24),
        ("helium_3", "Helium-3 Pocket", 2, 0.7, 120),
        ("iridium", "Iridium Shards", 3, 0.45, 260),
        ("quantum_silicate", "Quantum Silicate", 4, 0.55, 760),
        ("void_crystal", "Void Crystal", 5, 0.25, 1450),
    ]
    ore_count = OPEN_WORLD_BALANCE["ore_sites_per_galaxy"] if map_type == "galaxy" else OPEN_WORLD_BALANCE["ore_sites_per_system"]
    for i in range(int(ore_count)):
        anchor = rng.choice(nodes)
        center_value = int(anchor.get("center_value") or 1)
        weighted_ores = []
        for ore in ores:
            w = max(1, int((center_value + 1) ** max(1, ore[2] - 1)))
            if ore[2] <= center_value + 1:
                weighted_ores.extend([ore] * w)
        code, name, tier, mass, value = rng.choice(weighted_ores or ores)
        qty = rng.randint(8, 34) + tier * 5 + max(0, center_value - 2) * 4
        energy = clamp_int(OPEN_WORLD_BALANCE["ore_mine_min_energy"] + tier * 4 + qty // 4, OPEN_WORLD_BALANCE["ore_mine_min_energy"], OPEN_WORLD_BALANCE["ore_mine_max_energy"])
        x = clamp_pct(float(anchor.get("x_pct") or 50) + rng.uniform(-8, 8), 3, 97)
        y = clamp_pct(float(anchor.get("y_pct") or 50) + rng.uniform(-8, 8), 3, 97)
        key = f"mapobj:{scope_key}:ore:{code}:{i}"
        meta = {
            "kind": "ore",
            "energyCost": energy,
            "massEach": mass,
            "unitValue": value,
            "label": f"Mine {qty}x {name}. Backend tracked resource node.",
            "selectedSummary": f"{name} deposit near {anchor.get('name','open space')}. Tier {tier}, remaining {qty} units.",
            "outcomeFactors": "Mining yield uses DB node quantity, mining modules, mining skill, ship suitability, and cargo capacity.",
            "image_url": "/assets/fallbacks/material.svg",
        }
        conn.execute(
            "INSERT OR IGNORE INTO map_objects (object_key,map_type,galaxy_id,planet_id,kind,code,name,x_pct,y_pct,tier,qty_remaining,state,metadata_json,created_at,updated_at) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            (key, map_type, gid, pid, "ore", code, name, x, y, tier, qty, "available", encode_json(meta), now, now),
        )

    archetypes = [
        ("ancient_ruin", "Ancient Ruin", "partially resolved", 2),
        ("signal_echo", "Unknown Signal Echo", "unknown", 1),
        ("relic_vault", "Relic Vault", "high quality", 4),
        ("derelict_archive", "Derelict Archive", "partially resolved", 3),
        ("gravity_anomaly", "Gravity Anomaly", "unknown", 3),
        ("precursor_beacon", "Precursor Beacon", "high quality", 5),
    ]
    exp_count = OPEN_WORLD_BALANCE["exploration_sites_per_galaxy"] if map_type == "galaxy" else OPEN_WORLD_BALANCE["exploration_sites_per_system"]
    for i in range(int(exp_count)):
        code, base_name, state_label, base_tier = archetypes[rng.randrange(len(archetypes))]
        anchor = rng.choice(nodes)
        risk_level = clamp_int(int(anchor.get("risk_level") or anchor.get("conflict_avg") or anchor.get("security_avg") or 40) + rng.randint(-12, 18), 5, 98)
        center_value = int(anchor.get("center_value") or 1)
        reward_tier = clamp_int(base_tier + (1 if risk_level >= 65 else 0) + max(0, center_value - 2) + rng.choice([-1, 0, 0, 1]), 1, 7)
        quality = clamp_int(rng.randint(22, 88) + reward_tier * 3 - (10 if state_label == "unknown" else 0), 5, 99)
        signal_state = "unknown" if quality < 45 else "partial" if quality < 72 else "resolved"
        x = clamp_pct(float(anchor.get("x_pct") or 50) + rng.uniform(-10, 10), 3, 97)
        y = clamp_pct(float(anchor.get("y_pct") or 50) + rng.uniform(-10, 10), 3, 97)
        risk_band = "Extreme" if risk_level >= 80 else "High" if risk_level >= 60 else "Moderate" if risk_level >= 35 else "Low"
        reward_hint = "Jackpot" if reward_tier >= 5 else "High-value" if reward_tier >= 4 else "Useful" if reward_tier >= 2 else "Low-yield"
        real_name = f"{base_name} {chr(65 + (i % 26))}-{rng.randint(10, 99)}"
        key = f"mapobj:{scope_key}:explore:{code}:{i}"
        meta = {
            "kind": "exploration",
            "realName": real_name,
            "signalState": signal_state,
            "signalQuality": quality,
            "rewardTier": reward_tier,
            "rewardHint": reward_hint,
            "riskLevel": risk_level,
            "riskBand": risk_band,
            "scanEnergy": OPEN_WORLD_BALANCE["scan_site_energy"] + reward_tier,
            "investigateEnergy": OPEN_WORLD_BALANCE["investigate_site_energy"] + reward_tier * 2,
            "label": f"{real_name} • {risk_band} risk • {reward_hint} potential",
            "selectedSummary": f"{real_name} is a backend-persisted exploration contact. Signal quality {quality}%, risk {risk_band}.",
            "outcomeFactors": "Exploration result uses DB object state, signal quality, scan skill, exploration skill, ship scanner modules, and risk.",
            "image_url": "/assets/fallbacks/material.svg",
        }
        name = "Unknown Signal" if signal_state == "unknown" else real_name
        conn.execute(
            "INSERT OR IGNORE INTO map_objects (object_key,map_type,galaxy_id,planet_id,kind,code,name,x_pct,y_pct,tier,qty_remaining,state,metadata_json,created_at,updated_at) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            (key, map_type, gid, pid, "exploration", code, name, x, y, reward_tier, 1, "available", encode_json(meta), now, now),
        )


def db_map_objects(conn: sqlite3.Connection, player: Dict[str, Any], nodes: List[Dict[str, Any]], map_type: str, kind: Optional[str] = None) -> List[Dict[str, Any]]:
    ensure_db_map_objects(conn, player, nodes, map_type)
    scope = current_map_scope(conn, player, map_type)
    gid = int(scope["galaxy_id"] or 0)
    pid = scope["planet_id"]
    params = [map_type, gid, int(pid or 0)]
    sql = "SELECT * FROM map_objects WHERE map_type=? AND galaxy_id=? AND COALESCE(planet_id,0)=? AND state NOT IN ('deleted','expired') AND qty_remaining>0"
    if kind:
        sql += " AND kind=?"
        params.append(kind)
    sql += " ORDER BY id"
    return [map_object_to_payload(r, player) for r in rows(conn, sql, tuple(params))]


def active_player_map_operation(conn: sqlite3.Connection, player_id: int) -> Optional[Dict[str, Any]]:
    op = row(conn, "SELECT * FROM player_map_operations WHERE player_id=? AND status='active' ORDER BY id DESC LIMIT 1", (player_id,))
    if not op:
        return None
    ends = parse_dt(op.get("ends_at"))
    if ends and ends <= utcnow():
        conn.execute("UPDATE player_map_operations SET status='complete', updated_at=? WHERE id=?", (iso(), op["id"]))
        op["status"] = "complete"
    return op


def player_tool_capabilities(conn: sqlite3.Connection, player: Dict[str, Any]) -> Dict[str, Any]:
    ship_id = int(player.get("active_ship_id") or 0)
    equipped = rows(conn, "SELECT mt.code, mt.name, mt.slot_type, mt.stats_json, sm.equipped, sm.durability FROM ship_modules sm JOIN module_templates mt ON mt.id=sm.module_template_id WHERE sm.ship_id=? AND sm.equipped=1", (ship_id,))
    text = " ".join([f"{m.get('code','')} {m.get('name','')} {m.get('slot_type','')} {m.get('stats_json','')}" for m in equipped]).lower()
    stats_sum = {}
    for m in equipped:
        st = decode_json(m.get("stats_json"), {}) or {}
        for k, v in st.items():
            if isinstance(v, (int, float)):
                stats_sum[k] = stats_sum.get(k, 0) + float(v)
    has_weapon = any(str(m.get("slot_type") or "").lower() == "weapon" and "mining" not in str(m.get("code") or "").lower() for m in equipped)
    has_mining = "mining_laser" in text or "mining" in text or "drill" in text
    has_salvage = "salvage" in text or "wreck" in text or "grapple" in text
    has_scanner = "scanner" in text or "probe" in text or "relic" in text or "anomaly" in text or "radar" in text or float(stats_sum.get("scan_strength", 0)) > 0
    return {
        "can_attack": bool(has_weapon),
        "can_mine": bool(has_mining),
        "can_salvage": bool(has_salvage),
        "can_scan": bool(has_scanner),
        "can_investigate": bool(has_scanner),
        "equipped_count": len(equipped),
        "module_stats": stats_sum,
    }


def attach_tool_permissions(conn: sqlite3.Connection, player: Dict[str, Any], obj: Dict[str, Any]) -> Dict[str, Any]:
    caps = player_tool_capabilities(conn, player)
    kind = obj.get("kind")
    out = dict(obj)
    out["toolCaps"] = caps

    map_type = str(out.get("map_type") or out.get("mapType") or ("galaxy" if kind == "war_zone" else "system")).lower()
    if map_type not in {"system", "galaxy"}:
        map_type = "system"
    range_status = None
    if kind in {"ore", "salvage", "exploration", "pirate_station", "war_zone"} or out.get("attackable"):
        try:
            range_status = action_range_status(conn, player, out, map_type)
            out.update({
                "inActionRange": bool(range_status.get("inRange")),
                "actionRangePct": range_status.get("actionRangePct"),
                "actionDistancePct": range_status.get("distancePct"),
                "rangeLabel": range_status.get("rangeLabel"),
            })
        except Exception:
            range_status = None

    out_of_range_reason = ""
    if range_status and not range_status.get("inRange"):
        out_of_range_reason = f"Out of range. Distance {range_status.get('distancePct')}%, action range {range_status.get('actionRangePct')}%. Approach first."

    if kind == "ore":
        out["canMine"] = bool(caps["can_mine"] and (not range_status or range_status.get("inRange")))
        out["disabledReason"] = "" if out["canMine"] else (out_of_range_reason or "Requires an equipped mining laser/drill.")
    elif kind == "salvage":
        out["canSalvage"] = bool(caps["can_salvage"] and (not range_status or range_status.get("inRange")))
        out["disabledReason"] = "" if out["canSalvage"] else (out_of_range_reason or "Requires an equipped salvage module.")
    elif kind == "exploration":
        out["canScan"] = bool(caps["can_scan"] and (not range_status or range_status.get("inRange")))
        out["canInvestigate"] = bool(caps["can_investigate"] and (not range_status or range_status.get("inRange")))
        out["disabledReason"] = "" if (out["canScan"] or out["canInvestigate"]) else (out_of_range_reason or "Requires an equipped scanner/probe/relic module.")
    elif kind == "pirate_station":
        out["canEnter"] = bool(not range_status or range_status.get("inRange"))
        out["disabledReason"] = "" if out["canEnter"] else out_of_range_reason
    elif kind == "war_zone":
        out["canEnter"] = bool(not range_status or range_status.get("inRange"))
        out["disabledReason"] = "" if out["canEnter"] else out_of_range_reason
    elif kind in {"npc", "player"} or out.get("attackable"):
        out["canAttack"] = bool(caps["can_attack"])
        out["disabledReason"] = "" if caps["can_attack"] else "Requires an equipped weapon."
    return out

def start_player_map_operation(conn: sqlite3.Connection, player: Dict[str, Any], object_key: str, operation_type: str, seconds: int, message: str, result: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    now = utcnow()
    ends = now + timedelta(seconds=max(3, int(seconds or 3)))
    conn.execute("UPDATE player_map_operations SET status='superseded', updated_at=? WHERE player_id=? AND status='active'", (iso(now), player["id"]))
    conn.execute(
        "INSERT INTO player_map_operations (player_id,object_key,operation_type,status,started_at,ends_at,message,result_json,created_at,updated_at) VALUES (?,?,?,?,?,?,?,?,?,?)",
        (player["id"], object_key, operation_type, "active", iso(now), iso(ends), message, encode_json(result or {}), iso(now), iso(now)),
    )
    return {"operation_type": operation_type, "status": "active", "started_at": iso(now), "ends_at": iso(ends), "message": message, "object_key": object_key}


def choose_npc_target_from_objective(objective: Dict[str, Any], fallback_node: Dict[str, Any]) -> Dict[str, Any]:
    if objective.get("objectiveTargetX") is not None:
        return {
            "x_pct": float(objective.get("objectiveTargetX") or fallback_node.get("x_pct") or 50),
            "y_pct": float(objective.get("objectiveTargetY") or fallback_node.get("y_pct") or 50),
            "name": objective.get("objectiveTargetName") or fallback_node.get("name") or "objective",
            "object_key": objective.get("objectiveTargetObjectKey") or "",
        }
    return {
        "x_pct": float(fallback_node.get("x_pct") or 50),
        "y_pct": float(fallback_node.get("y_pct") or 50),
        "name": fallback_node.get("name") or "destination",
        "object_key": "",
    }


def npc_skill_focus_for_career(career: str) -> List[str]:
    role = str(career or "pilot").lower()
    if any(k in role for k in ("miner", "industrial", "hauler")):
        return ["mining", "hauling", "engineering", "defense", "combat"]
    if any(k in role for k in ("salvager", "engineer", "mechanic")):
        return ["salvage", "engineering", "scanning", "mining", "combat"]
    if any(k in role for k in ("pirate", "raider", "outlaw", "merc", "bounty", "hunter", "security", "patrol")):
        return ["combat", "piloting", "weapons", "defense", "scanning"]
    if any(k in role for k in ("explorer", "scout", "smuggler")):
        return ["scanning", "piloting", "stealth", "salvage", "combat"]
    if any(k in role for k in ("trader", "merchant", "broker")):
        return ["trading", "hauling", "piloting", "defense", "scanning"]
    return ["piloting", "defense", "scanning", "trading", "combat"]


def npc_level_from_xp(xp: int) -> int:
    return max(1, min(int(NPC_LIFE_BALANCE.get("max_level", 80)), 1 + int(math.sqrt(max(0, int(xp)) / 900.0))))


def grant_npc_progression(conn: sqlite3.Connection, npc_or_id: Any, action_key: str, xp_amount: int, rng: Optional[random.Random] = None) -> Dict[str, Any]:
    rng = rng or random.Random()
    npc = npc_or_id if isinstance(npc_or_id, dict) else row(conn, "SELECT * FROM npc_agents WHERE id=?", (int(npc_or_id),))
    if not npc:
        return {"level": 1, "xp": 0, "skills": {}}
    old_xp = int(npc.get("xp") or 0)
    new_xp = max(0, old_xp + max(1, int(xp_amount or 1)))
    old_level = int(npc.get("level") or 1)
    new_level = max(old_level, npc_level_from_xp(new_xp))
    skill_points = int(npc.get("skill_points") or 0) + max(0, new_level - old_level) * max(1, int(NPC_LIFE_BALANCE.get("skill_points_per_level", 1)))
    skills = decode_json(npc.get("skills_json"), {}) or {}
    focus = npc_skill_focus_for_career(str(npc.get("career_code") or npc.get("role") or "pilot"))
    spent = 0
    while skill_points > 0:
        roll = rng.random()
        secondary = float(NPC_LIFE_BALANCE.get("secondary_skill_chance", 0.22))
        tertiary = float(NPC_LIFE_BALANCE.get("tertiary_skill_chance", 0.08))
        primary = max(0.0, 1.0 - secondary - tertiary)
        if roll < primary:
            idx = 0
        elif roll < primary + secondary:
            idx = min(1, len(focus) - 1)
        else:
            idx = min(rng.randint(2, len(focus) - 1), len(focus) - 1) if len(focus) > 2 else 0
        key = focus[idx]
        skills[key] = int(skills.get(key) or 0) + 1
        skill_points -= 1
        spent += 1
    new_rank = clamp_int(1 + new_level // 9, 1, 12)
    power_gain = int((new_level - old_level) * float(NPC_LIFE_BALANCE.get("power_per_level", 24)) + spent * float(NPC_LIFE_BALANCE.get("power_per_skill", 11)))
    conn.execute(
        "UPDATE npc_agents SET xp=?, level=?, job_rank=?, skill_points=?, skills_json=?, power=power+?, last_action_at=? WHERE id=?",
        (new_xp, new_level, new_rank, skill_points, encode_json(skills), power_gain, iso(), int(npc["id"])),
    )
    return {"level": new_level, "xp": new_xp, "jobRank": new_rank, "skills": skills, "skillPoints": skill_points, "skillPointsSpent": spent}


def respawn_npc_agent(conn: sqlite3.Connection, npc: Dict[str, Any], rng: Optional[random.Random] = None) -> Dict[str, Any]:
    rng = rng or random.Random()
    min_loss = float(NPC_LIFE_BALANCE.get("respawn_xp_loss_min_pct", 0.0))
    max_loss = float(NPC_LIFE_BALANCE.get("respawn_xp_loss_max_pct", 15.0))
    if min_loss > 1: min_loss /= 100.0
    if max_loss > 1: max_loss /= 100.0
    loss_pct = rng.uniform(min_loss, max_loss)
    old_xp = int(npc.get("xp") or 0)
    new_xp = max(0, int(old_xp * (1.0 - loss_pct)))
    new_level = npc_level_from_xp(new_xp)
    old_power = max(80, int(npc.get("power") or 100))
    new_power = max(80, int(old_power * (1.0 - loss_pct * 0.65)))
    skills = decode_json(npc.get("skills_json"), {}) or {}
    for key in list(skills.keys()):
        if rng.random() < loss_pct:
            skills[key] = max(0, int(skills.get(key) or 0) - 1)
        if int(skills.get(key) or 0) <= 0:
            skills.pop(key, None)
    generation = int(npc.get("generation") or 1) + 1
    death_count = int(npc.get("death_count") or 0) + 1
    conn.execute(
        "UPDATE npc_agents SET alive=1, generation=?, death_count=?, xp=?, level=?, power=?, skills_json=?, last_action_at=? WHERE id=?",
        (generation, death_count, new_xp, new_level, new_power, encode_json(skills), iso(), int(npc["id"])),
    )
    conn.execute("DELETE FROM npc_map_state WHERE npc_id=?", (int(npc["id"]),))
    return {"generation": generation, "deathCount": death_count, "xpLossPct": round(loss_pct * 100, 1), "xp": new_xp, "level": new_level, "skills": skills}


def npc_map_combat_power(npc: Dict[str, Any]) -> int:
    skills = decode_json(npc.get("skills_json"), {}) or {}
    combat_skill = int(skills.get("combat") or 0) + int(skills.get("weapons") or 0) + int(skills.get("piloting") or 0)
    return max(25, int(npc.get("power") or 100) + int(npc.get("level") or 1) * 18 + combat_skill * 30 + int(npc.get("aggression") or 50))


def resolve_npc_map_combat(conn: sqlite3.Connection, attacker: Dict[str, Any], state: Dict[str, Any], rng: Optional[random.Random] = None) -> bool:
    rng = rng or random.Random()
    target_key = str(state.get("target_object_key") or "")
    if not target_key:
        return False
    if target_key == "player:self":
        gain = rng.randint(55, 150)
        prog = grant_npc_progression(conn, attacker, "npc_player_intercept", gain, rng)
        conn.execute(
            "INSERT INTO npc_action_log (planet_id,action_type,actor_name,message,impact_json,created_at) VALUES (?,?,?,?,?,?)",
            (state.get("planet_id"), "npc_player_intercept", attacker.get("name") or "NPC", f"{attacker.get('name') or 'NPC'} made an attack run on the player ship and broke off.", encode_json({"target": target_key, "xp": gain, "progression": prog}), iso()),
        )
        return True
    if not target_key.startswith("traveler:"):
        return False
    parts = target_key.split(":")
    try:
        defender_id = int(parts[1])
    except Exception:
        return False
    if defender_id == int(attacker.get("id") or 0):
        return False
    defender = row(conn, "SELECT * FROM npc_agents WHERE id=? AND COALESCE(alive,1)=1", (defender_id,))
    if not defender:
        return False
    atk = npc_map_combat_power(attacker) * rng.uniform(0.78, 1.24)
    dfn = npc_map_combat_power(defender) * rng.uniform(0.78, 1.24)
    attacker_won = atk >= dfn
    winner = attacker if attacker_won else defender
    loser = defender if attacker_won else attacker
    planet_id = state.get("planet_id") or attacker.get("planet_id") or defender.get("planet_id")
    enemy = npc_combat_ship_profile(loser)
    target_payload = {"name": loser.get("name"), "role": loser.get("role") or loser.get("career_code"), "level": loser.get("level"), "x_pct": state.get("x_pct") or state.get("destination_x_pct"), "y_pct": state.get("y_pct") or state.get("destination_y_pct")}
    salvage = None
    if planet_id:
        salvage = create_salvage_site(conn, int(planet_id), None, target_payload, enemy, "npc_map_combat")
    loser_respawn = respawn_npc_agent(conn, loser, rng)
    winner_prog = grant_npc_progression(conn, winner, "npc_map_combat_win", rng.randint(220, 620), rng)
    conn.execute(
        "INSERT INTO npc_action_log (planet_id,action_type,actor_name,message,impact_json,created_at) VALUES (?,?,?,?,?,?)",
        (planet_id, "npc_map_combat", winner.get("name") or "NPC", f"{winner.get('name') or 'NPC'} defeated {loser.get('name') or 'NPC'} in open space. {loser.get('name') or 'NPC'} respawned as generation {loser_respawn.get('generation')}.", encode_json({"winnerId": winner.get("id"), "loserId": loser.get("id"), "salvage": salvage, "winnerProgression": winner_prog, "loserRespawn": loser_respawn}), iso()),
    )
    return True


def apply_npc_map_action(conn: sqlite3.Connection, state: Dict[str, Any], npc: Optional[Dict[str, Any]] = None) -> None:
    objective = str(state.get("objective") or "")
    target_key = str(state.get("target_object_key") or "")
    rng = random.Random(f"npc-map-action:{state.get('npc_id')}:{state.get('id')}:{target_key}:{int(utcnow().timestamp() // 30)}")
    actor = npc or row(conn, "SELECT * FROM npc_agents WHERE id=?", (int(state.get("npc_id") or 0),)) or {}
    actor_name = actor.get("name") or "NPC"
    if objective in {"mine", "mine_ore", "mining"} and target_key:
        obj = row(conn, "SELECT * FROM map_objects WHERE object_key=? AND kind='ore' AND qty_remaining>0", (target_key,))
        if obj:
            qty = max(1, min(3 + int(actor.get("level") or 1) // 12, int(obj.get("qty_remaining") or 0)))
            conn.execute("UPDATE map_objects SET qty_remaining=max(0,qty_remaining-?), state=CASE WHEN qty_remaining-?<=0 THEN 'depleted' ELSE 'available' END, updated_at=? WHERE id=?", (qty, qty, iso(), obj["id"]))
            prog = grant_npc_progression(conn, actor, "mine", rng.randint(90, 230) + qty * 20, rng)
            conn.execute("INSERT INTO npc_action_log (planet_id,action_type,actor_name,message,impact_json,created_at) VALUES (?,?,?,?,?,?)", (state.get("planet_id"), "npc_mining", actor_name, f"{actor_name} mined {qty} units from {obj.get('name')}.", encode_json({"object_key": target_key, "qty": qty, "progression": prog}), iso()))
            return
    if objective in {"salvage", "salvage_wreck", "salvaging"} and target_key:
        salvage = row(conn, "SELECT * FROM salvage_sites WHERE (id=? OR CAST(id AS TEXT)=?) AND qty_remaining>0", (target_key if str(target_key).isdigit() else -1, target_key))
        if salvage:
            conn.execute("UPDATE salvage_sites SET qty_remaining=max(0,qty_remaining-1) WHERE id=?", (salvage["id"],))
            prog = grant_npc_progression(conn, actor, "salvage", rng.randint(130, 320), rng)
            conn.execute("INSERT INTO npc_action_log (planet_id,action_type,actor_name,message,impact_json,created_at) VALUES (?,?,?,?,?,?)", (salvage.get("planet_id") or state.get("planet_id"), "npc_salvage", actor_name, f"{actor_name} salvaged {salvage.get('ship_name') or 'a wreck'}.", encode_json({"salvageSiteId": salvage.get("id"), "progression": prog}), iso()))
            return
    if objective in {"explore", "explore_site", "exploration", "patrol_scan"} and target_key:
        obj = row(conn, "SELECT * FROM map_objects WHERE object_key=? AND kind='exploration' AND qty_remaining>0", (target_key,))
        if obj:
            meta = decode_json(obj.get("metadata_json"), {}) or {}
            meta["signalQuality"] = min(100, int(meta.get("signalQuality") or 50) + 3 + int(actor.get("level") or 1) // 20)
            conn.execute("UPDATE map_objects SET metadata_json=?, updated_at=? WHERE id=?", (encode_json(meta), iso(), obj["id"]))
            prog = grant_npc_progression(conn, actor, "explore", rng.randint(95, 260), rng)
            conn.execute("INSERT INTO npc_action_log (planet_id,action_type,actor_name,message,impact_json,created_at) VALUES (?,?,?,?,?,?)", (state.get("planet_id"), "npc_explore", actor_name, f"{actor_name} scanned {obj.get('name') or 'an ancient signal'}.", encode_json({"object_key": target_key, "signalQuality": meta.get("signalQuality"), "progression": prog}), iso()))
            return
    if objective in {"pirate_intercept", "bounty_hunt", "escort"}:
        if resolve_npc_map_combat(conn, actor, state, rng):
            return
    prog = grant_npc_progression(conn, actor, objective or "patrol", rng.randint(35, 120), rng) if actor else {}
    conn.execute("INSERT INTO npc_action_log (planet_id,action_type,actor_name,message,impact_json,created_at) VALUES (?,?,?,?,?,?)", (state.get("planet_id"), "npc_patrol", actor_name, f"{actor_name} completed {label_for_api(objective or 'patrol')} and chose a new route.", encode_json({"target": target_key, "progression": prog}), iso()))


def build_persistent_npc_traffic(conn: sqlite3.Connection, player: Dict[str, Any], map_type: str, nodes: List[Dict[str, Any]], by_id: Dict[int, Dict[str, Any]], radar_objects: List[Dict[str, Any]], traffic_so_far: List[Dict[str, Any]], max_count: int) -> List[Dict[str, Any]]:
    if len(nodes) < 2:
        return []
    node_ids = list(by_id.keys())
    scope = current_map_scope(conn, player, map_type)
    gid = int(scope.get("galaxy_id") or 0)
    pid = int(scope.get("planet_id") or 0) if map_type == "system" else None
    if map_type == "galaxy":
        npc_query = "SELECT * FROM npc_agents WHERE COALESCE(alive,1)=1 ORDER BY id LIMIT ?"
        params: tuple = (max_count,)
    else:
        npc_query = "SELECT * FROM npc_agents WHERE COALESCE(alive,1)=1 AND planet_id IN (%s) ORDER BY id LIMIT ?" % ",".join("?" for _ in node_ids)
        params = tuple(node_ids + [max_count])
    now = utcnow()
    out: List[Dict[str, Any]] = []
    for idx, npc in enumerate(rows(conn, npc_query, params)):
        npc_id = int(npc["id"])
        role = str(npc.get("role") or npc.get("career_code") or "pilot")
        role_l = role.lower()
        state = row(conn, "SELECT * FROM npc_map_state WHERE npc_id=? AND map_type=? AND galaxy_id=? AND COALESCE(planet_id,0)=?", (npc_id, map_type, gid, int(pid or 0)))
        rng = random.Random(f"persistent-npc:{map_type}:{gid}:{pid}:{npc_id}:{int(now.timestamp()//300)}")
        if not state:
            o_id, fallback_d_id = rng.sample(node_ids, 2)
            origin = by_id[o_id]
            radar_range = npc_radar_range_pct(npc, map_type)
            objective = npc_choose_objective_and_route(npc, map_type, nodes, by_id, rng, origin, radar_range, radar_objects, traffic_so_far + out, o_id, fallback_d_id)
            d_id = int(objective.get("objectiveDestinationId") or fallback_d_id)
            dest_node = by_id.get(d_id) or by_id[fallback_d_id]
            target = choose_npc_target_from_objective(objective, dest_node)
            speed = 0.65 if role_l in {"hauler", "trader", "miner"} else 0.9
            dist = pct_distance(origin, target)
            seconds = max(25, min(260, int(20 + dist * 3.2 / speed)))
            conn.execute(
                """INSERT INTO npc_map_state (npc_id,map_type,galaxy_id,planet_id,role,objective,target_object_key,x_pct,y_pct,origin_x_pct,origin_y_pct,destination_x_pct,destination_y_pct,started_at,arrival_at,action_until,action_state,cargo_json,updated_at)
                   VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""",
                (npc_id, map_type, gid, pid, role, objective.get("objective") or "patrol", target.get("object_key") or "", float(origin.get("x_pct") or 50), float(origin.get("y_pct") or 50), float(origin.get("x_pct") or 50), float(origin.get("y_pct") or 50), float(target.get("x_pct") or 50), float(target.get("y_pct") or 50), iso(now), iso(now + timedelta(seconds=seconds)), None, "moving", encode_json({"objectiveLabel": objective.get("objectiveLabel"), "objectiveTargetName": target.get("name"), "objectiveState": objective.get("objectiveState"), "visibleCounts": objective.get("visibleCounts")}), iso(now)),
            )
            state = row(conn, "SELECT * FROM npc_map_state WHERE npc_id=? AND map_type=? AND galaxy_id=? AND COALESCE(planet_id,0)=?", (npc_id, map_type, gid, int(pid or 0)))
            if not state:
                # Defensive guard: never let a failed/rolled-back NPC state insert crash /api/state.
                # The NPC will be retried and re-seeded on the next map tick.
                continue

        state = dict(state)
        arrival = parse_dt(state.get("arrival_at")) or now
        action_until = parse_dt(state.get("action_until")) if state.get("action_until") else None
        if state.get("action_state") == "moving" and now >= arrival:
            # Arrived. Start doing the objective instead of snapping home.
            action_seconds = 35 if state.get("objective") in {"mine_ore", "explore_site", "salvage_wreck"} else 18
            conn.execute("UPDATE npc_map_state SET x_pct=?, y_pct=?, action_state='working', action_until=?, updated_at=? WHERE id=?", (float(state.get("destination_x_pct") or 50), float(state.get("destination_y_pct") or 50), iso(now + timedelta(seconds=action_seconds)), iso(now), state["id"]))
            state.update({"x_pct": float(state.get("destination_x_pct") or 50), "y_pct": float(state.get("destination_y_pct") or 50), "action_state": "working", "action_until": iso(now + timedelta(seconds=action_seconds))})
        elif state.get("action_state") == "working" and action_until and now >= action_until:
            apply_npc_map_action(conn, state, npc)
            # Choose a new route from current location.
            current_pt = {"x_pct": float(state.get("x_pct") or state.get("destination_x_pct") or 50), "y_pct": float(state.get("y_pct") or state.get("destination_y_pct") or 50)}
            fallback_d_id = rng.choice(node_ids)
            radar_range = npc_radar_range_pct(npc, map_type)
            objective = npc_choose_objective_and_route(npc, map_type, nodes, by_id, rng, current_pt, radar_range, radar_objects, traffic_so_far + out, fallback_d_id, fallback_d_id)
            d_id = int(objective.get("objectiveDestinationId") or fallback_d_id)
            dest_node = by_id.get(d_id) or by_id[fallback_d_id]
            target = choose_npc_target_from_objective(objective, dest_node)
            dist = pct_distance(current_pt, target)
            seconds = max(25, min(260, int(20 + dist * 3.2)))
            conn.execute(
                """UPDATE npc_map_state SET objective=?, target_object_key=?, origin_x_pct=?, origin_y_pct=?, destination_x_pct=?, destination_y_pct=?, started_at=?, arrival_at=?, action_until=NULL, action_state='moving', cargo_json=?, updated_at=? WHERE id=?""",
                (objective.get("objective") or "patrol", target.get("object_key") or "", float(current_pt["x_pct"]), float(current_pt["y_pct"]), float(target.get("x_pct") or 50), float(target.get("y_pct") or 50), iso(now), iso(now + timedelta(seconds=seconds)), encode_json({"objectiveLabel": objective.get("objectiveLabel"), "objectiveTargetName": target.get("name"), "objectiveState": objective.get("objectiveState"), "visibleCounts": objective.get("visibleCounts")}), iso(now), state["id"]),
            )
            refreshed_state = row(conn, "SELECT * FROM npc_map_state WHERE id=?", (state["id"],))
            if not refreshed_state:
                # apply_npc_map_action can resolve combat where this NPC loses.
                # respawn_npc_agent deletes that NPC's npc_map_state, so dict(None)
                # would crash /api/state. Skip rendering this stale state and let
                # the respawned NPC get a clean route on the next map tick.
                continue
            state = dict(refreshed_state)

        started = parse_dt(state.get("started_at")) or now
        arrival = parse_dt(state.get("arrival_at")) or now
        total = max(1, (arrival - started).total_seconds())
        progress = 1.0 if state.get("action_state") == "working" else max(0.0, min(1.0, (now - started).total_seconds() / total))
        if state.get("action_state") == "moving":
            pt = deterministic_between({"x_pct": state.get("origin_x_pct"), "y_pct": state.get("origin_y_pct")}, {"x_pct": state.get("destination_x_pct"), "y_pct": state.get("destination_y_pct")}, progress)
            conn.execute("UPDATE npc_map_state SET x_pct=?, y_pct=?, updated_at=? WHERE id=?", (float(pt["x_pct"]), float(pt["y_pct"]), iso(now), state["id"]))
        else:
            pt = {"x_pct": float(state.get("x_pct") or state.get("destination_x_pct") or 50), "y_pct": float(state.get("y_pct") or state.get("destination_y_pct") or 50)}
        cargo_meta = decode_json(state.get("cargo_json"), {}) or {}
        objective_label = cargo_meta.get("objectiveLabel") or label_for_api(state.get("objective") or "patrol")
        objective_state = "working at objective" if state.get("action_state") == "working" else "moving to objective"
        radar_range = npc_radar_range_pct(npc, map_type)
        visible = {
            "ore": npc_visible_objects(pt, radar_range, radar_objects, "ore"),
            "salvage": npc_visible_objects(pt, radar_range, radar_objects, "salvage"),
            "exploration": npc_visible_objects(pt, radar_range, radar_objects, "exploration"),
            "ship": [t for t in traffic_so_far + out if t.get("id") != "player:self" and pct_distance(pt, t) <= radar_range],
        }
        hostile = role_l in COMBAT_LEGAL_ROLES or int(npc.get("aggression") or 0) > 70 or state.get("objective") in {"pirate_intercept"}
        traveler_id = f"traveler:{npc_id}:{map_type}"
        out.append({
            "id": traveler_id,
            "combatTargetRef": traveler_id,
            "kind": "npc",
            "name": npc.get("name") or f"NPC {label_for_api(role)}",
            "role": role,
            "progress": round(progress * 100, 1),
            **pt,
            "routeOriginX": float(state.get("origin_x_pct") or pt.get("x_pct") or 50),
            "routeOriginY": float(state.get("origin_y_pct") or pt.get("y_pct") or 50),
            "routeDestinationX": float(state.get("destination_x_pct") or pt.get("x_pct") or 50),
            "routeDestinationY": float(state.get("destination_y_pct") or pt.get("y_pct") or 50),
            "npcStartedAt": state.get("started_at"),
            "npcArrivalAt": state.get("arrival_at"),
            "npcActionUntil": state.get("action_until"),
            "npcActionStateRaw": state.get("action_state"),
            "npcLevel": int(npc.get("level") or 1),
            "npcXp": int(npc.get("xp") or 0),
            "npcSkills": decode_json(npc.get("skills_json"), {}) or {},
            "npcGeneration": int(npc.get("generation") or 1),
            "npcDeathCount": int(npc.get("death_count") or 0),
            "attackable": True,
            "hostile": hostile,
            "npcRadarRangePct": radar_range,
            "npcDetectedCount": sum(len(v) for v in visible.values()),
            "npcRadarBehavior": objective_state,
            "npcObjective": state.get("objective"),
            "npcObjectiveLabel": objective_label,
            "npcObjectiveState": objective_state,
            "npcObjectiveTargetName": cargo_meta.get("objectiveTargetName"),
            "npcVisibleCounts": {k: len(v) for k, v in visible.items()},
            "selectedSummary": f"{label_for_api(role)} is {objective_state}: {objective_label}. Target: {cargo_meta.get('objectiveTargetName') or 'open space'}. Position and action state are DB-backed.",
            "outcomeFactors": "NPC state is persisted in npc_map_state. NPCs move, work at objectives, update objects, then choose a new objective.",
            "label": f"{objective_label}: {objective_state}.",
        })
    return out[:max_count]


def build_open_world_ore_sites(conn: sqlite3.Connection, player: Dict[str, Any], nodes: List[Dict[str, Any]], map_type: str = "system") -> List[Dict[str, Any]]:
    return [attach_tool_permissions(conn, player, o) for o in db_map_objects(conn, player, nodes, map_type, "ore")]


def build_open_world_exploration_sites(conn: sqlite3.Connection, player: Dict[str, Any], nodes: List[Dict[str, Any]], map_type: str = "system") -> List[Dict[str, Any]]:
    return [attach_tool_permissions(conn, player, o) for o in db_map_objects(conn, player, nodes, map_type, "exploration")]


def build_map_salvage_icons(conn: sqlite3.Connection, planet_id: int) -> List[Dict[str, Any]]:
    icons = []
    for site in build_salvage_sites(conn, planet_id):
        rng = random.Random(f"salvage-icon:{site.get('id')}")
        x_pct = site.get("x_pct") if site.get("x_pct") is not None else rng.uniform(8, 92)
        y_pct = site.get("y_pct") if site.get("y_pct") is not None else rng.uniform(9, 91)
        icons.append({**site, "kind":"salvage", "x_pct":clamp_pct(x_pct), "y_pct":clamp_pct(y_pct), "label":f"Salvage wreck: {site.get('ship_name')} • energy {site.get('energy_cost')}", "salvageSiteId":site.get("id")})
    return icons


