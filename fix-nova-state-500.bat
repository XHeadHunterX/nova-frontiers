@echo off
setlocal enabledelayedexpansion

REM Nova Frontiers emergency /api/state 500 fix
REM Put this BAT in the root of your nova-frontiers project and run it.

set "PROJECT_DIR=%CD%"
set "COMMIT_MSG=Fix live state 500 legacy planet columns"
set "PAYLOAD_ZIP=%TEMP%\nova-state500-fix-%RANDOM%%RANDOM%.zip"

echo.
echo ==========================================
echo Nova Frontiers Emergency State 500 Fix
echo ==========================================
echo Project: %PROJECT_DIR%
echo.

if not exist "%PROJECT_DIR%\backend\app\main.py" (
    echo ERROR: Run this from the project root containing backend\app\main.py
    pause
    exit /b 1
)

echo Extracting embedded backend fix...
powershell -NoProfile -ExecutionPolicy Bypass -Command "$self='%~f0'; $lines=Get-Content -LiteralPath $self; $marker='__NOVA_STATE500_PAYLOAD_B64__'; $idx=[Array]::IndexOf($lines,$marker); if($idx -lt 0){ throw 'Payload marker not found.' }; $b64=($lines[($idx+1)..($lines.Length-1)] -join ''); [IO.File]::WriteAllBytes('%PAYLOAD_ZIP%',[Convert]::FromBase64String($b64)); Expand-Archive -LiteralPath '%PAYLOAD_ZIP%' -DestinationPath '%PROJECT_DIR%' -Force"
if errorlevel 1 (
    echo ERROR: Extract failed.
    pause
    exit /b 1
)

echo.
echo Backend syntax check...
cd /d "%PROJECT_DIR%\backend"
python -m py_compile app\main.py
if errorlevel 1 (
    echo ERROR: Backend syntax check failed.
    pause
    exit /b 1
)

cd /d "%PROJECT_DIR%"
git add backend/app/main.py
git commit -m "%COMMIT_MSG%"
if errorlevel 1 (
    echo WARNING: Commit failed, possibly no changes. Continuing to push.
)
git push
if errorlevel 1 (
    echo ERROR: git push failed.
    pause
    exit /b 1
)

echo.
echo Done. Wait for Render redeploy, then hard-refresh the site.
pause
exit /b 0

