@echo off
setlocal enabledelayedexpansion

REM Nova Frontiers image/assets deploy helper
REM Put this BAT in the root of your nova-frontiers project and run it.

set "PROJECT_DIR=%CD%"
set "COMMIT_MSG=Add Nova Frontiers generated image assets"
set "PAYLOAD_ZIP=%TEMP%\nova-image-assets-%RANDOM%%RANDOM%.zip"

echo.
echo ==========================================
echo Nova Frontiers Image Asset Push
echo ==========================================
echo Project: %PROJECT_DIR%
echo.

if not exist "%PROJECT_DIR%\frontend\package.json" (
    echo ERROR: Run this from the project root containing frontend\package.json
    pause
    exit /b 1
)

echo Extracting embedded image assets...
powershell -NoProfile -ExecutionPolicy Bypass -Command "$self='%~f0'; $lines=Get-Content -LiteralPath $self; $marker='__NOVA_IMAGE_ASSETS_PAYLOAD_B64__'; $idx=[Array]::IndexOf($lines,$marker); if($idx -lt 0){ throw 'Payload marker not found.' }; $b64=($lines[($idx+1)..($lines.Length-1)] -join ''); [IO.File]::WriteAllBytes('%PAYLOAD_ZIP%',[Convert]::FromBase64String($b64)); Expand-Archive -LiteralPath '%PAYLOAD_ZIP%' -DestinationPath '%PROJECT_DIR%' -Force"
if errorlevel 1 (
    echo ERROR: Extract failed.
    pause
    exit /b 1
)

echo.
echo Checking generated asset counts...
powershell -NoProfile -ExecutionPolicy Bypass -Command "$a=(Get-ChildItem -Path '%PROJECT_DIR%\frontend\public\assets\generated\ultra' -Filter *.svg -ErrorAction SilentlyContinue).Count; $b=(Get-ChildItem -Path '%PROJECT_DIR%\frontend\src\assets\generated\items' -Filter *.svg -ErrorAction SilentlyContinue).Count; Write-Host \"public ultra svg count: $a\"; Write-Host \"src generated item svg count: $b\""

echo.
echo Building frontend once...
cd /d "%PROJECT_DIR%\frontend"
call npm install
if errorlevel 1 (
    echo ERROR: npm install failed.
    pause
    exit /b 1
)

call npm run build
if errorlevel 1 (
    echo ERROR: frontend build failed.
    pause
    exit /b 1
)

cd /d "%PROJECT_DIR%"

echo.
echo Force-adding image assets in case gitignore is blocking them...
git add -f frontend/public/assets/generated/ultra
git add -f frontend/src/assets/generated/items
git add frontend/src/assets/gameAssets.js frontend/src/styles.css

echo.
echo Git status:
git status

echo.
echo Committing...
git commit -m "%COMMIT_MSG%"
if errorlevel 1 (
    echo WARNING: Commit failed. Usually means no changes were detected.
    echo Continuing to push anyway.
)

echo.
echo Pushing...
git push
if errorlevel 1 (
    echo ERROR: git push failed.
    pause
    exit /b 1
)

echo.
echo Done. Wait for Cloudflare Pages to redeploy.
echo Then hard refresh:
echo Ctrl + Shift + R
pause
exit /b 0

