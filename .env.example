# Nova Frontiers current Render-compatible settings
# No new variable in this file is required for the existing Render deployment.

# Existing/local database setting. Render can keep its current value.
# NOVA_DB=backend/app/data/nova_frontiers.db

# Existing CORS variable remains supported.
# NOVA_CORS_ORIGINS=https://novafrontiersgame.com,https://www.novafrontiersgame.com,https://nova-frontiers.pages.dev

# Future stack URLs. Optional; frontend/API can continue same-origin without them.
# PUBLIC_GAME_URL=https://novafrontiersgame.com
# API_BASE_URL=https://api.novafrontiersgame.com
# WS_BASE_URL=wss://api.novafrontiersgame.com
# CORS_ALLOWED_ORIGINS=https://novafrontiersgame.com,https://www.novafrontiersgame.com

# Platform mode is informational for runtime diagnostics.
PLATFORM_MODE=render

# Optional Redis. Missing REDIS_URL keeps in-memory single-instance behavior.
# REDIS_URL=redis://default:password@host:6379/0

# Optional object storage. Missing values keep local storage behavior.
OBJECT_STORAGE_PROVIDER=local
# OBJECT_STORAGE_PROVIDER=r2
# R2_BUCKET=nova-frontiers
# R2_ENDPOINT=https://accountid.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# OBJECT_STORAGE_PROVIDER=s3
# S3_BUCKET=nova-frontiers
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Optional separate worker mode. Missing/false keeps the current Render API
# process running background gameplay tasks in-process.
WORKER_ENABLED=false
# WORKER_LOOP_SECONDS=60
# WORKER_RUN_ONCE=0

# Optional diagnostics/tuning.
# SLOW_REQUEST_LOG_MS=750
# NOVA_RATE_LIMITS=1
# NOVA_API_MAX_BODY_BYTES=131072
