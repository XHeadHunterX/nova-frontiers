        <div><b>Salvage output</b><span>{item.salvage_preview ? `${fmt(item.salvage_preview.scrap)} scrap + ${(item.salvage_preview.materials || []).map(m=>`${m.qty}x ${m.name}`).join(', ')}` : 'Not salvageable'}</span></div>
