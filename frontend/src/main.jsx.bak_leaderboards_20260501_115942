      <div className="publicProfileHeader">
        <ProfileAvatar profile={profile} size="lg" />
        <div>
          <h2>{profile.displayName || 'Pilot'}</h2>
          <span>@{profile.username || 'unknown'} • Level {fmt(stats.level || 1)}</span>
